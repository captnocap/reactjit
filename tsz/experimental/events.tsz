// events.tsz — hit testing and event dispatch
// Walk the node tree back-to-front to find the deepest node
// containing a point that has event handlers.

import { Node } from './layout';

interface EventHandler {
  onPress: (() => void) | null;
  onHoverEnter: (() => void) | null;
  onHoverExit: (() => void) | null;
  onKey: ((key: c_int, mods: u16) => void) | null;
  onChangeText: (() => void) | null;
  onScroll: (() => void) | null;
  onRightClick: ((x: f32, y: f32) => void) | null;
}

// Walk tree back-to-front. Returns deepest node under (mx, my) with handlers.
export function hitTest(node: Node, mx: number, my: number): Node | null {
  if (node.style.display === Display.None) return null;

  let i = node.children.length;
  while (i > 0) {
    i -= 1;
    const hit = hitTest(node.children[i], mx, my);
    if (hit !== null) return hit;
  }

  if (hasHandlers(node.handlers) || node.inputId !== null || node.canvasType !== null) {
    const r = node.computed;
    if (mx >= r.x && mx < r.x + r.w && my >= r.y && my < r.y + r.h) {
      return node;
    }
  }

  return null;
}

function hasHandlers(h: EventHandler): boolean {
  return h.onPress !== null ||
    h.onHoverEnter !== null ||
    h.onHoverExit !== null ||
    h.onKey !== null ||
    h.onChangeText !== null ||
    h.onScroll !== null ||
    h.onRightClick !== null;
}

// Find deepest text node under (mx, my) — for text selection.
export function hitTestText(node: Node, mx: number, my: number): Node | null {
  if (node.style.display === Display.None) return null;

  let i = node.children.length;
  while (i > 0) {
    i -= 1;
    const hit = hitTestText(node.children[i], mx, my);
    if (hit !== null) return hit;
  }

  if (node.text !== null) {
    const r = node.computed;
    if (mx >= r.x && mx < r.x + r.w && my >= r.y && my < r.y + r.h) {
      return node;
    }
  }

  return null;
}

// Find deepest scroll container under (mx, my) — for mouse wheel dispatch.
export function findScrollContainer(node: Node, mx: number, my: number): Node | null {
  if (node.style.display === Display.None) return null;

  const r = node.computed;
  if (mx < r.x || mx >= r.x + r.w || my < r.y || my >= r.y + r.h) return null;

  let i = node.children.length;
  while (i > 0) {
    i -= 1;
    const hit = findScrollContainer(node.children[i], mx, my);
    if (hit !== null) return hit;
  }

  if (node.style.overflow === Overflow.Scroll) {
    return node;
  }

  return null;
}
