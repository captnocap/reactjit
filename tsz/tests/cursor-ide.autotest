# === TAB SWITCHING — go back to Sidebar.tsx ===
click "Sidebar.tsx"
expect "FileTree"

# === COLORS ===
color "EXPLORER" #6e6e6e
color "No problems" #6e6e6e
color "UTF-8" #3d3d3d

# === HIDDEN PANELS ===
reject "Project Search"
reject "$"

# =============================================================
# === AGENT INPUT — POWER USER COMPOSER ===
# =============================================================

# Mode pills all present
expect "Ask"
expect "Plan"
expect "Task"
expect "Agent"

# Tool buttons
expect "Files"
expect "Symbols"
expect "Attach"

# Capability toggles
expect "Web"
expect "Term"

# Model picker shows initial model
expect "Opus 4"

# Chat header new conversation + history buttons
expect "+ New"
expect "Index"

# === MODE SWITCHING — Plan ===
# Click Plan pill — plan hint should appear, send label should change
click "Plan"
expect "Plan mode"
reject "Task mode"
reject "Run Task"
reject "Launch"

# === MODE SWITCHING — Task ===
# Task mode adds the Auto-apply toggle and Run Task button
click "Task"
expect "Task mode"
expect "Auto"
expect "Run Task"
reject "Plan mode"

# Back to Ask — everything task-specific disappears
click "Ask"
reject "Task mode"
reject "Auto"
reject "Run Task"
expect "Send"

# === MODE SWITCHING — Agent ===
# "Agent" appears many times; pill is last — use #6
click "Agent" #6
expect "Launch"
reject "Task mode"
# Return to Ask for remaining tests
click "Ask"
reject "Launch"
expect "Send"

# === TOOL TOGGLES — verify style state changes on activation ===
styles before "Web"
click "Web"
styles after "Web"

styles before "Term"
click "Term"
styles after "Term"

# === ATTACHMENT FLOW ===
# Clear all is always present (compiler: early-return not compiled as display toggle)
expect "Clear all"
# Attach the currently open file (Sidebar.tsx active from tab-switch above)
click "Attach"
expect "Clear all"
# Remove all attachments
click "Clear all"
# Clear all stays visible (static tree — OA clear doesn't remove it yet)
expect "Clear all"

# === NEW CONVERSATION ===
# Existing messages are present
expect "I have analyzed the codebase"
expect "Found 3 files"
# Clear the conversation
click "+ New"
reject "I have analyzed the codebase"
reject "Found 3 files"
reject "Search for all components"

# === MODEL CYCLING ===
# Model is GPT-4o from earlier cycling (steps 98-103)
# Cycle: GPT-4o → o1
expect "GPT-4o"
click "GPT-4o"
expect "o1"
reject "GPT-4o"
# Cycle again: o1 → Opus 4
click "o1"
expect "Opus 4"
reject "o1"
