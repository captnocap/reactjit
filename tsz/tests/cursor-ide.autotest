# Cursor IDE — full baseline test
# Verifies rendering, file operations, tabs, icons, editing, panels

# === SHELL & TOP BAR ===
expect "src/components/Sidebar.tsx"

# === SIDEBAR ===
expect "EXPLORER"
expect "+"

# === FILE TREE — directories with chevrons ===
expect "cursor-ide"
expect "src"
expect "components"
expect "hooks"
expect "utils"
expect "styles"

# === FILE TREE — files with type badges ===
expect "Sidebar.tsx"
expect "Editor.tsx"
expect "ChatPanel.tsx"
expect "StatusBar.tsx"
expect "Terminal.tsx"
expect "useAgent.ts"
expect "package.json"
expect "README.md"
expect "tsconfig.json"
expect "theme.css"

# === FILE TYPE ICONS (colored badges) ===
expect "TS"
expect "JS"
expect "MD"

# === TABS ===
expect "Sidebar.tsx"

# === BREADCRUMBS ===
expect "components"

# === EDITOR ===
# Line count visible
expect "lines"
expect "20"

# === CHAT PANEL ===
expect "Agent"
expect "GPT-4"
expect "Cursor Agent"
expect "I have analyzed the codebase"
expect "Search for all components"
expect "Found 3 files"
expect "Send"
expect "#"

# === STATUS BAR ===
expect "git"
expect "main"
expect "No problems"
expect "Ln"
expect "Col"
expect "TypeScript TSX"
expect "UTF-8"
expect "LF"

# === PANEL TOGGLES ===
expect "Search"
expect "Terminal"
expect "Chat"

# === CLICK FILE — open Editor.tsx ===
click "Editor.tsx"
# New tab should appear
expect "Editor.tsx"
# Editor content changes to Editor.tsx file
expect "Editor Component"

# === CLICK FILE — open package.json ===
click "package.json"
expect "package.json"
expect "0.1.0"

# === CLICK FILE — open README.md ===
click "README.md"
expect "README.md"
expect "Agentic coding environment"

# === CLICK FILE — open theme.css ===
click "theme.css"
expect "theme.css"
expect "--bg-primary"

# === TAB SWITCHING — go back to Sidebar.tsx ===
click "Sidebar.tsx"
expect "FileTree"

# === COLORS ===
color "EXPLORER" #6e6e6e
color "No problems" #6e6e6e
color "UTF-8" #6e6e6e

# === HIDDEN PANELS ===
reject "Project Search"
reject "$"
