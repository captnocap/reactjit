# d99: border colors — verify text, text colors, AND border colors

# All labels present
expect "Border Color Test"
expect "RED"
expect "GREEN"
expect "BLUE"
expect "YELLOW"
expect "MAGENTA 6px"
expect "CYAN 2px"

# Text colors
color "RED" #ff0000
color "GREEN" #00ff00
color "BLUE" #0000ff
color "YELLOW" #ffff00
color "MAGENTA 6px" #ff00ff
color "CYAN 2px" #00ffff

# Border colors on parent containers
border "RED" #ff0000
border "GREEN" #00ff00
border "BLUE" #0000ff
border "YELLOW" #ffff00
border "MAGENTA 6px" #ff00ff
border "CYAN 2px" #00ffff
