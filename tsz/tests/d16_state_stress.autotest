# State-heavy updates should keep totals, phase, history, and reset logic coherent.
expect "State Stress"
expect "total:0 phase:0 history:0"
expect "a:0"
expect "b:0"
click "a:0"
click "b:0"
expect "total:2 phase:0 history:0"
# Phase handler: setPhase(phase+1), setHistory(history+phase), setTotal(total+1)
# After setPhase: phase=1. Then setHistory(0+1)=1. setTotal(2+1)=3.
click "Phase 0"
expect "total:3 phase:1 history:1"
# Second phase: setPhase(1+1)=2. setHistory(1+2)=3. setTotal(3+1)=4.
click "Phase 1"
expect "total:4 phase:2 history:3"
click "Reset Everything"
expect "total:0 phase:0 history:0"
expect "a:0"
expect "b:0"
