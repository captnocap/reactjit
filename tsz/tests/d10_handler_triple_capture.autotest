# d10: handler triple capture — closures must capture item fields, loop index, AND outer state

# Initial render
expect "Triple Capture"
expect "multiplier: 1"
expect "acc: 0"
expect "clicks: 0"

# Verify map rendered all 15 planets
expect "Mercury"
expect "Venus"
expect "Earth"
expect "Mars"
expect "Jupiter"
expect "Saturn"
expect "Uranus"
expect "Neptune"
expect "Pluto"

# Verify computed values visible (weight = (i+1)*3, so Mercury=3, Venus=6, Earth=9)
expect "w:3"
expect "w:6"
expect "w:9"

# Click multiplier button to increment
click "multiplier: 1"
expect "multiplier: 2"

# Click Earth row (idx=2, weight=9, multiplier=2)
# acc = 0 + 9*2 + 2 = 20, lastIdx=2, lastW=9, clicks=1
click "Earth"
expect "clicks: 1"
expect "acc: 20"

# Click multiplier again
click "multiplier: 2"
expect "multiplier: 3"

# Click Mercury (idx=0, weight=3, multiplier=3)
# acc = 20 + 3*3 + 0 = 29, lastIdx=0, lastW=3, clicks=2
click "Mercury"
expect "clicks: 2"
expect "acc: 29"
