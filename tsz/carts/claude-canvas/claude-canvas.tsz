// Claude Canvas — interactive token graph visualization.
// Reads the semantic graph from the terminal's classifier pipeline
// and renders it as an interactive Canvas with nodes and connections.
// Each node is a semantic block (turn, thinking, tool, text, etc.)
// colored by token type, connected by parent-child links.
//
// Uses: __sem_* bridge functions from qjs_runtime.zig
// Reference: love2d/lua/claude_graph.lua + claude_canvas.lua

const [modeName, setModeName] = useState('idle');
const [turnCount, setTurnCount] = useState(0);
const [nodeCount, setNodeCount] = useState(0);
const [selectedIdx, setSelectedIdx] = useState(-1);
const [selKind, setSelKind] = useState('');
const [selRole, setSelRole] = useState('');
const [selLane, setSelLane] = useState('');
const [selText, setSelText] = useState('');
const [selRows, setSelRows] = useState('');
const [classMode, setClassMode] = useState(1);

// 16 node slots: x, y, kind label, color, visible
const [n0x, setN0x] = useState(0);
const [n0y, setN0y] = useState(0);
const [n0k, setN0k] = useState('');
const [n0c, setN0c] = useState('#334155');
const [n0v, setN0v] = useState(0);
const [n1x, setN1x] = useState(0);
const [n1y, setN1y] = useState(0);
const [n1k, setN1k] = useState('');
const [n1c, setN1c] = useState('#334155');
const [n1v, setN1v] = useState(0);
const [n2x, setN2x] = useState(0);
const [n2y, setN2y] = useState(0);
const [n2k, setN2k] = useState('');
const [n2c, setN2c] = useState('#334155');
const [n2v, setN2v] = useState(0);
const [n3x, setN3x] = useState(0);
const [n3y, setN3y] = useState(0);
const [n3k, setN3k] = useState('');
const [n3c, setN3c] = useState('#334155');
const [n3v, setN3v] = useState(0);
const [n4x, setN4x] = useState(0);
const [n4y, setN4y] = useState(0);
const [n4k, setN4k] = useState('');
const [n4c, setN4c] = useState('#334155');
const [n4v, setN4v] = useState(0);
const [n5x, setN5x] = useState(0);
const [n5y, setN5y] = useState(0);
const [n5k, setN5k] = useState('');
const [n5c, setN5c] = useState('#334155');
const [n5v, setN5v] = useState(0);
const [n6x, setN6x] = useState(0);
const [n6y, setN6y] = useState(0);
const [n6k, setN6k] = useState('');
const [n6c, setN6c] = useState('#334155');
const [n6v, setN6v] = useState(0);
const [n7x, setN7x] = useState(0);
const [n7y, setN7y] = useState(0);
const [n7k, setN7k] = useState('');
const [n7c, setN7c] = useState('#334155');
const [n7v, setN7v] = useState(0);
const [n8x, setN8x] = useState(0);
const [n8y, setN8y] = useState(0);
const [n8k, setN8k] = useState('');
const [n8c, setN8c] = useState('#334155');
const [n8v, setN8v] = useState(0);
const [n9x, setN9x] = useState(0);
const [n9y, setN9y] = useState(0);
const [n9k, setN9k] = useState('');
const [n9c, setN9c] = useState('#334155');
const [n9v, setN9v] = useState(0);
const [n10x, setN10x] = useState(0);
const [n10y, setN10y] = useState(0);
const [n10k, setN10k] = useState('');
const [n10c, setN10c] = useState('#334155');
const [n10v, setN10v] = useState(0);
const [n11x, setN11x] = useState(0);
const [n11y, setN11y] = useState(0);
const [n11k, setN11k] = useState('');
const [n11c, setN11c] = useState('#334155');
const [n11v, setN11v] = useState(0);

// 12 connection paths (parent → child lines)
const [p0, setP0] = useState('');
const [p1, setP1] = useState('');
const [p2, setP2] = useState('');
const [p3, setP3] = useState('');
const [p4, setP4] = useState('');
const [p5, setP5] = useState('');
const [p6, setP6] = useState('');
const [p7, setP7] = useState('');
const [p8, setP8] = useState('');
const [p9, setP9] = useState('');
const [p10, setP10] = useState('');
const [p11, setP11] = useState('');

<script>
var TC = {
  output: '#475569', command: '#60a5fa', error: '#f87171',
  success: '#4ade80', heading: '#e2e8f0', separator: '#334155',
  progress: '#f97316', user_prompt: '#3b82f6', user_text: '#60a5fa',
  assistant_text: '#94a3b8', thinking: '#8b5cf6', thought_complete: '#7c3aed',
  tool: '#eab308', result: '#64748b', diff: '#22c55e',
  banner: '#475569', status_bar: '#334155', box_drawing: '#1e293b',
  input_border: '#334155', input_zone: '#3b82f6', permission: '#f97316',
  menu_title: '#94a3b8', menu_option: '#cbd5e1', menu_desc: '#64748b',
  hint: '#64748b', task_done: '#22c55e', task_active: '#f97316',
  task_open: '#94a3b8', task_summary: '#3b82f6', text: '#94a3b8'
};

function nodeColor(kind) { return TC[kind] || '#475569'; }

// Initialize classifier to claude_code (0=none, 1=basic, 2=claude_code)
__sem_set_mode(2);

function selectNode(idx) { setSelectedIdx(idx); }

// Layout the semantic graph as a tree on the canvas
setInterval(function() {
  var s = __sem_state();
  if (!s) return;
  setModeName(s.mode_name);
  setTurnCount(s.turn_count);
  setNodeCount(s.node_count);

  var nc = __sem_node_count();
  if (nc === 0) return;

  // Collect nodes, skip structural containers (session_root, turn containers)
  var contentNodes = [];
  var i = 0;
  while (nc > i) {
    var n = __sem_node(i);
    if (n && n.kind !== 'output') {
      n._idx = i;
      contentNodes.push(n);
    }
    i = i + 1;
  }

  // Layout: group by turn_id, each turn is a column
  var turns = {};
  var turnOrder = [];
  i = 0;
  while (contentNodes.length > i) {
    var node = contentNodes[i];
    var tid = node.turn_id;
    if (!turns[tid]) {
      turns[tid] = [];
      turnOrder.push(tid);
    }
    turns[tid].push(node);
    i = i + 1;
  }

  // Position nodes: turns spread horizontally, children stacked vertically
  var COL_W = 220;
  var ROW_H = 70;
  var START_X = -((turnOrder.length - 1) * COL_W) / 2;
  var positions = []; // { x, y, kind, color, idx }
  var pathList = [];

  var turnIdx = 0;
  while (turnOrder.length > turnIdx) {
    var tid2 = turnOrder[turnIdx];
    var children = turns[tid2];
    var cx = START_X + turnIdx * COL_W;
    var cy = -((children.length - 1) * ROW_H) / 2;

    // Turn header node
    if (positions.length > 11) { turnIdx = turnIdx + 1; continue; }
    var turnX = cx;
    var turnY = cy - ROW_H;
    positions.push({ x: turnX, y: turnY, kind: 'turn ' + tid2, color: '#1e40af', idx: -1 });
    var turnPosIdx = positions.length - 1;

    var ci = 0;
    while (children.length > ci) {
      if (positions.length > 11) { ci = ci + 1; continue; }
      var child = children[ci];
      var childX = cx;
      var childY = cy + ci * ROW_H;
      positions.push({ x: childX, y: childY, kind: child.kind, color: nodeColor(child.kind), idx: child._idx });

      // Path from turn header to child
      if (pathList.length > 11) { ci = ci + 1; continue; }
      var px1 = turnX + 90;
      var py1 = turnY + 20;
      var px2 = childX;
      var py2 = childY + 10;
      pathList.push('M ' + px1 + ',' + py1 + ' L ' + px2 + ',' + py2);
      ci = ci + 1;
    }
    turnIdx = turnIdx + 1;
  }

  // Write positions to state slots
  var sX = [setN0x,setN1x,setN2x,setN3x,setN4x,setN5x,setN6x,setN7x,setN8x,setN9x,setN10x,setN11x];
  var sY = [setN0y,setN1y,setN2y,setN3y,setN4y,setN5y,setN6y,setN7y,setN8y,setN9y,setN10y,setN11y];
  var sK = [setN0k,setN1k,setN2k,setN3k,setN4k,setN5k,setN6k,setN7k,setN8k,setN9k,setN10k,setN11k];
  var sC = [setN0c,setN1c,setN2c,setN3c,setN4c,setN5c,setN6c,setN7c,setN8c,setN9c,setN10c,setN11c];
  var sV = [setN0v,setN1v,setN2v,setN3v,setN4v,setN5v,setN6v,setN7v,setN8v,setN9v,setN10v,setN11v];
  var sP = [setP0,setP1,setP2,setP3,setP4,setP5,setP6,setP7,setP8,setP9,setP10,setP11];

  i = 0;
  while (12 > i) {
    if (positions.length > i) {
      sX[i](positions[i].x);
      sY[i](positions[i].y);
      sK[i](positions[i].kind);
      sC[i](positions[i].color);
      sV[i](1);
    } else {
      sV[i](0);
    }
    if (pathList.length > i) {
      sP[i](pathList[i]);
    } else {
      sP[i]('');
    }
    i = i + 1;
  }

  // Update selected node info
  if (selectedIdx >= 0) {
    var sel = __sem_node(selectedIdx);
    if (sel) {
      setSelKind(sel.kind);
      setSelRole(sel.role);
      setSelLane(sel.lane);
      setSelText(sel.text || '');
      setSelRows('r' + sel.row_start + '-' + sel.row_end + ' (' + sel.row_count + ' rows)');
    }
  }
}, 300);

function toggleClassifier() {
  // 0=none, 1=basic, 2=claude_code
  var next = classMode === 0 ? 1 : classMode === 1 ? 2 : 0;
  setClassMode(next);
  __sem_set_mode(next);
}
</script>

function NodeBox(kind, color) {
  return (
    <Box style={{ backgroundColor: color, borderRadius: 4, paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, minWidth: 140 }}>
      <Text fontSize={10} color="#0f172a" bold>{kind}</Text>
    </Box>
  );
}

function InfoPanel() {
  return (
    <Box style={{ width: 240, backgroundColor: '#0f172a', borderLeftWidth: 1, borderColor: '#1e293b', flexDirection: 'column', padding: 8, gap: 6 }}>
      <Text fontSize={12} color="#e2e8f0" bold>Node Inspector</Text>
      <Box style={{ flexDirection: 'column', gap: 3, paddingTop: 4 }}>
        <Text fontSize={10} color="#64748b">KIND</Text>
        <Text fontSize={11} color="#e2e8f0">{selKind}</Text>
      </Box>
      <Box style={{ flexDirection: 'column', gap: 3 }}>
        <Text fontSize={10} color="#64748b">ROLE / LANE</Text>
        <Text fontSize={11} color="#e2e8f0">{`${selRole} / ${selLane}`}</Text>
      </Box>
      <Box style={{ flexDirection: 'column', gap: 3 }}>
        <Text fontSize={10} color="#64748b">ROWS</Text>
        <Text fontSize={11} color="#e2e8f0">{selRows}</Text>
      </Box>
      <Box style={{ flexDirection: 'column', gap: 3 }}>
        <Text fontSize={10} color="#64748b">TEXT</Text>
        <Text fontSize={9} color="#94a3b8">{selText}</Text>
      </Box>
    </Box>
  );
}

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0f172a', flexDirection: 'column' }}>
      <Box style={{ flexDirection: 'row', paddingLeft: 8, paddingRight: 8, paddingTop: 6, paddingBottom: 6, backgroundColor: '#1e293b', alignItems: 'center', gap: 12 }}>
        <Text fontSize={13} color="#e2e8f0" bold>Claude Canvas</Text>
        <Pressable onPress={() => { toggleClassifier() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#94a3b8">{classMode === 0 ? 'none' : classMode === 1 ? 'basic' : 'claude_code'}</Text>
          </Box>
        </Pressable>
        <Text fontSize={10} color={modeName === 'idle' ? '#4ade80' : modeName === 'thinking' ? '#a78bfa' : '#f97316'}>{modeName}</Text>
        <Text fontSize={10} color="#64748b">{`turns:${turnCount} nodes:${nodeCount}`}</Text>
      </Box>

      <Box style={{ flexGrow: 1, flexDirection: 'row' }}>
        <Box style={{ flexGrow: 1, flexBasis: 0 }}>
          <Terminal fontSize={11} style={{ height: 200 }} />
          <Canvas style={{ flexGrow: 1, flexBasis: 0 }} viewX={0} viewY={0} viewZoom={0.9} driftX={0} driftY={0}>
            {p0 != '' && <Canvas.Path d={p0} stroke="#334155" strokeWidth={1} />}
            {p1 != '' && <Canvas.Path d={p1} stroke="#334155" strokeWidth={1} />}
            {p2 != '' && <Canvas.Path d={p2} stroke="#334155" strokeWidth={1} />}
            {p3 != '' && <Canvas.Path d={p3} stroke="#334155" strokeWidth={1} />}
            {p4 != '' && <Canvas.Path d={p4} stroke="#334155" strokeWidth={1} />}
            {p5 != '' && <Canvas.Path d={p5} stroke="#334155" strokeWidth={1} />}
            {p6 != '' && <Canvas.Path d={p6} stroke="#334155" strokeWidth={1} />}
            {p7 != '' && <Canvas.Path d={p7} stroke="#334155" strokeWidth={1} />}
            {p8 != '' && <Canvas.Path d={p8} stroke="#334155" strokeWidth={1} />}
            {p9 != '' && <Canvas.Path d={p9} stroke="#334155" strokeWidth={1} />}
            {p10 != '' && <Canvas.Path d={p10} stroke="#334155" strokeWidth={1} />}
            {p11 != '' && <Canvas.Path d={p11} stroke="#334155" strokeWidth={1} />}

            {n0v == 1 && <Canvas.Node gx={n0x} gy={n0y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(0) }}><NodeBox kind={n0k} color={n0c} /></Pressable>
            </Canvas.Node>}
            {n1v == 1 && <Canvas.Node gx={n1x} gy={n1y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(1) }}><NodeBox kind={n1k} color={n1c} /></Pressable>
            </Canvas.Node>}
            {n2v == 1 && <Canvas.Node gx={n2x} gy={n2y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(2) }}><NodeBox kind={n2k} color={n2c} /></Pressable>
            </Canvas.Node>}
            {n3v == 1 && <Canvas.Node gx={n3x} gy={n3y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(3) }}><NodeBox kind={n3k} color={n3c} /></Pressable>
            </Canvas.Node>}
            {n4v == 1 && <Canvas.Node gx={n4x} gy={n4y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(4) }}><NodeBox kind={n4k} color={n4c} /></Pressable>
            </Canvas.Node>}
            {n5v == 1 && <Canvas.Node gx={n5x} gy={n5y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(5) }}><NodeBox kind={n5k} color={n5c} /></Pressable>
            </Canvas.Node>}
            {n6v == 1 && <Canvas.Node gx={n6x} gy={n6y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(6) }}><NodeBox kind={n6k} color={n6c} /></Pressable>
            </Canvas.Node>}
            {n7v == 1 && <Canvas.Node gx={n7x} gy={n7y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(7) }}><NodeBox kind={n7k} color={n7c} /></Pressable>
            </Canvas.Node>}
            {n8v == 1 && <Canvas.Node gx={n8x} gy={n8y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(8) }}><NodeBox kind={n8k} color={n8c} /></Pressable>
            </Canvas.Node>}
            {n9v == 1 && <Canvas.Node gx={n9x} gy={n9y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(9) }}><NodeBox kind={n9k} color={n9c} /></Pressable>
            </Canvas.Node>}
            {n10v == 1 && <Canvas.Node gx={n10x} gy={n10y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(10) }}><NodeBox kind={n10k} color={n10c} /></Pressable>
            </Canvas.Node>}
            {n11v == 1 && <Canvas.Node gx={n11x} gy={n11y} gw={180} gh={0}>
              <Pressable onPress={() => { selectNode(11) }}><NodeBox kind={n11k} color={n11c} /></Pressable>
            </Canvas.Node>}
          </Canvas>
        </Box>

        {selectedIdx >= 0 && <InfoPanel />}
      </Box>
    </Box>
  );
}
