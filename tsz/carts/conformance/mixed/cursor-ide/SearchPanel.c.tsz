// SearchPanel — repo search with click-through results and workspace scope

function SearchResult(props) {
  var result = props.result;

  return (
    <C.SearchResult onPress={function() { props.onOpenResult(result.file, result.line); }}>
      <C.SearchResultHeader>
        <C.SearchResultFile>{result.file}</C.SearchResultFile>
        <C.SearchResultLine>:{result.line}</C.SearchResultLine>
        <Box style={{ flexGrow: 1 }} />
        <C.SearchResultBadge>{result.matches}</C.SearchResultBadge>
      </C.SearchResultHeader>
      <C.SearchResultText>{result.text}</C.SearchResultText>
    </C.SearchResult>
  );
}

function SearchPanel(props) {
  return (
    <C.SearchPanel>
      <C.SearchHeader>
        <C.SearchTopRow>
          <C.SearchTitle>Project Search</C.SearchTitle>
          <C.SearchScope>{props.workspaceName + ' / ' + props.gitBranch}</C.SearchScope>
          <Pressable onPress={function() { setShowSearch(0); }} style={{ paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={12} color="#6e6e6e">x</Text>
          </Pressable>
        </C.SearchTopRow>

        <C.SearchInputBox>
          <C.SearchInputIcon>?</C.SearchInputIcon>
          <C.SearchInput value={searchQuery} onChange={function(v) { searchProject(v); }} />
        </C.SearchInputBox>

        <C.SearchOptions>
          <C.SearchOption><Text fontSize={10} color="#79c0ff">repo</Text></C.SearchOption>
          <C.SearchOption><Text fontSize={10} color="#6e6e6e">case</Text></C.SearchOption>
          <C.SearchOption><Text fontSize={10} color="#6e6e6e">regex</Text></C.SearchOption>
        </C.SearchOptions>
      </C.SearchHeader>

      <C.SearchResults>
        <C.SearchResultsStack>
          {props.results.map(function(result, idx) {
            return <SearchResult key={idx} result={result} onOpenResult={props.onOpenResult} />;
          })}
        </C.SearchResultsStack>
      </C.SearchResults>

      <C.SearchFooter>
        <C.SearchFooterText>{props.results.length + ' results in workspace'}</C.SearchFooterText>
        <C.SearchActionBtn onPress={function() { searchProject(searchQuery); }}>
          <Text fontSize={10} color="#9db1c9">Refresh</Text>
        </C.SearchActionBtn>
      </C.SearchFooter>
    </C.SearchPanel>
  );
}

export { SearchPanel };
