// TopBar — workspace chrome, git summary, and panel toggles

function TopBarAction(props) {
  return (
    <C.TopBarAction onPress={props.onPress}>
      <C.TopBarActionLabel>{props.label}</C.TopBarActionLabel>
      {props.meta && <C.TopBarActionMeta>{props.meta}</C.TopBarActionMeta>}
    </C.TopBarAction>
  );
}

function TopBar(props) {
  return (
    <C.TopBar>
      <C.TopBarLeft>
        <C.TopBarTraffic>
          <C.TopBarTrafficDot style={{ backgroundColor: '#ff5f57' }} />
          <C.TopBarTrafficDot style={{ backgroundColor: '#febc2e' }} />
          <C.TopBarTrafficDot style={{ backgroundColor: '#28c840' }} />
        </C.TopBarTraffic>

        <C.TopBarWorkspaceBtn onPress={props.onOpenHome}>
          <C.TopBarWorkspaceGlyph>{props.workspaceName.charAt(0)}</C.TopBarWorkspaceGlyph>
          <C.TopBarWorkspaceText>{props.workspaceName}</C.TopBarWorkspaceText>
        </C.TopBarWorkspaceBtn>

        <C.TopBarCommandBar onPress={props.onOpenHome}>
          <C.TopBarCommandHint>Project landing</C.TopBarCommandHint>
          {props.title == '__landing__' && <C.TopBarCommandLabel>{props.workspaceTagline}</C.TopBarCommandLabel>}
          {props.title != '__landing__' && <C.TopBarCommandLabel>{props.title}</C.TopBarCommandLabel>}
        </C.TopBarCommandBar>
      </C.TopBarLeft>

      <C.TopBarRight>
        <C.TopBarGitChip>
          <C.TopBarGitDot />
          <C.TopBarGitText>{props.gitBranch}</C.TopBarGitText>
          <C.TopBarGitMeta>{props.changedCount + ' dirty / ' + props.stagedCount + ' staged'}</C.TopBarGitMeta>
        </C.TopBarGitChip>

        <TopBarAction label="Refresh" meta="R" onPress={props.onRefreshWorkspace} />
        <TopBarAction label="Search" meta="F3" onPress={props.onToggleSearch} />
        <TopBarAction label="Terminal" meta="~" onPress={props.onToggleTerminal} />
        <TopBarAction label="Agent" onPress={props.onToggleChat} />
      </C.TopBarRight>
    </C.TopBar>
  );
}

export { TopBar };
