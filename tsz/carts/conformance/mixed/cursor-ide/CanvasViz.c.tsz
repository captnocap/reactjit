// Canvas Visualization — Code graph, semantic structure

function CanvasNode(props) {
  var node = props.node;
  var isSelected = props.selected;

  return (
    <Canvas.Node gx={node.x} gy={node.y} gw={120} gh={40}>
      <Pressable onPress={function() { setSelectedNode(node.id); }}>
        {isSelected == 1 && (
          <C.CanvasNodeSelected>
            <C.CanvasNodeLabel>{node.label}</C.CanvasNodeLabel>
          </C.CanvasNodeSelected>
        )}
        {isSelected == 0 && (
          <C.CanvasNodeBox>
            <C.CanvasNodeLabel>{node.label}</C.CanvasNodeLabel>
          </C.CanvasNodeBox>
        )}
      </Pressable>
    </Canvas.Node>
  );
}

function CanvasViz(props) {
  // Generate mock graph nodes
  var nodes = [
    { id: 0, x: 0, y: 0, label: 'App' },
    { id: 1, x: -150, y: 100, label: 'Sidebar' },
    { id: 2, x: 0, y: 100, label: 'Editor' },
    { id: 3, x: 150, y: 100, label: 'Chat' },
    { id: 4, x: -200, y: 200, label: 'FileTree' },
    { id: 5, x: -100, y: 200, label: 'useSQLite' },
    { id: 6, x: -50, y: 200, label: 'useFSWatch' },
  ];

  var paths = [
    'M 0,20 L -150,100',
    'M 0,20 L 0,100',
    'M 0,20 L 150,100',
    'M -150,120 L -200,200',
    'M -150,120 L -100,200',
  ];

  return (
    <C.CanvasViz>
      <C.CanvasVizHeader>
        <C.CanvasVizTitle>Code Graph</C.CanvasVizTitle>
        <C.CanvasVizActions>
          <C.CanvasVizBtn>Force</C.CanvasVizBtn>
          <C.CanvasVizBtn>Tree</C.CanvasVizBtn>
        </C.CanvasVizActions>
      </C.CanvasVizHeader>

      <Canvas style={{ flexGrow: 1, flexBasis: 0 }} viewX={0} viewY={100} viewZoom={0.8}>
        <Canvas.Path d="M 0,20 L -150,100" stroke="#3d3d3d" strokeWidth={1} />
        <Canvas.Path d="M 0,20 L 0,100" stroke="#3d3d3d" strokeWidth={1} />
        <Canvas.Path d="M 0,20 L 150,100" stroke="#3d3d3d" strokeWidth={1} />
        <CanvasNode node={nodes[0]} selected={nodes[0].id == props.selectedNode ? 1 : 0} />
        <CanvasNode node={nodes[1]} selected={nodes[1].id == props.selectedNode ? 1 : 0} />
        <CanvasNode node={nodes[2]} selected={nodes[2].id == props.selectedNode ? 1 : 0} />
        <CanvasNode node={nodes[3]} selected={nodes[3].id == props.selectedNode ? 1 : 0} />
      </Canvas>

      <C.CanvasVizFooter>
        <C.CanvasVizStat>{props.nodeCount} nodes</C.CanvasVizStat>
        <C.CanvasVizStat>{props.edgeCount} edges</C.CanvasVizStat>
      </C.CanvasVizFooter>
    </C.CanvasViz>
  );
}

export { CanvasViz };
