// SettingsPanel — dense power-user settings surface for providers, context, memory, plugins, and capability pressure

import {
  PackageIcon, PaletteIcon, BracesIcon, GlobeIcon, BotIcon, SparklesIcon,
  BadgeInfoIcon, AlertTriangleIcon, FileJsonIcon, FileCodeIcon, FolderIcon,
  TerminalIcon
} from './Icon.c';

function SettingsSectionRow(props) {
  var section = props.section;
  var active = props.active == 1;
  var cardStyle = active == 1
    ? { padding: 12, borderRadius: 12, borderWidth: 1, borderColor: section.tone, backgroundColor: '#121a24', gap: 4 }
    : { padding: 12, borderRadius: 12, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#0f141c', gap: 4 };

  return (
    <Pressable onPress={function() { props.onSelect(section.id); }} style={cardStyle}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Box style={{ width: 12, height: 12, alignItems: 'center', justifyContent: 'center' }}>
          {section.icon == 'globe' && <GlobeIcon size={12} />}
          {section.icon == 'folder' && <FolderIcon size={12} />}
          {section.icon == 'bot' && <BotIcon size={12} />}
          {section.icon == 'palette' && <PaletteIcon size={12} />}
          {section.icon == 'sparkles' && <SparklesIcon size={12} />}
          {section.icon == 'braces' && <BracesIcon size={12} />}
        </Box>
        <Text fontSize={12} color={active == 1 ? '#eef2f8' : '#c9d2df'} bold={true}>{section.label}</Text>
        <Box style={{ flexGrow: 1 }} />
        <Text fontSize={10} color={section.tone}>{section.count}</Text>
      </Box>
      <Text fontSize={10} color="#5d6a7c">{section.meta}</Text>
    </Pressable>
  );
}

function DenseChip(props) {
  return (
    <Box style={{ paddingLeft: 9, paddingRight: 9, paddingTop: 5, paddingBottom: 5, borderRadius: 999, borderWidth: 1, borderColor: props.borderColor || '#1f2935', backgroundColor: props.backgroundColor || '#10151d' }}>
      <Text fontSize={10} color={props.color || '#c9d2df'}>{props.label}</Text>
    </Box>
  );
}

function PanelHeader(props) {
  return (
    <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9, justifyContent: 'space-between' }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9, flexGrow: 1, flexBasis: 0 }}>
        <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
          {props.icon == 'globe' && <GlobeIcon size={13} />}
          {props.icon == 'package' && <PackageIcon size={13} />}
          {props.icon == 'folder' && <FolderIcon size={13} />}
          {props.icon == 'bot' && <BotIcon size={13} />}
          {props.icon == 'palette' && <PaletteIcon size={13} />}
          {props.icon == 'sparkles' && <SparklesIcon size={13} />}
          {props.icon == 'alert' && <AlertTriangleIcon size={13} />}
          {props.icon == 'file-json' && <FileJsonIcon size={13} />}
          {props.icon == 'file-code' && <FileCodeIcon size={13} />}
          {props.icon == 'terminal' && <TerminalIcon size={13} />}
          {props.icon == 'badge-info' && <BadgeInfoIcon size={13} />}
        </Box>
        <Box style={{ flexDirection: 'column', gap: 3, flexGrow: 1, flexBasis: 0 }}>
          <Text fontSize={13} color="#eef2f8" bold={true}>{props.title}</Text>
          <Text fontSize={10} color="#5d6a7c">{props.meta}</Text>
        </Box>
      </Box>
      {props.trailing && <DenseChip label={props.trailing} color={props.trailingColor || '#79c0ff'} />}
    </Box>
  );
}

function ProviderRow(props) {
  var provider = props.provider;
  var active = props.active == 1;
  var cardStyle = active == 1
    ? { padding: 12, borderRadius: 12, borderWidth: 1, borderColor: provider.tone, backgroundColor: '#121a24', gap: 8 }
    : { padding: 12, borderRadius: 12, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#0f141c', gap: 8 };

  return (
    <Pressable onPress={function() { props.onSelect(provider.id); }} style={cardStyle}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <DenseChip label={provider.short} color={provider.tone} borderColor={provider.tone} backgroundColor="#0f141c" />
        <Box style={{ flexDirection: 'column', gap: 2, flexGrow: 1, flexBasis: 0 }}>
          <Text fontSize={12} color="#eef2f8" bold={true}>{provider.name}</Text>
          <Text fontSize={10} color="#5d6a7c">{provider.driver}</Text>
        </Box>
        <DenseChip label={provider.status} color={provider.tone} borderColor={provider.tone} backgroundColor="#11161f" />
      </Box>

      <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
        <DenseChip label={provider.route} />
        <DenseChip label={provider.defaultModel} color="#79c0ff" />
        <DenseChip label={provider.env} color="#7ee787" />
      </Box>

      <Text fontSize={11} color="#c9d2df" lineHeight={17}>{provider.summary}</Text>
    </Pressable>
  );
}

function InfoRow(props) {
  return (
    <Box style={{ flexDirection: 'row', alignItems: 'flex-start', gap: 10, padding: 12, borderRadius: 12, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#0f141c' }}>
      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: props.item.tone, marginTop: 5 }} />
      <Box style={{ flexDirection: 'column', gap: 5, flexGrow: 1, flexBasis: 0 }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
          <Text fontSize={12} color="#eef2f8" bold={true}>{props.item.name}</Text>
          <DenseChip label={props.item.owner || props.item.backend || props.item.runtime || props.item.status} />
          {props.item.scope && <DenseChip label={props.item.scope} color="#79c0ff" />}
          {props.item.retention && <DenseChip label={props.item.retention} color="#d2a8ff" />}
        </Box>
        {props.item.source && <Text fontSize={10} color="#5d6a7c">{props.item.source}</Text>}
        {props.item.summary && <Text fontSize={11} color="#c9d2df" lineHeight={17}>{props.item.summary}</Text>}
        {props.item.stress && <Text fontSize={10} color="#ffb86b">stress: {props.item.stress}</Text>}
        {props.item.output && <Text fontSize={10} color="#79c0ff">output: {props.item.output}</Text>}
        {props.item.risk && <Text fontSize={10} color="#ff7b72">risk: {props.item.risk}</Text>}
      </Box>
    </Box>
  );
}

function CapabilityRow(props) {
  var item = props.item;

  return (
    <Box style={{ padding: 12, borderRadius: 12, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#0f141c', gap: 8 }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
        <Text fontSize={12} color="#eef2f8" bold={true}>{item.name}</Text>
        <DenseChip label={item.status} color={item.tone} borderColor={item.tone} backgroundColor="#11161f" />
        <DenseChip label={item.surface} />
      </Box>
      <Text fontSize={11} color="#c9d2df" lineHeight={17}>{item.summary}</Text>
      <Text fontSize={10} color="#79c0ff">reference: {item.reference}</Text>
      <Text fontSize={10} color="#ffb86b">pressure: {item.pressure}</Text>
    </Box>
  );
}

function SettingsPanel(props) {
  var selectedProvider = props.providers[0];
  var selectedProviderCapabilities = [];
  for (var pi = 0; pi < props.providers.length; pi++) {
    if (props.providers[pi].id == props.selectedProviderId) selectedProvider = props.providers[pi];
  }
  if (selectedProvider && selectedProvider.capabilities) selectedProviderCapabilities = selectedProvider.capabilities;

  var desktopBand = props.widthBand exact 'desktop' ? 1 : 0;
  var navWidth = desktopBand == 1 ? 240 : 0;
  var stackedLayout = props.widthBand exact 'narrow' || props.widthBand exact 'widget' || props.widthBand exact 'minimum';

  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0, backgroundColor: '#0d1015' }}>
      <Box style={{ flexDirection: 'column', padding: stackedLayout == 1 ? 12 : 18, gap: 16, backgroundColor: '#0d1015' }}>
        <Box style={{ padding: stackedLayout == 1 ? 14 : 18, borderRadius: 16, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#10151d', gap: 10 }}>
          <Text fontSize={10} color="#79c0ff" letterSpacing={0.8}>SETTINGS SURFACE</Text>
          <Text fontSize={stackedLayout == 1 ? 20 : 24} color="#eef2f8" bold={true}>Provider routing, context layers, memory, and plugin runtimes</Text>
          <Text fontSize={11} color="#c9d2df" lineHeight={18}>This page is deliberately product-dense. It pulls compiler pressure into one surface instead of scattering it across toy carts: model providers, orchestrated context, SQLite-backed memory, Lua/QJS plugin runtimes, automation rules, and capability references.</Text>

          <Box style={{ flexDirection: 'row', gap: 8, flexWrap: 'wrap' }}>
            <DenseChip label={'model ' + props.selectedModelName} color="#ff7b72" borderColor="#5a1f24" backgroundColor="#181015" />
            <DenseChip label={props.workspaceName} color="#79c0ff" />
            <DenseChip label={props.gitBranch} color="#7ee787" />
            <DenseChip label={props.agentStatusText} color="#d2a8ff" />
            <DenseChip label={props.workDir} color="#8ca0b8" />
          </Box>
        </Box>

        <Box style={stackedLayout == 1 ? { flexDirection: 'column', gap: 14 } : { flexDirection: 'row', gap: 14, alignItems: 'flex-start' }}>
          <Box style={stackedLayout == 1 ? { flexDirection: 'column', gap: 10 } : { width: navWidth, flexDirection: 'column', gap: 10 }}>
            {props.sections.map(function(section, idx) {
              return <SettingsSectionRow key={idx} section={section} active={section.id == props.activeSection ? 1 : 0} onSelect={props.onSelectSection} />;
            })}

            <Box style={{ padding: 12, borderRadius: 12, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#0f141c', gap: 6 }}>
              <Text fontSize={11} color="#eef2f8" bold={true}>Compiler Goals</Text>
              <Text fontSize={10} color="#5d6a7c">Each area is intended to either compile as a real product slice or fail loudly enough to reduce into conformance work.</Text>
              <DenseChip label="vertical slice first" color="#79c0ff" />
              <DenseChip label="runtime harness before workarounds" color="#7ee787" />
              <DenseChip label="compiler break is success" color="#ffb86b" />
            </Box>
          </Box>

          <Box style={{ flexDirection: 'column', gap: 14, flexGrow: 1, flexBasis: 0 }}>
            {props.activeSection == 'providers' && <Box style={{ flexDirection: 'column', gap: 14 }}>
              <Box style={{ padding: 14, borderRadius: 14, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#10151d', gap: 12 }}>
                <PanelHeader icon="package" title="Model Providers" meta="Real routing, auth, and policy surfaces instead of one hard-coded picker." trailing={props.providers.length + ' providers'} />
                <Box style={{ flexDirection: 'column', gap: 10 }}>
                  {props.providers.map(function(provider, idx) {
                    return <ProviderRow key={idx} provider={provider} active={provider.id == props.selectedProviderId ? 1 : 0} onSelect={props.onSelectProvider} />;
                  })}
                </Box>
              </Box>

              <Box style={{ padding: 14, borderRadius: 14, borderWidth: 1, borderColor: selectedProvider.tone, backgroundColor: '#10151d', gap: 12 }}>
                <PanelHeader icon="globe" title={selectedProvider.name + ' Routing'} meta={selectedProvider.summary} trailing={selectedProvider.status} trailingColor={selectedProvider.tone} />
                <Box style={{ flexDirection: 'row', gap: 8, flexWrap: 'wrap' }}>
                  {selectedProviderCapabilities.map(function(capability, idx) {
                    return <DenseChip key={idx} label={capability} color={selectedProvider.tone} borderColor={selectedProvider.tone} backgroundColor="#11161f" />;
                  })}
                </Box>
                <Box style={{ flexDirection: stackedLayout == 1 ? 'column' : 'row', gap: 10 }}>
                  <Box style={{ flexDirection: 'column', gap: 6, flexGrow: 1, flexBasis: 0, padding: 12, borderRadius: 12, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#0f141c' }}>
                    <Text fontSize={11} color="#eef2f8" bold={true}>Default route</Text>
                    <Text fontSize={10} color="#79c0ff">{selectedProvider.route}</Text>
                    <Text fontSize={10} color="#5d6a7c">{selectedProvider.env}</Text>
                  </Box>
                  <Box style={{ flexDirection: 'column', gap: 6, flexGrow: 1, flexBasis: 0, padding: 12, borderRadius: 12, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#0f141c' }}>
                    <Text fontSize={11} color="#eef2f8" bold={true}>Compiler pressure</Text>
                    <Text fontSize={10} color="#ffb86b">{selectedProvider.pressure}</Text>
                    <Text fontSize={10} color="#5d6a7c">{selectedProvider.detail}</Text>
                  </Box>
                </Box>
              </Box>
            </Box>}

            {props.activeSection == 'context' && <Box style={{ flexDirection: 'column', gap: 14 }}>
              <Box style={{ padding: 14, borderRadius: 14, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#10151d', gap: 12 }}>
                <PanelHeader icon="folder" title="Context Components" meta="Workspace, MCP-like sources, git, and focus surfaces that should be sharable across chat, editor, landing, and automations." trailing={props.contextRows.length + ' sources'} />
                <Box style={{ flexDirection: 'column', gap: 10 }}>
                  {props.contextRows.map(function(item, idx) {
                    return <InfoRow key={idx} item={item} />;
                  })}
                </Box>
              </Box>
            </Box>}

            {props.activeSection == 'memory' && <Box style={{ flexDirection: 'column', gap: 14 }}>
              <Box style={{ padding: 14, borderRadius: 14, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#10151d', gap: 12 }}>
                <PanelHeader icon="bot" title="Memory Orchestration" meta="Session, workspace, and durable stores should coordinate instead of duplicating context." trailing={props.memoryRows.length + ' banks'} />
                <Box style={{ flexDirection: 'column', gap: 10 }}>
                  {props.memoryRows.map(function(item, idx) {
                    return <InfoRow key={idx} item={item} />;
                  })}
                </Box>
              </Box>
            </Box>}

            {props.activeSection == 'plugins' && <Box style={{ flexDirection: 'column', gap: 14 }}>
              <Box style={{ padding: 14, borderRadius: 14, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#10151d', gap: 12 }}>
                <PanelHeader icon="palette" title="Plugin Runtimes" meta="Cursor / VS Code parity has to be modeled as real runtime surfaces, not just docs." trailing={props.pluginRows.length + ' runtimes'} />
                <Box style={{ flexDirection: 'column', gap: 10 }}>
                  {props.pluginRows.map(function(item, idx) {
                    return <InfoRow key={idx} item={item} />;
                  })}
                </Box>
              </Box>
            </Box>}

            {props.activeSection == 'automations' && <Box style={{ flexDirection: 'column', gap: 14 }}>
              <Box style={{ padding: 14, borderRadius: 14, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#10151d', gap: 12 }}>
                <PanelHeader icon="sparkles" title="Automation Rules" meta="IFTTT-style orchestration belongs in the product surface so plugins and runtime hooks can consume the same rule graph." trailing={props.automationRows.length + ' rules'} />
                <Box style={{ flexDirection: 'column', gap: 10 }}>
                  {props.automationRows.map(function(item, idx) {
                    return <InfoRow key={idx} item={item} />;
                  })}
                </Box>
              </Box>
            </Box>}

            {props.activeSection == 'capabilities' && <Box style={{ flexDirection: 'column', gap: 14 }}>
              <Box style={{ padding: 14, borderRadius: 14, borderWidth: 1, borderColor: '#1f2935', backgroundColor: '#10151d', gap: 12 }}>
                <PanelHeader icon="alert" title="Compiler Stress Map" meta="Feature references already present in ReactJIT that should be pulled into the IDE cart as real production affordances." trailing={props.capabilityRows.length + ' capabilities'} />
                <Box style={{ flexDirection: 'column', gap: 10 }}>
                  {props.capabilityRows.map(function(item, idx) {
                    return <CapabilityRow key={idx} item={item} />;
                  })}
                </Box>
              </Box>
            </Box>}
          </Box>
        </Box>
      </Box>
    </ScrollView>
  );
}

export { SettingsPanel };
