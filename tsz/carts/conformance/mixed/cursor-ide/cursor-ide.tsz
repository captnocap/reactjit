// Cursor IDE — Agentic coding environment (Cursor clone)
// Deliberately ambitious conformance surface with real workspace hooks.

import { Sidebar } from './Sidebar.c';
import { Editor } from './Editor.c';
import { ChatPanel } from './ChatPanel.c';
import { StatusBar } from './StatusBar.c';
import { TopBar } from './TopBar.c';
import { TabBar } from './TabBar.c';
import { TerminalPanel } from './Terminal.c';
import { SearchPanel } from './SearchPanel.c';
import { ProjectLanding } from './ProjectLanding.c';
import { initData, activateTab, closeTab, openFileByPath, openLandingPage, refreshWorkspace, setCurrentInput, sendMessage, openTerminal, execCommand, searchProject, indexProject, fetchAgent, saveCurrentFile, createNewFile, updateEditorContent, setAgentMode, addAttachment, removeAttachment, clearAttachments, attachCurrentFile, attachGitContext, triggerFileMention, triggerSymbolMention, toggleWebSearch, toggleTermAccess, toggleAutoApply, cycleModel, startNewConversation, selectSlashCommand, stopBackgroundAgent, openSearchResult } from './cursor.script';

import {
  Shell, Workspace, Editor as EditorShell, Sidebar as SidebarShell, ChatPanel as ChatPanelShell,
  TopBar as TopBarShell, TabBar as TabBarShell, Breadcrumbs as BreadcrumbsShell, StatusBar as StatusBarShell,
  TerminalPanel as TerminalPanelShell, SearchPanel as SearchPanelShell, LandingPage as LandingPageShell
} from './cursor_cls';

// === CORE STATE ===
const [activeTabId, setActiveTabId] = useState('home');
const [currentInput, setCurrentInputState] = useState('');
const [isGenerating, setIsGenerating] = useState(0);
const [cursorPosition, setCursorPosition] = useState({ line: 1, column: 1 });
const [ready, setReady] = useState(0);

// === AGENT INPUT STATE ===
const [agentMode, setAgentModeState] = useState('ask');
const [attachments, setAttachmentsState] = useState([]);
const [selectedModel, setSelectedModelState] = useState('claude-opus-4');
const [webSearch, setWebSearchState] = useState(0);
const [termAccess, setTermAccessState] = useState(0);
const [autoApply, setAutoApplyState] = useState(0);
const [inputTokenEstimate, setInputTokenEstimateState] = useState(0);

// === AGENT SESSION + TOOL EXECUTION STATE ===
const [toolExecutions, setToolExecutions] = useState([]);
const [streamingText, setStreamingText] = useState('');
const [agentSessionId, setAgentSessionId] = useState('');
const [activeAgentId, setActiveAgentId] = useState('');
const [agentStatusText, setAgentStatusText] = useState('idle');
const [workDir, setWorkDir] = useState('.');

// === WORKSPACE + LANDING STATE ===
const [workspaceName, setWorkspaceName] = useState('reactjit');
const [workspaceTagline, setWorkspaceTagline] = useState('Native agent workspace');
const [workspaceStats, setWorkspaceStats] = useState([
  { label: 'indexed', value: '0', tone: '#2d62ff' },
  { label: 'dirty', value: '0', tone: '#ffb86b' },
  { label: 'tabs', value: '1', tone: '#7ee787' },
  { label: 'agents', value: 'idle', tone: '#d2a8ff' },
]);
const [landingProjects, setLandingProjects] = useState([
  { name: 'reactjit', path: '__landing__', summary: 'Live workspace overview', badge: 'workspace', accent: '#2d62ff' },
]);
const [landingRecentFiles, setLandingRecentFiles] = useState([]);
const [gitConnections, setGitConnections] = useState([]);
const [gitChanges, setGitChanges] = useState([]);
const [gitRemote, setGitRemote] = useState('origin');
const [branchAhead, setBranchAhead] = useState(0);
const [branchBehind, setBranchBehind] = useState(0);
const [changedCount, setChangedCount] = useState(0);
const [stagedCount, setStagedCount] = useState(0);
const [activeView, setActiveView] = useState('landing');

// === PANEL VISIBILITY ===
const [showChat, setShowChat] = useState(1);
const [showTerminal, setShowTerminal] = useState(0);
const [showSearch, setShowSearch] = useState(0);

// === FILE TREE STATE ===
const [files, setFiles] = useState([
  { name: 'reactjit', type: 'workspace', indent: 0, expanded: 1, selected: 1, visible: 1, git: '', path: '.' },
]);

// === EDITOR STATE ===
const [editorContent, setEditorContent] = useState('');
const [editorModified, setEditorModified] = useState(0);
const [currentFilePath, setCurrentFilePath] = useState('__landing__');
const [editorRows, setEditorRows] = useState([]);
const [totalLines, setTotalLines] = useState(0);
const [lineNumbers, setLineNumbers] = useState([
  { num: '1' },
]);

// === TABS ===
const [openTabs, setOpenTabs] = useState([
  { id: 'home', name: 'Projects', path: '__landing__', type: 'home', modified: 0, pinned: 1 },
]);

// === CHAT ===
const [chatMessages, setChatMessages] = useState([]);

// === TERMINAL STATE ===
const [terminalLines, setTerminalLines] = useState([
  { text: '$ cursor-ide --version', type: 'command' },
  { text: 'cursor-ide v0.1.0 (ReactJIT native)', type: 'output' },
  { text: '$', type: 'prompt' },
]);

// === SEARCH STATE ===
const [searchQuery, setSearchQuery] = useState('');
const [searchResults, setSearchResults] = useState([]);

// === MODEL DISPLAY ===
const [modelDisplayName, setModelDisplayName] = useState('Opus 4');

// === STATUS BAR ===
const [gitBranch, setGitBranch] = useState('main');
const [gitStatus, setGitStatus] = useState('');
const [errors, setErrors] = useState(0);
const [warnings, setWarnings] = useState(0);
const [languageMode, setLanguageMode] = useState('Workspace');

// Breadcrumbs derived from current file path
const [breadcrumbs, setBreadcrumbs] = useState([
  { label: 'Projects', icon: 'P', tone: '#2d62ff', active: 0, kind: 'home' },
  { label: 'reactjit', icon: 'R', tone: '#7ee787', active: 1, kind: 'workspace', meta: 'workspace' },
]);

// Initialize on first render
if (ready == 0) {
  initData();
  setReady(1);
}

function App() {
  return (
    <C.Shell>
      <TopBar
        title={currentFilePath}
        workspaceName={workspaceName}
        workspaceTagline={workspaceTagline}
        gitBranch={gitBranch}
        changedCount={changedCount}
        stagedCount={stagedCount}
        onOpenHome={function() { openLandingPage(); }}
        onRefreshWorkspace={function() { refreshWorkspace(); }}
        onToggleChat={function() { setShowChat(1 - showChat); }}
        onToggleTerminal={function() { openTerminal(); setShowTerminal(1 - showTerminal); }}
        onToggleSearch={function() { setShowSearch(1 - showSearch); }}
      />

      <C.Workspace>
        <Sidebar
          files={files}
          tabs={openTabs}
          gitChanges={gitChanges}
          workspaceName={workspaceName}
          workDir={workDir}
          gitBranch={gitBranch}
          changedCount={changedCount}
          stagedCount={stagedCount}
          currentFilePath={currentFilePath}
          onOpenHome={function() { openLandingPage(); }}
          onRefreshWorkspace={function() { refreshWorkspace(); }}
          onSelectPath={function(path) { openFileByPath(path); }}
        />

        <C.Editor>
          <TabBar tabs={openTabs} activeId={activeTabId} />
          <C.Breadcrumbs>
            {breadcrumbs.map(function(crumb, idx) {
              return (
                <C.BreadcrumbItem onPress={crumb.kind == 'home' ? function() { openLandingPage(); } : function() {}}>
                  {idx > 0 && <C.BreadcrumbSep>/</C.BreadcrumbSep>}
                  <C.BreadcrumbIconPill style={{ backgroundColor: crumb.tone }}>
                    <C.BreadcrumbIconText>{crumb.icon}</C.BreadcrumbIconText>
                  </C.BreadcrumbIconPill>
                  {crumb.active == 1 && <C.BreadcrumbTextActive>{crumb.label}</C.BreadcrumbTextActive>}
                  {crumb.active != 1 && <C.BreadcrumbText>{crumb.label}</C.BreadcrumbText>}
                  {crumb.meta && <C.BreadcrumbMeta>{crumb.meta}</C.BreadcrumbMeta>}
                </C.BreadcrumbItem>
              );
            })}
          </C.Breadcrumbs>

          {activeView == 'landing' && (
            <ProjectLanding
              workspaceName={workspaceName}
              workspaceTagline={workspaceTagline}
              workDir={workDir}
              gitBranch={gitBranch}
              gitRemote={gitRemote}
              branchAhead={branchAhead}
              branchBehind={branchBehind}
              changedCount={changedCount}
              stagedCount={stagedCount}
              stats={workspaceStats}
              projects={landingProjects}
              recentFiles={landingRecentFiles}
              connections={gitConnections}
              onOpenPath={function(path) { openFileByPath(path); }}
              onIndexWorkspace={function() { indexProject('.'); }}
            />
          )}

          {activeView == 'editor' && (
            <Editor
              content={editorContent}
              editorRows={editorRows}
              lineNumbers={lineNumbers}
              totalLines={totalLines}
              cursorLine={cursorPosition.line}
              modified={editorModified}
              currentFilePath={currentFilePath}
            />
          )}

          {showTerminal == 1 && <TerminalPanel workDir={workDir} gitBranch={gitBranch} />}
        </C.Editor>

        {showSearch == 1 && (
          <SearchPanel
            query={searchQuery}
            results={searchResults}
            workspaceName={workspaceName}
            gitBranch={gitBranch}
            onOpenResult={function(path, line) { openSearchResult(path, line); }}
          />
        )}

        {showChat == 1 && (
          <ChatPanel
            messages={chatMessages}
            isGenerating={isGenerating}
            currentFilePath={currentFilePath}
            gitBranch={gitBranch}
            gitRemote={gitRemote}
            changedCount={changedCount}
            workspaceName={workspaceName}
            gitConnections={gitConnections}
            activeView={activeView}
          />
        )}
      </C.Workspace>

      <StatusBar
        gitBranch={gitBranch}
        gitStatus={gitStatus}
        gitRemote={gitRemote}
        branchAhead={branchAhead}
        branchBehind={branchBehind}
        changedCount={changedCount}
        stagedCount={stagedCount}
        cursorLine={cursorPosition.line}
        cursorColumn={cursorPosition.column}
        languageMode={languageMode}
        errors={errors}
        warnings={warnings}
        modified={editorModified}
        fileName={currentFilePath}
        workDir={workDir}
        selectedModel={modelDisplayName}
        agentStatusText={agentStatusText}
      />
    </C.Shell>
  );
}
