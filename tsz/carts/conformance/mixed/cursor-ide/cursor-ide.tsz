// Cursor IDE — Agentic coding environment (Cursor clone)
// Real file editing, icons, line numbers, create/save

import { Sidebar } from './Sidebar.c';
import { Editor } from './Editor.c';
import { ChatPanel } from './ChatPanel.c';
import { StatusBar } from './StatusBar.c';
import { TopBar } from './TopBar.c';
import { TabBar } from './TabBar.c';
import { TerminalPanel } from './Terminal.c';
import { SearchPanel } from './SearchPanel.c';
import { initData, selectFile, activateTab, closeTab, openFile, setCurrentInput, sendMessage, openTerminal, execCommand, searchProject, indexProject, fetchAgent, saveCurrentFile, createNewFile, updateEditorContent, setAgentMode, addAttachment, removeAttachment, clearAttachments, attachCurrentFile, triggerFileMention, triggerSymbolMention, toggleWebSearch, toggleTermAccess, toggleAutoApply, cycleModel, startNewConversation, selectSlashCommand, stopBackgroundAgent } from './cursor.script';

import {
  Shell, Workspace, Editor as EditorShell, Sidebar as SidebarShell, ChatPanel as ChatPanelShell,
  TopBar as TopBarShell, TabBar as TabBarShell, Breadcrumbs as BreadcrumbsShell, StatusBar as StatusBarShell,
  TerminalPanel as TerminalPanelShell, SearchPanel as SearchPanelShell
} from './cursor_cls';

// === CORE STATE ===
const [activeTabId, setActiveTabId] = useState('1');
const [currentInput, setCurrentInputState] = useState('');
const [isGenerating, setIsGenerating] = useState(0);
const [cursorPosition, setCursorPosition] = useState({ line: 1, column: 1 });
const [ready, setReady] = useState(0);

// === AGENT INPUT STATE ===
const [agentMode, setAgentModeState] = useState('ask');
const [attachments, setAttachmentsState] = useState([]);
const [selectedModel, setSelectedModelState] = useState('claude-opus-4');
const [webSearch, setWebSearchState] = useState(0);
const [termAccess, setTermAccessState] = useState(0);
const [autoApply, setAutoApplyState] = useState(0);
const [inputTokenEstimate, setInputTokenEstimateState] = useState(0);

// === AGENT SESSION + TOOL EXECUTION STATE ===
const [toolExecutions, setToolExecutions] = useState([]);
const [streamingText, setStreamingText] = useState('');
const [agentSessionId, setAgentSessionId] = useState('');
const [activeAgentId, setActiveAgentId] = useState('');
const [agentStatusText, setAgentStatusText] = useState('idle');
const [workDir, setWorkDir] = useState('.');

// === PANEL VISIBILITY ===
const [showChat, setShowChat] = useState(1);
const [showTerminal, setShowTerminal] = useState(0);
const [showSearch, setShowSearch] = useState(0);

// === FILE TREE STATE ===
const [files, setFiles] = useState([
  { name: 'cursor-ide', type: 'dir', indent: 0, expanded: 1, selected: 0, path: '.' },
  { name: 'src', type: 'dir', indent: 1, expanded: 1, selected: 0, path: 'src' },
  { name: 'components', type: 'dir', indent: 2, expanded: 1, selected: 0, path: 'src/components' },
  { name: 'Sidebar.tsx', type: 'tsx', indent: 3, selected: 1, path: 'src/components/Sidebar.tsx' },
  { name: 'Editor.tsx', type: 'tsx', indent: 3, selected: 0, path: 'src/components/Editor.tsx' },
  { name: 'ChatPanel.tsx', type: 'tsx', indent: 3, selected: 0, path: 'src/components/ChatPanel.tsx' },
  { name: 'StatusBar.tsx', type: 'tsx', indent: 3, selected: 0, path: 'src/components/StatusBar.tsx' },
  { name: 'Terminal.tsx', type: 'tsx', indent: 3, selected: 0, path: 'src/components/Terminal.tsx' },
  { name: 'hooks', type: 'dir', indent: 2, expanded: 0, selected: 0, path: 'src/hooks' },
  { name: 'useAgent.ts', type: 'ts', indent: 3, selected: 0, path: 'src/hooks/useAgent.ts' },
  { name: 'useFSWatch.ts', type: 'ts', indent: 3, selected: 0, path: 'src/hooks/useFSWatch.ts' },
  { name: 'useSQLite.ts', type: 'ts', indent: 3, selected: 0, path: 'src/hooks/useSQLite.ts' },
  { name: 'utils', type: 'dir', indent: 1, expanded: 0, selected: 0, path: 'utils' },
  { name: 'index.ts', type: 'ts', indent: 2, selected: 0, path: 'utils/index.ts' },
  { name: 'styles', type: 'dir', indent: 1, expanded: 0, selected: 0, path: 'styles' },
  { name: 'theme.css', type: 'css', indent: 2, selected: 0, path: 'styles/theme.css' },
  { name: 'package.json', type: 'json', indent: 1, selected: 0, path: 'package.json' },
  { name: 'README.md', type: 'md', indent: 1, selected: 0, path: 'README.md' },
  { name: 'tsconfig.json', type: 'json', indent: 1, selected: 0, path: 'tsconfig.json' },
]);

// === EDITOR STATE ===
const [editorContent, setEditorContent] = useState('// Cursor IDE - Agentic Coding Environment\n\nimport { useState, useEffect } from "react";\n\n// SQLite bridge for project indexing\nconst db = __sqlite_open("project.db");\n\n// File system watcher\nconst watcher = __fs_watch("./src");\n\nfunction Sidebar() {\n  const [files, setFiles] = useState([]);\n\n  useEffect(() => {\n    // Index project files in SQLite\n    __sqlite_exec(db, "CREATE TABLE IF NOT EXISTS files...");\n  }, []);\n\n  return <FileTree />;\n}');
const [editorModified, setEditorModified] = useState(0);
const [currentFilePath, setCurrentFilePath] = useState('src/components/Sidebar.tsx');
const [totalLines, setTotalLines] = useState(20);
const [lineNumbers, setLineNumbers] = useState([
  { num: '1' }, { num: '2' }, { num: '3' }, { num: '4' }, { num: '5' },
  { num: '6' }, { num: '7' }, { num: '8' }, { num: '9' }, { num: '10' },
  { num: '11' }, { num: '12' }, { num: '13' }, { num: '14' }, { num: '15' },
  { num: '16' }, { num: '17' }, { num: '18' }, { num: '19' }, { num: '20' },
]);

// === TABS ===
const [openTabs, setOpenTabs] = useState([
  { id: '1', name: 'Sidebar.tsx', path: 'src/components/Sidebar.tsx', modified: 0 },
]);

// === CHAT ===
const [chatMessages, setChatMessages] = useState([
  { role: 'assistant', time: '2:34 PM', text: 'I have analyzed the codebase. Found 19 files across 5 directories.' },
  { role: 'user', time: '2:36 PM', text: 'Search for all components using the SQLite bridge' },
  { role: 'assistant', time: '2:36 PM', text: 'Found 3 files: useSQLite.ts, SearchPanel.tsx, and AgentTools.tsx.' },
]);

// === TERMINAL STATE ===
const [terminalLines, setTerminalLines] = useState([
  { text: '$ cursor-ide --version', type: 'command' },
  { text: 'cursor-ide v0.1.0 (ReactJIT native)', type: 'output' },
  { text: '$', type: 'prompt' },
]);

// === SEARCH STATE ===
const [searchQuery, setSearchQuery] = useState('');
const [searchResults, setSearchResults] = useState([
  { file: 'useSQLite.ts', line: 15, text: 'const db = __sqlite_open("project.db");', matches: 3 },
  { file: 'SearchPanel.tsx', line: 42, text: 'function searchProject(query) {', matches: 2 },
]);

// === STATUS BAR ===
const [gitBranch, setGitBranch] = useState('main');
const [gitStatus, setGitStatus] = useState('*1');
const [errors, setErrors] = useState(0);
const [warnings, setWarnings] = useState(0);
const [languageMode, setLanguageMode] = useState('TypeScript TSX');

// Breadcrumbs derived from current file path
const [breadcrumbs, setBreadcrumbs] = useState([
  { label: 'src' },
  { label: 'components' },
  { label: 'Sidebar.tsx' },
]);

// Initialize on first render
if (ready == 0) {
  initData();
  setReady(1);
}

function App() {
  return (
    <C.Shell>
      <TopBar title={currentFilePath} onToggleChat={function() { setShowChat(1 - showChat); }} onToggleTerminal={function() { setShowTerminal(1 - showTerminal); }} onToggleSearch={function() { setShowSearch(1 - showSearch); }} />

      <C.Workspace>
        <Sidebar files={files} onSelectFile={function(idx) { openFile(idx); }} />

        <C.Editor>
          <TabBar tabs={openTabs} activeId={activeTabId} />
          <C.Breadcrumbs>
            {breadcrumbs.map(function(crumb, idx) {
              return (
                <C.BreadcrumbItem>
                  <C.BreadcrumbText>{crumb.label}</C.BreadcrumbText>
                </C.BreadcrumbItem>
              );
            })}
          </C.Breadcrumbs>

          <Editor content={editorContent} lineNumbers={lineNumbers} totalLines={totalLines} cursorLine={cursorPosition.line} modified={editorModified} />

          {showTerminal == 1 && <TerminalPanel lines={terminalLines} />}
        </C.Editor>

        {showChat == 1 && <ChatPanel messages={chatMessages} isGenerating={isGenerating} />}
        {showSearch == 1 && <SearchPanel query={searchQuery} results={searchResults} />}
      </C.Workspace>

      <StatusBar
        gitBranch={gitBranch}
        gitStatus={gitStatus}
        cursorLine={cursorPosition.line}
        cursorColumn={cursorPosition.column}
        languageMode={languageMode}
        errors={errors}
        warnings={warnings}
        modified={editorModified}
        fileName={currentFilePath}
      />
    </C.Shell>
  );
}
