// Project landing page — recent projects, git wiring, workspace launchpad

import {
  HouseIcon, PackageIcon, FolderIcon, FileCodeIcon, FileJsonIcon, FileTextIcon, PaletteIcon,
  BracesIcon, TerminalIcon, PanelLeftIcon, GitBranchIcon, SearchIcon, RefreshCcwIcon
} from './Icon.c';

function LandingStat(props) {
  return (
    <C.LandingStatCard>
      <C.LandingStatValue style={{ color: props.stat.tone }}>{props.stat.value}</C.LandingStatValue>
      <C.LandingStatLabel>{props.stat.label}</C.LandingStatLabel>
    </C.LandingStatCard>
  );
}

function LandingProjectCard(props) {
  var item = props.item;
  var metaPath = item.path;
  if (item.path == '__landing__') metaPath = 'Project landing';

  return (
    <C.LandingProjectCard onPress={function() { props.onOpenPath(item.path); }}>
      <C.LandingProjectHeader>
        <C.LandingProjectAccent style={{ backgroundColor: item.accent }} />
        <C.LandingProjectName>{item.name}</C.LandingProjectName>
        <C.LandingProjectBadge>{item.badge}</C.LandingProjectBadge>
      </C.LandingProjectHeader>
      <C.LandingProjectSummary>{item.summary}</C.LandingProjectSummary>
      <C.LandingProjectMeta>{metaPath}</C.LandingProjectMeta>
    </C.LandingProjectCard>
  );
}

function ConnectionRow(props) {
  var item = props.item;

  return (
    <C.LandingConnectionRow>
      <C.LandingConnectionDot style={{ backgroundColor: item.tone }} />
      <C.LandingConnectionBody>
        <C.LandingConnectionName>{item.name}</C.LandingConnectionName>
        <C.LandingConnectionMeta>{item.detail}</C.LandingConnectionMeta>
      </C.LandingConnectionBody>
    </C.LandingConnectionRow>
  );
}

function RecentRow(props) {
  var item = props.item;

  return (
    <C.LandingRecentRow onPress={function() { props.onOpenPath(item.path); }} style={props.compactBand == 1 ? { flexBasis: 180, minHeight: 0, padding: 10 } : { minHeight: 0 }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <C.BreadcrumbIconPill style={{ backgroundColor: item.tone || '#1f2935' }}>
          <Box style={{ width: 10, height: 10, alignItems: 'center', justifyContent: 'center' }}>
            {item.icon == 'house' && <HouseIcon size={10} />}
            {item.icon == 'package' && <PackageIcon size={10} />}
            {item.icon == 'folder' && <FolderIcon size={10} />}
            {item.icon == 'palette' && <PaletteIcon size={10} />}
            {item.icon == 'braces' && <BracesIcon size={10} />}
            {item.icon == 'terminal' && <TerminalIcon size={10} />}
            {item.icon == 'panel-left' && <PanelLeftIcon size={10} />}
            {item.icon == 'file-json' && <FileJsonIcon size={10} />}
            {item.icon == 'file-code' && <FileCodeIcon size={10} />}
            {item.icon != 'house' && item.icon != 'package' && item.icon != 'folder' && item.icon != 'palette' && item.icon != 'braces' && item.icon != 'terminal' && item.icon != 'panel-left' && item.icon != 'file-json' && item.icon != 'file-code' && <FileTextIcon size={10} />}
          </Box>
        </C.BreadcrumbIconPill>
        <C.LandingRecentName>{item.label}</C.LandingRecentName>
        <Box style={{ flexGrow: 1 }} />
        <C.LandingRecentReason>{item.reason}</C.LandingRecentReason>
      </Box>
      {props.minimumBand != 1 && <C.LandingRecentPath>{item.path}</C.LandingRecentPath>}
    </C.LandingRecentRow>
  );
}

function ProjectLanding(props) {
  var compactBand = 0;
  var minimumBand = 0;
  var syncText = '+' + props.branchAhead + ' / -' + props.branchBehind;
  var dirtyText = props.changedCount + ' dirty / ' + props.stagedCount + ' staged';

  if (props.widthBand exact 'narrow' || props.widthBand exact 'widget' || props.widthBand exact 'minimum') compactBand = 1;
  if (props.widthBand exact 'minimum') minimumBand = 1;

  return (
    <C.LandingPage>
      <C.LandingContent style={compactBand == 1 ? { padding: 12, gap: 12 } : {}}>
        <C.LandingHero style={minimumBand == 1 ? { padding: 14, gap: 6 } : {}}>
          <C.LandingEyebrow>PROJECT LANDING</C.LandingEyebrow>
          <C.LandingTitle>{props.workspaceName}</C.LandingTitle>
          {minimumBand != 1 && <C.LandingSubtitle>{props.workDir}</C.LandingSubtitle>}
          {minimumBand != 1 && <C.LandingBody>{props.workspaceTagline}</C.LandingBody>}

          <C.LandingHeroMetaRow>
            <C.LandingHeroChip>
              <C.LandingHeroChipKey>branch</C.LandingHeroChipKey>
              <C.LandingHeroChipValue>{props.gitBranch}</C.LandingHeroChipValue>
            </C.LandingHeroChip>
            <C.LandingHeroChip>
              <C.LandingHeroChipKey>remote</C.LandingHeroChipKey>
              <C.LandingHeroChipValue>{props.gitRemote}</C.LandingHeroChipValue>
            </C.LandingHeroChip>
            <C.LandingHeroChip>
              <C.LandingHeroChipKey>sync</C.LandingHeroChipKey>
              <C.LandingHeroChipValue>{syncText}</C.LandingHeroChipValue>
            </C.LandingHeroChip>
            {minimumBand != 1 && <C.LandingHeroChip>
              <C.LandingHeroChipKey>dirty</C.LandingHeroChipKey>
              <C.LandingHeroChipValue>{dirtyText}</C.LandingHeroChipValue>
            </C.LandingHeroChip>}
          </C.LandingHeroMetaRow>

          <C.LandingActionRow style={compactBand == 1 ? { flexWrap: 'wrap', gap: 8 } : {}}>
            <C.LandingPrimaryAction onPress={function() { props.onIndexWorkspace(); }}>
              <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 7 }}>
                <Box style={{ width: 12, height: 12, alignItems: 'center', justifyContent: 'center' }}>
                  <RefreshCcwIcon size={12} />
                </Box>
                <C.LandingPrimaryLabel>Index Workspace</C.LandingPrimaryLabel>
              </Box>
            </C.LandingPrimaryAction>
            <C.LandingSecondaryAction onPress={function() { props.onOpenPath('tsz/carts/conformance/mixed/cursor-ide/cursor-ide.tsz'); }}>
              <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 7 }}>
                <Box style={{ width: 12, height: 12, alignItems: 'center', justifyContent: 'center' }}>
                  <BracesIcon size={12} />
                </Box>
                <C.LandingSecondaryLabel>Open cursor-ide cart</C.LandingSecondaryLabel>
              </Box>
            </C.LandingSecondaryAction>
            <C.LandingSecondaryAction onPress={function() { props.onOpenSettings(); }}>
              <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 7 }}>
                <Box style={{ width: 12, height: 12, alignItems: 'center', justifyContent: 'center' }}>
                  <PaletteIcon size={12} />
                </Box>
                <C.LandingSecondaryLabel>Open Settings Surface</C.LandingSecondaryLabel>
              </Box>
            </C.LandingSecondaryAction>
          </C.LandingActionRow>
        </C.LandingHero>

        <C.LandingStatsRow>
          {props.stats.map(function(stat, idx) {
            return <LandingStat key={idx} stat={stat} />;
          })}
        </C.LandingStatsRow>

        <C.LandingPanels>
          <C.LandingPanel>
            <C.LandingPanelHeader>
              <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
                <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
                  <PackageIcon size={13} />
                </Box>
                <C.LandingPanelTitle>Projects</C.LandingPanelTitle>
              </Box>
              <C.LandingPanelMeta>Curated entry points into the repo</C.LandingPanelMeta>
            </C.LandingPanelHeader>
            <C.LandingProjectList>
              {props.projects.map(function(item, idx) {
                return <LandingProjectCard key={idx} item={item} onOpenPath={props.onOpenPath} />;
              })}
            </C.LandingProjectList>
          </C.LandingPanel>

          <C.LandingPanel>
            <C.LandingPanelHeader>
              <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
                <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
                  <GitBranchIcon size={13} />
                </Box>
                <C.LandingPanelTitle>Git Connections</C.LandingPanelTitle>
              </Box>
              <C.LandingPanelMeta>Branch, remote, and worktree wiring</C.LandingPanelMeta>
            </C.LandingPanelHeader>
            <C.LandingConnectionList>
              {props.connections.map(function(item, idx) {
                return <ConnectionRow key={idx} item={item} />;
              })}
            </C.LandingConnectionList>
          </C.LandingPanel>
        </C.LandingPanels>

        <C.LandingPanelCompact style={compactBand == 1 ? { gap: 8, padding: 12 } : {}}>
          <C.LandingPanelHeader>
            <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
              <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
                <SearchIcon size={13} />
              </Box>
              <C.LandingPanelTitle>Recent Focus</C.LandingPanelTitle>
            </Box>
            <C.LandingPanelMeta>Dirty files, open tabs, and cart hotspots</C.LandingPanelMeta>
          </C.LandingPanelHeader>
          <C.LandingRecentList>
            {props.recentFiles.map(function(item, idx) {
              return <RecentRow key={idx} item={item} compactBand={compactBand} minimumBand={minimumBand} onOpenPath={props.onOpenPath} />;
            })}
          </C.LandingRecentList>
        </C.LandingPanelCompact>
      </C.LandingContent>
    </C.LandingPage>
  );
}

export { ProjectLanding };
