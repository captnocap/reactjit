// Minimal cursor-ide pattern test: component with props.array.map()

const [items, setItems] = useState([{ name: '', icon: '' }]);

function ItemRow(props) {
  return (
    <Box style={{ flexDirection: 'row', gap: 6 }}>
      <Text fontSize={12} color="#6e6e6e">{props.file.icon}</Text>
      <Text fontSize={12} color="#b0b0b0">{props.file.name}</Text>
    </Box>
  );
}

function ItemList(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 2 }}>
      {props.items.map(function(file, idx) {
        return (
          <ItemRow file={file} />
        );
      })}
    </Box>
  );
}

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0d0d0d' }}>
      <Text fontSize={14} color="#ffffff">Cursor Mini Test</Text>
      <ItemList items={items} />
    </Box>
  );
}
