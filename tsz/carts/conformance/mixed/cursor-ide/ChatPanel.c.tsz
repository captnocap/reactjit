// ChatPanel — agent console that shares workspace, git, and editor context

function ToolCallCard(props) {
  var exec = props.exec;
  var tone = '#79c0ff';
  if (exec.status == 'completed') tone = '#7ee787';
  if (exec.status == 'error') tone = '#ff7b72';

  return (
    <C.ToolCallCard>
      <C.ToolCallHeader>
        <C.ToolCallName>{exec.name}</C.ToolCallName>
        <C.ToolCallInput>{exec.input}</C.ToolCallInput>
        <C.ToolCallStatus style={{ color: tone }}>{exec.status}</C.ToolCallStatus>
      </C.ToolCallHeader>
      <C.ToolCallOutput>
        <C.ToolCallOutputText>{exec.result}</C.ToolCallOutputText>
      </C.ToolCallOutput>
    </C.ToolCallCard>
  );
}

function AgentSessionBanner() {
  var isStreaming = agentStatusText == 'streaming';
  var isExecuting = agentStatusText == 'executing';
  var hasAgent = activeAgentId.length > 0;
  var isActive = isStreaming || isExecuting || hasAgent;

  if (!isActive) return null;

  var dotColor = '#4a4a4a';
  var label = 'idle';
  if (isStreaming) { dotColor = '#2d62ff'; label = 'streaming response'; }
  else if (isExecuting) { dotColor = '#e6b450'; label = 'running tools'; }
  else if (hasAgent) { dotColor = '#7ee787'; label = 'background agent ' + activeAgentId.substring(6, 18); }

  return (
    <C.SessionBanner>
      <C.SessionBannerDot style={{ backgroundColor: dotColor }} />
      <C.SessionBannerText>{label}</C.SessionBannerText>
      {hasAgent && (
        <C.SessionBannerStop onPress={function() { stopBackgroundAgent(); }}>
          <C.SessionBannerStopText>Stop</C.SessionBannerStopText>
        </C.SessionBannerStop>
      )}
    </C.SessionBanner>
  );
}

function ContextStrip(props) {
  return (
    <C.ChatContextStrip>
      <C.ChatContextChip>
        <C.ChatContextChipLabel>view</C.ChatContextChipLabel>
        <C.ChatContextChipValue>{props.activeView}</C.ChatContextChipValue>
      </C.ChatContextChip>
      <C.ChatContextChip>
        <C.ChatContextChipLabel>branch</C.ChatContextChipLabel>
        <C.ChatContextChipValue>{props.gitBranch}</C.ChatContextChipValue>
      </C.ChatContextChip>
      <C.ChatContextChip>
        <C.ChatContextChipLabel>focus</C.ChatContextChipLabel>
        <C.ChatContextChipValue>{props.currentFilePath == '__landing__' ? props.workspaceName : props.currentFilePath}</C.ChatContextChipValue>
      </C.ChatContextChip>
      <C.ChatContextChip>
        <C.ChatContextChipLabel>dirty</C.ChatContextChipLabel>
        <C.ChatContextChipValue>{'' + props.changedCount}</C.ChatContextChipValue>
      </C.ChatContextChip>
    </C.ChatContextStrip>
  );
}

function Message(props) {
  var msg = props.msg;
  var isUser = msg.role == 'user';
  var bubbleBg = isUser ? '#101827' : '#10141c';
  var bubbleBorder = isUser ? '#20324f' : '#1c2531';

  return (
    <C.Message>
      <C.MessageHeader>
        <C.MessageAvatar style={{ backgroundColor: isUser ? '#17345d' : '#143120' }}>
          <C.MessageAvatarText>{isUser ? 'U' : 'A'}</C.MessageAvatarText>
        </C.MessageAvatar>
        <C.MessageAuthor>{isUser ? 'You' : 'Agent'}</C.MessageAuthor>
        <C.MessageTime>{msg.time}</C.MessageTime>
        {msg.mode && <C.MessageModeBadge><C.MessageModeText>{msg.mode}</C.MessageModeText></C.MessageModeBadge>}
        {msg.model && <C.MessageModelBadge><C.MessageModelText>{msg.model}</C.MessageModelText></C.MessageModelBadge>}
      </C.MessageHeader>

      <C.MessageBubble style={{ backgroundColor: bubbleBg, borderColor: bubbleBorder }}>
        <C.MessageText>{msg.text}</C.MessageText>

        {msg.attachments && msg.attachments.length > 0 && (
          <C.ContextBar>
            {msg.attachments.map(function(a, i) {
              return (
                <C.ContextChip key={i}>
                  <C.ContextChipFile>{a.name}</C.ContextChipFile>
                </C.ContextChip>
              );
            })}
          </C.ContextBar>
        )}

        {msg.toolSnapshot && msg.toolSnapshot.length > 0 && (
          <C.MessageToolList>
            {msg.toolSnapshot.map(function(exec, idx) {
              return <ToolCallCard key={idx} exec={exec} />;
            })}
          </C.MessageToolList>
        )}
      </C.MessageBubble>
    </C.Message>
  );
}

function ThinkingIndicator() {
  var activeLabel = 'thinking';
  for (var ti = 0; ti < toolExecutions.length; ti++) {
    if (toolExecutions[ti].status == 'running') activeLabel = 'running ' + toolExecutions[ti].name;
  }

  return (
    <C.ThinkingRow>
      <C.ThinkingAvatar>
        <C.ThinkingAvatarText>AI</C.ThinkingAvatarText>
      </C.ThinkingAvatar>
      <C.ThinkingBubble>
        <C.ThinkingDot />
        <C.ThinkingDot />
        <C.ThinkingDot />
      </C.ThinkingBubble>
      <C.ThinkingLabel>{activeLabel}</C.ThinkingLabel>
    </C.ThinkingRow>
  );
}

function ModePillBar() {
  return (
    <C.ModePillBar>
      <C.ModePill onPress={function() { setAgentMode('ask'); }} style={agentMode == 'ask' ? { backgroundColor: '#10213d', borderColor: '#2d62ff' } : {}}>
        <C.ModePillLabel style={agentMode == 'ask' ? { color: '#79c0ff' } : {}}>Ask</C.ModePillLabel>
      </C.ModePill>
      <C.ModePill onPress={function() { setAgentMode('plan'); }} style={agentMode == 'plan' ? { backgroundColor: '#10213d', borderColor: '#2d62ff' } : {}}>
        <C.ModePillLabel style={agentMode == 'plan' ? { color: '#79c0ff' } : {}}>Plan</C.ModePillLabel>
      </C.ModePill>
      <C.ModePill onPress={function() { setAgentMode('task'); }} style={agentMode == 'task' ? { backgroundColor: '#182510', borderColor: '#7ee787' } : {}}>
        <C.ModePillLabel style={agentMode == 'task' ? { color: '#7ee787' } : {}}>Task</C.ModePillLabel>
      </C.ModePill>
      <C.ModePill onPress={function() { setAgentMode('agent'); }} style={agentMode == 'agent' ? { backgroundColor: '#26180f', borderColor: '#ffa657' } : {}}>
        <C.ModePillLabel style={agentMode == 'agent' ? { color: '#ffa657' } : {}}>Agent</C.ModePillLabel>
      </C.ModePill>
    </C.ModePillBar>
  );
}

function AttachBadge(props) {
  var a = props.attachment;
  var icon = '#';
  var tone = '#79c0ff';
  if (a.type == 'symbol') { icon = '@'; tone = '#d2a8ff'; }
  if (a.type == 'git') { icon = 'G'; tone = '#7ee787'; }

  return (
    <C.AttachBadge>
      <C.AttachBadgeIcon style={{ color: tone }}>{icon}</C.AttachBadgeIcon>
      <C.AttachBadgeName>{a.name}</C.AttachBadgeName>
      <C.AttachBadgeRemove onPress={function() { removeAttachment(a.id); }}>
        <C.AttachBadgeRemoveIcon>x</C.AttachBadgeRemoveIcon>
      </C.AttachBadgeRemove>
    </C.AttachBadge>
  );
}

function AttachmentBar() {
  if (attachments.length == 0) return null;

  return (
    <C.AttachmentBar>
      <C.AttachmentList>
        {attachments.map(function(a, idx) {
          return <AttachBadge key={idx} attachment={a} />;
        })}
      </C.AttachmentList>
      <C.AttachClearAll onPress={function() { clearAttachments(); }}>
        <C.AttachClearLabel>Clear</C.AttachClearLabel>
      </C.AttachClearAll>
    </C.AttachmentBar>
  );
}

function ToolToggle(props) {
  return (
    <C.InputToolToggle onPress={props.onToggle} style={props.active == 1 ? { backgroundColor: '#10213d', borderColor: '#2d62ff' } : {}}>
      <C.InputToolToggleIcon style={props.active == 1 ? { color: '#79c0ff' } : {}}>{props.icon}</C.InputToolToggleIcon>
      <C.InputToolToggleLabel style={props.active == 1 ? { color: '#79c0ff' } : {}}>{props.label}</C.InputToolToggleLabel>
    </C.InputToolToggle>
  );
}

function ModelPicker() {
  return (
    <C.ModelPickerBtn onPress={function() { cycleModel(); }}>
      <C.ModelPickerDot style={{ backgroundColor: '#ff7b72' }} />
      <C.ModelPickerLabel>{modelDisplayName}</C.ModelPickerLabel>
      <C.ModelPickerChevron>v</C.ModelPickerChevron>
    </C.ModelPickerBtn>
  );
}

function TokenCountBadge() {
  if (inputTokenEstimate == 0) return null;

  var color = '#4a4a4a';
  if (inputTokenEstimate > 8000) color = '#e6b450';
  if (inputTokenEstimate > 16000) color = '#ff7b72';

  return (
    <C.TokenCount>
      <C.TokenCountText style={{ color: color }}>{inputTokenEstimate + ' tkns'}</C.TokenCountText>
    </C.TokenCount>
  );
}

function SlashHints() {
  var cmds = [
    { cmd: '/fix', desc: 'Fix current file' },
    { cmd: '/review', desc: 'Review recent changes' },
    { cmd: '/plan', desc: 'Plan the next edit' },
    { cmd: '/docs', desc: 'Draft docs' },
    { cmd: '/commit', desc: 'Draft commit message' },
  ];
  var filtered = [];

  for (var i = 0; i < cmds.length; i++) {
    if (currentInput == '/' || cmds[i].cmd.indexOf(currentInput) == 0) filtered.push(cmds[i]);
  }

  if (filtered.length == 0) return null;

  return (
    <C.SlashHints>
      {filtered.map(function(c, idx) {
        return (
          <C.SlashHint key={idx} onPress={function() { selectSlashCommand(c.cmd); }}>
            <C.SlashHintCmd>{c.cmd}</C.SlashHintCmd>
            <C.SlashHintDesc>{c.desc}</C.SlashHintDesc>
          </C.SlashHint>
        );
      })}
    </C.SlashHints>
  );
}

function ChatInput() {
  return (
    <C.ChatInputArea>
      <ModePillBar />

      {currentInput.indexOf('/') == 0 && <SlashHints />}

      <C.ChatInputBox>
        <C.ChatComposerSummary>
          <C.ChatComposerContext>{currentFilePath == '__landing__' ? workspaceName : currentFilePath}</C.ChatComposerContext>
          <C.ChatComposerMeta>{gitBranch + ' / ' + gitRemote}</C.ChatComposerMeta>
        </C.ChatComposerSummary>

        <AttachmentBar />

        <C.ChatInputField
          value={currentInput}
          onChange={function(v) { setCurrentInput(v); }}
          multiline={true}
        />

        <C.ChatInputToolbar>
          <C.ChatInputToolsLeft>
            <C.ChatToolBtnCompact onPress={function() { triggerFileMention(); }}>
              <C.ChatToolIconCompact>#</C.ChatToolIconCompact>
            </C.ChatToolBtnCompact>
            <C.ChatToolBtnCompact onPress={function() { triggerSymbolMention(); }}>
              <C.ChatToolIconCompact>@</C.ChatToolIconCompact>
            </C.ChatToolBtnCompact>
            <C.ChatToolBtnCompact onPress={function() { attachGitContext(); }}>
              <C.ChatToolIconCompact>G</C.ChatToolIconCompact>
            </C.ChatToolBtnCompact>
            <C.ChatToolBtnCompact onPress={function() { attachCurrentFile(); }}>
              <C.ChatToolIconCompact>+</C.ChatToolIconCompact>
            </C.ChatToolBtnCompact>
            <C.InputToolDivider />
            <ToolToggle icon="W" label="Web" active={webSearch} onToggle={function() { toggleWebSearch(); }} />
            <ToolToggle icon=">" label="Term" active={termAccess} onToggle={function() { toggleTermAccess(); }} />
            <ToolToggle icon="A" label="Auto" active={autoApply} onToggle={function() { toggleAutoApply(); }} />
          </C.ChatInputToolsLeft>

          <C.ChatInputToolsRight>
            <TokenCountBadge />
            <ModelPicker />
            <C.ChatSendBtn onPress={function() { sendMessage(); }}>
              <C.ChatSendLabel>{agentMode == 'agent' ? 'Launch' : agentMode == 'task' ? 'Run Task' : agentMode == 'plan' ? 'Plan' : 'Send'}</C.ChatSendLabel>
            </C.ChatSendBtn>
          </C.ChatInputToolsRight>
        </C.ChatInputToolbar>
      </C.ChatInputBox>

      {agentMode == 'task' && (
        <C.TaskModeHint>
          <C.TaskModeHintIcon>!</C.TaskModeHintIcon>
          <C.TaskModeHintText>Task mode can read the workspace, inspect git, and use the terminal.</C.TaskModeHintText>
        </C.TaskModeHint>
      )}

      {agentMode == 'plan' && (
        <C.PlanModeHint>
          <C.PlanModeHintIcon>i</C.PlanModeHintIcon>
          <C.PlanModeHintText>Plan mode stays descriptive first, edit second.</C.PlanModeHintText>
        </C.PlanModeHint>
      )}
    </C.ChatInputArea>
  );
}

function ToolFeed() {
  if (toolExecutions.length == 0) return null;

  return (
    <C.ToolFeed>
      <C.ToolFeedLabel>Live tool calls</C.ToolFeedLabel>
      {toolExecutions.map(function(exec, idx) {
        return <ToolCallCard key={idx} exec={exec} />;
      })}
    </C.ToolFeed>
  );
}

function ChatPanel(props) {
  return (
    <C.ChatPanel>
      <C.ChatHeader>
        <C.ChatHeaderLeft>
          <C.ChatTitle>Agent Console</C.ChatTitle>
          <C.ChatModelBadge>
            <C.ChatModelDot />
            <C.ChatModelLabel>{selectedModel}</C.ChatModelLabel>
          </C.ChatModelBadge>
        </C.ChatHeaderLeft>
        <C.ChatActions>
          <C.ChatActionBtn onPress={function() { startNewConversation(); }}>
            <C.ChatActionLabel>New</C.ChatActionLabel>
          </C.ChatActionBtn>
          <C.ChatActionBtn onPress={function() { indexProject('.'); }}>
            <C.ChatActionLabel>Index</C.ChatActionLabel>
          </C.ChatActionBtn>
        </C.ChatActions>
      </C.ChatHeader>

      <ContextStrip
        activeView={props.activeView}
        currentFilePath={props.currentFilePath}
        workspaceName={props.workspaceName}
        gitBranch={props.gitBranch}
        gitRemote={props.gitRemote}
        changedCount={props.changedCount}
      />

      <AgentSessionBanner />

      <C.ChatMessages>
        <C.ChatStack>
          <C.ChatWelcome>
            <C.ChatWelcomeTitle>{props.workspaceName + ' agent session'}</C.ChatWelcomeTitle>
            <C.ChatWelcomeText>{props.gitBranch + ' / ' + props.gitRemote + ' / ' + props.changedCount + ' dirty paths'}</C.ChatWelcomeText>
          </C.ChatWelcome>

          {props.messages.map(function(msg, idx) {
            return <Message key={idx} msg={msg} />;
          })}

          {props.isGenerating == 1 && <ToolFeed />}
          {props.isGenerating == 1 && <ThinkingIndicator />}
        </C.ChatStack>
      </C.ChatMessages>

      <ChatInput />
    </C.ChatPanel>
  );
}

export { ChatPanel };
