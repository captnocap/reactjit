// Terminal Panel — PTY integration

function TerminalLine(props) {
  var line = props.line;
  var color = '#b0b0b0';
  if (line.type == 'command') color = '#79c0ff';
  if (line.type == 'error') color = '#ff7b72';
  if (line.type == 'info') color = '#7ee787';
  if (line.type == 'prompt') color = '#d2a8ff';

  return (
    <C.TerminalLine>
      <C.TerminalLineText style={{ color: color }}>{line.text}</C.TerminalLineText>
    </C.TerminalLine>
  );
}

function TerminalPanel(props) {
  return (
    <C.TerminalPanel>
      <C.TerminalHeader>
        <C.TerminalTitle>Terminal</C.TerminalTitle>
        <C.TerminalTabs>
          <C.TerminalTabActive>bash</C.TerminalTabActive>
          <C.TerminalTab>node</C.TerminalTab>
          <C.TerminalTab>sqlite</C.TerminalTab>
        </C.TerminalTabs>
        <C.TerminalActions>
          <C.TerminalActionBtn onPress={function() { openTerminal(); }}>+</C.TerminalActionBtn>
          <C.TerminalActionBtn>x</C.TerminalActionBtn>
        </C.TerminalActions>
      </C.TerminalHeader>

      <C.TerminalContent>
        <C.TerminalScroll>
          <C.TerminalStack>
            {props.lines.map(function(line, idx) {
              return <TerminalLine line={line} />;
            })}
          </C.TerminalStack>
        </C.TerminalScroll>
      </C.TerminalContent>

      <C.TerminalInputBar>
        <C.TerminalPrompt>$</C.TerminalPrompt>
        <C.TerminalInput value="" onChange={function(v) { if (v.indexOf('\n') >= 0) execCommand(v.trim()); }} />
      </C.TerminalInputBar>
    </C.TerminalPanel>
  );
}

export { TerminalPanel };
