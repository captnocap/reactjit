// Terminal panel — same chrome as editor and chat, real PTY underneath

function TerminalPanel(props) {
  return (
    <C.TerminalPanel>
      <C.TerminalHeader>
        <C.TerminalHeaderMain>
          <C.TerminalTitle>Terminal</C.TerminalTitle>
          <C.TerminalMeta>{props.gitBranch}</C.TerminalMeta>
          <C.TerminalMeta>{props.workDir}</C.TerminalMeta>
        </C.TerminalHeaderMain>
        <C.TerminalActions>
          <C.TerminalActionBtn onPress={function() { setShowTerminal(0); }}>
            <C.TerminalActionLabel>x</C.TerminalActionLabel>
          </C.TerminalActionBtn>
        </C.TerminalActions>
      </C.TerminalHeader>

      <C.TerminalBody>
        <Terminal style={{ flexGrow: 1, flexBasis: 0 }} fontSize={13} />
      </C.TerminalBody>

      <C.TerminalFooter>
        <C.TerminalFooterText>pty attached to workspace shell</C.TerminalFooterText>
      </C.TerminalFooter>
    </C.TerminalPanel>
  );
}

export { TerminalPanel };
