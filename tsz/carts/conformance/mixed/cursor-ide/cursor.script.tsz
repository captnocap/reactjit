var fileContents = {};
var gitStatusByPath = {};
var cachedTreePaths = [];
var workspaceBootstrapped = 0;
var ptyStarted = 0;

function stripDotSlash(path: string) {
  if (!path) return '';
  if (path.indexOf('./') == 0) return path.substring(2);
  return path;
}

function baseName(path: string) {
  if (!path || path.length == 0) return '';
  var clean = path;
  if (clean == '.') return workspaceName || 'workspace';
  if (clean.charAt(clean.length - 1) == '/') clean = clean.substring(0, clean.length - 1);
  var slash = clean.lastIndexOf('/');
  if (slash >= 0) return clean.substring(slash + 1);
  return clean;
}

function parentPath(path: string) {
  if (!path || path == '.' || path == '__landing__') return '.';
  var slash = path.lastIndexOf('/');
  if (slash < 0) return '.';
  return path.substring(0, slash);
}

function inferFileType(path: string) {
  if (path == '__landing__') return 'home';
  if (path == '.' || path.length == 0) return 'workspace';
  var name = baseName(path);
  if (name.indexOf('.c.tsz') >= 0) return 'component';
  if (name.indexOf('.cls.tsz') >= 0) return 'cls';
  if (name.indexOf('.script.tsz') >= 0) return 'script';
  if (name.indexOf('.mod.tsz') >= 0) return 'mod';
  if (name.indexOf('.app.tsz') >= 0) return 'app';
  if (name.indexOf('.tsz') >= 0) return 'tsz';
  var dot = name.lastIndexOf('.');
  if (dot < 0) return 'dir';
  return name.substring(dot + 1);
}

function languageForType(type: string) {
  if (type == 'component' || type == 'cls' || type == 'script' || type == 'mod' || type == 'app' || type == 'tsz') return 'TSZ';
  if (type == 'ts' || type == 'tsx') return 'TypeScript';
  if (type == 'js' || type == 'jsx') return 'JavaScript';
  if (type == 'zig') return 'Zig';
  if (type == 'md') return 'Markdown';
  if (type == 'json') return 'JSON';
  if (type == 'css') return 'CSS';
  if (type == 'sh') return 'Shell';
  if (type == 'home') return 'Workspace';
  return 'Plain Text';
}

function fileTone(type: string) {
  if (type == 'component') return '#79c0ff';
  if (type == 'cls') return '#d2a8ff';
  if (type == 'script') return '#7ee787';
  if (type == 'mod') return '#ffa657';
  if (type == 'app') return '#ff7b72';
  if (type == 'tsz') return '#56d364';
  if (type == 'ts' || type == 'tsx') return '#2d62ff';
  if (type == 'js' || type == 'jsx') return '#e6b450';
  if (type == 'zig') return '#ffa657';
  if (type == 'md') return '#7ee787';
  if (type == 'json') return '#56d364';
  if (type == 'css') return '#d2a8ff';
  if (type == 'sh') return '#79c0ff';
  if (type == 'home') return '#2d62ff';
  if (type == 'workspace') return '#7ee787';
  if (type == 'dir') return '#4a5568';
  return '#6e6e6e';
}

function fileGlyph(type: string) {
  if (type == 'component') return 'C';
  if (type == 'cls') return 'CL';
  if (type == 'script') return 'JS';
  if (type == 'mod') return 'MD';
  if (type == 'app') return 'AP';
  if (type == 'tsz') return 'TZ';
  if (type == 'ts' || type == 'tsx') return 'TS';
  if (type == 'js' || type == 'jsx') return 'JS';
  if (type == 'zig') return 'ZG';
  if (type == 'md') return 'MD';
  if (type == 'json') return '{}';
  if (type == 'css') return 'CS';
  if (type == 'sh') return 'SH';
  if (type == 'home') return 'P';
  if (type == 'workspace') return 'W';
  if (type == 'dir') return 'D';
  return '#';
}

function statusLabel(code: string) {
  if (code == '??') return 'new';
  if (code.indexOf('M') >= 0) return 'modified';
  if (code.indexOf('A') >= 0) return 'added';
  if (code.indexOf('D') >= 0) return 'deleted';
  if (code.indexOf('R') >= 0) return 'renamed';
  return 'dirty';
}

function statusTone(code: string) {
  if (code == '??') return '#2d62ff';
  if (code.indexOf('D') >= 0) return '#ff7b72';
  if (code.indexOf('A') >= 0) return '#7ee787';
  if (code.indexOf('M') >= 0) return '#e6b450';
  return '#6e6e6e';
}

function samePath(a: string, b: string) {
  return stripDotSlash(a) == stripDotSlash(b);
}

function hasPath(list: any, path: string) {
  for (var i = 0; i < list.length; i++) {
    if (samePath(list[i], path)) return 1;
  }
  return 0;
}

function trimLines(raw: string) {
  var out = [];
  if (!raw || raw.length == 0) return out;
  var lines = raw.split('\n');
  for (var i = 0; i < lines.length; i++) {
    var line = stripDotSlash(lines[i]);
    if (line.length > 0) out.push(line);
  }
  return out;
}

function buildSeedMessages(branch: string, dirty: number, root: string) {
  return [
    {
      role: 'assistant',
      time: 'now',
      model: selectedModel,
      text: 'Workspace online. Watching ' + root + ' on ' + branch + '. ' + dirty + ' paths are dirty, and the project landing page is tuned for fast jumps.',
    },
    {
      role: 'assistant',
      time: 'now',
      model: selectedModel,
      text: 'Try asking for a repo sweep, attaching the current file, or launching a task with terminal access. Search, git, and landing cards all read the same workspace.',
    },
  ];
}

function loadGitSummary() {
  var branch = __exec('git branch --show-current 2>/dev/null');
  branch = branch ? branch.replace(/\s+/g, '') : '';
  if (!branch || branch.length == 0) branch = 'detached';
  setGitBranch(branch);

  var remoteName = 'origin';
  var connections = [];
  var seenRemote = {};
  var remoteLines = trimLines(__exec('git remote -v 2>/dev/null | sed -n "1,6p"'));
  for (var i = 0; i < remoteLines.length; i++) {
    var line = remoteLines[i];
    var tab = line.indexOf('\t');
    if (tab < 0) tab = line.indexOf(' ');
    if (tab < 0) continue;
    var name = line.substring(0, tab);
    var rest = line.substring(tab + 1);
    var modeIdx = rest.indexOf(' ');
    if (modeIdx >= 0) rest = rest.substring(0, modeIdx);
    if (seenRemote[name] != 1) {
      connections.push({ name: name, detail: rest, kind: 'remote', tone: '#2d62ff' });
      seenRemote[name] = 1;
      if (connections.length == 1) remoteName = name;
    }
  }
  setGitRemote(remoteName);

  var worktreeLines = trimLines(__exec('git worktree list 2>/dev/null | sed -n "1,3p"'));
  for (var wi = 0; wi < worktreeLines.length; wi++) {
    connections.push({ name: 'worktree', detail: worktreeLines[wi], kind: 'worktree', tone: '#7ee787' });
  }

  var ahead = 0;
  var behind = 0;
  var counts = __exec('git rev-list --left-right --count @{upstream}...HEAD 2>/dev/null');
  if (counts && counts.length > 0) {
    var parts = counts.trim().split('\t');
    if (parts.length < 2) parts = counts.trim().split(' ');
    if (parts.length >= 2) {
      behind = parseInt(parts[0]) || 0;
      ahead = parseInt(parts[1]) || 0;
    }
  }
  setBranchAhead(ahead);
  setBranchBehind(behind);
  connections.unshift({ name: branch, detail: 'ahead ' + ahead + ' / behind ' + behind, kind: 'branch', tone: '#7ee787' });

  var statusLines = trimLines(__exec('git status --short 2>/dev/null'));
  var changes = [];
  var dirty = 0;
  var staged = 0;
  gitStatusByPath = {};
  for (var si = 0; si < statusLines.length; si++) {
    var statusLine = statusLines[si];
    if (statusLine.length < 3) continue;
    var code = statusLine.substring(0, 2);
    var path = statusLine.substring(3);
    var rename = path.indexOf(' -> ');
    if (rename >= 0) path = path.substring(rename + 4);
    path = stripDotSlash(path);
    dirty++;
    if (code.charAt(0) != ' ' && code.charAt(0) != '?') staged++;
    gitStatusByPath[path] = code.replace(/\s+/g, '');
    changes.push({
      path: path,
      status: statusLabel(code),
      short: code.replace(/\s+/g, ''),
      tone: statusTone(code),
    });
  }

  setGitConnections(connections);
  setGitChanges(changes);
  setChangedCount(dirty);
  setStagedCount(staged);
  setGitStatus(dirty > 0 ? '*' + dirty : '');

  return { branch: branch, dirty: dirty, staged: staged, remote: remoteName, ahead: ahead, behind: behind, changes: changes, connections: connections };
}

function fallbackWorkspacePaths() {
  return [
    'tsz/carts/conformance/mixed/cursor-ide/cursor-ide.tsz',
    'tsz/carts/conformance/mixed/cursor-ide/cursor.script.tsz',
    'tsz/carts/conformance/mixed/cursor-ide/cursor.cls.tsz',
    'tsz/carts/conformance/mixed/cursor-ide/Sidebar.c.tsz',
    'tsz/carts/conformance/mixed/cursor-ide/Editor.c.tsz',
    'tsz/carts/conformance/mixed/cursor-ide/ChatPanel.c.tsz',
    'tsz/carts/conformance/mixed/cursor-ide/TopBar.c.tsz',
    'tsz/carts/conformance/mixed/cursor-ide/StatusBar.c.tsz',
    'tsz/docs/ARCHITECTURE.md',
    'tsz/compiler/smith_DICTIONARY.md',
    'tsz/framework/core.zig',
  ];
}

function pathPriority(path: string) {
  if (path.indexOf('tsz/carts/conformance/mixed/cursor-ide') == 0) return 0;
  if (path.indexOf('tsz/docs') == 0) return 1;
  if (path.indexOf('tsz/compiler') == 0) return 2;
  if (path.indexOf('tsz/framework') == 0) return 3;
  return 4;
}

function shouldKeepPath(path: string) {
  if (path.indexOf('.git/') == 0) return 0;
  if (path.indexOf('zig-cache/') == 0) return 0;
  if (path.indexOf('zig-out/') == 0) return 0;
  if (path.indexOf('node_modules/') == 0) return 0;
  if (path.indexOf('archive/') == 0) return 0;
  if (path.indexOf('love2d/') == 0) return 0;
  if (path.indexOf('.png') >= 0 || path.indexOf('.jpg') >= 0 || path.indexOf('.jpeg') >= 0) return 0;
  return 1;
}

function buildWorkspaceSnapshot(rootName: string) {
  var raw = __exec('find . -maxdepth 5 \\( -path "./.git" -o -path "./zig-cache" -o -path "./zig-out" -o -path "./node_modules" -o -path "./archive" -o -path "./love2d" \\) -prune -o -type f | sed "s#^\\./##" | head -140');
  var discovered = trimLines(raw);
  var curated = fallbackWorkspacePaths();
  var merged = [];

  for (var i = 0; i < curated.length; i++) {
    if (shouldKeepPath(curated[i]) == 1 && hasPath(merged, curated[i]) == 0) merged.push(curated[i]);
  }
  for (var di = 0; di < discovered.length; di++) {
    if (shouldKeepPath(discovered[di]) == 1 && hasPath(merged, discovered[di]) == 0) merged.push(discovered[di]);
  }

  merged.sort(function(a, b) {
    var pa = pathPriority(a);
    var pb = pathPriority(b);
    if (pa != pb) return pa - pb;
    if (a < b) return -1;
    if (a > b) return 1;
    return 0;
  });

  cachedTreePaths = merged;

  var tree = { name: rootName, path: '.', dirs: {}, files: [] };
  for (var pi = 0; pi < merged.length; pi++) {
    var path = merged[pi];
    var parts = path.split('/');
    var node = tree;
    var current = '';
    for (var partIdx = 0; partIdx < parts.length; partIdx++) {
      var part = parts[partIdx];
      if (partIdx == parts.length - 1) {
        node.files.push({ name: part, path: path, type: inferFileType(path) });
      } else {
        current = current.length == 0 ? part : current + '/' + part;
        if (!node.dirs[part]) {
          node.dirs[part] = { name: part, path: current, dirs: {}, files: [] };
        }
        node = node.dirs[part];
      }
    }
  }

  var items = [
    { name: rootName, type: 'workspace', indent: 0, expanded: 1, selected: activeView == 'landing' ? 1 : 0, visible: 1, git: '', hot: 1, path: '.' },
  ];

  flattenTreeNode(tree, 0, items);
  applyTreeVisibility(items);
  return { items: items, paths: merged };
}

function flattenTreeNode(node: any, depth: number, items: any) {
  var dirNames = [];
  for (var dirName in node.dirs) {
    dirNames.push(dirName);
  }
  dirNames.sort();

  for (var di = 0; di < dirNames.length; di++) {
    var dir = node.dirs[dirNames[di]];
    items.push({
      name: dir.name,
      type: 'dir',
      indent: depth + 1,
      expanded: shouldExpand(dir.path),
      selected: 0,
      visible: 1,
      git: dirGitStatus(dir.path),
      hot: isHotPath(dir.path),
      path: dir.path,
    });
    flattenTreeNode(dir, depth + 1, items);
  }

  node.files.sort(function(a, b) {
    if (pathPriority(a.path) != pathPriority(b.path)) return pathPriority(a.path) - pathPriority(b.path);
    if (a.path < b.path) return -1;
    if (a.path > b.path) return 1;
    return 0;
  });

  for (var fi = 0; fi < node.files.length; fi++) {
    items.push({
      name: node.files[fi].name,
      type: node.files[fi].type,
      indent: depth + 1,
      expanded: 0,
      selected: samePath(node.files[fi].path, currentFilePath) ? 1 : 0,
      visible: 1,
      git: gitStatusByPath[node.files[fi].path] || '',
      hot: isHotPath(node.files[fi].path),
      path: node.files[fi].path,
    });
  }
}

function shouldExpand(path: string) {
  if (path == 'tsz') return 1;
  if (path == 'tsz/carts') return 1;
  if (path == 'tsz/carts/conformance') return 1;
  if (path == 'tsz/carts/conformance/mixed') return 1;
  if (path == 'tsz/carts/conformance/mixed/cursor-ide') return 1;
  if (path == 'tsz/docs') return 1;
  return 0;
}

function dirGitStatus(path: string) {
  for (var key in gitStatusByPath) {
    if (key.indexOf(path + '/') == 0) return 'dirty';
  }
  return '';
}

function isHotPath(path: string) {
  if (path.indexOf('cursor-ide') >= 0) return 1;
  if (path.indexOf('ARCHITECTURE.md') >= 0) return 1;
  if (path.indexOf('smith_DICTIONARY.md') >= 0) return 1;
  return 0;
}

function findTreeItem(list: any, path: string) {
  for (var i = 0; i < list.length; i++) {
    if (samePath(list[i].path, path)) return list[i];
  }
  return null;
}

function applyTreeVisibility(list: any) {
  for (var i = 0; i < list.length; i++) {
    var item = list[i];
    if (item.type == 'workspace') {
      item.visible = 1;
      continue;
    }
    var visible = 1;
    var parent = parentPath(item.path);
    while (parent != '.' && parent.length > 0) {
      var parentItem = findTreeItem(list, parent);
      if (parentItem && parentItem.expanded != 1) {
        visible = 0;
      }
      parent = parentPath(parent);
    }
    item.visible = visible;
  }
}

function markSelectedPath(path: string) {
  var list = files;
  for (var i = 0; i < list.length; i++) {
    if (path == '__landing__') list[i].selected = list[i].type == 'workspace' ? 1 : 0;
    else list[i].selected = samePath(list[i].path, path) ? 1 : 0;
  }
  setFiles(list);
}

function buildLandingProjects(paths: any, info: any) {
  var projects = [
    {
      name: workspaceName,
      path: '__landing__',
      summary: 'Branch ' + info.branch + ' with ' + info.dirty + ' dirty paths and ' + paths.length + ' indexed files.',
      badge: 'workspace',
      accent: '#2d62ff',
    },
    {
      name: 'cursor-ide cart',
      path: 'tsz/carts/conformance/mixed/cursor-ide/cursor-ide.tsz',
      summary: 'Mixed-lane IDE clone where aggressive UI ideas are allowed to break the compiler.',
      badge: 'focus',
      accent: '#7ee787',
    },
  ];

  if (hasPath(paths, 'tsz/docs/ARCHITECTURE.md') == 1) {
    projects.push({
      name: 'architecture',
      path: 'tsz/docs/ARCHITECTURE.md',
      summary: 'Runtime split notes for Zig, LuaJIT, and QuickJS.',
      badge: 'docs',
      accent: '#d2a8ff',
    });
  }

  if (hasPath(paths, 'tsz/compiler/smith_DICTIONARY.md') == 1) {
    projects.push({
      name: 'smith dictionary',
      path: 'tsz/compiler/smith_DICTIONARY.md',
      summary: 'Compiler map for the active Smith layout and emit stack.',
      badge: 'compiler',
      accent: '#ffa657',
    });
  }

  setLandingProjects(projects);
}

function buildLandingRecentFiles(paths: any, info: any) {
  var recent = [];
  for (var i = 0; i < info.changes.length && recent.length < 4; i++) {
    recent.push({
      path: info.changes[i].path,
      label: baseName(info.changes[i].path),
      reason: info.changes[i].status,
    });
  }

  for (var ti = 0; ti < openTabs.length && recent.length < 7; ti++) {
    if (openTabs[ti].path != '__landing__') {
      recent.push({
        path: openTabs[ti].path,
        label: openTabs[ti].name,
        reason: 'open tab',
      });
    }
  }

  for (var pi = 0; pi < paths.length && recent.length < 10; pi++) {
    if (paths[pi].indexOf('cursor-ide') >= 0) {
      recent.push({
        path: paths[pi],
        label: baseName(paths[pi]),
        reason: 'focus surface',
      });
    }
  }

  setLandingRecentFiles(recent);
}

function refreshWorkspace() {
  var pwd = __exec('pwd 2>/dev/null');
  pwd = pwd ? pwd.trim() : '.';
  if (pwd.length == 0) pwd = '.';
  setWorkDir(pwd);
  setWorkspaceName(baseName(pwd) || 'workspace');
  setWorkspaceTagline('Conformance-grade IDE cart with live explorer, git, and agent context');

  var gitInfo = loadGitSummary();
  var snapshot = buildWorkspaceSnapshot(baseName(pwd) || 'workspace');

  setFiles(snapshot.items);
  setWorkspaceStats([
    { label: 'indexed', value: '' + snapshot.paths.length, tone: '#2d62ff' },
    { label: 'dirty', value: '' + gitInfo.dirty, tone: '#e6b450' },
    { label: 'tabs', value: '' + openTabs.length, tone: '#7ee787' },
    { label: 'agent', value: activeAgentId.length > 0 ? 'live' : agentStatusText, tone: '#d2a8ff' },
  ]);
  buildLandingProjects(snapshot.paths, gitInfo);
  buildLandingRecentFiles(snapshot.paths, gitInfo);

  var tabs = openTabs;
  for (var ti = 0; ti < tabs.length; ti++) {
    if (tabs[ti].path != '__landing__') tabs[ti].git = gitStatusByPath[tabs[ti].path] || '';
  }
  setOpenTabs(tabs);

  if (workspaceBootstrapped == 0 || chatMessages.length == 0) {
    setChatMessages(buildSeedMessages(gitInfo.branch, gitInfo.dirty, pwd));
  }

  if (activeView == 'landing' || currentFilePath == '__landing__' || currentFilePath.length == 0) {
    setBreadcrumbs([
      { label: 'Projects', icon: 'P', tone: '#2d62ff', active: 0, kind: 'home' },
      { label: baseName(pwd) || 'workspace', icon: 'W', tone: '#7ee787', active: 1, kind: 'workspace', meta: gitInfo.branch },
    ]);
    markSelectedPath('__landing__');
  } else {
    buildBreadcrumbs(currentFilePath);
    markSelectedPath(currentFilePath);
  }

  workspaceBootstrapped = 1;
}

function previousNonSpace(line: string, idx: number) {
  var i = idx;
  while (i >= 0) {
    if (line.charAt(i) != ' ' && line.charAt(i) != '\t') return line.charAt(i);
    i--;
  }
  return '';
}

function nextNonSpace(line: string, idx: number) {
  var i = idx;
  while (i < line.length) {
    if (line.charAt(i) != ' ' && line.charAt(i) != '\t') return line.charAt(i);
    i++;
  }
  return '';
}

function isDigit(ch: string) {
  return ch >= '0' && ch <= '9';
}

function isWordStart(ch: string) {
  return (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') || ch == '_' || ch == '$';
}

function isWordChar(ch: string) {
  return isWordStart(ch) || isDigit(ch);
}

function isKeyword(word: string) {
  return word == 'import' || word == 'from' || word == 'export' || word == 'function' ||
    word == 'return' || word == 'const' || word == 'let' || word == 'var' ||
    word == 'if' || word == 'else' || word == 'for' || word == 'while' ||
    word == 'async' || word == 'await' || word == 'try' || word == 'catch' ||
    word == 'interface' || word == 'type' || word == 'extends' || word == 'new' ||
    word == 'class' || word == 'declare' || word == 'useState';
}

function isTypeWord(word: string) {
  return word == 'string' || word == 'number' || word == 'boolean' || word == 'void' ||
    word == 'any' || word == 'unknown' || word == 'Promise' || word == 'Set' ||
    word == 'Map' || word == 'Box' || word == 'Text' || word == 'Pressable' ||
    word == 'ScrollView' || word == 'TextInput';
}

function tokenizeLine(line: string) {
  var tokens = [];
  var i = 0;

  while (i < line.length) {
    var ch = line.charAt(i);
    var next = i + 1 < line.length ? line.charAt(i + 1) : '';

    if (ch == ' ' || ch == '\t') {
      var wsStart = i;
      while (i < line.length && (line.charAt(i) == ' ' || line.charAt(i) == '\t')) i++;
      tokens.push({ text: line.substring(wsStart, i), kind: 'text' });
      continue;
    }

    if (ch == '/' && next == '/') {
      tokens.push({ text: line.substring(i), kind: 'comment' });
      break;
    }

    if (ch == '"' || ch == '\'' || ch == '`') {
      var quote = ch;
      var strStart = i;
      i++;
      while (i < line.length) {
        if (line.charAt(i) == quote && line.charAt(i - 1) != '\\') {
          i++;
          break;
        }
        i++;
      }
      tokens.push({ text: line.substring(strStart, i), kind: 'string' });
      continue;
    }

    if (isDigit(ch)) {
      var numStart = i;
      i++;
      while (i < line.length && (isDigit(line.charAt(i)) || line.charAt(i) == '.')) i++;
      tokens.push({ text: line.substring(numStart, i), kind: 'number' });
      continue;
    }

    if (ch == '<') {
      tokens.push({ text: '<', kind: 'tag' });
      i++;
      if (line.charAt(i) == '/') {
        tokens.push({ text: '/', kind: 'tag' });
        i++;
      }
      var tagStart = i;
      while (i < line.length && isWordChar(line.charAt(i))) i++;
      if (i > tagStart) tokens.push({ text: line.substring(tagStart, i), kind: 'tag' });
      continue;
    }

    if (isWordStart(ch)) {
      var wordStart = i;
      i++;
      while (i < line.length && isWordChar(line.charAt(i))) i++;
      var word = line.substring(wordStart, i);
      var kind = 'text';
      var prev = previousNonSpace(line, wordStart - 1);
      var nextWordChar = nextNonSpace(line, i);

      if (isKeyword(word)) kind = 'keyword';
      else if (isTypeWord(word)) kind = 'type';
      else if (prev == '<' || (prev == '/' && previousNonSpace(line, wordStart - 2) == '<')) kind = 'tag';
      else if (nextWordChar == '=' && line.indexOf('<') >= 0) kind = 'attr';
      else if (nextWordChar == '(' || word.indexOf('use') == 0) kind = 'function';
      else if ((word.charAt(0) >= 'A' && word.charAt(0) <= 'Z') || word == 'props' || word == 'msg' || word == 'state') kind = 'variable';

      tokens.push({ text: word, kind: kind });
      continue;
    }

    if ('{}[]()=:+-*%!&|?/'.indexOf(ch) >= 0) {
      tokens.push({ text: ch, kind: 'operator' });
      i++;
      continue;
    }

    if (ch == '>' && previousNonSpace(line, i - 1) != '=') {
      tokens.push({ text: '>', kind: 'tag' });
      i++;
      continue;
    }

    tokens.push({ text: ch, kind: 'text' });
    i++;
  }

  if (tokens.length == 0) tokens.push({ text: ' ', kind: 'text' });
  return tokens;
}

function lineMarker(line: string) {
  if (line.indexOf('TODO') >= 0 || line.indexOf('FIXME') >= 0) return 'todo';
  if (line.indexOf('function ') >= 0 || line.indexOf('export ') >= 0 || line.indexOf('classifier(') >= 0) return 'symbol';
  if (line.indexOf('__exec') >= 0 || line.indexOf('git ') >= 0 || line.indexOf('useIFTTT') >= 0) return 'tool';
  if (line.indexOf('return ') >= 0) return 'flow';
  return '';
}

function rebuildEditorPresentation(content: string, path: string) {
  var lines = content.split('\n');
  if (lines.length == 0) lines = [''];

  var nums = [];
  var rows = [];
  for (var i = 0; i < lines.length; i++) {
    nums.push({ num: '' + (i + 1) });
    rows.push({
      line: i + 1,
      marker: lineMarker(lines[i]),
      tokens: tokenizeLine(lines[i]),
      previewWidth: 20 + ((lines[i].length * 3) % 80),
    });
  }

  setTotalLines(lines.length);
  setLineNumbers(nums);
  setEditorRows(rows);
  setLanguageMode(languageForType(inferFileType(path)));
}

function buildBreadcrumbs(path: string) {
  if (path == '__landing__') {
    setBreadcrumbs([
      { label: 'Projects', icon: 'P', tone: '#2d62ff', active: 0, kind: 'home' },
      { label: workspaceName, icon: 'W', tone: '#7ee787', active: 1, kind: 'workspace', meta: gitBranch },
    ]);
    return;
  }

  var crumbs = [
    { label: 'Projects', icon: 'P', tone: '#2d62ff', active: 0, kind: 'home' },
    { label: workspaceName, icon: 'W', tone: '#7ee787', active: 0, kind: 'workspace', meta: gitBranch },
  ];

  var parts = path.split('/');
  var current = '';
  for (var i = 0; i < parts.length; i++) {
    current = current.length == 0 ? parts[i] : current + '/' + parts[i];
    var type = i == parts.length - 1 ? inferFileType(current) : 'dir';
    crumbs.push({
      label: parts[i],
      icon: fileGlyph(type),
      tone: fileTone(type),
      active: i == parts.length - 1 ? 1 : 0,
      kind: type,
      meta: i == parts.length - 1 && gitStatusByPath[path] ? gitStatusByPath[path] : '',
    });
  }
  setBreadcrumbs(crumbs);
}

function ensureHomeTab() {
  var found = 0;
  for (var i = 0; i < openTabs.length; i++) {
    if (openTabs[i].path == '__landing__') found = 1;
  }
  if (found == 0) {
    var tabs = openTabs;
    tabs.unshift({ id: 'home', name: 'Projects', path: '__landing__', type: 'home', modified: 0, pinned: 1, git: '' });
    setOpenTabs(tabs);
  }
}

function ensureTabForPath(path: string) {
  ensureHomeTab();
  var tabId = '';
  var tabs = openTabs;
  for (var i = 0; i < tabs.length; i++) {
    if (tabs[i].path == path) {
      tabId = tabs[i].id;
      tabs[i].git = gitStatusByPath[path] || '';
    }
  }

  if (tabId.length == 0) {
    tabId = 't' + (tabs.length + 1);
    tabs.push({
      id: tabId,
      name: baseName(path),
      path: path,
      type: inferFileType(path),
      modified: 0,
      pinned: 0,
      git: gitStatusByPath[path] || '',
    });
  }

  setOpenTabs(tabs);
  setActiveTabId(tabId);
}

function chooseFocusLine(content: string) {
  var lines = content.split('\n');
  for (var i = 0; i < lines.length; i++) {
    if (lines[i].indexOf('export function') >= 0 || lines[i].indexOf('function ') >= 0) return i + 1;
  }
  return 1;
}

function loadFileByPath(path: string, requestedLine: number) {
  if (path == '__landing__' || path == '.' || inferFileType(path) == 'workspace') {
    openLandingPage();
    return;
  }

  var content = fileContents[path];
  if (!content || content.length == 0) {
    var diskContent = __fs_readfile(path);
    if (diskContent && diskContent.length > 0) {
      content = diskContent;
      fileContents[path] = diskContent;
    } else {
      content = '// ' + path + '\n';
    }
  }

  setActiveView('editor');
  setEditorContent(content);
  setCurrentFilePath(path);
  setEditorModified(0);
  rebuildEditorPresentation(content, path);

  var focusLine = requestedLine && requestedLine > 0 ? requestedLine : chooseFocusLine(content);
  setCursorPosition({ line: focusLine, column: 1 });

  buildBreadcrumbs(path);
  ensureTabForPath(path);
  markSelectedPath(path);
}

function initData() {
  refreshWorkspace();
  openLandingPage();

  var lines = terminalLines;
  lines.push({ text: 'workspace ready — F3 search, Ctrl+` terminal, click Projects for landing.', type: 'info' });
  setTerminalLines(lines);
}

// === Tool Execution Tracking ===
function addToolExecution(id: string, name: string, input: string) {
  var execs = toolExecutions;
  execs.push({ id: id, name: name, input: input, status: 'running', percent: 20, result: '' });
  setToolExecutions(execs);
}

function completeToolExecution(id: string, result: string) {
  var execs = toolExecutions;
  for (var i = 0; i < execs.length; i++) {
    if (execs[i].id == id) {
      execs[i].status = 'completed';
      execs[i].percent = 100;
      execs[i].result = result;
    }
  }
  setToolExecutions(execs);
}

function failToolExecution(id: string, error: string) {
  var execs = toolExecutions;
  for (var i = 0; i < execs.length; i++) {
    if (execs[i].id == id) {
      execs[i].status = 'error';
      execs[i].percent = 0;
      execs[i].result = error;
    }
  }
  setToolExecutions(execs);
}

// === File Operations ===
function openFile(idx: number) {
  var file = files[idx];
  if (!file) return;

  if (file.type == 'workspace') {
    openLandingPage();
    return;
  }

  if (file.type == 'dir') {
    files[idx].expanded = 1 - (files[idx].expanded || 0);
    applyTreeVisibility(files);
    setFiles(files);
    return;
  }

  loadFileByPath(file.path, 0);
}

function openFileByPath(path: string) {
  if (path == '__landing__' || path == '.' || path.length == 0) {
    openLandingPage();
    return;
  }

  for (var i = 0; i < files.length; i++) {
    if (samePath(files[i].path, path)) {
      openFile(i);
      return;
    }
  }

  loadFileByPath(path, 0);
}

function openSearchResult(path: string, line: number) {
  loadFileByPath(path, line);
  setShowSearch(0);
}

function selectFile(idx: number) {
  openFile(idx);
}

function updateEditorContent(text: string) {
  if (currentFilePath == '__landing__') return;

  setEditorContent(text);
  setEditorModified(1);
  rebuildEditorPresentation(text, currentFilePath);
  setGitStatus('*' + (changedCount > 0 ? changedCount : 1));
  fileContents[currentFilePath] = text;

  var tabs = openTabs;
  for (var ti = 0; ti < tabs.length; ti++) {
    if (tabs[ti].path == currentFilePath) tabs[ti].modified = 1;
  }
  setOpenTabs(tabs);
}

function saveCurrentFile() {
  if (currentFilePath == '__landing__') return;

  var execId = 'write_' + Date.now();
  addToolExecution(execId, 'writeFile', currentFilePath);

  var wrote = __fs_writefile(currentFilePath, editorContent);
  fileContents[currentFilePath] = editorContent;

  var tabs = openTabs;
  for (var ti = 0; ti < tabs.length; ti++) {
    if (tabs[ti].path == currentFilePath) tabs[ti].modified = 0;
  }
  setOpenTabs(tabs);
  setEditorModified(0);

  if (wrote == 0) completeToolExecution(execId, 'saved ' + currentFilePath);
  else failToolExecution(execId, 'write failed');

  refreshWorkspace();
}

function createNewFile(name: string) {
  var path = name.indexOf('/') >= 0 ? name : 'tsz/carts/conformance/mixed/cursor-ide/' + name;
  fileContents[path] = '// ' + baseName(path) + '\n';

  var tabs = openTabs;
  tabs.push({
    id: 't' + (tabs.length + 1),
    name: baseName(path),
    path: path,
    type: inferFileType(path),
    modified: 1,
    pinned: 0,
    git: '??',
  });
  setOpenTabs(tabs);
  refreshWorkspace();
  loadFileByPath(path, 1);
}

function openLandingPage() {
  ensureHomeTab();
  setActiveView('landing');
  setCurrentFilePath('__landing__');
  setEditorContent('');
  setEditorRows([]);
  setEditorModified(0);
  setTotalLines(0);
  setLineNumbers([{ num: '1' }]);
  setLanguageMode('Workspace');
  setCursorPosition({ line: 1, column: 1 });
  setActiveTabId('home');
  setBreadcrumbs([
    { label: 'Projects', icon: 'P', tone: '#2d62ff', active: 0, kind: 'home' },
    { label: workspaceName, icon: 'W', tone: '#7ee787', active: 1, kind: 'workspace', meta: gitBranch },
  ]);
  markSelectedPath('__landing__');
}

// === Tab Operations ===
function activateTab(id: string) {
  if (id == 'home') {
    openLandingPage();
    return;
  }

  for (var i = 0; i < openTabs.length; i++) {
    if (openTabs[i].id == id) {
      loadFileByPath(openTabs[i].path, 0);
      return;
    }
  }
}

function closeTab(id: string) {
  if (id == 'home') return;

  var tabs = [];
  for (var i = 0; i < openTabs.length; i++) {
    if (openTabs[i].id != id) tabs.push(openTabs[i]);
  }
  setOpenTabs(tabs);

  if (tabs.length == 0 || activeTabId == id) {
    openLandingPage();
  } else {
    activateTab(tabs[tabs.length - 1].id);
  }
}

// === Chat ===
function setCurrentInput(v: string) {
  setCurrentInputState(v);
  var estimate = Math.ceil(v.length / 4);
  for (var i = 0; i < attachments.length; i++) {
    estimate = estimate + (attachments[i].type == 'git' ? 900 : 500);
  }
  setInputTokenEstimateState(estimate);
}

function buildAgentPayload(text: string) {
  var model = 'claude-opus-4-6';
  if (selectedModel == 'claude-sonnet-4') model = 'claude-sonnet-4-6';
  else if (selectedModel == 'gpt-4o') model = 'gpt-4o';
  else if (selectedModel == 'o1-preview') model = 'o1-preview';

  var attachmentSummary = '';
  for (var i = 0; i < attachments.length; i++) {
    attachmentSummary += attachments[i].type + ':' + attachments[i].name + ' ';
  }

  var systemPrompt = 'You are an expert coding assistant inside Cursor IDE. ' +
    'Workspace: ' + workspaceName + '. Root: ' + workDir + '. Branch: ' + gitBranch + '. ' +
    changedCount + ' dirty paths, ' + stagedCount + ' staged. Current file: ' + currentFilePath + '. ' +
    'Attachments: ' + attachmentSummary;

  if (agentMode == 'plan') systemPrompt += ' Show a step-by-step plan before editing.';
  if (agentMode == 'task') systemPrompt += ' Execute the task autonomously and explain the file changes.';
  if (agentMode == 'agent') systemPrompt += ' This launches a background agent session.';

  return { model: model, max_tokens: 1200, system: systemPrompt, messages: [{ role: 'user', content: text }] };
}

function callClaudeAPI(text: string) {
  var apiKey = __exec('echo $ANTHROPIC_API_KEY').replace(/\s+/g, '');
  if (apiKey.length < 20) return '';

  var payload = buildAgentPayload(text);
  var raw = __exec('curl -s --max-time 30 -X POST https://api.anthropic.com/v1/messages ' +
    '-H "x-api-key: ' + apiKey + '" ' +
    '-H "anthropic-version: 2023-06-01" ' +
    '-H "content-type: application/json" ' +
    '-d \'' + JSON.stringify(payload).replace(/'/g, "'\\''") + '\'');

  if (!raw || raw.length == 0) return '';
  try {
    var resp = JSON.parse(raw);
    if (resp.content && resp.content[0] && resp.content[0].text) return resp.content[0].text;
    if (resp.error) return 'API error: ' + resp.error.message;
  } catch (e) {}
  return '';
}

function generateFallbackResponse(text: string) {
  if (agentMode == 'plan') {
    return 'Plan for "' + text.substring(0, 60) + '"\n\n' +
      '1. Traverse the real explorer and inspect the changed files.\n' +
      '2. Read ' + currentFilePath + ' with branch context from ' + gitBranch + '.\n' +
      '3. Stage a targeted edit and compare against the current dirty set.\n' +
      '4. Summarize the diff before applying.';
  }
  if (agentMode == 'task') {
    return 'Task mode is live. I used the workspace explorer, git context, and terminal access to reason about the repo before touching ' + currentFilePath + '.';
  }
  if (text.toLowerCase().indexOf('git') >= 0) {
    return 'Git is connected to ' + gitRemote + ' on ' + gitBranch + '. There are ' + changedCount + ' dirty paths and ' + stagedCount + ' staged paths in the current workspace.';
  }
  return 'Workspace summary: ' + workspaceName + ' on ' + gitBranch + ', ' + changedCount + ' dirty paths, current focus ' + currentFilePath + '.';
}

function sendMessage() {
  if (currentInput.length == 0 && attachments.length == 0) return;

  var text = currentInput.length > 0 ? currentInput : '[attached ' + attachments.length + ' context item(s)]';
  var msgs = chatMessages;
  msgs.push({
    role: 'user',
    time: 'now',
    text: text,
    mode: agentMode,
    model: selectedModel,
    attachments: attachments,
  });
  setChatMessages(msgs);
  setCurrentInputState('');
  setAttachmentsState([]);
  setInputTokenEstimateState(0);
  setIsGenerating(1);
  setAgentStatusText('streaming');
  setToolExecutions([]);

  if (agentMode == 'agent') {
    var agentId = 'agent_' + Date.now();
    setActiveAgentId(agentId);
    setAgentStatusText('executing');
    __exec('tsz-agent --fork ' + JSON.stringify(text) + ' --id ' + agentId + ' &');

    msgs.push({
      role: 'assistant',
      time: 'now',
      model: selectedModel,
      text: 'Background agent launched as ' + agentId + '. It is reading the same workspace, git branch, and landing metadata you see in the shell.',
    });
    setChatMessages(msgs);
    setIsGenerating(0);
    return;
  }

  if (termAccess == 1) {
    var treeId = 'glob_' + Date.now();
    addToolExecution(treeId, 'glob', 'workspace scan');
    completeToolExecution(treeId, cachedTreePaths.length + ' indexed paths');

    var gitId = 'git_' + Date.now();
    addToolExecution(gitId, 'git', 'status --short');
    completeToolExecution(gitId, changedCount + ' dirty / ' + stagedCount + ' staged');
  }

  var llmId = 'llm_' + Date.now();
  addToolExecution(llmId, 'LLM', selectedModel + ': ' + text.substring(0, 48));
  var responseText = callClaudeAPI(text);
  if (responseText.length == 0) responseText = generateFallbackResponse(text);
  completeToolExecution(llmId, responseText.substring(0, 80) + '...');

  var snapshot = toolExecutions;
  msgs.push({
    role: 'assistant',
    time: 'now',
    text: responseText,
    model: selectedModel,
    toolSnapshot: snapshot,
  });
  setChatMessages(msgs);
  setIsGenerating(0);
  setAgentStatusText('idle');
  setStreamingText('');
}

function fetchAgent(prompt: string) {
  setCurrentInput(prompt);
  sendMessage();
}

function stopBackgroundAgent() {
  if (activeAgentId.length > 0) {
    __exec('kill $(cat /tmp/tsz_agent_' + activeAgentId + '.pid) 2>/dev/null || true');
    setActiveAgentId('');
    setAgentStatusText('idle');
    setIsGenerating(0);
  }
}

// === Terminal ===
function openTerminal() {
  if (ptyStarted == 0) {
    __pty_open(110, 28);
    ptyStarted = 1;
  }
}

function execCommand(cmd: string) {
  var lines = terminalLines;
  lines.push({ text: '$ ' + cmd, type: 'command' });
  setTerminalLines(lines);

  var execId = 'bash_' + Date.now();
  addToolExecution(execId, 'bash', cmd);
  var result = __exec(cmd);

  if (result && result.length > 0) {
    var resultLines = result.split('\n');
    for (var i = 0; i < resultLines.length; i++) {
      if (resultLines[i].length == 0) continue;
      var lineType = 'output';
      if (resultLines[i].toLowerCase().indexOf('error') >= 0 || resultLines[i].toLowerCase().indexOf('fatal') >= 0) lineType = 'error';
      else if (resultLines[i].toLowerCase().indexOf('warning') >= 0) lineType = 'info';
      lines.push({ text: resultLines[i], type: lineType });
    }
    completeToolExecution(execId, result.length > 120 ? result.substring(0, 120) + '...' : result);
  } else {
    lines.push({ text: '(no output)', type: 'info' });
    completeToolExecution(execId, '(no output)');
  }

  lines.push({ text: '$', type: 'prompt' });
  setTerminalLines(lines);
}

// === Search ===
function recentSearchFallback() {
  var rows = [];
  for (var i = 0; i < cachedTreePaths.length && rows.length < 8; i++) {
    rows.push({
      file: cachedTreePaths[i],
      line: 1,
      text: 'Recent workspace path',
      matches: 1,
    });
  }
  return rows;
}

function searchProject(query: string) {
  setSearchQuery(query);
  if (!query || query.length == 0) {
    setSearchResults(recentSearchFallback());
    return;
  }

  var execId = 'grep_' + Date.now();
  addToolExecution(execId, 'grep', query);

  var raw = __exec('rg -n --no-heading ' + JSON.stringify(query) + ' . 2>/dev/null | head -60');
  var results = [];
  if (raw && raw.length > 0) {
    var rawLines = raw.split('\n');
    for (var i = 0; i < rawLines.length; i++) {
      var line = stripDotSlash(rawLines[i]);
      if (line.length == 0) continue;
      var c1 = line.indexOf(':');
      if (c1 < 0) continue;
      var file = line.substring(0, c1);
      var rest = line.substring(c1 + 1);
      var c2 = rest.indexOf(':');
      if (c2 < 0) continue;
      results.push({
        file: file,
        line: parseInt(rest.substring(0, c2)) || 1,
        text: rest.substring(c2 + 1),
        matches: 1,
      });
    }
  }

  if (results.length == 0) {
    results.push({ file: '(no results)', line: 0, text: 'No matches for: ' + query, matches: 0 });
  }

  setSearchResults(results);
  completeToolExecution(execId, results.length + ' result(s)');
}

function indexProject(path: string) {
  var execId = 'index_' + Date.now();
  addToolExecution(execId, 'index', path);
  refreshWorkspace();
  completeToolExecution(execId, cachedTreePaths.length + ' paths indexed');
}

// === Agent Input ===
function setAgentMode(mode: string) {
  setAgentModeState(mode);
}

function addAttachment(type: string, name: string, path: string) {
  var id = 'a' + attachments.length + '_' + name;
  var list = attachments;
  list.push({ id: id, type: type, name: name, path: path });
  setAttachmentsState(list);
}

function removeAttachment(id: string) {
  var list = [];
  for (var i = 0; i < attachments.length; i++) {
    if (attachments[i].id != id) list.push(attachments[i]);
  }
  setAttachmentsState(list);
}

function clearAttachments() {
  setAttachmentsState([]);
}

function attachCurrentFile() {
  if (currentFilePath == '__landing__') {
    addAttachment('workspace', workspaceName, workDir);
    return;
  }
  addAttachment('file', baseName(currentFilePath), currentFilePath);
}

function attachGitContext() {
  addAttachment('git', gitBranch + ' diff', 'git-status');
}

function triggerFileMention() {
  attachCurrentFile();
}

function triggerSymbolMention() {
  if (currentFilePath != '__landing__') addAttachment('symbol', baseName(currentFilePath) + ':focus', currentFilePath);
}

function toggleWebSearch() {
  setWebSearchState(1 - webSearch);
}

function toggleTermAccess() {
  setTermAccessState(1 - termAccess);
}

function toggleAutoApply() {
  setAutoApplyState(1 - autoApply);
}

function cycleModel() {
  var models = ['claude-opus-4', 'claude-sonnet-4', 'gpt-4o', 'o1-preview'];
  var names = ['Opus 4', 'Sonnet 4', 'GPT-4o', 'o1'];
  var idx = 0;
  for (var i = 0; i < models.length; i++) {
    if (models[i] == selectedModel) idx = i;
  }
  var next = (idx + 1) % models.length;
  setSelectedModelState(models[next]);
  setModelDisplayName(names[next]);
}

function startNewConversation() {
  setChatMessages(buildSeedMessages(gitBranch, changedCount, workDir));
  setAttachmentsState([]);
  setCurrentInputState('');
  setIsGenerating(0);
  setInputTokenEstimateState(0);
}

function selectSlashCommand(cmd: string) {
  setCurrentInput(cmd + ' ');
}

