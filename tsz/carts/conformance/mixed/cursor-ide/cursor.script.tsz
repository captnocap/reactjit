// Cursor IDE — Script logic with file operations

declare function setFiles(v: any): void;
declare function setOpenTabs(v: any): void;
declare function setActiveTabId(v: string): void;
declare function setCurrentInputState(v: string): void;
declare function setIsGenerating(v: number): void;
declare function setChatMessages(v: any): void;
declare function setTerminalLines(v: any): void;
declare function setSearchResults(v: any): void;
declare function setErrors(v: number): void;
declare function setWarnings(v: number): void;
declare function setEditorContent(v: string): void;
declare function setEditorModified(v: number): void;
declare function setCurrentFilePath(v: string): void;
declare function setTotalLines(v: number): void;
declare function setLineNumbers(v: any): void;
declare function setBreadcrumbs(v: any): void;
declare function setLanguageMode(v: string): void;
declare function setGitStatus(v: string): void;
declare function setCursorPosition(v: any): void;
declare var files: any;
declare var openTabs: any;
declare var chatMessages: any;
declare var terminalLines: any;
declare var currentInput: string;
declare var searchQuery: string;
declare var editorContent: string;
declare var currentFilePath: string;
declare var agentMode: string;
declare var attachments: any;
declare var selectedModel: string;
declare var webSearch: number;
declare var termAccess: number;
declare var autoApply: number;
declare var inputTokenEstimate: number;
declare function setAgentModeState(v: string): void;
declare function setAttachmentsState(v: any): void;
declare function setSelectedModelState(v: string): void;
declare function setWebSearchState(v: number): void;
declare function setTermAccessState(v: number): void;
declare function setAutoApplyState(v: number): void;
declare function setInputTokenEstimateState(v: number): void;

// === Agent session + tool execution state ===
declare function setToolExecutions(v: any): void;
declare function setStreamingText(v: string): void;
declare function setAgentSessionId(v: string): void;
declare function setActiveAgentId(v: string): void;
declare function setAgentStatusText(v: string): void;
declare function setWorkDir(v: string): void;
declare var toolExecutions: any;
declare var streamingText: string;
declare var agentSessionId: string;
declare var activeAgentId: string;
declare var agentStatusText: string;
declare var workDir: string;

// === File Content Store ===
// In a real app this would be backed by __fs_readfile/__fs_writefile
var fileContents = {};

// Default file contents for the mock project
function initData() {
  fileContents['src/components/Sidebar.tsx'] = '// Sidebar Component\nimport { useState } from "react";\nimport { FileTree } from "./FileTree";\n\ninterface SidebarProps {\n  files: FileNode[];\n  onSelect: (path: string) => void;\n}\n\nexport function Sidebar({ files, onSelect }: SidebarProps) {\n  const [expanded, setExpanded] = useState<Set<string>>(new Set());\n\n  const toggle = (path: string) => {\n    const next = new Set(expanded);\n    if (next.has(path)) next.delete(path);\n    else next.add(path);\n    setExpanded(next);\n  };\n\n  return (\n    <div className="sidebar">\n      <FileTree\n        files={files}\n        expanded={expanded}\n        onToggle={toggle}\n        onSelect={onSelect}\n      />\n    </div>\n  );\n}';
  fileContents['src/components/Editor.tsx'] = '// Editor Component\nimport { useRef, useEffect } from "react";\nimport { highlight } from "../utils/highlight";\n\ninterface EditorProps {\n  content: string;\n  language: string;\n  onChange: (content: string) => void;\n}\n\nexport function Editor({ content, language, onChange }: EditorProps) {\n  const ref = useRef<HTMLTextAreaElement>(null);\n\n  useEffect(() => {\n    if (ref.current) {\n      ref.current.value = content;\n    }\n  }, [content]);\n\n  return (\n    <textarea\n      ref={ref}\n      className="editor-textarea"\n      onChange={(e) => onChange(e.target.value)}\n      spellCheck={false}\n    />\n  );\n}';
  fileContents['src/components/ChatPanel.tsx'] = '// Chat Panel Component\nimport { useState } from "react";\n\ninterface Message {\n  role: "user" | "assistant";\n  text: string;\n  time: string;\n}\n\nexport function ChatPanel() {\n  const [messages, setMessages] = useState<Message[]>([]);\n  const [input, setInput] = useState("");\n\n  const send = async () => {\n    if (!input.trim()) return;\n    setMessages([...messages, { role: "user", text: input, time: "now" }]);\n    setInput("");\n    // TODO: call agent API\n  };\n\n  return (\n    <div className="chat-panel">\n      {messages.map((m, i) => (\n        <div key={i} className={m.role}>{m.text}</div>\n      ))}\n      <input value={input} onChange={e => setInput(e.target.value)} />\n      <button onClick={send}>Send</button>\n    </div>\n  );\n}';
  fileContents['src/components/StatusBar.tsx'] = '// Status Bar\nexport function StatusBar({ branch, cursor, language }) {\n  return (\n    <div className="status-bar">\n      <span>git: {branch}</span>\n      <span>Ln {cursor.line}, Col {cursor.col}</span>\n      <span>{language}</span>\n    </div>\n  );\n}';
  fileContents['src/components/Terminal.tsx'] = '// Terminal Component\nimport { useRef, useEffect } from "react";\n\nexport function Terminal() {\n  const ref = useRef<HTMLDivElement>(null);\n  const [lines, setLines] = useState<string[]>([]);\n\n  const exec = (cmd: string) => {\n    setLines([...lines, `$ ${cmd}`, "..."]);\n  };\n\n  return (\n    <div className="terminal" ref={ref}>\n      {lines.map((l, i) => <div key={i}>{l}</div>)}\n    </div>\n  );\n}';
  fileContents['src/hooks/useAgent.ts'] = '// Agent hook — manages AI agent communication\nimport { useState, useCallback } from "react";\n\ninterface AgentState {\n  status: "idle" | "thinking" | "error";\n  progress: number;\n}\n\nexport function useAgent() {\n  const [state, setState] = useState<AgentState>({\n    status: "idle",\n    progress: 0,\n  });\n\n  const send = useCallback(async (prompt: string) => {\n    setState({ status: "thinking", progress: 0 });\n    try {\n      const res = await fetch("/api/agent", {\n        method: "POST",\n        body: JSON.stringify({ prompt }),\n      });\n      const data = await res.json();\n      setState({ status: "idle", progress: 100 });\n      return data;\n    } catch (e) {\n      setState({ status: "error", progress: 0 });\n    }\n  }, []);\n\n  return { ...state, send };\n}';
  fileContents['src/hooks/useFSWatch.ts'] = '// File system watcher hook\nimport { useEffect, useState } from "react";\n\nexport function useFSWatch(path: string) {\n  const [changes, setChanges] = useState<string[]>([]);\n\n  useEffect(() => {\n    // In production: use chokidar or node fs.watch\n    const interval = setInterval(() => {\n      // poll for changes\n    }, 1000);\n    return () => clearInterval(interval);\n  }, [path]);\n\n  return changes;\n}';
  fileContents['src/hooks/useSQLite.ts'] = '// SQLite hook for project indexing\nimport { useRef, useCallback } from "react";\n\ninterface DB {\n  exec(sql: string): void;\n  query(sql: string): any[];\n}\n\nexport function useSQLite(dbPath: string) {\n  const db = useRef<DB | null>(null);\n\n  const open = useCallback(() => {\n    // db.current = __sqlite_open(dbPath);\n  }, [dbPath]);\n\n  const query = useCallback((sql: string) => {\n    if (!db.current) return [];\n    return db.current.query(sql);\n  }, []);\n\n  return { open, query };\n}';
  fileContents['utils/index.ts'] = '// Utility functions\nexport function debounce(fn: Function, ms: number) {\n  let timer: any;\n  return (...args: any[]) => {\n    clearTimeout(timer);\n    timer = setTimeout(() => fn(...args), ms);\n  };\n}\n\nexport function throttle(fn: Function, ms: number) {\n  let last = 0;\n  return (...args: any[]) => {\n    const now = Date.now();\n    if (now - last >= ms) {\n      last = now;\n      fn(...args);\n    }\n  };\n}';
  fileContents['styles/theme.css'] = ':root {\n  --bg-primary: #0d0d0d;\n  --bg-secondary: #131313;\n  --bg-tertiary: #1a1a1a;\n  --border: #1f1f1f;\n  --text-primary: #e0e0e0;\n  --text-secondary: #b0b0b0;\n  --text-muted: #6e6e6e;\n  --accent-blue: #2d62ff;\n  --accent-yellow: #e6b450;\n  --accent-green: #7ee787;\n  --accent-red: #ff7b72;\n  --accent-purple: #d2a8ff;\n}\n\n.editor-textarea {\n  font-family: monospace;\n  font-size: 13px;\n  background: var(--bg-primary);\n  color: var(--text-secondary);\n  border: none;\n  outline: none;\n  resize: none;\n}';
  fileContents['package.json'] = '{\n  "name": "cursor-ide",\n  "version": "0.1.0",\n  "private": true,\n  "scripts": {\n    "dev": "next dev",\n    "build": "next build",\n    "start": "next start"\n  },\n  "dependencies": {\n    "react": "^18.2.0",\n    "next": "^14.0.0"\n  }\n}';
  fileContents['README.md'] = '# Cursor IDE\n\nAgentic coding environment built with ReactJIT.\n\n## Features\n- File explorer with SQLite indexing\n- AI-powered code agent\n- Integrated terminal\n- Code graph visualization\n\n## Getting Started\n```\nnpm install\nnpm run dev\n```';
  fileContents['tsconfig.json'] = '{\n  "compilerOptions": {\n    "target": "ES2020",\n    "lib": ["dom", "es2020"],\n    "jsx": "react-jsx",\n    "strict": true,\n    "moduleResolution": "node",\n    "outDir": "./dist"\n  },\n  "include": ["src/**/*"]\n}';

  // Detect working directory from shell
  var pwd = __exec('pwd');
  if (pwd && pwd.trim().length > 0) setWorkDir(pwd.trim());

  // === IFTTT Rules (useIFTTT from qjs_runtime.zig → ifttt.zig engine) ===

  // Ctrl+S → save current file
  useIFTTT('key:ctrl+s', function() { saveCurrentFile(); });

  // Ctrl+Enter → send chat message
  useIFTTT('key:ctrl+enter', function() { sendMessage(); });

  // Escape → close search and terminal panels
  useIFTTT('key:escape', function() {
    setShowSearch(0);
    setShowTerminal(0);
  });

  // F3 → toggle search panel
  useIFTTT('key:f3', function() { setShowSearch(1 - showSearch); });

  // Ctrl+` → toggle terminal
  useIFTTT('key:ctrl+grave', function() { setShowTerminal(1 - showTerminal); });

  // Ctrl+Shift+N → new file
  useIFTTT('key:ctrl+shift+n', function() { createNewFile('untitled-' + Date.now() + '.ts'); });

  // Auto-save: every 30 seconds if file is modified (timer_every → tools_builtin writeFile)
  useIFTTT('timer:every:30000', function() {
    if (editorModified == 1) saveCurrentFile();
  });

  // State edge: when isGenerating drops to 0, clear streaming state
  useIFTTT('state:isGenerating:0', function() {
    setAgentStatusText('idle');
    setStreamingText('');
  });

  // State edge: when editorModified becomes 1, update git indicator
  useIFTTT('state:editorModified:1', function() {
    setGitStatus('*1');
  });

  // Mount: show welcome message in terminal
  useIFTTT('mount', function() {
    var lines = terminalLines;
    lines.push({ text: 'cursor-ide ready. Ctrl+S to save, F3 to search, Ctrl+` for terminal.', type: 'info' });
    setTerminalLines(lines);
  });
}

// === Tool Execution Tracking ===
// Maps to ProgressUpdate stream from tool_framework.zig / tools_builtin.zig

function addToolExecution(id: string, name: string, input: string) {
  var execs = toolExecutions;
  execs.push({ id: id, name: name, input: input, status: 'running', percent: 10, result: '' });
  setToolExecutions(execs);
}

function completeToolExecution(id: string, result: string) {
  var execs = toolExecutions;
  for (var i = 0; i < execs.length; i++) {
    if (execs[i].id == id) {
      execs[i].status = 'completed';
      execs[i].percent = 100;
      execs[i].result = result;
    }
  }
  setToolExecutions(execs);
}

function failToolExecution(id: string, error: string) {
  var execs = toolExecutions;
  for (var i = 0; i < execs.length; i++) {
    if (execs[i].id == id) {
      execs[i].status = 'error';
      execs[i].percent = 0;
      execs[i].result = error;
    }
  }
  setToolExecutions(execs);
}

// === Line Numbers Helper ===
function rebuildLineNumbers(content: string) {
  var count = 1;
  for (var i = 0; i < content.length; i++) {
    if (content.charAt(i) == '\n') count++;
  }
  setTotalLines(count);
  var nums = [];
  for (var n = 1; n < count + 1; n++) {
    nums.push({ num: '' + n });
  }
  setLineNumbers(nums);
}

// === File Operations ===
function openFile(idx: number) {
  var f = files;
  var file = f[idx];

  // Toggle directory expansion
  if (file.type == 'dir') {
    f[idx].expanded = 1 - (f[idx].expanded || 0);
    setFiles(f);
    return;
  }

  // Select file in tree
  for (var i = 0; i < f.length; i++) {
    f[i].selected = (i == idx) ? 1 : 0;
  }
  setFiles(f);

  // Load content — try disk first (__fs_readfile from qjs_runtime.zig),
  // fall back to in-memory cache, then placeholder
  var content = fileContents[file.path];
  if (!content || content.length == 0) {
    var diskContent = __fs_readfile(file.path);
    if (diskContent && diskContent.length > 0) {
      content = diskContent;
      fileContents[file.path] = diskContent;
    } else {
      content = '// ' + file.path + '\n';
    }
  }
  setEditorContent(content);
  setCurrentFilePath(file.path);
  setEditorModified(0);

  // Rebuild line numbers gutter
  rebuildLineNumbers(content);

  // Update language mode
  var ext = file.type;
  if (ext == 'tsx' || ext == 'ts') setLanguageMode('TypeScript TSX');
  else if (ext == 'js') setLanguageMode('JavaScript');
  else if (ext == 'css') setLanguageMode('CSS');
  else if (ext == 'json') setLanguageMode('JSON');
  else if (ext == 'md') setLanguageMode('Markdown');
  else setLanguageMode('Plain Text');

  // Update breadcrumbs
  var parts = file.path.split('/');
  var crumbs = [];
  for (var pi = 0; pi < parts.length; pi++) {
    crumbs.push({ label: parts[pi] });
  }
  setBreadcrumbs(crumbs);

  // Add to tabs if not already open
  var found = 0;
  var tabId = '';
  for (var ti = 0; ti < openTabs.length; ti++) {
    if (openTabs[ti].path == file.path) {
      found = 1;
      tabId = openTabs[ti].id;
    }
  }
  if (found == 0) {
    tabId = '' + (openTabs.length + 1);
    var tabs = openTabs;
    tabs.push({ id: tabId, name: file.name, path: file.path, modified: 0 });
    setOpenTabs(tabs);
  }
  setActiveTabId(tabId);
}

function selectFile(idx: number) {
  openFile(idx);
}

function updateEditorContent(text: string) {
  setEditorContent(text);
  setEditorModified(1);

  // Rebuild line numbers gutter
  rebuildLineNumbers(text);

  // Update git status indicator
  setGitStatus('*1');

  // Store in memory
  fileContents[currentFilePath] = text;

  // Mark tab as modified
  var tabs = openTabs;
  for (var ti = 0; ti < tabs.length; ti++) {
    if (tabs[ti].path == currentFilePath) {
      tabs[ti].modified = 1;
    }
  }
  setOpenTabs(tabs);
}

function saveCurrentFile() {
  var execId = 'write_' + Date.now();
  addToolExecution(execId, 'writeFile', currentFilePath);

  // Real file write via __fs_writefile (qjs_runtime.zig → hostFsWritefile)
  var wrote = __fs_writefile(currentFilePath, editorContent);
  fileContents[currentFilePath] = editorContent;

  setEditorModified(0);
  var tabs = openTabs;
  for (var ti = 0; ti < tabs.length; ti++) {
    if (tabs[ti].path == currentFilePath) {
      tabs[ti].modified = 0;
    }
  }
  setOpenTabs(tabs);
  setGitStatus('');

  if (wrote == 0) {
    completeToolExecution(execId, 'saved ' + currentFilePath);
  } else {
    failToolExecution(execId, 'write failed (path may not exist on disk)');
  }
}

function createNewFile(name: string) {
  var f = files;
  // Add at root level
  f.push({ name: name, type: 'ts', indent: 1, selected: 0, path: name });
  setFiles(f);
  fileContents[name] = '// ' + name + '\n';
}

// === Tab Operations ===
function activateTab(id: string) {
  setActiveTabId(id);
  // Load the file for this tab
  for (var i = 0; i < openTabs.length; i++) {
    if (openTabs[i].id == id) {
      var content = fileContents[openTabs[i].path] || '';
      setEditorContent(content);
      setCurrentFilePath(openTabs[i].path);
      // Update line count
      var lines = 1;
      for (var ci = 0; ci < content.length; ci++) {
        if (content.charAt(ci) == '\n') lines++;
      }
      setTotalLines(lines);
    }
  }
}

function closeTab(id: string) {
  var tabs = [];
  for (var i = 0; i < openTabs.length; i++) {
    if (openTabs[i].id != id) {
      tabs.push(openTabs[i]);
    }
  }
  setOpenTabs(tabs);
  // If we closed the active tab, switch to the last remaining
  if (tabs.length > 0) {
    activateTab(tabs[tabs.length - 1].id);
  }
}

// === Chat ===
function setCurrentInput(v: string) {
  setCurrentInputState(v);
  // Token estimate: ~4 chars per token, 500 per attached file
  var estimate = Math.ceil(v.length / 4);
  for (var i = 0; i < attachments.length; i++) {
    estimate = estimate + 500;
  }
  setInputTokenEstimateState(estimate);
}

function buildAgentPayload(text: string) {
  var model = 'claude-opus-4-6';
  if (selectedModel == 'claude-sonnet-4') model = 'claude-sonnet-4-6';
  else if (selectedModel == 'gpt-4o') model = 'gpt-4o';
  else if (selectedModel == 'o1-preview') model = 'o1-preview';

  var systemPrompt = 'You are an expert coding assistant embedded in Cursor IDE. ' +
    'Current file: ' + currentFilePath + '. Project files: ' + files.length + '.';
  if (agentMode == 'plan') systemPrompt += ' Show a step-by-step plan and file diffs before applying any changes.';
  if (agentMode == 'task') systemPrompt += ' Execute the task autonomously. Use tools to read, edit, and run code.';

  return { model: model, max_tokens: 1024, system: systemPrompt,
    messages: [{ role: 'user', content: text }] };
}

function callClaudeAPI(text: string) {
  var apiKey = __exec('echo $ANTHROPIC_API_KEY').replace(/\s+/g, '');
  if (apiKey.length < 20) return '';

  var payload = buildAgentPayload(text);

  // Real HTTP via curl — agent_session.zig HTTP pipeline maps to this
  var raw = __exec('curl -s --max-time 30 -X POST https://api.anthropic.com/v1/messages ' +
    '-H "x-api-key: ' + apiKey + '" ' +
    '-H "anthropic-version: 2023-06-01" ' +
    '-H "content-type: application/json" ' +
    '-d \'' + JSON.stringify(payload).replace(/'/g, "'\\''") + '\'');

  if (!raw || raw.length == 0) return '';
  try {
    var resp = JSON.parse(raw);
    if (resp.content && resp.content[0] && resp.content[0].text) return resp.content[0].text;
    if (resp.error) return 'API error: ' + resp.error.message;
  } catch(e) {}
  return '';
}

function generateFallbackResponse(text: string) {
  var lower = text.toLowerCase();
  if (agentMode == 'plan') {
    return 'Plan for: "' + text.substring(0, 60) + '"\n\n' +
      '1. Read ' + currentFilePath + '\n' +
      '2. Identify the relevant section (' + totalLines + ' lines)\n' +
      '3. Apply targeted changes\n4. Verify no regressions\n\nShowing diff before applying.';
  }
  if (agentMode == 'task') {
    return 'Task started. I read ' + files.length + ' files, ran analysis, and applied the changes. ' +
      'Check the terminal for execution logs.';
  }
  if (lower.indexOf('fix') >= 0 || lower.indexOf('bug') >= 0) {
    return 'Found issue in ' + currentFilePath + ' around line ' + Math.floor(totalLines / 2) +
      '. The problem is in the event handler. Applying fix now.';
  }
  if (lower.indexOf('explain') >= 0 || lower.indexOf('what') >= 0) {
    return currentFilePath + ' (' + totalLines + ' lines) — ' +
      'this component manages state and renders the UI tree. ' +
      'Key functions handle file selection, tab management, and editor sync.';
  }
  if (lower.indexOf('test') >= 0) {
    return 'Writing tests for ' + currentFilePath + '. Found ' +
      Math.ceil(totalLines / 20) + ' testable functions.';
  }
  return 'Analyzing ' + files.length + ' files in the project. ' +
    currentFilePath + ' is ' + totalLines + ' lines. Ready to help.';
}

function sendMessage() {
  if (currentInput.length == 0 && attachments.length == 0) return;

  var text = currentInput;
  if (text.length == 0) text = '[attached ' + attachments.length + ' file(s)]';

  var msgs = chatMessages;
  msgs.push({ role: 'user', time: 'now', text: text,
    mode: agentMode, model: selectedModel, attachments: attachments });
  setChatMessages(msgs);
  setCurrentInputState('');
  setAttachmentsState([]);
  setInputTokenEstimateState(0);
  setIsGenerating(1);
  setAgentStatusText('streaming');
  setToolExecutions([]);

  if (agentMode == 'agent') {
    // Fork background agent via agent_spawner.zig
    var agentId = 'agent_' + Date.now();
    setActiveAgentId(agentId);
    setAgentStatusText('executing');

    // Spawn agent process (tsz-agent CLI wraps agent_spawner.zig ForkedAgent)
    __exec('tsz-agent --fork ' + JSON.stringify(text) + ' --id ' + agentId + ' &');

    msgs.push({ role: 'assistant', time: 'now', model: selectedModel,
      text: 'Background agent launched (id: ' + agentId + ').\nRunning autonomously — I will edit files and report when done.\nCheck the Agents panel for live status.' });
    setChatMessages(msgs);
    setIsGenerating(0);
    return;
  }

  // task mode: run shell tools first, then ask
  if (agentMode == 'task' && termAccess == 1) {
    var scanId = 'glob_' + Date.now();
    addToolExecution(scanId, 'glob', 'scanning project...');
    var fileTree = __exec('find . -type f -name "*.ts" -o -name "*.tsx" -o -name "*.js" 2>/dev/null | head -30');
    completeToolExecution(scanId, (fileTree.split('\n').length - 1) + ' source files');

    var readId = 'read_' + Date.now();
    addToolExecution(readId, 'readFile', currentFilePath);
    var fileContent = __fs_readfile(currentFilePath);
    completeToolExecution(readId, fileContent.length > 0 ? fileContent.length + ' bytes' : 'not on disk');
  }

  var llmId = 'llm_' + Date.now();
  addToolExecution(llmId, 'LLM', selectedModel + ': ' + text.substring(0, 50));

  var responseText = callClaudeAPI(text);
  if (responseText.length == 0) responseText = generateFallbackResponse(text);

  completeToolExecution(llmId, responseText.substring(0, 60) + '...');

  var snapshot = toolExecutions;
  msgs.push({ role: 'assistant', time: 'now', text: responseText,
    model: selectedModel, toolSnapshot: snapshot });
  setChatMessages(msgs);
  setIsGenerating(0);
  setAgentStatusText('idle');
  setStreamingText('');
}

function fetchAgent(prompt: string) {
  sendMessage();
}

function stopBackgroundAgent() {
  if (activeAgentId.length > 0) {
    // Terminate via agent_pool.terminateAll() equivalent
    __exec('kill $(cat /tmp/tsz_agent_' + activeAgentId + '.pid) 2>/dev/null || true');
    setActiveAgentId('');
    setAgentStatusText('idle');
    setIsGenerating(0);
  }
}

// === Terminal ===
function openTerminal() {
  var lines = terminalLines;
  lines.push({ text: '[new terminal session]', type: 'info' });
  setTerminalLines(lines);
}

function execCommand(cmd: string) {
  var lines = terminalLines;
  lines.push({ text: '$ ' + cmd, type: 'command' });
  setTerminalLines(lines);

  // Real execution via __exec (qjs_runtime.zig → popen, maps to tools_builtin.zig BashTool)
  var execId = 'bash_' + Date.now();
  addToolExecution(execId, 'bash', cmd);

  var result = __exec(cmd);

  if (result && result.length > 0) {
    var resultLines = result.split('\n');
    for (var i = 0; i < resultLines.length; i++) {
      var l = resultLines[i];
      if (l.length > 0) {
        var lineType = 'output';
        if (l.toLowerCase().indexOf('error') >= 0 || l.toLowerCase().indexOf('fatal') >= 0) lineType = 'error';
        if (l.indexOf('warning') >= 0) lineType = 'info';
        lines.push({ text: l, type: lineType });
      }
    }
    completeToolExecution(execId, result.length > 120 ? result.substring(0, 120) + '...' : result);
  } else {
    lines.push({ text: '(no output)', type: 'info' });
    completeToolExecution(execId, '(no output)');
  }

  lines.push({ text: '$', type: 'prompt' });
  setTerminalLines(lines);
}

// === Search ===
function searchProject(query: string) {
  var execId = 'grep_' + Date.now();
  addToolExecution(execId, 'grep', query);

  // Real ripgrep via __exec (tools_builtin.zig grepTool maps to rg)
  var raw = __exec('rg -n --no-heading ' + JSON.stringify(query) + ' . 2>/dev/null | head -50');

  var results = [];
  if (raw && raw.length > 0) {
    var rawLines = raw.split('\n');
    for (var i = 0; i < rawLines.length; i++) {
      var line = rawLines[i];
      if (line.length == 0) continue;
      var c1 = line.indexOf(':');
      if (c1 < 0) continue;
      var file = line.substring(0, c1);
      var rest = line.substring(c1 + 1);
      var c2 = rest.indexOf(':');
      if (c2 >= 0) {
        var lineNum = parseInt(rest.substring(0, c2)) || 0;
        var text = rest.substring(c2 + 1);
        results.push({ file: file, line: lineNum, text: text, matches: 1 });
      }
    }
  }

  if (results.length == 0) {
    results.push({ file: '(no results)', line: 0, text: 'No matches for: ' + query, matches: 0 });
  }
  setSearchResults(results);
  completeToolExecution(execId, results.length + ' match(es)');
}

function indexProject(path: string) {
  var execId = 'glob_' + Date.now();
  addToolExecution(execId, 'glob', path);

  // Real file scan via __fs_scandir (tools_builtin.zig globTool)
  var fileList = __exec('find ' + path + ' -type f 2>/dev/null | head -100');
  var count = 0;
  if (fileList && fileList.length > 0) {
    var fileLines = fileList.split('\n');
    for (var fi = 0; fi < fileLines.length; fi++) {
      if (fileLines[fi].length > 0) count++;
    }
  }
  completeToolExecution(execId, 'indexed ' + count + ' files in ' + path);
}

// === Agent Input ===
function setAgentMode(mode: string) {
  setAgentModeState(mode);
}

function addAttachment(type: string, name: string, path: string) {
  var id = 'a' + attachments.length + '_' + name;
  var list = attachments;
  list.push({ id: id, type: type, name: name, path: path });
  setAttachmentsState(list);
}

function removeAttachment(id: string) {
  var list = [];
  for (var i = 0; i < attachments.length; i++) {
    if (attachments[i].id != id) {
      list.push(attachments[i]);
    }
  }
  setAttachmentsState(list);
}

function clearAttachments() {
  setAttachmentsState([]);
}

function attachCurrentFile() {
  var name = currentFilePath;
  var parts = currentFilePath.split('/');
  if (parts.length > 0) name = parts[parts.length - 1];
  addAttachment('file', name, currentFilePath);
}

function triggerFileMention() {
  // In production: opens file picker overlay
  attachCurrentFile();
}

function triggerSymbolMention() {
  // In production: opens symbol picker overlay
}

function toggleWebSearch() {
  setWebSearchState(1 - webSearch);
}

function toggleTermAccess() {
  setTermAccessState(1 - termAccess);
}

function toggleAutoApply() {
  setAutoApplyState(1 - autoApply);
}

function cycleModel() {
  var models = ['claude-opus-4', 'claude-sonnet-4', 'gpt-4o', 'o1-preview'];
  var idx = 0;
  for (var i = 0; i < models.length; i++) {
    if (models[i] == selectedModel) { idx = i; }
  }
  var next = (idx + 1) % models.length;
  setSelectedModelState(models[next]);
}

function startNewConversation() {
  setChatMessages([]);
  setAttachmentsState([]);
  setCurrentInputState('');
  setIsGenerating(0);
  setInputTokenEstimateState(0);
}

function selectSlashCommand(cmd: string) {
  setCurrentInputState(cmd + ' ');
  setInputTokenEstimateState(0);
}

// Auto-init on script load (top-level blocks outside functions don't compile yet)
initData();

export {
  initData,
  selectFile,
  activateTab,
  closeTab,
  openFile,
  setCurrentInput,
  sendMessage,
  openTerminal,
  execCommand,
  searchProject,
  indexProject,
  fetchAgent,
  saveCurrentFile,
  createNewFile,
  updateEditorContent,
  setAgentMode,
  addAttachment,
  removeAttachment,
  clearAttachments,
  attachCurrentFile,
  triggerFileMention,
  triggerSymbolMention,
  toggleWebSearch,
  toggleTermAccess,
  toggleAutoApply,
  cycleModel,
  startNewConversation,
  selectSlashCommand,
  stopBackgroundAgent,
  addToolExecution,
  completeToolExecution,
  failToolExecution,
};
