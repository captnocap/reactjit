// Cursor IDE — unified dark classifier for workspace, editor, and agent surfaces

classifier({
  // === SHELL ===
  Shell: { type: 'Box', style: { flexDirection: 'column', width: '100%', height: '100%', backgroundColor: '#090c11' } },
  Workspace: { type: 'Box', style: { flexDirection: 'row', flexGrow: 1, flexBasis: 0, overflow: 'hidden', backgroundColor: '#090c11' } },
  Editor: { type: 'Box', style: { flexGrow: 1, flexBasis: 0, flexDirection: 'column', backgroundColor: '#0d1015', borderLeftWidth: 1, borderRightWidth: 1, borderColor: '#171d26' } },

  // === TOP BAR ===
  TopBar: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', height: 46, backgroundColor: '#0b0f15', borderBottomWidth: 1, borderColor: '#171d26', paddingLeft: 14, paddingRight: 14 } },
  TopBarLeft: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 10, flexGrow: 1, flexBasis: 0 } },
  TopBarTraffic: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 7 } },
  TopBarTrafficDot: { type: 'Box', style: { width: 11, height: 11, borderRadius: 6 } },
  TopBarWorkspaceBtn: { type: 'Pressable', style: { flexDirection: 'row', alignItems: 'center', gap: 8, paddingLeft: 10, paddingRight: 10, paddingTop: 6, paddingBottom: 6, backgroundColor: '#10151d', borderRadius: 8, borderWidth: 1, borderColor: '#1f2935' } },
  TopBarWorkspaceGlyph: { type: 'Text', fontSize: 10, color: '#79c0ff' },
  TopBarWorkspaceText: { type: 'Text', fontSize: 12, color: '#d4dbe7', bold: true },
  TopBarCommandBar: { type: 'Pressable', style: { flexGrow: 1, flexBasis: 0, flexDirection: 'column', gap: 2, paddingLeft: 12, paddingRight: 12, paddingTop: 7, paddingBottom: 7, backgroundColor: '#0f141c', borderRadius: 8, borderWidth: 1, borderColor: '#1c2531' } },
  TopBarCommandHint: { type: 'Text', fontSize: 10, color: '#5d6a7c' },
  TopBarCommandLabel: { type: 'Text', fontSize: 12, color: '#c9d2df' },
  TopBarRight: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 8, marginLeft: 12 } },
  TopBarGitChip: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 6, paddingLeft: 10, paddingRight: 10, paddingTop: 6, paddingBottom: 6, backgroundColor: '#10151d', borderRadius: 999, borderWidth: 1, borderColor: '#1f2935' } },
  TopBarGitDot: { type: 'Box', style: { width: 7, height: 7, borderRadius: 4, backgroundColor: '#7ee787' } },
  TopBarGitText: { type: 'Text', fontSize: 11, color: '#d4dbe7', bold: true },
  TopBarGitMeta: { type: 'Text', fontSize: 10, color: '#7f8a99' },
  TopBarAction: { type: 'Pressable', style: { flexDirection: 'row', alignItems: 'center', gap: 5, paddingLeft: 10, paddingRight: 10, paddingTop: 6, paddingBottom: 6, backgroundColor: '#10151d', borderRadius: 8, borderWidth: 1, borderColor: '#1c2531' } },
  TopBarActionLabel: { type: 'Text', fontSize: 11, color: '#c9d2df' },
  TopBarActionMeta: { type: 'Text', fontSize: 10, color: '#5d6a7c' },

  // === SIDEBAR ===
  Sidebar: { type: 'Box', style: { width: 312, flexDirection: 'column', backgroundColor: '#0c1016', borderRightWidth: 1, borderColor: '#171d26' } },
  SidebarHeader: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', paddingLeft: 14, paddingRight: 12, paddingTop: 12, paddingBottom: 10 } },
  SidebarTitle: { type: 'Text', fontSize: 11, color: '#5d6a7c', letterSpacing: 0.6 },
  SidebarActions: { type: 'Box', style: { flexDirection: 'row', gap: 6 } },
  SidebarActionBtn: { type: 'Pressable', style: { width: 26, height: 26, borderRadius: 7, backgroundColor: '#10151d', borderWidth: 1, borderColor: '#1f2935', alignItems: 'center', justifyContent: 'center' } },
  SidebarActionIcon: { type: 'Text', fontSize: 11, color: '#c9d2df' },
  SidebarWorkspaceCard: { type: 'Pressable', style: { marginLeft: 12, marginRight: 12, marginBottom: 10, padding: 12, backgroundColor: '#10151d', borderRadius: 10, borderWidth: 1, borderColor: '#1c2531', flexDirection: 'column', gap: 4 } },
  SidebarWorkspaceName: { type: 'Text', fontSize: 13, color: '#eef2f8', bold: true },
  SidebarWorkspaceMeta: { type: 'Text', fontSize: 11, color: '#9db1c9' },
  SidebarWorkspacePath: { type: 'Text', fontSize: 10, color: '#5d6a7c' },
  SidebarSection: { type: 'Box', style: { flexDirection: 'column', marginTop: 2 } },
  SidebarSectionHeader: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 6, paddingLeft: 12, paddingRight: 12, paddingTop: 8, paddingBottom: 6 } },
  SidebarChevron: { type: 'Text', fontSize: 10, color: '#5d6a7c' },
  SidebarSectionTitle: { type: 'Text', fontSize: 11, color: '#778395', letterSpacing: 0.5 },
  SidebarMiniList: { type: 'Box', style: { flexDirection: 'column', paddingLeft: 8, paddingRight: 8, gap: 4 } },
  SidebarMiniRow: { type: 'Pressable', style: { flexDirection: 'row', alignItems: 'center', gap: 8, paddingLeft: 8, paddingRight: 8, paddingTop: 6, paddingBottom: 6, backgroundColor: '#10151d', borderRadius: 8 } },
  SidebarMiniLabel: { type: 'Text', fontSize: 11, color: '#c9d2df', flexGrow: 1, flexBasis: 0 },
  SidebarMiniDot: { type: 'Box', style: { width: 6, height: 6, borderRadius: 3, backgroundColor: '#2d62ff' } },
  SidebarChangeRow: { type: 'Pressable', style: { flexDirection: 'row', alignItems: 'center', gap: 8, paddingLeft: 8, paddingRight: 8, paddingTop: 6, paddingBottom: 6, backgroundColor: '#10151d', borderRadius: 8 } },
  SidebarChangeDot: { type: 'Box', style: { width: 7, height: 7, borderRadius: 4 } },
  SidebarChangeLabel: { type: 'Text', fontSize: 10, color: '#c9d2df', bold: true },
  SidebarChangePath: { type: 'Text', fontSize: 10, color: '#7f8a99', flexGrow: 1, flexBasis: 0 },
  FileTree: { type: 'ScrollView', style: { flexGrow: 1, flexBasis: 0, marginTop: 6 } },
  FileTreeStack: { type: 'Box', style: { flexDirection: 'column', paddingBottom: 16 } },

  // === TAB BAR ===
  TabBar: { type: 'Box', style: { flexDirection: 'row', height: 38, backgroundColor: '#0a0d12', borderBottomWidth: 1, borderColor: '#171d26' } },
  TabName: { type: 'Text', fontSize: 12, color: '#7f8a99' },
  TabNameActive: { type: 'Text', fontSize: 12, color: '#eef2f8' },
  TabGitBadge: { type: 'Text', fontSize: 9, color: '#7f8a99' },
  TabModified: { type: 'Box', style: { width: 6, height: 6, borderRadius: 3, backgroundColor: '#e6b450' } },
  TabClose: { type: 'Pressable', style: { width: 18, height: 18, borderRadius: 4, alignItems: 'center', justifyContent: 'center', backgroundColor: '#141b24' } },
  TabCloseIcon: { type: 'Text', fontSize: 10, color: '#7f8a99' },

  // === BREADCRUMBS ===
  Breadcrumbs: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 6, paddingLeft: 14, paddingRight: 14, paddingTop: 9, paddingBottom: 9, backgroundColor: '#0d1015', borderBottomWidth: 1, borderColor: '#171d26' } },
  BreadcrumbItem: { type: 'Pressable', style: { flexDirection: 'row', alignItems: 'center', gap: 6, paddingLeft: 6, paddingRight: 6, paddingTop: 3, paddingBottom: 3, borderRadius: 8 } },
  BreadcrumbSep: { type: 'Text', fontSize: 10, color: '#425062' },
  BreadcrumbIconPill: { type: 'Box', style: { paddingLeft: 5, paddingRight: 5, paddingTop: 2, paddingBottom: 2, borderRadius: 999 } },
  BreadcrumbIconText: { type: 'Text', fontSize: 9, color: '#eaf1fb' },
  BreadcrumbText: { type: 'Text', fontSize: 11, color: '#7f8a99' },
  BreadcrumbTextActive: { type: 'Text', fontSize: 11, color: '#eef2f8', bold: true },
  BreadcrumbMeta: { type: 'Text', fontSize: 10, color: '#5d6a7c' },

  // === LANDING ===
  LandingPage: { type: 'ScrollView', style: { flexGrow: 1, flexBasis: 0, backgroundColor: '#0d1015' } },
  LandingContent: { type: 'Box', style: { flexDirection: 'column', padding: 18, gap: 16 } },
  LandingHero: { type: 'Box', style: { flexDirection: 'column', gap: 8, padding: 18, backgroundColor: '#10151d', borderRadius: 14, borderWidth: 1, borderColor: '#1c2531' } },
  LandingEyebrow: { type: 'Text', fontSize: 10, color: '#79c0ff', letterSpacing: 0.8 },
  LandingTitle: { type: 'Text', fontSize: 26, color: '#eef2f8', bold: true },
  LandingSubtitle: { type: 'Text', fontSize: 12, color: '#8ca0b8' },
  LandingBody: { type: 'Text', fontSize: 12, color: '#c9d2df', lineHeight: 18 },
  LandingHeroMetaRow: { type: 'Box', style: { flexDirection: 'row', gap: 8, flexWrap: 'wrap', paddingTop: 6 } },
  LandingHeroChip: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 6, paddingLeft: 10, paddingRight: 10, paddingTop: 6, paddingBottom: 6, backgroundColor: '#0f141c', borderRadius: 999, borderWidth: 1, borderColor: '#1f2935' } },
  LandingHeroChipKey: { type: 'Text', fontSize: 10, color: '#5d6a7c' },
  LandingHeroChipValue: { type: 'Text', fontSize: 11, color: '#d4dbe7' },
  LandingActionRow: { type: 'Box', style: { flexDirection: 'row', gap: 10, paddingTop: 8 } },
  LandingPrimaryAction: { type: 'Pressable', style: { paddingLeft: 14, paddingRight: 14, paddingTop: 9, paddingBottom: 9, backgroundColor: '#2d62ff', borderRadius: 10 } },
  LandingPrimaryLabel: { type: 'Text', fontSize: 11, color: '#ffffff', bold: true },
  LandingSecondaryAction: { type: 'Pressable', style: { paddingLeft: 14, paddingRight: 14, paddingTop: 9, paddingBottom: 9, backgroundColor: '#10151d', borderRadius: 10, borderWidth: 1, borderColor: '#1f2935' } },
  LandingSecondaryLabel: { type: 'Text', fontSize: 11, color: '#c9d2df' },
  LandingStatsRow: { type: 'Box', style: { flexDirection: 'row', gap: 10, flexWrap: 'wrap' } },
  LandingStatCard: { type: 'Box', style: { minWidth: 120, paddingLeft: 12, paddingRight: 12, paddingTop: 10, paddingBottom: 10, backgroundColor: '#10151d', borderRadius: 10, borderWidth: 1, borderColor: '#1c2531' } },
  LandingStatValue: { type: 'Text', fontSize: 18, bold: true },
  LandingStatLabel: { type: 'Text', fontSize: 10, color: '#5d6a7c', marginTop: 4 },
  LandingPanels: { type: 'Box', style: { flexDirection: 'row', gap: 12, flexWrap: 'wrap' } },
  LandingPanel: { type: 'Box', style: { flexGrow: 1, flexBasis: 280, flexDirection: 'column', gap: 10, padding: 14, backgroundColor: '#10151d', borderRadius: 12, borderWidth: 1, borderColor: '#1c2531' } },
  LandingPanelHeader: { type: 'Box', style: { flexDirection: 'column', gap: 3 } },
  LandingPanelTitle: { type: 'Text', fontSize: 13, color: '#eef2f8', bold: true },
  LandingPanelMeta: { type: 'Text', fontSize: 10, color: '#5d6a7c' },
  LandingProjectList: { type: 'Box', style: { flexDirection: 'column', gap: 10 } },
  LandingProjectCard: { type: 'Pressable', style: { flexDirection: 'column', gap: 8, padding: 12, backgroundColor: '#0f141c', borderRadius: 10, borderWidth: 1, borderColor: '#1f2935' } },
  LandingProjectHeader: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 8 } },
  LandingProjectAccent: { type: 'Box', style: { width: 8, height: 24, borderRadius: 4 } },
  LandingProjectName: { type: 'Text', fontSize: 12, color: '#eef2f8', bold: true, flexGrow: 1, flexBasis: 0 },
  LandingProjectBadge: { type: 'Text', fontSize: 10, color: '#79c0ff' },
  LandingProjectSummary: { type: 'Text', fontSize: 11, color: '#c9d2df', lineHeight: 17 },
  LandingProjectMeta: { type: 'Text', fontSize: 10, color: '#5d6a7c' },
  LandingConnectionList: { type: 'Box', style: { flexDirection: 'column', gap: 8 } },
  LandingConnectionRow: { type: 'Box', style: { flexDirection: 'row', alignItems: 'flex-start', gap: 8, padding: 10, backgroundColor: '#0f141c', borderRadius: 10, borderWidth: 1, borderColor: '#1f2935' } },
  LandingConnectionDot: { type: 'Box', style: { width: 8, height: 8, borderRadius: 4, marginTop: 5 } },
  LandingConnectionBody: { type: 'Box', style: { flexDirection: 'column', gap: 3, flexGrow: 1, flexBasis: 0 } },
  LandingConnectionName: { type: 'Text', fontSize: 11, color: '#eef2f8' },
  LandingConnectionMeta: { type: 'Text', fontSize: 10, color: '#7f8a99' },
  LandingRecentList: { type: 'Box', style: { flexDirection: 'column', gap: 8 } },
  LandingRecentRow: { type: 'Pressable', style: { flexDirection: 'column', gap: 3, padding: 12, backgroundColor: '#0f141c', borderRadius: 10, borderWidth: 1, borderColor: '#1f2935' } },
  LandingRecentName: { type: 'Text', fontSize: 11, color: '#eef2f8' },
  LandingRecentReason: { type: 'Text', fontSize: 10, color: '#79c0ff' },
  LandingRecentPath: { type: 'Text', fontSize: 10, color: '#5d6a7c' },

  // === EDITOR ===
  EditorViewportShell: { type: 'Box', style: { flexGrow: 1, flexBasis: 0, flexDirection: 'column', backgroundColor: '#0d1015' } },
  EditorHeaderBar: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', paddingLeft: 14, paddingRight: 14, paddingTop: 10, paddingBottom: 10, borderBottomWidth: 1, borderColor: '#171d26' } },
  EditorHeaderLeft: { type: 'Box', style: { flexDirection: 'column', gap: 3 } },
  EditorHeaderTitle: { type: 'Text', fontSize: 12, color: '#eef2f8', bold: true },
  EditorHeaderMeta: { type: 'Text', fontSize: 10, color: '#5d6a7c' },
  EditorHeaderRight: { type: 'Box', style: { flexDirection: 'row', gap: 8, flexWrap: 'wrap', justifyContent: 'flex-end' } },
  EditorHeaderBadge: { type: 'Box', style: { paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: '#10151d', borderRadius: 999, borderWidth: 1, borderColor: '#1f2935' } },
  EditorHeaderBadgeText: { type: 'Text', fontSize: 10, color: '#7f8a99' },
  EditorViewport: { type: 'Box', style: { flexDirection: 'row', flexGrow: 1, flexBasis: 0 } },
  EditorCodeScroll: { type: 'ScrollView', style: { flexGrow: 1, flexBasis: 0 } },
  EditorCodeStack: { type: 'Box', style: { flexDirection: 'column', paddingTop: 4, paddingBottom: 10 } },
  EditorMinimap: { type: 'Box', style: { width: 84, borderLeftWidth: 1, borderColor: '#171d26', backgroundColor: '#0b0f15' } },
  EditorMinimapHeader: { type: 'Box', style: { height: 34, borderBottomWidth: 1, borderColor: '#171d26' } },
  EditorMinimapScroll: { type: 'ScrollView', style: { flexGrow: 1, flexBasis: 0, paddingLeft: 8, paddingRight: 8, paddingTop: 10, paddingBottom: 10 } },
  EditorMinimapStack: { type: 'Box', style: { flexDirection: 'column' } },
  EditorScratchPane: { type: 'Box', style: { borderTopWidth: 1, borderColor: '#171d26', backgroundColor: '#0c1016', paddingTop: 10, paddingBottom: 10 } },
  EditorScratchHeader: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', paddingLeft: 12, paddingRight: 12, paddingBottom: 8 } },
  EditorScratchTitle: { type: 'Text', fontSize: 11, color: '#c9d2df' },
  EditorScratchMeta: { type: 'Text', fontSize: 10, color: '#5d6a7c' },

  // Syntax tokens
  TokenText: { type: 'Text', fontSize: 13, color: '#c9d2df', fontFamily: 'monospace' },
  TokenKeyword: { type: 'Text', fontSize: 13, color: '#ff7b72', fontFamily: 'monospace' },
  TokenString: { type: 'Text', fontSize: 13, color: '#a5d6ff', fontFamily: 'monospace' },
  TokenComment: { type: 'Text', fontSize: 13, color: '#5d6a7c', fontFamily: 'monospace' },
  TokenFunction: { type: 'Text', fontSize: 13, color: '#d2a8ff', fontFamily: 'monospace' },
  TokenNumber: { type: 'Text', fontSize: 13, color: '#79c0ff', fontFamily: 'monospace' },
  TokenType: { type: 'Text', fontSize: 13, color: '#ffa657', fontFamily: 'monospace' },
  TokenVariable: { type: 'Text', fontSize: 13, color: '#d2dae8', fontFamily: 'monospace' },
  TokenOperator: { type: 'Text', fontSize: 13, color: '#ffb86b', fontFamily: 'monospace' },
  TokenTag: { type: 'Text', fontSize: 13, color: '#7ee787', fontFamily: 'monospace' },
  TokenAttr: { type: 'Text', fontSize: 13, color: '#79c0ff', fontFamily: 'monospace' },

  // === CHAT PANEL ===
  ChatPanel: { type: 'Box', style: { width: 420, flexDirection: 'column', backgroundColor: '#0c1016', borderLeftWidth: 1, borderColor: '#171d26' } },
  ChatHeader: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', paddingLeft: 14, paddingRight: 14, paddingTop: 12, paddingBottom: 12, borderBottomWidth: 1, borderColor: '#171d26' } },
  ChatHeaderLeft: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 10 } },
  ChatTitle: { type: 'Text', fontSize: 13, color: '#eef2f8', bold: true },
  ChatModelBadge: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 5, paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: '#10151d', borderRadius: 999, borderWidth: 1, borderColor: '#1f2935' } },
  ChatModelDot: { type: 'Box', style: { width: 6, height: 6, borderRadius: 3, backgroundColor: '#ff7b72' } },
  ChatModelLabel: { type: 'Text', fontSize: 10, color: '#c9d2df' },
  ChatActions: { type: 'Box', style: { flexDirection: 'row', gap: 8 } },
  ChatActionBtn: { type: 'Pressable', style: { paddingLeft: 10, paddingRight: 10, paddingTop: 6, paddingBottom: 6, backgroundColor: '#10151d', borderRadius: 8, borderWidth: 1, borderColor: '#1f2935' } },
  ChatActionLabel: { type: 'Text', fontSize: 10, color: '#c9d2df' },
  ChatContextStrip: { type: 'Box', style: { flexDirection: 'row', gap: 8, flexWrap: 'wrap', paddingLeft: 14, paddingRight: 14, paddingTop: 10, paddingBottom: 10, borderBottomWidth: 1, borderColor: '#171d26', backgroundColor: '#0f141c' } },
  ChatContextChip: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 6, paddingLeft: 8, paddingRight: 8, paddingTop: 5, paddingBottom: 5, backgroundColor: '#10151d', borderRadius: 999, borderWidth: 1, borderColor: '#1f2935' } },
  ChatContextChipLabel: { type: 'Text', fontSize: 9, color: '#5d6a7c' },
  ChatContextChipValue: { type: 'Text', fontSize: 10, color: '#c9d2df' },
  ChatMessages: { type: 'ScrollView', style: { flexGrow: 1, flexBasis: 0 } },
  ChatStack: { type: 'Box', style: { flexDirection: 'column', padding: 14, gap: 14 } },
  ChatWelcome: { type: 'Box', style: { flexDirection: 'column', gap: 4, padding: 12, backgroundColor: '#10151d', borderRadius: 12, borderWidth: 1, borderColor: '#1f2935' } },
  ChatWelcomeTitle: { type: 'Text', fontSize: 12, color: '#eef2f8', bold: true },
  ChatWelcomeText: { type: 'Text', fontSize: 11, color: '#7f8a99' },

  Message: { type: 'Box', style: { flexDirection: 'column', gap: 8 } },
  MessageHeader: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 8 } },
  MessageAvatar: { type: 'Box', style: { width: 24, height: 24, borderRadius: 12, alignItems: 'center', justifyContent: 'center' } },
  MessageAvatarText: { type: 'Text', fontSize: 10, color: '#eef2f8' },
  MessageAuthor: { type: 'Text', fontSize: 11, color: '#eef2f8', bold: true },
  MessageTime: { type: 'Text', fontSize: 10, color: '#5d6a7c' },
  MessageModeBadge: { type: 'Box', style: { paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2, backgroundColor: '#182510', borderRadius: 999 } },
  MessageModeText: { type: 'Text', fontSize: 9, color: '#7ee787' },
  MessageModelBadge: { type: 'Box', style: { paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2, backgroundColor: '#10151d', borderRadius: 999 } },
  MessageModelText: { type: 'Text', fontSize: 9, color: '#79c0ff' },
  MessageBubble: { type: 'Box', style: { flexDirection: 'column', gap: 8, padding: 12, borderRadius: 12, borderWidth: 1 } },
  MessageText: { type: 'Text', fontSize: 12, color: '#d4dbe7', lineHeight: 18 },
  MessageToolList: { type: 'Box', style: { flexDirection: 'column', gap: 6 } },
  ContextBar: { type: 'Box', style: { flexDirection: 'row', gap: 6, flexWrap: 'wrap' } },
  ContextChip: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 4, paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: '#0f141c', borderRadius: 999, borderWidth: 1, borderColor: '#1f2935' } },
  ContextChipFile: { type: 'Text', fontSize: 10, color: '#79c0ff' },

  ToolCallCard: { type: 'Box', style: { flexDirection: 'column', gap: 5, padding: 10, backgroundColor: '#0f141c', borderRadius: 10, borderWidth: 1, borderColor: '#1f2935' } },
  ToolCallHeader: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 8 } },
  ToolCallName: { type: 'Text', fontSize: 10, color: '#eef2f8', bold: true },
  ToolCallInput: { type: 'Text', fontSize: 10, color: '#5d6a7c', flexGrow: 1, flexBasis: 0 },
  ToolCallStatus: { type: 'Text', fontSize: 10 },
  ToolCallOutput: { type: 'Box', style: { backgroundColor: '#0b0f15', borderRadius: 8, padding: 8 } },
  ToolCallOutputText: { type: 'Text', fontSize: 10, color: '#9db1c9', fontFamily: 'monospace' },
  ToolFeed: { type: 'Box', style: { flexDirection: 'column', gap: 6, paddingLeft: 30 } },
  ToolFeedLabel: { type: 'Text', fontSize: 10, color: '#5d6a7c' },

  SessionBanner: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 8, paddingLeft: 14, paddingRight: 14, paddingTop: 8, paddingBottom: 8, backgroundColor: '#0f141c', borderBottomWidth: 1, borderColor: '#171d26' } },
  SessionBannerDot: { type: 'Box', style: { width: 7, height: 7, borderRadius: 4 } },
  SessionBannerText: { type: 'Text', fontSize: 11, color: '#9db1c9', flexGrow: 1, flexBasis: 0 },
  SessionBannerStop: { type: 'Pressable', style: { paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: '#341316', borderRadius: 8, borderWidth: 1, borderColor: '#5a1f24' } },
  SessionBannerStopText: { type: 'Text', fontSize: 10, color: '#ff7b72' },

  ThinkingRow: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', gap: 8, paddingLeft: 32 } },
  ThinkingAvatar: { type: 'Box', style: { width: 24, height: 24, borderRadius: 12, backgroundColor: '#17345d', alignItems: 'center', justifyContent: 'center' } },
  ThinkingAvatarText: { type: 'Text', fontSize: 10, color: '#eef2f8' },
  ThinkingBubble: { type: 'Box', style: { flexDirection: 'row', gap: 4, paddingLeft: 10, paddingRight: 10, paddingTop: 7, paddingBottom: 7, backgroundColor: '#10151d', borderRadius: 999, borderWidth: 1, borderColor: '#1f2935' } },
  ThinkingDot: { type: 'Box', style: { width: 5, height: 5, borderRadius: 3, backgroundColor: '#2d62ff' } },
  ThinkingLabel: { type: 'Text', fontSize: 10, color: '#5d6a7c' },

  ChatInputArea: { type: 'Box', style: { flexDirection: 'column', gap: 8, padding: 12, borderTopWidth: 1, borderColor: '#171d26', backgroundColor: '#0b0f15' } },
  ModePillBar: { type: 'Box', style: { flexDirection: 'row', gap: 6, flexWrap: 'wrap' } },
  ModePill: { type: 'Pressable', style: { paddingLeft: 10, paddingRight: 10, paddingTop: 5, paddingBottom: 5, backgroundColor: '#10151d', borderRadius: 999, borderWidth: 1, borderColor: '#1f2935' } },
  ModePillLabel: { type: 'Text', fontSize: 10, color: '#7f8a99' },
  ChatInputBox: { type: 'Box', style: { flexDirection: 'column', gap: 8, padding: 10, backgroundColor: '#0f141c', borderRadius: 12, borderWidth: 1, borderColor: '#1f2935' } },
  ChatComposerSummary: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', gap: 8 } },
  ChatComposerContext: { type: 'Text', fontSize: 11, color: '#c9d2df' },
