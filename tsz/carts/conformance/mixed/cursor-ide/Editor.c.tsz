// Editor Component — code editor with gutter, active line, cursor tracking, minimap
// Built entirely from primitives around a TextInput — no framework changes needed.
// Inspired by love2d MonacoMirror: Input handles editing, everything else is chrome.

function GutterLine(props) {
  var isActive = props.isActive == 1;
  return (
    <Box style={{ height: 20, flexDirection: 'row', alignItems: 'center', justifyContent: 'flex-end', paddingRight: 12, paddingLeft: 8, backgroundColor: isActive ? '#1a1a1a' : '#0d0d0d' }}>
      <Text fontSize={12} color={isActive ? '#c0c0c0' : '#3d3d3d'}>{props.num}</Text>
    </Box>
  );
}

function MinimapLine(props) {
  var len = props.len || 1;
  var pct = Math.min(100, Math.max(8, len * 2));
  var isActive = props.isActive == 1;
  return (
    <Box style={{ height: 2, marginBottom: 1, flexDirection: 'row' }}>
      <Box style={{ width: pct + '%', height: 2, borderRadius: 1, backgroundColor: isActive ? '#2d62ff40' : '#2a2a2a' }} />
    </Box>
  );
}

function Editor(props) {
  var cursorLine = props.cursorLine || 1;
  var isModified = props.modified == 1;

  return (
    <Box style={{ flexGrow: 1, flexBasis: 0, flexDirection: 'row', backgroundColor: '#0d0d0d' }}>
      {/* === LINE NUMBER GUTTER === */}
      <Box style={{ width: 52, flexDirection: 'column', paddingTop: 4, backgroundColor: '#0d0d0d', borderRightWidth: 1, borderColor: '#1a1a1a' }}>
        <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
          <Box style={{ flexDirection: 'column' }}>
            {props.lineNumbers.map(function(line, idx) {
              return (
                <GutterLine num={line.num} isActive={idx + 1 == cursorLine ? 1 : 0} />
              );
            })}
          </Box>
        </ScrollView>
        {/* Gutter footer: total line count */}
        <Box style={{ height: 20, alignItems: 'center', justifyContent: 'center', borderTopWidth: 1, borderColor: '#1a1a1a' }}>
          <Text fontSize={9} color="#3d3d3d">{props.totalLines}</Text>
        </Box>
      </Box>

      {/* === EDITOR BODY === */}
      <Box style={{ flexGrow: 1, flexBasis: 0, flexDirection: 'column' }}>
        {/* Active line highlight bar */}
        <Box style={{ flexGrow: 1, flexBasis: 0, flexDirection: 'row' }}>
          <Box style={{ flexGrow: 1, flexBasis: 0 }}>
            <TextInput
              value={props.content}
              onChange={function(v) { updateEditorContent(v); }}
              multiline={1}
              fontSize={13}
              color="#b0b0b0"
              style={{ flexGrow: 1, flexBasis: 0, paddingTop: 4, paddingLeft: 12, paddingRight: 12, paddingBottom: 8, backgroundColor: '#0d0d0d' }}
            />
          </Box>

          {/* === MINIMAP === */}
          <Box style={{ width: 60, flexDirection: 'column', paddingTop: 4, paddingRight: 4, paddingLeft: 4, backgroundColor: '#0d0d0d', borderLeftWidth: 1, borderColor: '#1a1a1a' }}>
            {/* Viewport indicator */}
            <Box style={{ height: 4, borderRadius: 2, backgroundColor: '#ffffff08', marginBottom: 4 }} />
            <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
              <Box style={{ flexDirection: 'column' }}>
                {props.lineNumbers.map(function(line, idx) {
                  return (
                    <MinimapLine len={20 + idx * 3 % 40} isActive={idx + 1 == cursorLine ? 1 : 0} />
                  );
                })}
              </Box>
            </ScrollView>
          </Box>
        </Box>

        {/* Editor footer: cursor position + modified indicator */}
        <Box style={{ height: 22, flexDirection: 'row', alignItems: 'center', paddingLeft: 12, paddingRight: 12, borderTopWidth: 1, borderColor: '#1a1a1a', backgroundColor: '#0d0d0d' }}>
          <Text fontSize={10} color="#4a4a4a">Ln {cursorLine}</Text>
          <Box style={{ width: 1, height: 10, backgroundColor: '#1f1f1f', marginLeft: 8, marginRight: 8 }} />
          <Text fontSize={10} color="#4a4a4a">{props.totalLines} lines</Text>
          {isModified && (
            <Box style={{ marginLeft: 8 }}>
              <Text fontSize={10} color="#e6b450">modified</Text>
            </Box>
          )}
          <Box style={{ flexGrow: 1 }} />
          <Text fontSize={10} color="#3d3d3d">UTF-8 LF</Text>
        </Box>
      </Box>
    </Box>
  );
}

export { Editor };
