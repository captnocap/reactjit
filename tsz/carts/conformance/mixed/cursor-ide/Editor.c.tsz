// Editor Component — code editor with gutter, minimap, cursor position
// No local vars in JSX ternaries (compiler drops them in lua-tree)

function GutterLine(props) {
  return (
    <Box style={{ height: 20, flexDirection: 'row', alignItems: 'center', justifyContent: 'flex-end', paddingRight: 12, paddingLeft: 8 }}>
      <Text fontSize={12} color={props.isActive == 1 ? '#c0c0c0' : '#3d3d3d'}>{props.num}</Text>
    </Box>
  );
}

function Editor(props) {
  return (
    <Box style={{ flexGrow: 1, flexBasis: 0, flexDirection: 'row', backgroundColor: '#111111' }}>
      {/* === LINE NUMBER GUTTER === */}
      <Box style={{ width: 52, flexDirection: 'column', paddingTop: 4, backgroundColor: '#141414', borderRightWidth: 1, borderColor: '#1f1f1f' }}>
        <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
          <Box style={{ flexDirection: 'column' }}>
            {props.lineNumbers.map(function(line, idx) {
              return (
                <GutterLine num={line.num} isActive={idx + 1 == props.cursorLine ? 1 : 0} />
              );
            })}
          </Box>
        </ScrollView>
        <Box style={{ height: 20, alignItems: 'center', justifyContent: 'center', borderTopWidth: 1, borderColor: '#1f1f1f' }}>
          <Text fontSize={9} color="#3d3d3d">{props.totalLines}</Text>
        </Box>
      </Box>

      {/* === EDITOR BODY === */}
      <Box style={{ flexGrow: 1, flexBasis: 0, flexDirection: 'column' }}>
        <Box style={{ flexGrow: 1, flexBasis: 0, flexDirection: 'row' }}>
          <Box style={{ flexGrow: 1, flexBasis: 0 }}>
            <TextInput
              value={props.content}
              onChange={function(v) { updateEditorContent(v); }}
              multiline={1}
              fontSize={13}
              color="#b0b0b0"
              style={{ flexGrow: 1, flexBasis: 0, paddingTop: 4, paddingLeft: 12, paddingRight: 12, paddingBottom: 8, backgroundColor: '#111111' }}
            />
          </Box>

          {/* === MINIMAP === */}
          <Box style={{ width: 54, flexDirection: 'column', paddingTop: 4, paddingRight: 4, paddingLeft: 4, backgroundColor: '#111111', borderLeftWidth: 1, borderColor: '#1a1a1a' }}>
            <Box style={{ height: 4, borderRadius: 2, backgroundColor: '#ffffff08', marginBottom: 4 }} />
            <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
              <Box style={{ flexDirection: 'column' }}>
                {props.lineNumbers.map(function(line, idx) {
                  return (
                    <Box style={{ height: 2, marginBottom: 1, flexDirection: 'row' }}>
                      <Box style={{ height: 2, borderRadius: 1, backgroundColor: '#2a2a2a', width: '50%' }} />
                    </Box>
                  );
                })}
              </Box>
            </ScrollView>
          </Box>
        </Box>

        {/* Editor footer */}
        <Box style={{ height: 22, flexDirection: 'row', alignItems: 'center', paddingLeft: 12, paddingRight: 12, borderTopWidth: 1, borderColor: '#1f1f1f', backgroundColor: '#111111' }}>
          <Text fontSize={10} color="#4a4a4a">Ln {props.cursorLine}</Text>
          <Box style={{ width: 1, height: 10, backgroundColor: '#1f1f1f', marginLeft: 8, marginRight: 8 }} />
          <Text fontSize={10} color="#4a4a4a">{props.totalLines} lines</Text>
          {props.modified == 1 && (
            <Box style={{ marginLeft: 8 }}>
              <Text fontSize={10} color="#e6b450">modified</Text>
            </Box>
          )}
          <Box style={{ flexGrow: 1 }} />
          <Text fontSize={10} color="#3d3d3d">UTF-8 LF</Text>
        </Box>
      </Box>
    </Box>
  );
}

export { Editor };
