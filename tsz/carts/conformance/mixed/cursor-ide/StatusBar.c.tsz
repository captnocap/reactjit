// StatusBar — git health, cursor, file mode, and agent context

function StatusBar(props) {
  return (
    <C.StatusBar>
      <C.StatusLeft>
        <C.StatusBranch>
          <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: '#7ee787' }} />
          <C.StatusTextHighlight>{props.gitBranch}</C.StatusTextHighlight>
          <C.StatusText>{props.gitRemote}</C.StatusText>
        </C.StatusBranch>

        <C.StatusSeparator />

        <C.StatusItem>
          <C.StatusText>{'dirty ' + props.changedCount}</C.StatusText>
          <C.StatusText>{'staged ' + props.stagedCount}</C.StatusText>
          <C.StatusText>{'+' + props.branchAhead + ' / -' + props.branchBehind}</C.StatusText>
        </C.StatusItem>

        <C.StatusSeparator />

        <C.StatusItem>
          <C.StatusText>{'Ln ' + props.cursorLine}</C.StatusText>
          <C.StatusText>{'Col ' + props.cursorColumn}</C.StatusText>
        </C.StatusItem>
      </C.StatusLeft>

      <C.StatusRight>
        <C.StatusItem>
          {props.fileName == '__landing__' && <C.StatusText>{props.workDir}</C.StatusText>}
          {props.fileName != '__landing__' && <C.StatusText>{props.fileName}</C.StatusText>}
        </C.StatusItem>

        <C.StatusSeparator />

        <C.StatusItem>
          <C.StatusText>{props.languageMode}</C.StatusText>
        </C.StatusItem>

        <C.StatusSeparator />

        <C.StatusItem>
          <C.StatusText>{props.selectedModel}</C.StatusText>
          <C.StatusText>{props.agentStatusText}</C.StatusText>
        </C.StatusItem>
      </C.StatusRight>
    </C.StatusBar>
  );
}

export { StatusBar };
