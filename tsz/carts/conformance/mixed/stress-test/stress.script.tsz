// Stress-everything script: progressive load ramp
// Starts mild, increases pressure every 2 seconds across all subsystems

let _tick = 0;
let _level = 1;
let _maxLevel = 10;
let _items = [];
let _colors = [0x3b82f6, 0x22c55e, 0xf59e0b, 0xef4444, 0x8b5cf6, 0xec4899, 0x14b8a6, 0xf97316];

// Build item array for current level
function rebuildItems() {
  let count = _level * 25;
  _items = [];
  for (let i = 0; i < count; i++) {
    _items.push({
      label: 'N' + i,
      value: i,
      color: _colors[i % 8]
    });
  }
  setMapItems(_items);
  setItemCount(count);
}

// Rapid state mutation — slams N state slots per tick
function slamStates() {
  _tick++;
  let v = _tick;
  setS0(v);
  setS1(v * 2);
  setS2(v * 3);
  setS3(v * 4);
  setS4(v * 5);
  setS5(v * 6);
  setS6(v * 7);
  setS7(v * 8);

  if (_level > 2) {
    setS8(v * 9);
    setS9(v * 10);
    setS10(v * 11);
    setS11(v * 12);
  }
  if (_level > 4) {
    setS12(v * 13);
    setS13(v * 14);
    setS14(v * 15);
    setS15(v * 16);
  }
  if (_level > 6) {
    setS16(v * 17);
    setS17(v * 18);
    setS18(v * 19);
    setS19(v * 20);
  }
  if (_level > 8) {
    setS20(v * 21);
    setS21(v * 22);
    setS22(v * 23);
    setS23(v * 24);
  }

  setFrameCount(_tick);

  // Style cycling: rotate background hue
  let hueSlot = (_tick % 8);
  setStyleCycle(hueSlot);

  // Conditional toggle: flip visibility every N frames based on level
  let flipRate = 11 - _level;
  if (flipRate > 0) {
    setShowExtra(_tick % flipRate !== 0 ? 1 : 0);
  }
}

// Level ramp: every 2 seconds, increase pressure
setInterval(function() {
  if (_level > _maxLevel - 1) return;
  _level++;
  setLevel(_level);
  rebuildItems();
  console.log('STRESS LEVEL ' + _level + '/10 — ' + (_level * 25) + ' map items, ' + (8 + Math.min(_level - 1, 4) * 4) + ' state slots');
}, 2000);

// State mutation at ~60fps
setInterval(slamStates, 16);

// Telemetry at 4Hz
setInterval(function() {
  setFps(getFps());
  setTickUs(getTickUs());
  setLayoutUs(getLayoutUs());
  setPaintUs(getPaintUs());
}, 250);

// Init
rebuildItems();
slamStates();
console.log('Stress-everything loaded. Level 1/10.');
