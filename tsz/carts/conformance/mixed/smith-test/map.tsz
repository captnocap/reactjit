const [items, setItems] = useState([{ label: '', color: 0x000000 }]);

import { map_data } from "./map.script";

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1a1a2e', padding: 16, gap: 8 }}>
      <Text fontSize={24} color="#ffffff">Items</Text>
      {items.map((item, i) => (
        <Box style={{ padding: 12, backgroundColor: '#0f3460', borderRadius: 8, flexDirection: 'row', gap: 8, alignItems: 'center' }}>
          <Text color="#ffffff">{item.label}</Text>
          <Text fontSize={10} color="#888888">{`#${i}`}</Text>
        </Box>
      ))}
    </Box>
  );
}
