const [mode, setMode] = useState(0);

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1a1a2e', justifyContent: 'center', alignItems: 'center', gap: 16 }}>
      <Pressable onPress={() => { setMode(mode == 0 ? 1 : 0) }} style={{ padding: 16, backgroundColor: '#e94560', borderRadius: 8 }}>
        <Text color="#ffffff">Toggle</Text>
      </Pressable>
      {mode == 0 && <Box style={{ padding: 20, backgroundColor: '#0f3460', borderRadius: 8 }}>
        <Text color="#ffffff">Mode A</Text>
      </Box>}
      {mode != 0 && <Box style={{ padding: 20, backgroundColor: '#533483', borderRadius: 8 }}>
        <Text color="#ffffff">Mode B</Text>
      </Box>}
    </Box>
  );
}
