function App() {
  const [count, setCount] = useState(0);

  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1e1e1e', flexDirection: 'column', justifyContent: 'center', alignItems: 'center', gap: 16 }}>
      <Text style={{ fontSize: 32 }}>{count}</Text>
      <Box style={{ flexDirection: 'row', gap: 8 }}>
        <Pressable onPress={() => setCount(count - 1)} style={{ padding: 16, backgroundColor: '#ff4444', borderRadius: 8 }}>
          <Text>-</Text>
        </Pressable>
        <Pressable onPress={() => setCount(0)} style={{ padding: 16, backgroundColor: '#888888', borderRadius: 8 }}>
          <Text>Reset</Text>
        </Pressable>
        <Pressable onPress={() => setCount(count + 1)} style={{ padding: 16, backgroundColor: '#4488ff', borderRadius: 8 }}>
          <Text>+</Text>
        </Pressable>
      </Box>
    </Box>
  );
}
