// Test cart: process spawning diagnostic
// Press buttons to test different spawn mechanisms and see what happens.

<script>
var _spawnLog = [];
var _logCounter = 0;

function addLog(msg) {
  _logCounter++;
  _spawnLog.push({ id: _logCounter, text: msg });
  if (_spawnLog.length > 20) _spawnLog = _spawnLog.slice(-20);
  setLogLines(_spawnLog);
  setLogCount(_spawnLog.length);
}

function testSpawnSelf() {
  addLog('--- spawn_self test ---');
  addLog('Calling __spawn_self()...');
  var pid = __spawn_self();
  addLog('Result PID: ' + pid);
  if (pid > 0) {
    addLog('SUCCESS: child spawned with PID ' + pid);
  } else {
    addLog('FAILED: __spawn_self returned ' + pid);
  }
}

function testExecEcho() {
  addLog('--- exec echo test ---');
  var out = __exec('echo hello from child');
  addLog('Output: ' + (out || '(empty)'));
}

function testExecBg() {
  addLog('--- exec background test ---');
  var out = __exec('sleep 2 & echo spawned $!');
  addLog('Output: ' + (out || '(empty)'));
}

function testInspectPaths() {
  addLog('--- inspect paths test ---');
  var appDir = __get_app_dir();
  addLog('App dir: ' + appDir);
  var runPath = __get_run_path();
  addLog('Run path: ' + runPath);
  var runExists = __exec('test -f "' + runPath + '" && echo YES || echo NO');
  addLog('Run wrapper exists: ' + (runExists ? runExists.trim() : '(unknown)'));
  var appBinExists = __exec('test -f "' + appDir + 'app.bin" && echo YES || echo NO');
  addLog('app.bin exists: ' + (appBinExists ? appBinExists.trim() : '(unknown)'));
  var ls = __exec('ls -la "' + appDir + '" 2>&1');
  if (ls) {
    var lines = ls.split('\n');
    for (var i = 0; i < lines.length; i++) {
      if (lines[i].length > 0) addLog('  ' + lines[i]);
    }
  }
}

function testExecFork() {
  addLog('--- exec fork test ---');
  var runPath = __get_run_path();
  addLog('Run path: ' + runPath);
  var exists = __exec('test -f "' + runPath + '" && echo YES || echo NO');
  if (exists && exists.trim() === 'YES') {
    addLog('Launching: nohup ' + runPath + ' &');
    var out = __exec('nohup "' + runPath + '" </dev/null >/dev/null 2>&1 & echo PID=$!');
    addLog('Result: ' + (out ? out.trim() : '(empty)'));
  } else {
    addLog('FAILED: run wrapper not found at ' + runPath);
  }
}

addLog('Spawn test cart loaded');
addLog('Press buttons to test each spawn method');
</script>

const [logLines, setLogLines] = useState([{ id: 0, text: '' }]);
const [logCount, setLogCount] = useState(0);

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0d1117', padding: 16 }}>
      <Text fontSize={24} color="#58a6ff">Process Spawn Test</Text>
      <Text fontSize={14} color="#8b949e" style={{ marginTop: 4 }}>Tests whether we can spawn child processes from a running app</Text>

      <Box style={{ flexDirection: 'row', gap: 8, marginTop: 16, flexWrap: 'wrap' }}>
        <Pressable onPress={testSpawnSelf} style={{ padding: 12, backgroundColor: '#238636', borderRadius: 6 }}>
          <Text fontSize={14} color="#ffffff">1. spawn_self()</Text>
        </Pressable>

        <Pressable onPress={testExecEcho} style={{ padding: 12, backgroundColor: '#1f6feb', borderRadius: 6 }}>
          <Text fontSize={14} color="#ffffff">2. exec echo</Text>
        </Pressable>

        <Pressable onPress={testExecBg} style={{ padding: 12, backgroundColor: '#1f6feb', borderRadius: 6 }}>
          <Text fontSize={14} color="#ffffff">3. exec bg</Text>
        </Pressable>

        <Pressable onPress={testInspectPaths} style={{ padding: 12, backgroundColor: '#da3633', borderRadius: 6 }}>
          <Text fontSize={14} color="#ffffff">4. inspect paths</Text>
        </Pressable>

        <Pressable onPress={testExecFork} style={{ padding: 12, backgroundColor: '#da3633', borderRadius: 6 }}>
          <Text fontSize={14} color="#ffffff">5. exec fork</Text>
        </Pressable>
      </Box>

      <Box style={{ flexGrow: 1, backgroundColor: '#161b22', borderRadius: 8, marginTop: 16, padding: 12, overflow: 'scroll' }}>
        <Text fontSize={12} color="#484f58">{`Log (${logCount} entries)`}</Text>
        {logLines.map((line) => (
          <Text key={line.id} fontSize={13} color="#c9d1d9" style={{ marginTop: 2 }}>{line.text}</Text>
        ))}
      </Box>
    </Box>
  );
}
