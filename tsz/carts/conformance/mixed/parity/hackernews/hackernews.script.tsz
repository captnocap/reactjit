    { rank: 30, title: 'The joy of building things nobody needs', points: 87, author: 'hobbyist', timeAgo: '1 day ago', comments: 145, domain: 'blog.jvns.ca' }
  ];

  var sl = [];
  for (var i = 0; stories.length > i; i = i + 1) {
    var s = stories[i];
    var meta = s.points + ' points by ' + s.author + ' ' + s.timeAgo;
    var commentLabel = s.comments + ' comments';
    if (s.comments === 0) commentLabel = 'discuss';
    sl.push({
      rank: s.rank,
      title: s.title,
      domain: s.domain,
      meta: meta,
      commentLabel: commentLabel,
      points: s.points
    });
  }
  setStories(sl);
  setStoryCount(sl.length);
}

function upvote(idx) {
  // Visual feedback: increment points for the story
  var current = stories;
  if (current.length > idx) {
    var s = current[idx];
    var pts = s.points + 1;
    var parts = s.meta.split(' points');
    var newMeta = pts + ' points' + parts[1];
    current[idx] = {
      rank: s.rank,
      title: s.title,
      domain: s.domain,
      meta: newMeta,
      commentLabel: s.commentLabel,
      points: pts
    };
    setStories(current);
  }
}

loadStories();
