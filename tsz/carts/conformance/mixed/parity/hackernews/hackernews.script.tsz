    { rank: 17, title: 'Firefox 140 ships with native vertical tabs', points: 234, author: 'moz_fan', timeAgo: '7 hours ago', comments: 189, domain: 'mozilla.org' },
    { rank: 18, title: 'GitHub Copilot now generates entire PRs from issue descriptions', points: 223, author: 'natfriedman', timeAgo: '3 hours ago', comments: 312, domain: 'github.blog' },
    { rank: 19, title: 'The hidden costs of microservices nobody talks about', points: 212, author: 'monolith_fan', timeAgo: '16 hours ago', comments: 267, domain: 'blog.pragmaticengineer.com' },
