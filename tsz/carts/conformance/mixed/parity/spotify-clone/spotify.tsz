          </ScrollView>
        </Box>
      </Box>

      <Box style={{ flexDirection: 'row', alignItems: 'center', height: 60, backgroundColor: '#181818', borderColor: '#282828', borderWidth: 1, paddingLeft: 12, paddingRight: 12 }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 10, width: 200 }}>
          <Box style={{ width: 40, height: 40, backgroundColor: '#282828', borderRadius: 4 }} />
