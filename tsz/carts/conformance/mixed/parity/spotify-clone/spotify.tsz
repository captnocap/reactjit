            </Box>
            <Text fontSize={9} color="#b3b3b3">5:55</Text>
          </Box>
        </Box>

        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6, width: 120, justifyContent: 'flexEnd' }}>
          <Text fontSize={9} color="#b3b3b3">Vol</Text>
          <Box style={{ width: 80, height: 4, backgroundColor: '#535353', borderRadius: 2 }}>
            <Box style={{ width: 56, height: 4, backgroundColor: '#1DB954', borderRadius: 2 }} />
