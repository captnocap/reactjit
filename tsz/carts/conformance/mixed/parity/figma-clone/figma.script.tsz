// Figma clone — hardcoded layers + design properties
// Exercises: nested panel layout, .map() over layers, property inspector

var _selectedLayer = 0;
var _zoom = 100;

setInterval(function() {
  setSelectedLayer(_selectedLayer);
  setZoom(_zoom);
}, 100);

function zoomIn() {
  _zoom = _zoom + 25;
  if (_zoom > 400) _zoom = 400;
  setZoom(_zoom);
}

function zoomOut() {
  _zoom = _zoom - 25;
  if (_zoom > 0) _zoom = _zoom;
  else _zoom = 25;
  setZoom(_zoom);
}
