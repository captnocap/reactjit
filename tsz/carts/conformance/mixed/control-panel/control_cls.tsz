  CartActions: { type: 'Box', style: { flexDirection: 'row', gap: 4 } },

  BtnDev: { type: 'Pressable', style: { paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: '#1f6feb', borderRadius: 4 } },
  BtnBuild: { type: 'Pressable', style: { paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: '#238636', borderRadius: 4 } },
  BtnCheck: { type: 'Pressable', style: { paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: '#9e6a03', borderRadius: 4 } },
  BtnStop: { type: 'Pressable', style: { paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: '#da3633', borderRadius: 4 } },
  BtnCompiler: { type: 'Pressable', style: { paddingLeft: 10, paddingRight: 10, paddingTop: 6, paddingBottom: 6, backgroundColor: '#30363d', borderRadius: 4, borderWidth: 1, borderColor: '#484f58' } },
