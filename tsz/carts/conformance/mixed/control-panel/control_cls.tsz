  ProcName: { type: 'Text', fontSize: 11, color: '#3fb950' },
  ProcPid: { type: 'Text', fontSize: 9, color: '#484f58' },

  LogPanel: { type: 'Box', style: { flexDirection: 'column', backgroundColor: '#161b22', borderColor: '#30363d', borderWidth: 1, gap: 0 } },
