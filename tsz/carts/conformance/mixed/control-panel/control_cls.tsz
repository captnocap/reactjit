classifier({
  Shell: { type: 'Box', style: { flexDirection: 'column', width: '100%', height: '100%', backgroundColor: '#0d1117' } },

  Header: { type: 'Box', style: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', paddingLeft: 16, paddingRight: 16, paddingTop: 10, paddingBottom: 10, backgroundColor: '#161b22', borderColor: '#30363d', borderWidth: 1 } },
  Title: { type: 'Text', fontSize: 14, color: '#58a6ff' },
