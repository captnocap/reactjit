// Semantic Terminal — structured data layer for CLI output.
// Runs a real shell via <Terminal>, classifies every row into semantic
// tokens (prompt, command, output, error, tool, thinking, etc.) and
// exposes that structure in sidebars. Any CLI piped through here
// becomes machine-readable structured data.
//
// Pipeline: PTY → vterm → classifier → semantic graph → this UI
// Port of: love2d/lua/capabilities/semantic_terminal.lua

const [modeName, setModeName] = useState('idle');
const [streaming, setStreaming] = useState(0);
const [turnCount, setTurnCount] = useState(0);
const [nodeCount, setNodeCount] = useState(0);
const [cacheCount, setCacheCount] = useState(0);
const [semFrame, setSemFrame] = useState(0);
const [classMode, setClassMode] = useState(0);
const [streamKind, setStreamKind] = useState('output');
const [awaitInput, setAwaitInput] = useState(0);
const [showTree, setShowTree] = useState(0);
const [treeText, setTreeText] = useState('(no graph yet)');
const [showTokens, setShowTokens] = useState(0);
const [showDebug, setShowDebug] = useState(0);
const [recording, setRecording] = useState(0);
const [recFrames, setRecFrames] = useState(0);
const [showPlayback, setShowPlayback] = useState(0);
const [playPlaying, setPlayPlaying] = useState(0);
const [playProgress, setPlayProgress] = useState(0);
const [playFrame, setPlayFrame] = useState(0);
const [playTotal, setPlayTotal] = useState(0);
const [playSpeed, setPlaySpeed] = useState(1);
const [playAtEnd, setPlayAtEnd] = useState(0);

// Status line info
const [debugLine1, setDebugLine1] = useState('');
const [debugLine2, setDebugLine2] = useState('');
const [debugLine3, setDebugLine3] = useState('');

// 15 classified rows: kind + text
const [k0, setK0] = useState('');
const [t0, setT0] = useState('');
const [k1, setK1] = useState('');
const [t1, setT1] = useState('');
const [k2, setK2] = useState('');
const [t2, setT2] = useState('');
const [k3, setK3] = useState('');
const [t3, setT3] = useState('');
const [k4, setK4] = useState('');
const [t4, setT4] = useState('');
const [k5, setK5] = useState('');
const [t5, setT5] = useState('');
const [k6, setK6] = useState('');
const [t6, setT6] = useState('');
const [k7, setK7] = useState('');
const [t7, setT7] = useState('');
const [k8, setK8] = useState('');
const [t8, setT8] = useState('');
const [k9, setK9] = useState('');
const [t9, setT9] = useState('');
const [k10, setK10] = useState('');
const [t10, setT10] = useState('');
const [k11, setK11] = useState('');
const [t11, setT11] = useState('');
const [k12, setK12] = useState('');
const [t12, setT12] = useState('');
const [k13, setK13] = useState('');
const [t13, setT13] = useState('');
const [k14, setK14] = useState('');
const [t14, setT14] = useState('');

// Mode color: 0=green(idle), 1=purple(thinking), 2=orange(other)
const [modeColor, setModeColor] = useState(0);

<script>
// Poll semantic state every 200ms
setInterval(function() {
  var s = __sem_state();
  if (!s) return;
  setModeName(s.mode_name);
  setStreaming(s.streaming ? 1 : 0);
  setStreamKind(s.streaming_kind_name);
  setTurnCount(s.turn_count);
  setNodeCount(s.node_count);
  setAwaitInput(s.awaiting_input ? 1 : 0);
  setCacheCount(__sem_cache_count());
  setSemFrame(__sem_frame());

  // Mode color: 0=idle(green), 1=thinking(purple), 2=other(orange)
  if (s.mode_name == 'idle') {
    setModeColor(0);
  } else if (s.mode_name == 'thinking') {
    setModeColor(1);
  } else {
    setModeColor(2);
  }

  // Last 15 classified rows
  var cc = __sem_cache_count();
  var start = cc > 15 ? cc - 15 : 0;
  var sK = [setK0,setK1,setK2,setK3,setK4,setK5,setK6,setK7,setK8,setK9,setK10,setK11,setK12,setK13,setK14];
  var sT = [setT0,setT1,setT2,setT3,setT4,setT5,setT6,setT7,setT8,setT9,setT10,setT11,setT12,setT13,setT14];
  var i = 0;
  while (15 > i) {
    var ci = start + i;
    if (cc > ci) {
      var e = __sem_cache_entry(ci);
      if (e) {
        sK[i](e.kind);
        var txt = e.text;
        if (txt.length > 60) txt = txt.substring(0, 57) + '...';
        sT[i](txt);
      }
    } else {
      sK[i]('');
      sT[i]('');
    }
    i = i + 1;
  }

  // Recording state
  setRecording(__rec_is_recording() ? 1 : 0);
  if (recording) setRecFrames(__rec_frame_count());

  // Playback state
  if (showPlayback) {
    var ps = __play_state();
    if (ps) {
      setPlayPlaying(ps.playing ? 1 : 0);
      setPlayProgress(Math.round(ps.progress * 100));
      setPlayFrame(ps.frame);
      setPlayTotal(ps.total_frames);
      setPlaySpeed(ps.speed);
      setPlayAtEnd(ps.at_end ? 1 : 0);
    }
  }

  // Debug lines
  if (showDebug) {
    setDebugLine1('classifier=' + (classMode == 0 ? 'none' : classMode == 1 ? 'basic' : 'claude_code') + '  cached=' + cc + '  frame=' + __sem_frame());
    setDebugLine2('mode=' + s.mode_name + '  streaming=' + (s.streaming ? 'yes' : 'no') + '  turns=' + s.turn_count + '  nodes=' + s.node_count);
    setDebugLine3('groups=' + s.group_count + '  awaiting_input=' + (s.awaiting_input ? 'yes' : 'no'));
  }
}, 200);

// Poll tree less often
setInterval(function() {
  if (showTree) { setTreeText(__sem_tree()); }
}, 500);

function toggleClassifier() {
  var next = classMode == 0 ? 1 : classMode == 1 ? 2 : 0;
  setClassMode(next);
  __sem_set_mode(next);
}

function toggleTree() {
  setShowTree(showTree ? 0 : 1);
}

function toggleTokens() {
  setShowTokens(showTokens ? 0 : 1);
}

function toggleDebug() {
  setShowDebug(showDebug ? 0 : 1);
}

function toggleRecording() {
  __rec_toggle();
  setRecording(__rec_is_recording() ? 1 : 0);
}

function saveRecording() {
  __rec_save('/tmp/session_' + Date.now() + '.trec');
}

function loadPlayback() {
  // Load from in-memory recorder data
  __rec_stop();
  setRecording(0);
  var ok = __play_load();
  if (ok) setShowPlayback(1);
}

function playToggle() { __play_toggle(); }
function playStepFwd() { __play_step(); }
function playSpeedUp() { __play_speed(playSpeed + 0.5); }
function playSpeedDown() { __play_speed(playSpeed - 0.5); }
function playSeekStart() { __play_seek(0); }
function playSeekEnd() { __play_seek(1); }

function exportBuffer() {
  var rows = __sem_export();
  if (!rows) return;
  var lines = ['-- SemanticTerminal buffer export'];
  lines.push('-- Format: [kind] text');
  var i = 0;
  while (rows.length > i) {
    var r = rows[i];
    lines.push('[' + r.kind + '] ' + r.text);
    i = i + 1;
  }
  __fs_writefile('/tmp/semantic_export_' + Date.now() + '.txt', lines.join('\n'));
}
</script>

function CRow(kind, text) {
  return (
    <Box style={{ flexDirection: 'row', paddingLeft: 4, paddingRight: 4, paddingTop: 1, paddingBottom: 1, alignItems: 'center' }}>
      <Box style={{ backgroundColor: '#334155', borderRadius: 2, paddingLeft: 3, paddingRight: 3, paddingTop: 1, paddingBottom: 1, minWidth: 90 }}>
        <Text fontSize={9} color="#94a3b8">{kind}</Text>
      </Box>
      <Text fontSize={9} color="#94a3b8" style={{ paddingLeft: 4 }}>{text}</Text>
    </Box>
  );
}

function TreePanel() {
  return (
    <Box style={{ flexGrow: 1, backgroundColor: '#0f172a', flexDirection: 'column' }}>
      <Box style={{ paddingLeft: 6, paddingTop: 4, paddingBottom: 4, backgroundColor: '#1e293b' }}>
        <Text fontSize={10} color="#64748b">SEMANTIC GRAPH</Text>
      </Box>
      <ScrollView style={{ flexGrow: 1 }}>
        <Text fontSize={9} color="#94a3b8" style={{ padding: 4 }}>{treeText}</Text>
      </ScrollView>
    </Box>
  );
}

function PlaybackBar() {
  return (
    <Box style={{ backgroundColor: '#0f172a', paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, flexDirection: 'row', alignItems: 'center', gap: 8 }}>
      <Pressable onPress={() => { playSeekStart() }}>
        <Text fontSize={10} color="#94a3b8">|&lt;</Text>
      </Pressable>
      <Pressable onPress={() => { playToggle() }}>
        <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 8, paddingRight: 8, paddingTop: 2, paddingBottom: 2 }}>
          <Text fontSize={10} color="#e2e8f0">{playPlaying ? 'pause' : 'play'}</Text>
        </Box>
      </Pressable>
      <Pressable onPress={() => { playStepFwd() }}>
        <Text fontSize={10} color="#94a3b8">step</Text>
      </Pressable>
      <Pressable onPress={() => { playSeekEnd() }}>
        <Text fontSize={10} color="#94a3b8">&gt;|</Text>
      </Pressable>
      <Box style={{ flexGrow: 1, height: 6, backgroundColor: '#1e293b', borderRadius: 3 }}>
        <Box style={{ width: playProgress, height: 6, backgroundColor: '#60a5fa', borderRadius: 3 }} />
      </Box>
      <Text fontSize={9} color="#64748b">{`${playProgress}%`}</Text>
      <Text fontSize={9} color="#64748b">{`f${playFrame}/${playTotal}`}</Text>
      <Pressable onPress={() => { playSpeedDown() }}>
        <Text fontSize={10} color="#94a3b8">-</Text>
      </Pressable>
      <Text fontSize={9} color="#94a3b8">{`${playSpeed}x`}</Text>
      <Pressable onPress={() => { playSpeedUp() }}>
        <Text fontSize={10} color="#94a3b8">+</Text>
      </Pressable>
    </Box>
  );
}

function DebugFooter() {
  return (
    <Box style={{ backgroundColor: '#0f172a', paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, flexDirection: 'column', gap: 2 }}>
      <Text fontSize={9} color="#eab308">{debugLine1}</Text>
      <Text fontSize={9} color="#eab308">{debugLine2}</Text>
      <Text fontSize={9} color="#eab308">{debugLine3}</Text>
    </Box>
  );
}

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0f172a', flexDirection: 'column' }}>
      <Box style={{ flexDirection: 'row', paddingLeft: 8, paddingRight: 8, paddingTop: 6, paddingBottom: 6, backgroundColor: '#1e293b', alignItems: 'center', gap: 12 }}>
        <Text fontSize={13} color="#e2e8f0" bold>Semantic Terminal</Text>
        <Pressable onPress={() => { toggleClassifier() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#94a3b8">{classMode == 0 ? 'none' : classMode == 1 ? 'basic' : 'claude'}</Text>
          </Box>
        </Pressable>
        <Pressable onPress={() => { toggleTokens() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#94a3b8">{showTokens ? 'hide tokens' : 'tokens'}</Text>
          </Box>
        </Pressable>
        <Pressable onPress={() => { toggleTree() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#94a3b8">{showTree ? 'hide tree' : 'tree'}</Text>
          </Box>
        </Pressable>
        <Pressable onPress={() => { toggleDebug() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#94a3b8">{showDebug ? 'hide debug' : 'debug'}</Text>
          </Box>
        </Pressable>
        <Pressable onPress={() => { toggleRecording() }}>
          <Box style={{ backgroundColor: recording ? '#7f1d1d' : '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color={recording ? '#f87171' : '#94a3b8'}>{recording ? 'REC' : 'rec'}</Text>
          </Box>
        </Pressable>
        {recording == 1 && <Pressable onPress={() => { saveRecording() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#94a3b8">save</Text>
          </Box>
        </Pressable>}
        {recording == 1 && <Text fontSize={9} color="#f87171">{`${recFrames}f`}</Text>}
        <Pressable onPress={() => { exportBuffer() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#94a3b8">export</Text>
          </Box>
        </Pressable>
        {recFrames > 0 && <Pressable onPress={() => { loadPlayback() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#60a5fa">replay</Text>
          </Box>
        </Pressable>}
        <Text fontSize={10} color={modeColor == 0 ? '#4ade80' : modeColor == 1 ? '#a78bfa' : '#f97316'}>{modeName}</Text>
        <Text fontSize={10} color="#64748b">{`t:${turnCount} n:${nodeCount} r:${cacheCount} f:${semFrame}`}</Text>
        {streaming == 1 && <Text fontSize={10} color="#a78bfa">{streamKind}</Text>}
        {awaitInput == 1 && <Text fontSize={10} color="#4ade80">awaiting input</Text>}
      </Box>

      <Box style={{ flexGrow: 1, flexDirection: 'row' }}>
        <Box style={{ flexGrow: 1, flexBasis: 0, flexDirection: 'column' }}>
          <Terminal fontSize={13} style={{ flexGrow: 1 }} />
          {showPlayback == 1 && <PlaybackBar />}
          {showDebug == 1 && <DebugFooter />}
        </Box>

        {showTokens == 1 && <Box style={{ width: 320, backgroundColor: '#0f172a', flexDirection: 'column' }}>
          <Box style={{ paddingLeft: 6, paddingTop: 4, paddingBottom: 4, backgroundColor: '#1e293b' }}>
            <Text fontSize={10} color="#64748b">CLASSIFIED ROWS (last 15)</Text>
          </Box>
          <ScrollView style={{ flexGrow: 1 }}>
            {k0 != '' && <CRow kind={k0} text={t0} />}
            {k1 != '' && <CRow kind={k1} text={t1} />}
            {k2 != '' && <CRow kind={k2} text={t2} />}
            {k3 != '' && <CRow kind={k3} text={t3} />}
            {k4 != '' && <CRow kind={k4} text={t4} />}
            {k5 != '' && <CRow kind={k5} text={t5} />}
            {k6 != '' && <CRow kind={k6} text={t6} />}
            {k7 != '' && <CRow kind={k7} text={t7} />}
            {k8 != '' && <CRow kind={k8} text={t8} />}
            {k9 != '' && <CRow kind={k9} text={t9} />}
            {k10 != '' && <CRow kind={k10} text={t10} />}
            {k11 != '' && <CRow kind={k11} text={t11} />}
            {k12 != '' && <CRow kind={k12} text={t12} />}
            {k13 != '' && <CRow kind={k13} text={t13} />}
            {k14 != '' && <CRow kind={k14} text={t14} />}
          </ScrollView>

          {showTree == 1 && <TreePanel />}
        </Box>}
      </Box>
    </Box>
  );
}
