// CONFORMANCE TEST 125: Command Classifier Pipeline
//
// Ported from: Claude Code BashTool.tsx isSearchOrReadBashCommand()
//
// A terminal command classifier UI. User picks commands from a list,
// the classifier categorizes each into search/read/list/write/dangerous
// using set-membership checks, then renders results with category badges.
//
// Patterns tested:
// - Array-based set membership lookups in script block
// - Multi-flag classification (isSearch, isRead, isList, isWrite, isDangerous)
// - Pipeline parsing: skip operators, skip redirect targets
// - Compound boolean: early return on unknown command in pipeline
// - Conditional badge rendering based on multiple boolean flags
// - Map over classification results with per-item multi-conditional rendering
// - State-driven category counts updated in classify function

const [commands, setCommands] = useState([{ cmd: '', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 }]);
const [selectedCmd, setSelectedCmd] = useState(0);
const [searchCount, setSearchCount] = useState(0);
const [readCount, setReadCount] = useState(0);
const [listCount, setListCount] = useState(0);
const [writeCount, setWriteCount] = useState(0);
const [dangerousCount, setDangerousCount] = useState(0);
const [totalClassified, setTotalClassified] = useState(0);
const [lastResult, setLastResult] = useState('');

<script>
var searchCmds = ['find', 'grep', 'rg', 'ag', 'ack', 'locate', 'which', 'whereis'];
var readCmds = ['cat', 'head', 'tail', 'less', 'more', 'wc', 'stat', 'file', 'strings', 'jq', 'awk', 'cut', 'sort', 'uniq', 'tr'];
var listCmds = ['ls', 'tree', 'du'];
var writeCmds = ['mv', 'cp', 'mkdir', 'touch', 'ln', 'chmod', 'chown'];
var dangerousCmds = ['rm', 'rmdir', 'dd', 'mkfs', 'fdisk'];
var neutralCmds = ['echo', 'printf', 'true', 'false'];
var operators = ['|', '&&', '||', ';', '>', '>>', '>&'];

var cmdList = [
  { cmd: 'grep -r "TODO" src/', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 },
  { cmd: 'cat package.json | jq .name', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 },
  { cmd: 'ls -la && echo done', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 },
  { cmd: 'find . -name *.tsx | wc -l', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 },
  { cmd: 'rm -rf node_modules', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 },
  { cmd: 'cp src/app.ts dist/', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 },
  { cmd: 'echo hello', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 },
  { cmd: 'tree src/ | head -20', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 },
  { cmd: 'rg pattern && ls results/', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 },
  { cmd: 'cat file.txt > output.log', isSearch: 0, isRead: 0, isList: 0, isWrite: 0, isDangerous: 0, classified: 0 }
];
setCommands(cmdList);

function contains(arr, val) {
  for (var i = 0; i < arr.length; i++) {
    if (arr[i] === val) return 1;
  }
  return 0;
}

function classifyCommand(idx) {
  var entry = cmdList[idx];
  var parts = entry.cmd.split(' ');
  var hasSearch = 0;
  var hasRead = 0;
  var hasList = 0;
  var hasWrite = 0;
  var hasDangerous = 0;
  var hasUnknown = 0;
  var skipNext = 0;

  for (var i = 0; i < parts.length; i++) {
    var p = parts[i];
    if (skipNext === 1) { skipNext = 0; continue; }
    if (p === '>' || p === '>>' || p === '>&') { skipNext = 1; continue; }
    if (contains(operators, p) === 1) continue;
    if (p.charAt(0) === '-') continue;
    if (p.indexOf('/') >= 0 || p.indexOf('.') >= 0) continue;
    if (p.indexOf('*') >= 0) continue;
    if (contains(neutralCmds, p) === 1) continue;
    if (contains(searchCmds, p) === 1) { hasSearch = 1; continue; }
    if (contains(readCmds, p) === 1) { hasRead = 1; continue; }
    if (contains(listCmds, p) === 1) { hasList = 1; continue; }
    if (contains(writeCmds, p) === 1) { hasWrite = 1; continue; }
    if (contains(dangerousCmds, p) === 1) { hasDangerous = 1; continue; }
  }

  entry.isSearch = hasSearch;
  entry.isRead = hasRead;
  entry.isList = hasList;
  entry.isWrite = hasWrite;
  entry.isDangerous = hasDangerous;
  entry.classified = 1;
  setCommands(cmdList);

  var sc = 0; var rc = 0; var lc = 0; var wc = 0; var dc = 0; var tc = 0;
  for (var j = 0; j < cmdList.length; j++) {
    if (cmdList[j].classified === 1) {
      tc++;
      if (cmdList[j].isSearch === 1) sc++;
      if (cmdList[j].isRead === 1) rc++;
      if (cmdList[j].isList === 1) lc++;
      if (cmdList[j].isWrite === 1) wc++;
      if (cmdList[j].isDangerous === 1) dc++;
    }
  }
  setSearchCount(sc);
  setReadCount(rc);
  setListCount(lc);
  setWriteCount(wc);
  setDangerousCount(dc);
  setTotalClassified(tc);

  var tags = '';
  if (hasSearch === 1) tags = tags + 'search ';
  if (hasRead === 1) tags = tags + 'read ';
  if (hasList === 1) tags = tags + 'list ';
  if (hasWrite === 1) tags = tags + 'write ';
  if (hasDangerous === 1) tags = tags + 'DANGER ';
  if (tags === '') tags = 'neutral';
  setLastResult(tags);
}

function classifyAll() {
  for (var i = 0; i < cmdList.length; i++) {
    classifyCommand(i);
  }
}
</script>

function CategoryBadge(label, count, color) {
  return (
    <Box style={{ flexDirection: "row", gap: 4, alignItems: "center", padding: 4, backgroundColor: "#1e293b", borderRadius: 4 }}>
      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: color }} />
      <Text fontSize={9} color="#e2e8f0">{label}</Text>
      <Text fontSize={9} color="#64748b">{`${count}`}</Text>
    </Box>
  );
}

function CommandRow(cmd, isSearch, isRead, isList, isWrite, isDangerous, classified, idx) {
  return (
    <Pressable onPress={() => { classifyCommand(idx); setSelectedCmd(idx) }} style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center", padding: 8, backgroundColor: selectedCmd == idx ? "#334155" : "#1e293b", borderRadius: 6 }}>
      <Box style={{ flexGrow: 1, gap: 2 }}>
        <Text fontSize={10} color={isDangerous == 1 ? "#ef4444" : "#e2e8f0"}>{cmd}</Text>
        {classified == 1 && <Box style={{ flexDirection: "row", gap: 4 }}>
          {isSearch == 1 && <Text fontSize={7} color="#3b82f6">SEARCH</Text>}
          {isRead == 1 && <Text fontSize={7} color="#22c55e">READ</Text>}
          {isList == 1 && <Text fontSize={7} color="#a855f7">LIST</Text>}
          {isWrite == 1 && <Text fontSize={7} color="#f59e0b">WRITE</Text>}
          {isDangerous == 1 && <Text fontSize={7} color="#ef4444">DANGEROUS</Text>}
          {isSearch == 0 && isRead == 0 && isList == 0 && isWrite == 0 && isDangerous == 0 && <Text fontSize={7} color="#475569">neutral</Text>}
        </Box>}
        {classified == 0 && <Text fontSize={7} color="#475569">tap to classify</Text>}
      </Box>
      {classified == 1 && <Box style={{ width: 12, height: 12, borderRadius: 6, backgroundColor: isDangerous == 1 ? "#dc2626" : isWrite == 1 ? "#f59e0b" : "#22c55e" }} />}
    </Pressable>
  );
}

function App() {
  return (
    <Box style={{ backgroundColor: "#0f172a", padding: 16, width: "100%", height: "100%", flexDirection: "column", gap: 12 }}>
      <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center" }}>
        <Text fontSize={16} color="#e2e8f0">Command Classifier</Text>
        <Pressable onPress={() => { classifyAll() }} style={{ padding: 6, backgroundColor: "#3b82f6", borderRadius: 4 }}>
          <Text fontSize={9} color="#ffffff">Classify All</Text>
        </Pressable>
      </Box>

      <Box style={{ flexDirection: "row", gap: 6, flexWrap: "wrap" }}>
        <CategoryBadge label="Search" count={searchCount} color="#3b82f6" />
        <CategoryBadge label="Read" count={readCount} color="#22c55e" />
        <CategoryBadge label="List" count={listCount} color="#a855f7" />
        <CategoryBadge label="Write" count={writeCount} color="#f59e0b" />
        <CategoryBadge label="Danger" count={dangerousCount} color="#ef4444" />
      </Box>

      <ScrollView style={{ flexGrow: 1, gap: 4 }}>
        {commands.map((c, i) => (
          <CommandRow cmd={c.cmd} isSearch={c.isSearch} isRead={c.isRead} isList={c.isList} isWrite={c.isWrite} isDangerous={c.isDangerous} classified={c.classified} idx={i} />
        ))}
      </ScrollView>

      <Text fontSize={9} color="#475569">{`${totalClassified}/10 classified · last: ${lastResult}`}</Text>
    </Box>
  );
}
