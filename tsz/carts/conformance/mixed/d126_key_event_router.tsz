// CONFORMANCE TEST 126: Key Event Router
//
// Ported from: Claude Code ScrollKeybindingHandler.tsx
//   shouldClearSelectionOnKey(), selectionFocusMoveForKey(), computeWheelStep()
//
// A keyboard shortcut tester UI. Simulated key events with modifier flags
// are routed through classifier logic to determine the action. The UI shows
// which modifier combinations trigger which behaviors.
//
// Patterns tested:
// - Objects with 8+ boolean fields (key event shape)
// - OR chains across boolean fields: (a || b || c || d || e || f || g || h)
// - Compound modifier checks: isNav && (shift || meta || super)
// - Early return based on boolean flag combinations
// - State object mutation (wheel accel state with 10+ numeric fields)
// - Math.pow, Math.floor, Math.min in computed values
// - Conditional style based on active modifier flags
// - Map over key definitions with per-key multi-conditional badges

const [keys, setKeys] = useState([{ name: '', shift: 0, ctrl: 0, alt: 0, meta: 0, isNav: 0, isWheel: 0 }]);
const [activeKey, setActiveKey] = useState(0);
const [clearSelection, setClearSelection] = useState(0);
const [focusMove, setFocusMove] = useState('');
const [wheelMult, setWheelMult] = useState(0);
const [wheelDir, setWheelDir] = useState(0);
const [wheelTime, setWheelTime] = useState(0);
const [wheelMode, setWheelMode] = useState(0);
const [actionLog, setActionLog] = useState('');
const [logCount, setLogCount] = useState(0);

<script>
var keyDefs = [
  { name: 'A',           shift: 0, ctrl: 0, alt: 0, meta: 0, isNav: 0, isWheel: 0 },
  { name: 'Left',        shift: 0, ctrl: 0, alt: 0, meta: 0, isNav: 1, isWheel: 0 },
  { name: 'Shift+Left',  shift: 1, ctrl: 0, alt: 0, meta: 0, isNav: 1, isWheel: 0 },
  { name: 'Shift+Right', shift: 1, ctrl: 0, alt: 0, meta: 0, isNav: 1, isWheel: 0 },
  { name: 'Shift+Up',    shift: 1, ctrl: 0, alt: 0, meta: 0, isNav: 1, isWheel: 0 },
  { name: 'Shift+Down',  shift: 1, ctrl: 0, alt: 0, meta: 0, isNav: 1, isWheel: 0 },
  { name: 'Shift+Home',  shift: 1, ctrl: 0, alt: 0, meta: 0, isNav: 1, isWheel: 0 },
  { name: 'Shift+End',   shift: 1, ctrl: 0, alt: 0, meta: 0, isNav: 1, isWheel: 0 },
  { name: 'Meta+Left',   shift: 0, ctrl: 0, alt: 0, meta: 1, isNav: 1, isWheel: 0 },
  { name: 'Ctrl+C',      shift: 0, ctrl: 1, alt: 0, meta: 0, isNav: 0, isWheel: 0 },
  { name: 'Alt+Tab',     shift: 0, ctrl: 0, alt: 1, meta: 0, isNav: 0, isWheel: 0 },
  { name: 'WheelUp',     shift: 0, ctrl: 0, alt: 0, meta: 0, isNav: 0, isWheel: 1 },
  { name: 'WheelDown',   shift: 0, ctrl: 0, alt: 0, meta: 0, isNav: 0, isWheel: 1 },
  { name: 'Shift+Meta+Down', shift: 1, ctrl: 0, alt: 0, meta: 1, isNav: 1, isWheel: 0 },
  { name: 'Enter',       shift: 0, ctrl: 0, alt: 0, meta: 0, isNav: 0, isWheel: 0 },
  { name: 'Escape',      shift: 0, ctrl: 0, alt: 0, meta: 0, isNav: 0, isWheel: 0 }
];
setKeys(keyDefs);

// Wheel acceleration state
var wMult = 1;
var wDir = 0;
var wTime = 0;
var wMode = 0;
var halflife = 150;
var step = 5;

function shouldClear(k) {
  if (k.isWheel === 1) return 0;
  if (k.isNav === 1 && (k.shift === 1 || k.meta === 1)) return 0;
  return 1;
}

function getFocusMove(k) {
  if (k.shift === 0 || k.meta === 1) return 'none';
  if (k.name === 'Shift+Left') return 'left';
  if (k.name === 'Shift+Right') return 'right';
  if (k.name === 'Shift+Up') return 'up';
  if (k.name === 'Shift+Down') return 'down';
  if (k.name === 'Shift+Home') return 'lineStart';
  if (k.name === 'Shift+End') return 'lineEnd';
  return 'none';
}

function simulateWheel(dir) {
  var now = wTime + 50;
  var gap = now - wTime;
  wTime = now;
  setWheelTime(now);

  if (dir !== wDir && wDir !== 0) {
    wMult = 1;
    wDir = dir;
    setWheelMult(1);
    setWheelDir(dir);
    return;
  }
  wDir = dir;
  setWheelDir(dir);

  var m = Math.pow(0.5, gap / halflife);
  var cap = 6;
  var next = 1 + (wMult - 1) * m + step * m;
  if (next > cap) next = cap;
  wMult = next;
  var rows = Math.floor(wMult);
  setWheelMult(rows);
}

function routeKey(idx) {
  var k = keyDefs[idx];
  setActiveKey(idx);

  var clears = shouldClear(k);
  setClearSelection(clears);

  var fm = getFocusMove(k);
  setFocusMove(fm);

  if (k.isWheel === 1) {
    var d = k.name === 'WheelUp' ? 1 : -1;
    simulateWheel(d);
  }

  var desc = k.name + ' -> ';
  if (k.isWheel === 1) {
    desc = desc + 'scroll:' + Math.floor(wMult) + 'rows';
  } else if (fm !== 'none') {
    desc = desc + 'select:' + fm;
  } else if (clears === 1) {
    desc = desc + 'clearSelection';
  } else {
    desc = desc + 'passthrough';
  }
  setActionLog(desc);
  setLogCount(logCount + 1);
}
</script>

function ModBadge(label, active) {
  return (
    <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 1, paddingBottom: 1, borderRadius: 3, backgroundColor: active == 1 ? "#3b82f6" : "#1e293b" }}>
      <Text fontSize={7} color={active == 1 ? "#ffffff" : "#475569"}>{label}</Text>
    </Box>
  );
}

function ActionBadge(action) {
  return (
    <Box style={{ paddingLeft: 5, paddingRight: 5, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: action === "clearSelection" ? "#dc2626" : action === "passthrough" ? "#334155" : "#22c55e" }}>
      <Text fontSize={8} color="#ffffff">{action}</Text>
    </Box>
  );
}

function KeyRow(k, idx) {
  return (
    <Pressable onPress={() => { routeKey(idx) }} style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center", padding: 8, backgroundColor: activeKey == idx ? "#334155" : "#0f172a", borderRadius: 6, borderWidth: activeKey == idx ? 1 : 0, borderColor: "#3b82f6" }}>
      <Box style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
        <Text fontSize={10} color={k.isWheel == 1 ? "#f59e0b" : k.isNav == 1 ? "#3b82f6" : "#e2e8f0"}>{k.name}</Text>
        <Box style={{ flexDirection: "row", gap: 2 }}>
          {k.shift == 1 && <ModBadge label="Shift" active={1} />}
          {k.ctrl == 1 && <ModBadge label="Ctrl" active={1} />}
          {k.alt == 1 && <ModBadge label="Alt" active={1} />}
          {k.meta == 1 && <ModBadge label="Meta" active={1} />}
        </Box>
      </Box>
      <Box style={{ flexDirection: "row", gap: 4, alignItems: "center" }}>
        {k.isNav == 1 && <Text fontSize={7} color="#3b82f6">NAV</Text>}
        {k.isWheel == 1 && <Text fontSize={7} color="#f59e0b">WHEEL</Text>}
      </Box>
    </Pressable>
  );
}

function App() {
  return (
    <Box style={{ backgroundColor: "#0f172a", padding: 16, width: "100%", height: "100%", flexDirection: "column", gap: 12 }}>
      <Text fontSize={16} color="#e2e8f0">Key Event Router</Text>

      <Box style={{ flexDirection: "row", gap: 12, padding: 10, backgroundColor: "#1e293b", borderRadius: 8 }}>
        <Box style={{ gap: 4 }}>
          <Text fontSize={8} color="#475569">Clear Selection</Text>
          <Text fontSize={14} color={clearSelection == 1 ? "#ef4444" : "#22c55e"}>{clearSelection == 1 ? "YES" : "NO"}</Text>
        </Box>
        <Box style={{ gap: 4 }}>
          <Text fontSize={8} color="#475569">Focus Move</Text>
          <Text fontSize={14} color={focusMove === "none" ? "#475569" : "#3b82f6"}>{focusMove}</Text>
        </Box>
        <Box style={{ gap: 4 }}>
          <Text fontSize={8} color="#475569">Wheel Mult</Text>
          <Text fontSize={14} color="#f59e0b">{`${wheelMult}x`}</Text>
        </Box>
        <Box style={{ gap: 4 }}>
          <Text fontSize={8} color="#475569">Direction</Text>
          <Text fontSize={14} color="#94a3b8">{wheelDir == 1 ? "UP" : wheelDir == -1 ? "DOWN" : "-"}</Text>
        </Box>
      </Box>

      <ScrollView style={{ flexGrow: 1, gap: 3 }}>
        {keys.map((k, i) => (
          <KeyRow k={k} idx={i} />
        ))}
      </ScrollView>

      <Text fontSize={9} color="#475569">{`${logCount} events · ${actionLog}`}</Text>
    </Box>
  );
}
