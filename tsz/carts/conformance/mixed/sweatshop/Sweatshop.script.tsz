// Sweatshop — minimal script bridge for shell scaffolding.
// These functions intentionally stay narrow so Spark 2 can replace behavior.

declare function setActiveTabId(v: string): void;
declare function setActiveView(v: string): void;
declare function setCurrentFilePath(v: string): void;
declare function setShowCommandPalette(v: number): void;
declare function setShowDockedSearch(v: number): void;
declare function setWorkspaceName(v: string): void;
declare function setWorkspaceTagline(v: string): void;
declare function setChangedCount(v: number): void;
declare function setStagedCount(v: number): void;
declare function setCursorLine(v: number): void;
declare function setCursorColumn(v: number): void;
declare function setErrors(v: number): void;
declare function setWarnings(v: number): void;
declare function setOpenTabs(v: any): void;
declare function setModelDisplayName(v: string): void;
declare function setAgentStatusText(v: string): void;
declare var openTabs: any;
declare var activeTabId: string;
declare var showCommandPalette: number;

declare var showDockedSearch: number;

function activateTab(tabId) {
  if (tabId == activeTabId) return;
  setActiveTabId(tabId);
  setActiveView(tabId == 'settings' ? 'settings' : 'workbench');
  setCurrentFilePath(tabId);
}

function closeTab(tabId) {
  var next = [];
  for (var i = 0; i < openTabs.length; i++) {
    var tab = openTabs[i];
    if (tab.id != tabId) {
      next.push(tab);
    }
  }
  setOpenTabs(next);
  if (activeTabId == tabId && next.length > 0) {
    setActiveTabId(next[0].id);
    setCurrentFilePath(next[0].id);
  }
}

function openLandingPage() {
  setActiveView('workbench');
  setActiveTabId('workspace');
  setCurrentFilePath('workspace');
  setShowCommandPalette(0);
}

function openSettingsSurface() {
  setActiveView('settings');
  setActiveTabId('state');
  setCurrentFilePath('settings');
  setShowCommandPalette(0);
}

function refreshWorkspace() {
  setWorkspaceName('Sweatshop Cockpit');
  setWorkspaceTagline('Live supervision cockpit shell');
  setChangedCount(0);
  setStagedCount(0);
  setCursorLine(1);
  setCursorColumn(1);
  setErrors(0);
  setWarnings(0);
  setModelDisplayName('Sweatshop Model');
  setAgentStatusText('ready');
}

function openTerminal() {
  // TODO(claude-stitch): wire terminal command rail when terminal tile lands.
  setShowCommandPalette(0);
}

function toggleCommandPalette() {
  if (showCommandPalette == 1) {
    setShowCommandPalette(0);
    return;
  }
  setShowCommandPalette(1);
}

function hideCommandPalette() {
  setShowCommandPalette(0);
}

function initData() {
  setShowDockedSearch(0);
  setShowCommandPalette(0);
  refreshWorkspace();
  openLandingPage();
  setCurrentFilePath('Sweatshop Cockpit');
}
