// Typed supervisor event bus API for sweatshop.
// Consumers register handlers by stream and receive stream-specific payloads.

import {
  WorkerEventHandler,
  WorkerEventPayload,
  WorkerEventStream,
  WorkerEventPayloadMap,
} from './event_types.mod';

const SUPERVISOR_STREAMS = [
  'worker.damage',
  'worker.classify',
  'worker.token',
  'worker.mode',
  'worker.tool_call',
  'worker.edit',
  'worker.turn',
];

var nextHandle = 1;
var handlers = {};
var handlesByStream = {};

function ensureStream(stream) {
  if (!handlesByStream[stream]) handlesByStream[stream] = [];
}

function isKnownStream(stream) {
  for (var i = 0; i < SUPERVISOR_STREAMS.length; i++) {
    if (SUPERVISOR_STREAMS[i] === stream) return 1;
  }
  return 0;
}

function register(handle, stream, handler) {
  var h = {
    handle: handle,
    stream: stream,
    handler: handler,
  };
  handlers[handle] = h;
  ensureStream(stream);
  handlesByStream[stream].push(handle);
}

function unregister(stream, handle) {
  ensureStream(stream);
  var list = handlesByStream[stream];
  var next = [];
  var i = 0;
  while (i < list.length) {
    if (list[i] != handle) next.push(list[i]);
    i = i + 1;
  }
  handlesByStream[stream] = next;
}

export function subscribe<T extends WorkerEventStream>(stream: T, handler: WorkerEventHandler<T>): number {
  if (!isKnownStream(stream)) return -1;
  if (typeof handler != 'function') return -1;

  var handle = nextHandle;
  nextHandle = nextHandle + 1;
  register(handle, stream, handler);
  return handle;
}

export function unsubscribe(handle: number): number {
  var record = handlers[handle];
  if (record == undefined) return 0;

  unregister(record.stream, handle);
  delete handlers[handle];
  return 1;
}

export function dispatchEvent<T extends WorkerEventStream>(stream: T, payload: WorkerEventPayload<T>): number {
  if (!isKnownStream(stream)) return 0;
  ensureStream(stream);

  var list = handlesByStream[stream];
  var i = 0;
  while (i < list.length) {
    var handle = list[i];
    var record = handlers[handle];
    if (record && record.handler) {
      record.handler(payload);
    }
    i = i + 1;
  }
  return list.length;
}

export function allStreams() {
  return SUPERVISOR_STREAMS;
}

export { SUPERVISOR_STREAMS, handlers, handlesByStream, WorkerEventPayloadMap };
