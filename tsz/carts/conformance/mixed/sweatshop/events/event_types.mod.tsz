// Event payload types for sweatshop supervisor event streams.
// Source of truth for stream payload contracts used by the reactive bridge.

export type WorkerDamageEvent = {
  dirty_rows: number[];
};

export type WorkerClassifyRow = {
  row: number;
  kind: string;
  text: string;
  colors: any[];
  trace: string;
};

export type WorkerClassifyEvent = {
  turn_id: string;
  rows: WorkerClassifyRow[];
};

export type WorkerTokenEvent = {
  turn_id: string;
  token_kind: string;
  text: string;
  row: number;
  timestamp: number;
};

export type WorkerModeEvent = {
  prev_mode: string;
  new_mode: string;
  timestamp: number;
};

export type WorkerToolCallEvent = {
  tool_name: string;
  args: any;
  cwd: string;
  timestamp: number;
};

export type WorkerEditEvent = {
  file_path: string;
  diff: string;
  tool_call_id: string;
  timestamp: number;
};

export type WorkerTurnEvent = {
  turn_id: string;
  started_at: number;
  ended_at: number;
  tool_calls: WorkerToolCallEvent[];
  edits: WorkerEditEvent[];
  tokens: WorkerTokenEvent[];
  final_status: string;
};

export type WorkerEventStream =
  | 'worker.damage'
  | 'worker.classify'
  | 'worker.token'
  | 'worker.mode'
  | 'worker.tool_call'
  | 'worker.edit'
  | 'worker.turn';

export type WorkerEventPayloadMap = {
  'worker.damage': WorkerDamageEvent;
  'worker.classify': WorkerClassifyEvent;
  'worker.token': WorkerTokenEvent;
  'worker.mode': WorkerModeEvent;
  'worker.tool_call': WorkerToolCallEvent;
  'worker.edit': WorkerEditEvent;
  'worker.turn': WorkerTurnEvent;
};

export type WorkerEventPayload<T extends WorkerEventStream> = WorkerEventPayloadMap[T];

export type WorkerEventHandler<T extends WorkerEventStream> = (payload: WorkerEventPayload<T>) => void;
