// Claim verifier — deterministic evidence matcher backed by the supervisor.db reader.
// Per Stitcher plan step 6: walk the worker's recent edit events from queryListEvents
// and check whether the files claimed in claimEvent actually appear in those edits.

import { queryListEvents, queryListMessages } from '../data/database.mod';

function normalizeInput(value) {
  if (!value) return '';
  return String(value).trim();
}

function pickWorkerId(claimEvent) {
  if (!claimEvent) return '';
  return claimEvent.worker_id || claimEvent.workerId || '';
}

function pickProjectId(spec, claimEvent) {
  if (claimEvent && (claimEvent.project_id || claimEvent.projectId)) {
    return claimEvent.project_id || claimEvent.projectId;
  }
  if (spec && (spec.project_id || spec.projectId)) {
    return spec.project_id || spec.projectId;
  }
  return null;
}

function uniqueStrings(values) {
  var seen = {};
  var out = [];
  for (var i = 0; i < values.length; i++) {
    var v = normalizeInput(values[i]);
    if (v.length === 0) continue;
    if (seen[v]) continue;
    seen[v] = 1;
    out.push(v);
  }
  return out;
}

function claimedFilesFrom(claimEvent) {
  if (!claimEvent) return [];
  if (claimEvent.claimedFiles && claimEvent.claimedFiles.length) {
    return uniqueStrings(claimEvent.claimedFiles);
  }
  if (claimEvent.files && claimEvent.files.length) {
    return uniqueStrings(claimEvent.files);
  }
  // Fall back to scanning the claim text for path-shaped tokens.
  var text = normalizeInput(claimEvent.claim || claimEvent.text || '');
  if (text.length === 0) return [];
  var tokens = text.split(/\s+/);
  var out = [];
  for (var i = 0; i < tokens.length; i++) {
    var t = tokens[i];
    if (t.indexOf('/') > 0 || t.indexOf('.') > 0) out.push(t);
  }
  return uniqueStrings(out);
}

function parsePayloadJson(raw) {
  if (!raw) return null;
  if (typeof raw !== 'string') return raw;
  try {
    return JSON.parse(raw);
  } catch (err) {
    return null;
  }
}

function isEditTool(toolName) {
  if (!toolName) return 0;
  if (toolName === 'Edit' || toolName === 'Write' || toolName === 'MultiEdit') return 1;
  return 0;
}

function editedFilesFromEvents(rows) {
  var files = [];
  if (!rows) return files;
  for (var i = 0; i < rows.length; i++) {
    var ev = rows[i];
    var payload = parsePayloadJson(ev && ev.payload_json);
    if (!payload) continue;
    var tool = payload.tool || payload.tool_name || '';
    if (isEditTool(tool) === 0) continue;
    var path = payload.file || payload.file_path || (payload.input && payload.input.file_path) || '';
    if (path) files.push(path);
  }
  return uniqueStrings(files);
}

function matchedFilesFor(claimedFiles, editedFiles) {
  var matched = [];
  for (var i = 0; i < claimedFiles.length; i++) {
    var c = claimedFiles[i];
    for (var j = 0; j < editedFiles.length; j++) {
      var e = editedFiles[j];
      if (e === c || e.indexOf(c) >= 0 || c.indexOf(e) >= 0) {
        matched.push(c);
        break;
      }
    }
  }
  return uniqueStrings(matched);
}

function statusFromConfidence(confidence) {
  if (confidence >= 1) return 'verified';
  if (confidence > 0) return 'partial';
  return 'unsupported';
}

function classifyClaim(spec, claimEvent, evidence) {
  var workerId = pickWorkerId(claimEvent);
  var projectId = pickProjectId(spec, claimEvent);
  var claimedFiles = claimedFilesFrom(claimEvent);

  if (claimedFiles.length === 0) {
    return {
      worker_id: workerId,
      status: 'unsupported',
      confidence: 0,
      matched_files: [],
      claimed_files: [],
      edited_files: [],
      reason: 'no claimed file paths could be extracted from the claim event',
    };
  }

  var editsRes = null;
  try {
    editsRes = queryListEvents(projectId, workerId || null, 'tool_use', 50, null);
  } catch (err) {
    editsRes = null;
  }

  if (!editsRes || editsRes.ok === 0 || !editsRes.rows) {
    return {
      worker_id: workerId,
      status: 'unverifiable',
      confidence: 0,
      matched_files: [],
      claimed_files: claimedFiles,
      edited_files: [],
      reason: 'database query for recent tool_use events failed or returned no rows',
    };
  }

  var editedFiles = editedFilesFromEvents(editsRes.rows);
  var matched = matchedFilesFor(claimedFiles, editedFiles);
  var confidence = claimedFiles.length === 0 ? 0 : (matched.length / claimedFiles.length);

  return {
    worker_id: workerId,
    status: statusFromConfidence(confidence),
    confidence: confidence,
    matched_files: matched,
    claimed_files: claimedFiles,
    edited_files: editedFiles,
    reason: matched.length + '/' + claimedFiles.length + ' claimed files match recent worker edits',
  };
}

// Legacy-compatible surface for any caller still on the stub shape.
function claimVerifySurface(spec, claimEvent, evidence) {
  return classifyClaim(spec, claimEvent, evidence);
}

export {
  claimVerifySurface,
  classifyClaim,
};
