// classifier_runtime — central dispatch hub for the cockpit's L2 classifiers.
// Subscribes to event streams from supervisor_events, runs the appropriate detector
// per event, updates per-worker affect, and fires sound cues on salient verdicts.

import { detectRationalization } from './rationalization.mod';
import { compareEditsToSpec } from './drift.mod';
import { classifyToolRisk } from './tool_risk.mod';
import { classifyClaim } from './claim_verify.mod';
import { subscribe } from '../events/supervisor_events.mod';
import { isSoundCueEvent, soundCuePayload } from '../audio/sound_cues_types.mod';

// Per-worker state.
var affectByWorker = {};
var lastVerdictByWorker = {};
var cooldownByCue = {};
const CUE_COOLDOWN_MS = 500;

function nowMs() {
  if (typeof Date === 'function' && Date.now) return Date.now();
  return 0;
}

function getWorkerAffect(workerId) {
  var key = workerId || '';
  if (key.length === 0) return 'confident';
  return affectByWorker[key] || 'confident';
}

function setWorkerAffect(workerId, affect) {
  var key = workerId || '';
  if (key.length === 0) return 0;
  affectByWorker[key] = affect || 'confident';
  return 1;
}

function getLastVerdict(workerId) {
  var key = workerId || '';
  return lastVerdictByWorker[key] || null;
}

function setLastVerdict(workerId, verdict) {
  var key = workerId || '';
  if (key.length === 0) return 0;
  lastVerdictByWorker[key] = verdict;
  return 1;
}

function playCue(cueName, payload) {
  if (!cueName) return 0;
  if (isSoundCueEvent && isSoundCueEvent(cueName) === false) return 0;

  var now = nowMs();
  var last = cooldownByCue[cueName] || 0;
  if (now > 0 && (now - last) < CUE_COOLDOWN_MS) return 0;
  cooldownByCue[cueName] = now;

  if (typeof __lua_call !== 'function') {
    // TODO(claude-stitch): __lua_call host fn unavailable; cue would be 'sound_cues_play(' + cueName + ')'.
    return 0;
  }
  try {
    __lua_call('sound_cues_play', cueName, payload || {});
    return 1;
  } catch (err) {
    return 0;
  }
}

function workerIdOf(payload) {
  if (!payload) return '';
  return payload.worker_id || payload.workerId || payload.session_id || payload.sessionId || '';
}

function rowsOf(payload) {
  if (!payload) return [];
  if (payload.rows && payload.rows.length !== undefined) return payload.rows;
  return [];
}

function rowText(row) {
  if (!row) return '';
  if (typeof row === 'string') return row;
  return row.text || '';
}

function applyRationalizationVerdict(workerId, tier, matched) {
  if (!tier) return;
  if (tier === 'canonical') {
    setWorkerAffect(workerId, 'rationalizing');
    playCue('fake_green_caught', soundCuePayload('fake_green_caught', { worker: workerId, matched: matched }));
    setLastVerdict(workerId, { kind: 'rationalization', tier: tier, matched: matched });
  } else if (tier === 'strong') {
    setWorkerAffect(workerId, 'rationalizing');
    playCue('tunnel_vision_warning', soundCuePayload('tunnel_vision_warning', { worker: workerId, matched: matched }));
    setLastVerdict(workerId, { kind: 'rationalization', tier: tier, matched: matched });
  } else if (tier === 'mild') {
    setWorkerAffect(workerId, 'uncertain');
    setLastVerdict(workerId, { kind: 'rationalization', tier: tier, matched: matched });
  }
}

function runWorkerClassify(payload) {
  var workerId = workerIdOf(payload);
  var rows = rowsOf(payload);
  for (var i = 0; i < rows.length; i++) {
    var text = rowText(rows[i]);
    if (text.length === 0) continue;
    var verdict = detectRationalization(text);
    if (verdict && verdict.tier) {
      applyRationalizationVerdict(workerId, verdict.tier, verdict.matched_phrase || text);
    }
  }
}

function runWorkerToken(payload) {
  var workerId = workerIdOf(payload);
  var text = (payload && payload.text) ? payload.text : '';
  if (text.length === 0) return;
  var verdict = detectRationalization(text);
  if (verdict && verdict.tier) {
    applyRationalizationVerdict(workerId, verdict.tier, verdict.matched_phrase || text);
  }
}

function runWorkerToolCall(payload) {
  var workerId = workerIdOf(payload);
  if (!payload) return;
  var tool = payload.tool_name || payload.tool || '';
  var args = payload.args || {};
  var argsText = '';
  try {
    argsText = JSON.stringify(args);
  } catch (err) {
    argsText = '';
  }
  var verdict = classifyToolRisk(tool + ' ' + argsText);
  if (!verdict) return;
  setLastVerdict(workerId, { kind: 'tool_risk', verdict: verdict });
  if (verdict.action === 'block' || verdict.severity === 'critical') {
    setWorkerAffect(workerId, 'frustrated');
    playCue('ralph_injection', soundCuePayload('ralph_injection', { worker: workerId, tool: tool, reason: verdict.reason || '' }));
  }
}

function runWorkerEdit(payload) {
  // TODO(claude-stitch): wire spec-aware claim_verify when active spec is reachable
  // through state_board (the spec column is not in supervisor.db today).
  var workerId = workerIdOf(payload);
  if (!workerId) return;
  setLastVerdict(workerId, { kind: 'edit', file: (payload && payload.file_path) || '' });
}

function runWorkerMode(payload) {
  var workerId = workerIdOf(payload);
  if (!payload) return;
  var newMode = payload.new_mode || payload.newMode || '';
  if (newMode === 'stuck') setWorkerAffect(workerId, 'stuck');
  else if (newMode === 'streaming') setWorkerAffect(workerId, 'confident');
  // 'thinking' / 'idle' / 'permission' / 'tool_use' leave affect unchanged.
}

function runWorkerTurn(payload) {
  // TODO(claude-stitch): on streaming->idle transition, run compareEditsToSpec(activeSpec, payload.edits)
  // once a single source-of-truth for the active spec lands in state_board.
  var workerId = workerIdOf(payload);
  if (!workerId) return;
  setLastVerdict(workerId, { kind: 'turn', endedAt: (payload && payload.ended_at) || '' });
}

function subscribeAllSweatshopClassifiers() {
  var handles = [];
  handles.push(subscribe('worker.classify', runWorkerClassify));
  handles.push(subscribe('worker.token', runWorkerToken));
  handles.push(subscribe('worker.tool_call', runWorkerToolCall));
  handles.push(subscribe('worker.edit', runWorkerEdit));
  handles.push(subscribe('worker.mode', runWorkerMode));
  handles.push(subscribe('worker.turn', runWorkerTurn));
  return handles;
}

export {
  getWorkerAffect,
  setWorkerAffect,
  getLastVerdict,
  playCue,
  runWorkerClassify,
  runWorkerToken,
  runWorkerToolCall,
  runWorkerEdit,
  runWorkerMode,
  runWorkerTurn,
  subscribeAllSweatshopClassifiers,
};
