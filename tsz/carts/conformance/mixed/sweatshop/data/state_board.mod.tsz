// State board API: read/write and field-level mutation for A16 supervisor memory.
// No UI live wiring here; this is pure data shape + file IO utility.

import {
  emptyStateBoard,
  normalizeStateBoard,
  normalizeWorkerEntry,
  normalizeSectionEntry,
  toInt,
  toText,
} from './state_board_types.mod';

import {
  isOpen as dbIsOpen,
  queryListWorkers,
  queryListPlans,
  queryListPhases,
  queryListTasks,
} from './database.mod';

const DEFAULT_BOARD_PATH = 'state/board.json';

function hasHostFs() {
  return typeof __fs_readfile === 'function' && typeof __fs_writefile === 'function';
}

function asPath(path) {
  return path || DEFAULT_BOARD_PATH;
}

function makeResult(ok, board, path, error) {
  return {
    ok: ok,
    path: toText(path, DEFAULT_BOARD_PATH),
    board: board,
    error: toText(error, ''),
  };
}

function readBoard(boardPath) {
  var path = asPath(boardPath);
  if (!hasHostFs()) {
    return makeResult(0, emptyStateBoard(), path, '__fs_readfile is unavailable');
  }

  var raw = '';
  try {
    raw = __fs_readfile(path);
  } catch (err) {
    return makeResult(0, emptyStateBoard(), path, toText(err && err.message, toText(err, 'read failed')));
  }

  if (!raw || raw.length == 0) {
    return makeResult(0, emptyStateBoard(), path, 'board file not found or empty');
  }

  var parsed = null;
  try {
    parsed = JSON.parse(raw);
  } catch (err) {
    return makeResult(0, emptyStateBoard(), path, 'board JSON parse failed');
  }

  return makeResult(1, normalizeStateBoard(parsed), path, '');
}

function writeBoard(board, boardPath) {
  var path = asPath(boardPath);
  if (!hasHostFs()) {
    return makeResult(0, normalizeStateBoard(board || {}), path, '__fs_writefile is unavailable');
  }

  var normalized = normalizeStateBoard(board || {});
  var payload = JSON.stringify(normalized, null, 2);
  var wrote = 0;
  try {
    wrote = __fs_writefile(path, payload);
  } catch (err) {
    return makeResult(0, normalized, path, toText(err && err.message, toText(err, 'write failed')));
  }

  if (wrote === 0 || wrote === undefined || wrote === null) return makeResult(1, normalized, path, '');
  return makeResult(0, normalized, path, 'write returned error code ' + wrote);
}

function cloneIfObject(value) {
  if (value === null || value === undefined) return {};
  try {
    return JSON.parse(JSON.stringify(value));
  } catch (err) {
    return {};
  }
}

function updateWorker(name, partial, boardPath) {
  var target = toText(name, '');
  if (target.length == 0) return makeResult(0, emptyStateBoard(), asPath(boardPath), 'worker name is required');

  var read = readBoard(boardPath);
  var board = read.board;
  if (!board) board = emptyStateBoard();

  var workers = cloneIfObject(board.workers);
  var existing = workers[target];
  if (!existing || typeof existing != 'object') existing = {};

  var patch = partial || {};
  var next = {
    pane: toInt(patch.pane, existing.pane),
    model: toText(patch.model, existing.model),
    task: toText(patch.task, existing.task),
    status: toText(patch.status, existing.status),
    trust: toText(patch.trust, existing.trust),
  };

  workers[target] = normalizeWorkerEntry(next, target);
  board.workers = workers;

  return writeBoard(board, pathOrDefault(read.path, boardPath));
}

function updateSection(sectionId, sectionData, boardPath) {
  var sid = toText(sectionId, '');
  if (sid.length == 0) return makeResult(0, emptyStateBoard(), asPath(boardPath), 'section id is required');

  var read = readBoard(boardPath);
  var board = read.board;
  if (!board) board = emptyStateBoard();

  var sections = cloneIfObject(board.sections);
  var existing = sections[sid];
  if (!existing || typeof existing != 'object') existing = {};
  var patch = sectionData || {};
  var next = {
    worker: toText(patch.worker, existing.worker),
    status: toText(patch.status, existing.status),
    steps_done: toInt(patch.steps_done, existing.steps_done),
    steps_total: toInt(patch.steps_total, existing.steps_total),
  };

  sections[sid] = normalizeSectionEntry(next, sid);
  board.sections = sections;

  return writeBoard(board, pathOrDefault(read.path, boardPath));
}

function markSectionProgress(sectionId, done, total, boardPath) {
  var sid = toText(sectionId, '');
  if (sid.length == 0) return makeResult(0, emptyStateBoard(), asPath(boardPath), 'section id is required');

  var read = readBoard(boardPath);
  var board = read.board;
  if (!board) board = emptyStateBoard();

  var sections = cloneIfObject(board.sections);
  var existing = sections[sid];
  if (!existing || typeof existing != 'object') {
    existing = { worker: '', status: 'in-progress', steps_done: 0, steps_total: toInt(total, 0) };
  }

  var nextDone = toInt(done, existing.steps_done);
  var nextTotal = toInt(total, existing.steps_total);
  if (nextTotal < 0) nextTotal = 0;
  if (nextDone < 0) nextDone = 0;
  if (nextDone > nextTotal && nextTotal > 0) nextDone = nextTotal;

  var status = toText(existing.status, 'in-progress');
  if (nextTotal > 0 && nextDone >= nextTotal) status = 'done';
  else if (nextDone == 0) status = 'queued';

  sections[sid] = normalizeSectionEntry({
    worker: existing.worker,
    status: status,
    steps_done: nextDone,
    steps_total: nextTotal,
  }, sid);

  board.sections = sections;
  return writeBoard(board, pathOrDefault(read.path, boardPath));
}

function pathOrDefault(readPath, explicitPath) {
  if (explicitPath && explicitPath.length > 0) return explicitPath;
  return readPath || DEFAULT_BOARD_PATH;
}

function sampleStateBoard() {
  return normalizeStateBoard({
    workers: {
      Frank: { pane: 12, model: 'opus', task: 'S1 steps 001-030', status: 'active', trust: 0.7 },
      Diane: { pane: 6, model: 'kimi', task: 'S3 steps 061-089', status: 'active', trust: 0.9 },
      '5e48': { pane: 2, model: 'opus', task: 'planner/auditor', status: 'idle', trust: 0.95 },
      Atlas: { pane: 9, model: 'codex', task: 'stuck in readback', status: 'stuck', trust: 0.42 },
    },
    plan: 'plan-emit-unification',
    sections: {
      S1: { worker: 'Frank', status: 'in-progress', steps_done: 12, steps_total: 30 },
      S3: { worker: 'Diane', status: 'in-progress', steps_done: 0, steps_total: 28 },
      S4: { worker: '5e48', status: 'queued', steps_done: 0, steps_total: 14 },
    },
    human_last_active: '2026-04-13T05:42:00Z',
    loop_status: 'active',
    last_audit: '2026-04-13T05:38:00Z',
  });
}

// liveStateBoard — read supervisor.db for the current cockpit state.
// Returns null when the DB isn't open or any required query fails; caller falls back
// to sampleStateBoard() per Stitcher plan step 2.
function mapWorkerStatus(s) {
  var t = toText(s, 'idle');
  if (t === 'active') return 'active';
  if (t === 'stuck') return 'stuck';
  if (t === 'idle') return 'idle';
  return 'idle';
}

function liveStateBoard() {
  if (typeof dbIsOpen !== 'function' || dbIsOpen() === 0) return null;

  var workersRes = queryListWorkers(null, null, 64, null);
  if (!workersRes || workersRes.ok === 0) return null;

  var plansRes = queryListPlans(null, 'in-progress', 1, null);
  if (!plansRes || plansRes.ok === 0) plansRes = queryListPlans(null, 'active', 1, null);
  if (!plansRes || plansRes.ok === 0) return null;

  var planRow = (plansRes.rows && plansRes.rows.length > 0) ? plansRes.rows[0] : null;
  var planId = planRow ? (planRow.id || null) : null;
  var planLabel = planRow ? toText(planRow.name, toText(planRow.id, '')) : '';

  var phasesRes = planId ? queryListPhases(planId, 64, null) : { ok: 1, rows: [] };
  if (!phasesRes || phasesRes.ok === 0) return null;

  // Build sections keyed by phase_number.
  var sections = {};
  var phases = phasesRes.rows || [];
  for (var i = 0; i < phases.length; i++) {
    var p = phases[i];
    var sid = 'S' + toInt(p.phase_number, i + 1);
    var tasksRes = queryListTasks(null, p.id, null, null, 256, null);
    var doneCount = 0;
    var totalCount = 0;
    if (tasksRes && tasksRes.ok !== 0 && tasksRes.rows) {
      totalCount = tasksRes.rows.length;
      for (var j = 0; j < tasksRes.rows.length; j++) {
        var st = toText(tasksRes.rows[j].status, '');
        if (st === 'complete' || st === 'verified' || st === 'done') doneCount++;
      }
    }
    sections[sid] = normalizeSectionEntry({
      worker: '',
      status: toText(p.status, totalCount > 0 && doneCount >= totalCount ? 'done' : 'in-progress'),
      steps_done: doneCount,
      steps_total: totalCount,
    }, sid);
  }

  // Build workers map.
  var workers = {};
  var anyActive = 0;
  var rows = workersRes.rows || [];
  for (var k = 0; k < rows.length; k++) {
    var w = rows[k];
    var name = toText(w.name, toText(w.id, 'worker_' + k));
    var status = mapWorkerStatus(w.status);
    if (status === 'active') anyActive = 1;
    workers[name] = normalizeWorkerEntry({
      pane: toInt(w.pane_id, 0),
      model: toText(w.model, ''),
      task: toText(w.current_task_id, ''),
      status: status,
      // TODO(claude-stitch): trust score lives outside the DB right now; default 0.7 per plan.
      trust: 0.7,
    }, name);
  }

  return normalizeStateBoard({
    workers: workers,
    plan: planLabel,
    sections: sections,
    human_last_active: '',
    loop_status: anyActive === 1 ? 'active' : 'idle',
    last_audit: '',
  });
}

export {
  DEFAULT_BOARD_PATH,
  readBoard,
  writeBoard,
  updateWorker,
  markSectionProgress,
  sampleStateBoard,
  liveStateBoard,
  updateSection,
};
