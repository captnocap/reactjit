// Sweatshop git audit parser (read-only TSV contract for git_data.sh).
// Parses commit/restore/recent/lag modes into typed row objects.

const DATA_SCRIPT = '/home/siah/creative/reactjit/tsz/carts/conformance/mixed/sweatshop/data/git_data.sh';
const DEFAULT_REPO_ROOT = '/home/siah/creative/reactjit';
const DEFAULT_TRAIL_ROOT = '/run/user/1000/claude-sessions/reactjit/edit-trail-wt';
const DEFAULT_LIMIT = 120;

function toText(value, fallback) {
  var out = fallback;
  if (value === null || value === undefined) return out;
  var next = String(value).trim();
  if (next.length === 0) return out;
  return next;
}

function toInt(value, fallback) {
  if (value === null || value === undefined) return fallback;
  if (typeof value === 'number' && Number.isFinite(value)) return value;

  var parsed = parseInt(String(value), 10);
  if (Number.isNaN(parsed)) return fallback;
  return parsed;
}

function splitLines(raw) {
  if (raw === null || raw === undefined) return [];
  var text = String(raw);
  if (text.length === 0) return [];
  return text.split('\n');
}

function parseDayRows(lines) {
  var out = [];
  var i = 0;

  while (i < lines.length) {
    var line = toText(lines[i], '');
    if (line.length > 0) {
      var parts = line.split('\t');
      if (parts[0] === 'DAY' && parts.length >= 3) {
        out.push({
          day: toText(parts[1], ''),
          count: toInt(parts[2], 0),
        });
      }
    }
    i = i + 1;
  }

  out.sort(function(left, right) {
    return left.day > right.day ? 1 : (left.day < right.day ? -1 : 0);
  });

  return out;
}

function parseAreaRows(lines) {
  var map = {};
  var i = 0;

  while (i < lines.length) {
    var line = toText(lines[i], '');
    if (line.length > 0) {
      var parts = line.split('\t');
      if (parts[0] === 'AREA' && parts.length >= 3) {
        var name = toText(parts[1], 'other');
        if (!map[name]) {
          map[name] = {
            area: name,
            adds: 0,
            firstDay: toText(parts[3], ''),
            lastDay: toText(parts[4], ''),
          };
        }
        map[name].adds = map[name].adds + toInt(parts[2], 0);
      }
    }
    i = i + 1;
  }

  var names = [];
  var area = null;
  for (area in map) names.push(area);

  names.sort();

  var rows = [];
  i = 0;
  while (i < names.length) {
    rows.push(map[names[i]]);
    i = i + 1;
  }

  return rows;
}

function parseFreshRows(lines) {
  var freshTotal = 0;
  var byDay = {};
  var byDayList = [];
  var files = [];
  var i = 0;

  while (i < lines.length) {
    var line = toText(lines[i], '');
    if (line.length > 0) {
      var parts = line.split('\t');
      if (parts[0] === 'FRESH' && parts.length >= 2) {
        freshTotal = toInt(parts[1], 0);
      }
      if (parts[0] === 'FRESH_DAY' && parts.length >= 3) {
        var day = toText(parts[1], '');
        byDay[day] = toInt(parts[2], 0);
      }
      if (parts[0] === 'FRESH_FILE' && parts.length >= 5) {
        files.push({
          index: toInt(parts[1], 0),
          day: toText(parts[2], ''),
          area: toText(parts[3], 'other'),
          path: toText(parts[4], ''),
        });
      }
    }
    i = i + 1;
  }

  for (day in byDay) byDayList.push({ day: day, count: byDay[day] });
  byDayList.sort(function(left, right) {
    return left.day > right.day ? 1 : (left.day < right.day ? -1 : 0);
  });

  files.sort(function(left, right) {
    if (left.day === right.day) {
      return left.index - right.index;
    }
    return left.day < right.day ? 1 : -1;
  });

  return {
    total: freshTotal,
    byDay: byDayList,
    files: files,
  };
}

function parseRecentCommits(lines) {
  var out = [];
  var i = 0;

  while (i < lines.length) {
    var line = toText(lines[i], '');
    if (line.length > 0) {
      var parts = line.split('\t');
      if (parts[0] === 'RECENT' && parts.length >= 5) {
        out.push({
          sha: toText(parts[1], ''),
          day: toText(parts[2], ''),
          worker: toText(parts[3], ''),
          subject: toText(parts[4], ''),
        });
      }
    }
    i = i + 1;
  }

  return out;
}

function parseRecentEdits(lines) {
  var out = [];
  var i = 0;

  while (i < lines.length) {
    var line = toText(lines[i], '');
    if (line.length > 0) {
      var parts = line.split('\t');
      if (parts[0] === 'RECENT_EDIT' && parts.length >= 6) {
        var human = toText(parts[4], '');
        out.push({
          worker: toText(parts[1], ''),
          sha: toText(parts[2], ''),
          epoch: toInt(parts[3], 0),
          humanTime: human,
          subject: toText(parts[5], ''),
        });
      }
    }
    i = i + 1;
  }

  return out;
}

function parseRestorePoints(lines) {
  var out = [];
  var i = 0;

  while (i < lines.length) {
    var line = toText(lines[i], '');
    if (line.length > 0) {
      var parts = line.split('\t');
      if (parts[0] === 'RESTORE' && parts.length >= 7) {
        out.push({
          index: toInt(parts[1], 0),
          sha: toText(parts[2], ''),
          epoch: toInt(parts[3], 0),
          humanTime: toText(parts[4], ''),
          worker: toText(parts[5], ''),
          subject: toText(parts[6], ''),
        });
      }
    }
    i = i + 1;
  }

  return out;
}

function parseWorkerLag(lines) {
  var out = [];
  var i = 0;

  while (i < lines.length) {
    var line = toText(lines[i], '');
    if (line.length > 0) {
      var parts = line.split('\t');
      if (parts[0] === 'WORKER_LAG' && parts.length >= 9) {
        var lag = toInt(parts[5], 0);
        out.push({
          worker: toText(parts[1], ''),
          lastCommitSha: toText(parts[2], ''),
          lastCommitEpoch: toInt(parts[3], 0),
          lastCommitHuman: toText(parts[4], ''),
          lagSeconds: lag,
          lagMinutes: Math.round(lag / 60),
          lagLabel: formatLagSeconds(lag),
          status: toText(parts[6], 'clean'),
          editsSeen: toInt(parts[7], 0),
          uncommitted: toInt(parts[8], 0),
        });
      }
    }
    i = i + 1;
  }

  out.sort(function(left, right) {
    if (left.lagSeconds === right.lagSeconds) return 0;
    return right.lagSeconds - left.lagSeconds;
  });

  return out;
}

function parseError(lines) {
  var i = 0;
  while (i < lines.length) {
    var line = toText(lines[i], '');
    if (line.indexOf('ERR\t') === 0) {
      var parts = line.split('\t');
      var code = toText(parts[1], 'error');
      var detail = toText(parts[2], '');
      return code + ': ' + detail;
    }
    i = i + 1;
  }

  return '';
}

function parseCommitsMode(raw) {
  var lines = splitLines(toText(raw, ''));
  var out = {
    mode: 'commits',
    total: 0,
    days: parseDayRows(lines),
    areaAdds: parseAreaRows(lines),
    fresh: parseFreshRows(lines),
    recentCommits: parseRecentCommits(lines),
  };

  var i = 0;
  while (i < lines.length) {
    var line = toText(lines[i], '');
    if (line.length > 0) {
      var parts = line.split('\t');
      if (parts[0] === 'TOTAL' && parts.length >= 2) out.total = toInt(parts[1], 0);
      if (parts[0] === 'FIRST' && parts.length >= 2) out.firstDay = toText(parts[1], '');
      if (parts[0] === 'LAST' && parts.length >= 2) out.lastDay = toText(parts[1], '');
    }
    i = i + 1;
  }

  return out;
}

function parseRecentEditsMode(raw) {
  return {
    mode: 'recent-edits',
    recentEdits: parseRecentEdits(splitLines(toText(raw, ''))),
  };
}

function parseRestorePointsMode(raw) {
  return {
    mode: 'restore-points',
    points: parseRestorePoints(splitLines(toText(raw, ''))),
  };
}

function parseWorkerLagMode(raw) {
  return {
    mode: 'worker-lag',
    workers: parseWorkerLag(splitLines(toText(raw, ''))),
  };
}

function formatLagSeconds(seconds) {
  var total = toInt(seconds, 0);
  var mins = Math.floor(total / 60);
  var hours = Math.floor(mins / 60);
  var days = Math.floor(hours / 24);

  if (days > 0) return days + 'd ' + (hours % 24) + 'h ' + (mins % 60) + 'm';
  if (hours > 0) return hours + 'h ' + (mins % 60) + 'm';
  return mins + 'm';
}

function shellQuote(value) {
  var safe = toText(value, '');
  return "'" + safe.split("'").join("'\"'\"'") + "'";
}

function defaultTrailRoot() {
  var base = DEFAULT_TRAIL_ROOT;
  if (typeof __getenv === 'function') {
    var uid = toText(__getenv('UID'), '');
    if (uid.length > 0) return '/run/user/' + uid + '/claude-sessions/reactjit/edit-trail-wt';
    var uidAlt = toText(__getenv('UID_NUMBER'), '');
    if (uidAlt.length > 0) return '/run/user/' + uidAlt + '/claude-sessions/reactjit/edit-trail-wt';
  } else {
    // TODO(claude-stitch): __getenv is unavailable; defaulting trail root to 1000 uid path.
  }
  return base;
}

function parseMode(mode, raw) {
  if (mode === 'commits') return parseCommitsMode(raw);
  if (mode === 'recent-edits') return parseRecentEditsMode(raw);
  if (mode === 'restore-points') return parseRestorePointsMode(raw);
  if (mode === 'worker-lag') return parseWorkerLagMode(raw);

  return {
    mode: mode,
    error: 'unsupported mode',
    total: 0,
  };
}

function loadGitAudit(mode, repoRoot, trailRoot, limit) {
  if (!mode || String(mode).length === 0) {
    return { ok: 0, mode: '', data: null, error: 'mode is required' };
  }

  if (typeof __exec !== 'function') {
    return { ok: 0, mode: mode, data: null, error: '__exec host unavailable' };
  }

  var m = String(mode);
  var root = toText(repoRoot, DEFAULT_REPO_ROOT);
  var trail = toText(trailRoot, defaultTrailRoot());
  var maxRows = toInt(limit, DEFAULT_LIMIT);
  var safeLimit = maxRows > 0 ? maxRows : DEFAULT_LIMIT;
  var command = 'bash ' + shellQuote(DATA_SCRIPT) + ' ' + shellQuote(m) + ' ' + shellQuote(root) + ' ' + shellQuote(trail) + ' ' + String(safeLimit) + ' 2>/dev/null';

  var output = '';
  try {
    output = __exec(command);
  } catch (e) {
    return { ok: 0, mode: m, data: null, error: toText(e && e.message, toText(e, 'command failure')) };
  }

  var lines = splitLines(toText(output, '').trim());
  var parseErr = parseError(lines);
  if (parseErr.length > 0) {
    return { ok: 0, mode: m, data: null, error: parseErr };
  }

  return {
    ok: 1,
    mode: m,
    data: parseMode(m, output),
    error: '',
  };
}

export {
  DATA_SCRIPT,
  DEFAULT_REPO_ROOT,
  DEFAULT_TRAIL_ROOT,
  DEFAULT_LIMIT,
  parseCommitsMode,
  parseRecentEditsMode,
  parseRestorePointsMode,
  parseWorkerLagMode,
  parseDayRows,
  parseAreaRows,
  parseFreshRows,
  parseRecentCommits,
  parseWorkerLag,
  formatLagSeconds,
  loadGitAudit,
};
