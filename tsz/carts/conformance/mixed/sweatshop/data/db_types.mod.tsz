// typed row helpers for supervisor.db readers
// Mixed-lane TSX module: no intent-syntax forms, no writes.

function toText(value, fallback) {
  var text = fallback;
  if (text === undefined || text === null) text = '';
  if (value === null || value === undefined) return text;
  return String(value);
}

function toInt(value, fallback) {
  if (value === null || value === undefined) return fallback;
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  var parsed = parseInt(String(value), 10);
  if (Number.isNaN(parsed)) return fallback;
  return parsed;
}

function toFloat(value, fallback) {
  if (value === null || value === undefined) return fallback;
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  var parsed = parseFloat(String(value));
  if (Number.isNaN(parsed)) return fallback;
  return parsed;
}

function toBoolean(value, fallback) {
  if (value === null || value === undefined) return fallback;
  if (value === true || value === false) return value;
  if (typeof value === 'number') return value !== 0;
  if (typeof value === 'string') {
    var lower = value.toLowerCase();
    if (lower === '1' || lower === 'true' || lower === 'yes' || lower === 'on') return true;
    if (lower === '0' || lower === 'false' || lower === 'no' || lower === 'off') return false;
  }
  return fallback;
}

function toJson(value, fallback) {
  if (value === null || value === undefined) return fallback;
  if (typeof value !== 'string') return fallback;
  try {
    var parsed = JSON.parse(value);
    return parsed;
  } catch (err) {
    return fallback;
  }
}

function asArray(value, fallback) {
  var result = toJson(value, null);
  if (Array.isArray(result)) return result;
  return fallback || [];
}

function asObject(value, fallback) {
  var result = toJson(value, null);
  if (result && typeof result === 'object' && !Array.isArray(result)) return result;
  return fallback || {};
}

function withDefaultQueryResult() {
  return { ok: 1, data: [], error: null };
}

function queryOk(data) {
  return { ok: 1, data: data || [], error: null };
}

function queryErr(code, message, detail) {
  return {
    ok: 0,
    data: [],
    error: {
      code: toText(code, 'query_error'),
      message: toText(message, 'query failed'),
      detail: toText(detail, ''),
    },
  };
}

function projectRow(row) {
  return {
    id: toInt(row.id, 0),
    name: toText(row.name, ''),
    description: toText(row.description, ''),
    repo_path: toText(row.repo_path, ''),
    created_at: toText(row.created_at, ''),
    updated_at: toText(row.updated_at, ''),
  };
}

function workerRow(row) {
  return {
    id: toInt(row.id, 0),
    project_id: toInt(row.project_id, 0),
    pane_id: toInt(row.pane_id, 0),
    session_id: toText(row.session_id, ''),
    status: toText(row.status, ''),
    current_task_id: toInt(row.current_task_id, 0),
    registered_at: toText(row.registered_at, ''),
    last_seen_at: toText(row.last_seen_at, ''),
  };
}

