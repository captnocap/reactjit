    created_at: toText(row.created_at, ''),
  };
}

function dbMetaTablesRow(row) {
  return {
    name: toText(row.name, ''),
    type: toText(row.type, ''),
    sql: toText(row.sql, ''),
    nrow: toInt(row.nrow, 0),
  };
}
