    motivation: toText(row.motivation, ''),
    approach: toText(row.approach, ''),
    constraints: asArray(row.constraints, []),
    non_goals: asArray(row.non_goals, []),
    key_decisions: asArray(row.key_decisions, []),
    starting_point: asArray(row.starting_point, []),
    known_problems: asArray(row.known_problems, []),
    dependencies: asArray(row.dependencies, []),
    risks: asArray(row.risks, []),
    file_map: asArray(row.file_map, []),
    boundaries: asArray(row.boundaries, []),
    parallel_tracks: asArray(row.parallel_tracks, []),
    critical_path: asArray(row.critical_path, []),
    max_concurrent_workers: toInt(row.max_concurrent_workers, 1),
    shared_files: asArray(row.shared_files, []),
    done_criteria: asArray(row.done_criteria, []),
    rollback_plan: toText(row.rollback_plan, ''),
    changelog_entry: toText(row.changelog_entry, ''),
    commit_trail: asArray(row.commit_trail, []),
    notes: asArray(row.notes, []),
    created_by: toText(row.created_by, ''),
    created_at: toText(row.created_at, ''),
    updated_at: toText(row.updated_at, ''),
  };
}

