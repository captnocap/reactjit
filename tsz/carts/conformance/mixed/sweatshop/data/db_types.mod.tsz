}

function violationLogRow(row) {
  return {
    id: toInt(row.id, 0),
    rule_id: toInt(row.rule_id, 0),
    worker_id: toInt(row.worker_id, 0),
    task_id: toInt(row.task_id, 0),
    matched_text: toText(row.matched_text, ''),
    action_taken: toText(row.action_taken, ''),
    resolved: toBoolean(row.resolved, false),
