// Database facade for supervisor.db (read-only, mixed-lane).
// Opens a shared read path once, then re-exports typed query helpers from queries.mod.

import {
  queryErr,
} from './db_types.mod';

import {
  queryListProjects as qQueryListProjects,
  queryGetProject as qQueryGetProject,
  queryListWorkers as qQueryListWorkers,
  queryGetWorker as qQueryGetWorker,
  queryGetWorkerBySession as qQueryGetWorkerBySession,
  queryListEvents as qQueryListEvents,
  queryListSessions as qQueryListSessions,
  queryGetSession as qQueryGetSession,
  queryListMessages as qQueryListMessages,
  queryGetMessage as qQueryGetMessage,
  queryListPlans as qQueryListPlans,
  queryGetPlan as qQueryGetPlan,
  queryListPhases as qQueryListPhases,
  queryGetPhase as qQueryGetPhase,
  queryListTasks as qQueryListTasks,
  queryGetTask as qQueryGetTask,
  queryListWorkerAssignments as qQueryListWorkerAssignments,
  queryGetWorkerAssignment as qQueryGetWorkerAssignment,
  queryListViolationLog as qQueryListViolationLog,
  queryGetViolationLog as qQueryGetViolationLog,
  querySearchMessages as qQuerySearchMessages,
  querySearchMessagesBySession as qQuerySearchMessagesBySession,
} from './queries.mod';

const FALLBACK_UID = '1000';
const SUPERVISOR_DB_RELATIVE = '/claude-sessions/supervisor.db';
const SUPERVISOR_DB_PREFIX = '/run/user/';
const DB_OPEN_QUERY = 'SELECT 1 as open_probe';

var dbPath = buildDefaultDbPath();
var dbOpen = 0;
var dbLastError = '';

function trimText(value) {
  if (typeof value === 'string') {
    if (value.trim) return value.trim();
    return value;
  }
  return '';
}

function resolveUid() {
  if (typeof __getenv !== 'function') {
    // TODO(claude-stitch): host function __getenv unavailable; fallback UID is hard-coded to 1000.
    return FALLBACK_UID;
  }

  var envUid = trimText(__getenv('UID'));
  if (envUid.length > 0) return envUid;

  var fallback = trimText(__getenv('UID_NUMBER'));
  if (fallback.length > 0) return fallback;

  return FALLBACK_UID;
}

function buildDefaultDbPath() {
  return SUPERVISOR_DB_PREFIX + resolveUid() + SUPERVISOR_DB_RELATIVE;
}

function normalizeDbPath(path) {
  var p = trimText(path);
  if (p.length === 0) return '';
  return p;
}

function probe(path) {
  if (typeof __db_query !== 'function') return 0;
  try {
    var raw = __db_query(path, DB_OPEN_QUERY);
    return typeof raw === 'string' && raw.length > 0 ? 1 : 0;
  } catch (e) {
    return 0;
  }
}

function open(path) {
  var nextPath = normalizeDbPath(path);
  if (nextPath.length === 0) {
    nextPath = dbPath;
  }

  if (nextPath.length === 0) {
    dbOpen = 0;
    dbLastError = 'database path is missing';
    return queryErr('INVALID_DB_PATH', dbLastError, 'dbPath');
  }

  if (probe(nextPath) === 0) {
    dbOpen = 0;
    dbLastError = 'unable to open or read supervisor database at ' + nextPath;
    return queryErr('DB_OPEN_ERROR', dbLastError, 'dbPath');
  }

  dbPath = nextPath;
  dbOpen = 1;
  dbLastError = '';
  return { ok: 1, data: [{ path: dbPath }], error: null };
}

function close() {
  dbOpen = 0;
  return { ok: 1, data: [], error: null };
}

function isOpen() {
  return dbOpen;
}

function getDbPath() {
  return dbPath;
}

function setDbPath(path) {
  var nextPath = normalizeDbPath(path);
  if (nextPath.length === 0) {
    return queryErr('INVALID_DB_PATH', 'database path is missing', 'dbPath');
  }

  dbPath = nextPath;
  dbOpen = 0;
  dbLastError = '';
  return { ok: 1, data: [{ path: dbPath }], error: null };
}

function ensureOpen(path) {
  var requested = normalizeDbPath(path);
  if (requested.length > 0 && requested !== dbPath) {
    var switched = open(requested);
    if (switched.ok !== 1) return '';
  } else {
    if (dbOpen === 0) {
      var initial = open(dbPath);
      if (initial.ok !== 1) return '';
    }
  }
  return dbPath;
}

function lastError() {
  return dbLastError;
}

function queryListProjects(limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListProjects(usePath, limit);
}

function queryGetProject(projectId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetProject(usePath, projectId);
}

function queryListWorkers(projectId, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListWorkers(usePath, projectId, limit);
}

function queryGetWorker(workerId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetWorker(usePath, workerId);
}

function queryGetWorkerBySession(sessionId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetWorkerBySession(usePath, sessionId);
}

function queryListEvents(projectId, workerId, eventType, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListEvents(usePath, projectId, workerId, eventType, limit);
}

function queryListSessions(projectId, workerId, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListSessions(usePath, projectId, workerId, limit);
}

function queryGetSession(sessionId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetSession(usePath, sessionId);
}

function queryListMessages(sessionId, role, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListMessages(usePath, sessionId, role, limit);
}

function queryGetMessage(messageId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetMessage(usePath, messageId);
}

function queryListPlans(projectId, status, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListPlans(usePath, projectId, status, limit);
}

function queryGetPlan(planId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetPlan(usePath, planId);
}

function queryListPhases(planId, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListPhases(usePath, planId, limit);
}

function queryGetPhase(phaseId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetPhase(usePath, phaseId);
}

function queryListTasks(projectId, phaseId, status, assignedWorkerId, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListTasks(usePath, projectId, phaseId, status, assignedWorkerId, limit);
}

function queryGetTask(taskId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetTask(usePath, taskId);
}

function queryListWorkerAssignments(planId, taskId, workerId, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListWorkerAssignments(usePath, planId, taskId, workerId, limit);
}

function queryGetWorkerAssignment(assignmentId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetWorkerAssignment(usePath, assignmentId);
}

function queryListViolationLog(ruleId, workerId, taskId, unresolvedOnly, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryListViolationLog(usePath, ruleId, workerId, taskId, unresolvedOnly, limit);
}

function queryGetViolationLog(logId, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQueryGetViolationLog(usePath, logId);
}

function querySearchMessages(matchQuery, projectId, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQuerySearchMessages(usePath, matchQuery, projectId, limit);
}

function querySearchMessagesBySession(sessionId, matchQuery, limit, path) {
  var usePath = ensureOpen(path);
  if (usePath.length === 0) return queryErr('DB_NOT_OPEN', dbLastError, 'dbPath');
  return qQuerySearchMessagesBySession(usePath, sessionId, matchQuery, limit);
}

open();

export {
  open,
  close,
  isOpen,
  getDbPath,
  setDbPath,
  lastError,
  queryListProjects,
  queryGetProject,
  queryListWorkers,
  queryGetWorker,
  queryGetWorkerBySession,
  queryListEvents,
  queryListSessions,
  queryGetSession,
  queryListMessages,
  queryGetMessage,
  queryListPlans,
  queryGetPlan,
  queryListPhases,
  queryGetPhase,
  queryListTasks,
  queryGetTask,
  queryListWorkerAssignments,
  queryGetWorkerAssignment,
  queryListViolationLog,
  queryGetViolationLog,
  querySearchMessages,
  querySearchMessagesBySession,
};
