// Query strings and typed readers for /run/user/$UID/claude-sessions/supervisor.db
// Read-only, mixed-lane TSX. Output rows are mapped through db_types constructors.

import {
  queryOk,
  queryErr,
  toInt,
  toText,
  projectRow,
  workerRow,
  eventRow,
  sessionRow,
  messageRow,
  messageSearchRow,
  planRow,
  phaseRow,
  taskRow,
  workerAssignmentRow,
  violationLogRow,
} from './db_types.mod';

const DEFAULT_LIMIT = 200;
const MAX_LIMIT = 1000;

function safeLimit(value) {
  var limit = toInt(value, DEFAULT_LIMIT);
  if (limit <= 0) limit = DEFAULT_LIMIT;
  if (limit > MAX_LIMIT) limit = MAX_LIMIT;
  return limit;
}

function isReadableDbPath(dbPath) {
  return typeof dbPath === 'string' && dbPath.length > 0;
}

function textToSql(value) {
  return toText(value, '').replace(/'/g, "''");
}

function executeRows(dbPath, sql, mapFn, fallbackName) {
  if (!isReadableDbPath(dbPath)) {
    return queryErr('INVALID_DB_PATH', 'database path is missing', fallbackName || 'db_path');
  }
  if (typeof __db_query !== 'function') {
    return queryErr('DB_QUERY_UNAVAILABLE', '__db_query host function is unavailable', fallbackName || 'runtime');
  }

  var raw = '';
  try {
    raw = __db_query(dbPath, sql);
  } catch (err) {
    return queryErr(
      'DB_QUERY_FAILED',
      'query execution threw',
      toText(err && err.message, toText(err, 'unknown')),
    );
  }

  if (!raw) return queryOk([]);
  if (typeof raw !== 'string') raw = toText(raw, '');
  raw = raw.trim();
  if (raw.length === 0) return queryOk([]);

  var lines = raw.split('\n');
  var out = [];
  var i;
  for (i = 0; i < lines.length; i = i + 1) {
    var line = lines[i];
    if (line === '') continue;

    var parsed = null;
    try {
      if (line.indexOf('|') >= 0) {
        var parts = line.split('|');
        if (parts.length > 0 && parts[0].length > 0) {
          parsed = JSON.parse(parts[0]);
        }
      } else {
        parsed = JSON.parse(line);
      }
    } catch (err) {
      parsed = null;
    }

    if (parsed !== null && typeof parsed === 'object' && parsed !== undefined) {
      if (parsed.row !== undefined) parsed = parsed.row;
      if (mapFn) {
        out.push(mapFn(parsed));
      } else {
        out.push(parsed);
      }
      continue;
    }

    // Fallback: one-delimited raw mode for unexpected host output formats.
    out.push(line);
  }

  return queryOk(out);
}

const SQL_PROJECTS = "SELECT json_object('id', id, 'name', COALESCE(name, ''), 'description', COALESCE(description, ''), 'repo_path', COALESCE(repo_path, ''), 'created_at', COALESCE(created_at, ''), 'updated_at', COALESCE(updated_at, '')) as row FROM projects";

const SQL_WORKERS = "SELECT json_object('id', id, 'project_id', project_id, 'pane_id', pane_id, 'session_id', COALESCE(session_id, ''), 'status', COALESCE(status, ''), 'current_task_id', COALESCE(current_task_id, 0), 'registered_at', COALESCE(registered_at, ''), 'last_seen_at', COALESCE(last_seen_at, '')) as row FROM workers";

const SQL_EVENTS = "SELECT json_object('id', id, 'project_id', project_id, 'worker_id', COALESCE(worker_id, 0), 'event_type', COALESCE(event_type, ''), 'payload_json', COALESCE(payload_json, '{}'), 'created_at', COALESCE(created_at, '')) as row FROM events";

const SQL_SESSIONS = "SELECT json_object('id', id, 'project_id', project_id, 'worker_id', COALESCE(worker_id, 0), 'jsonl_path', COALESCE(jsonl_path, ''), 'started_at', COALESCE(started_at, ''), 'ended_at', COALESCE(ended_at, '')) as row FROM sessions";

const SQL_MESSAGES = "SELECT json_object('id', id, 'session_id', session_id, 'role', COALESCE(role, ''), 'content', COALESCE(content, ''), 'timestamp', COALESCE(timestamp, '')) as row FROM messages";

const SQL_PLANS = "SELECT json_object('id', id, 'project_id', project_id, 'title', COALESCE(title, ''), 'status', COALESCE(status, ''), 'goal', COALESCE(goal, ''), 'motivation', COALESCE(motivation, ''), 'approach', COALESCE(approach, ''), 'constraints', COALESCE(constraints, '[]'), 'non_goals', COALESCE(non_goals, '[]'), 'key_decisions', COALESCE(key_decisions, '[]'), 'starting_point', COALESCE(starting_point, '[]'), 'known_problems', COALESCE(known_problems, '[]'), 'dependencies', COALESCE(dependencies, '[]'), 'risks', COALESCE(risks, '[]'), 'file_map', COALESCE(file_map, '[]'), 'boundaries', COALESCE(boundaries, '[]'), 'parallel_tracks', COALESCE(parallel_tracks, '[]'), 'critical_path', COALESCE(critical_path, '[]'), 'max_concurrent_workers', COALESCE(max_concurrent_workers, 1), 'shared_files', COALESCE(shared_files, '[]'), 'done_criteria', COALESCE(done_criteria, '[]'), 'rollback_plan', COALESCE(rollback_plan, ''), 'changelog_entry', COALESCE(changelog_entry, ''), 'commit_trail', COALESCE(commit_trail, '[]'), 'notes', COALESCE(notes, '[]'), 'created_by', COALESCE(created_by, 'user'), 'created_at', COALESCE(created_at, ''), 'updated_at', COALESCE(updated_at, '')) as row FROM plans";

const SQL_PHASES = "SELECT json_object('id', id, 'plan_id', plan_id, 'phase_number', phase_number, 'title', COALESCE(title, ''), 'description', COALESCE(description, ''), 'status', COALESCE(status, ''), 'gate_description', COALESCE(gate_description, ''), 'depends_on', COALESCE(depends_on, '[]'), 'created_at', COALESCE(created_at, ''), 'updated_at', COALESCE(updated_at, '')) as row FROM phases";

const SQL_TASKS = "SELECT json_object('id', id, 'project_id', project_id, 'phase_id', COALESCE(phase_id, 0), 'title', COALESCE(title, ''), 'spec_text', COALESCE(spec_text, ''), 'status', COALESCE(status, ''), 'priority', COALESCE(priority, 3), 'objective', COALESCE(objective, ''), 'context', COALESCE(context, ''), 'acceptance_criteria', COALESCE(acceptance_criteria, '[]'), 'known_exists', COALESCE(known_exists, '[]'), 'known_gaps', COALESCE(known_gaps, '[]'), 'tests', COALESCE(tests, '[]'), 'visual_verification', COALESCE(visual_verification, ''), 'docs_required', COALESCE(docs_required, '[]'), 'commit_trail', COALESCE(commit_trail, '[]'), 'changelog_entry', COALESCE(changelog_entry, ''), 'max_workers', COALESCE(max_workers, 1), 'assigned_worker_id', COALESCE(assigned_worker_id, 0), 'file_boundaries', COALESCE(file_boundaries, '[]'), 'conflict_zones', COALESCE(conflict_zones, '[]'), 'blocked_by', COALESCE(blocked_by, ''), 'created_by', COALESCE(created_by, 'user'), 'created_at', COALESCE(created_at, ''), 'updated_at', COALESCE(updated_at, '')) as row FROM tasks";

const SQL_WORKER_ASSIGNMENTS = "SELECT json_object('id', id, 'plan_id', COALESCE(plan_id, 0), 'task_id', COALESCE(task_id, 0), 'worker_id', worker_id, 'assigned_steps', COALESCE(assigned_steps, '[]'), 'created_at', COALESCE(created_at, '')) as row FROM worker_assignments";

const SQL_VIOLATION_LOG = "SELECT json_object('id', id, 'rule_id', rule_id, 'worker_id', COALESCE(worker_id, 0), 'task_id', COALESCE(task_id, 0), 'matched_text', COALESCE(matched_text, ''), 'action_taken', COALESCE(action_taken, ''), 'resolved', COALESCE(resolved, 0), 'resolved_at', COALESCE(resolved_at, ''), 'created_at', COALESCE(created_at, '')) as row FROM violation_log";

function queryListProjects(dbPath, limit) {
  return executeRows(dbPath, SQL_PROJECTS + ' ORDER BY updated_at DESC LIMIT ' + safeLimit(limit), projectRow, 'projects');
}

function queryGetProject(dbPath, projectId) {
  var pid = toInt(projectId, 0);
  if (pid <= 0) {
    return queryErr('INVALID_PROJECT_ID', 'project id must be a positive integer', 'projectId');
  }
  return executeRows(dbPath, SQL_PROJECTS + ' WHERE id = ' + pid + ' LIMIT 1', projectRow, 'projects');
}

function queryListWorkers(dbPath, projectId, limit) {
  var sql = SQL_WORKERS;
  var pid = toInt(projectId, 0);
  if (pid > 0) {
    sql = sql + ' WHERE project_id = ' + pid;
  }
  return executeRows(dbPath, sql + ' ORDER BY last_seen_at DESC LIMIT ' + safeLimit(limit), workerRow, 'workers');
}

function queryGetWorker(dbPath, workerId) {
  var wid = toInt(workerId, 0);
  if (wid <= 0) {
    return queryErr('INVALID_WORKER_ID', 'worker id must be a positive integer', 'workerId');
  }
  return executeRows(dbPath, SQL_WORKERS + ' WHERE id = ' + wid + ' LIMIT 1', workerRow, 'workers');
}

function queryGetWorkerBySession(dbPath, sessionId) {
  var sid = toText(sessionId, '');
  if (sid.length === 0) {
    return queryErr('INVALID_SESSION_ID', 'session_id must be a non-empty string', 'sessionId');
  }
  return executeRows(dbPath, SQL_WORKERS + " WHERE session_id = '" + textToSql(sid) + "' LIMIT 1", workerRow, 'workers');
}

function queryListEvents(dbPath, projectId, workerId, eventType, limit) {
  var sql = SQL_EVENTS;
  var pid = toInt(projectId, 0);
  var wid = toInt(workerId, 0);
  var whereCount = 0;
  var filters = [];
  if (pid > 0) filters.push('project_id = ' + pid);
  if (wid > 0) filters.push('worker_id = ' + wid);
  if (eventType !== undefined && eventType !== null) {
    var et = toText(eventType, '');
    if (et.length > 0) filters.push("event_type = '" + textToSql(et) + "'");
  }
  if (filters.length > 0) {
    sql = sql + ' WHERE ' + filters[0] + (filters.length > 1 ? (' AND ' + filters[1]) : '');
    if (filters.length > 2) {
      var i;
      for (i = 2; i < filters.length; i = i + 1) {
        sql = sql + ' AND ' + filters[i];
      }
    }
  }
  return executeRows(dbPath, sql + ' ORDER BY created_at DESC LIMIT ' + safeLimit(limit), eventRow, 'events');
}

function queryListSessions(dbPath, projectId, workerId, limit) {
  var sql = SQL_SESSIONS;
  var pid = toInt(projectId, 0);
  var wid = toInt(workerId, 0);
  var conds = [];
  if (pid > 0) conds.push('project_id = ' + pid);
  if (wid > 0) conds.push('worker_id = ' + wid);
  if (conds.length > 0) {
    sql = sql + ' WHERE ' + conds[0];
    if (conds.length > 1) {
      sql = sql + ' AND ' + conds[1];
    }
  }
  return executeRows(dbPath, sql + ' ORDER BY id DESC LIMIT ' + safeLimit(limit), sessionRow, 'sessions');
}

function queryGetSession(dbPath, sessionId) {
  var sid = toInt(sessionId, 0);
  if (sid <= 0) {
    return queryErr('INVALID_SESSION_ID', 'session id must be a positive integer', 'sessionId');
  }
  return executeRows(dbPath, SQL_SESSIONS + ' WHERE id = ' + sid + ' LIMIT 1', sessionRow, 'sessions');
}

function queryListMessages(dbPath, sessionId, role, limit) {
  var sql = SQL_MESSAGES;
  var sid = toInt(sessionId, 0);
  var conds = [];
  if (sid > 0) conds.push('session_id = ' + sid);
  if (role !== undefined && role !== null) {
    var r = toText(role, '');
    if (r.length > 0) conds.push("role = '" + textToSql(r) + "'");
  }
  if (conds.length > 0) {
    sql = sql + ' WHERE ' + conds[0];
    if (conds.length > 1) sql = sql + ' AND ' + conds[1];
  }
  return executeRows(dbPath, sql + ' ORDER BY id DESC LIMIT ' + safeLimit(limit), messageRow, 'messages');
}

function queryGetMessage(dbPath, messageId) {
  var mid = toInt(messageId, 0);
  if (mid <= 0) {
    return queryErr('INVALID_MESSAGE_ID', 'message id must be a positive integer', 'messageId');
  }
  return executeRows(dbPath, SQL_MESSAGES + ' WHERE id = ' + mid + ' LIMIT 1', messageRow, 'messages');
}

function queryListPlans(dbPath, projectId, status, limit) {
  var sql = SQL_PLANS;
  var pid = toInt(projectId, 0);
  var conds = [];
  if (pid > 0) conds.push('project_id = ' + pid);
  if (status !== undefined && status !== null) {
    var s = toText(status, '');
    if (s.length > 0) conds.push("status = '" + textToSql(s) + "'");
  }
  if (conds.length > 0) {
    sql = sql + ' WHERE ' + conds[0];
    if (conds.length > 1) sql = sql + ' AND ' + conds[1];
  }
  return executeRows(dbPath, sql + ' ORDER BY updated_at DESC LIMIT ' + safeLimit(limit), planRow, 'plans');
}

function queryGetPlan(dbPath, planId) {
  var pid = toInt(planId, 0);
  if (pid <= 0) {
    return queryErr('INVALID_PLAN_ID', 'plan id must be a positive integer', 'planId');
  }
  return executeRows(dbPath, SQL_PLANS + ' WHERE id = ' + pid + ' LIMIT 1', planRow, 'plans');
}

function queryListPhases(dbPath, planId, limit) {
  var sql = SQL_PHASES;
  var pid = toInt(planId, 0);
  if (pid > 0) sql = sql + ' WHERE plan_id = ' + pid;
  return executeRows(dbPath, sql + ' ORDER BY plan_id, phase_number LIMIT ' + safeLimit(limit), phaseRow, 'phases');
}

function queryGetPhase(dbPath, phaseId) {
  var pid = toInt(phaseId, 0);
  if (pid <= 0) {
    return queryErr('INVALID_PHASE_ID', 'phase id must be a positive integer', 'phaseId');
  }
  return executeRows(dbPath, SQL_PHASES + ' WHERE id = ' + pid + ' LIMIT 1', phaseRow, 'phases');
}

function queryListTasks(dbPath, projectId, phaseId, status, assignedWorkerId, limit) {
  var sql = SQL_TASKS;
  var conds = [];
  var pid = toInt(projectId, 0);
  var phid = toInt(phaseId, 0);
  var aid = toInt(assignedWorkerId, 0);
  if (pid > 0) conds.push('project_id = ' + pid);
  if (phid > 0) conds.push('phase_id = ' + phid);
  if (aid > 0) conds.push('assigned_worker_id = ' + aid);
  if (status !== undefined && status !== null) {
    var s = toText(status, '');
    if (s.length > 0) conds.push("status = '" + textToSql(s) + "'");
  }

  if (conds.length > 0) {
    var i;
    sql = sql + ' WHERE ' + conds[0];
    for (i = 1; i < conds.length; i = i + 1) {
      sql = sql + ' AND ' + conds[i];
    }
  }

  return executeRows(
    dbPath,
    sql + ' ORDER BY status, priority, id DESC LIMIT ' + safeLimit(limit),
    taskRow,
    'tasks',
  );
}

function queryGetTask(dbPath, taskId) {
  var tid = toInt(taskId, 0);
  if (tid <= 0) {
    return queryErr('INVALID_TASK_ID', 'task id must be a positive integer', 'taskId');
  }
  return executeRows(dbPath, SQL_TASKS + ' WHERE id = ' + tid + ' LIMIT 1', taskRow, 'tasks');
}

function queryListWorkerAssignments(dbPath, planId, taskId, workerId, limit) {
  var sql = SQL_WORKER_ASSIGNMENTS;
  var conds = [];
  var pid = toInt(planId, 0);
  var tid = toInt(taskId, 0);
  var wid = toInt(workerId, 0);
  if (pid > 0) conds.push('plan_id = ' + pid);
  if (tid > 0) conds.push('task_id = ' + tid);
  if (wid > 0) conds.push('worker_id = ' + wid);

  if (conds.length > 0) {
    var i;
    sql = sql + ' WHERE ' + conds[0];
    for (i = 1; i < conds.length; i = i + 1) {
      sql = sql + ' AND ' + conds[i];
    }
  }

  return executeRows(dbPath, sql + ' ORDER BY id DESC LIMIT ' + safeLimit(limit), workerAssignmentRow, 'worker_assignments');
}

function queryGetWorkerAssignment(dbPath, assignmentId) {
  var aid = toInt(assignmentId, 0);
  if (aid <= 0) {
    return queryErr('INVALID_ASSIGNMENT_ID', 'assignment id must be a positive integer', 'assignmentId');
  }
  return executeRows(dbPath, SQL_WORKER_ASSIGNMENTS + ' WHERE id = ' + aid + ' LIMIT 1', workerAssignmentRow, 'worker_assignments');
}

function queryListViolationLog(dbPath, ruleId, workerId, taskId, unresolvedOnly, limit) {
  var sql = SQL_VIOLATION_LOG;
  var conds = [];
  var rid = toInt(ruleId, 0);
  var wid = toInt(workerId, 0);
  var tid = toInt(taskId, 0);
  if (rid > 0) conds.push('rule_id = ' + rid);
  if (wid > 0) conds.push('worker_id = ' + wid);
  if (tid > 0) conds.push('task_id = ' + tid);
  if (unresolvedOnly) conds.push('resolved = 0');
  if (conds.length > 0) {
    var i;
    sql = sql + ' WHERE ' + conds[0];
    for (i = 1; i < conds.length; i = i + 1) {
      sql = sql + ' AND ' + conds[i];
    }
  }
  return executeRows(dbPath, sql + ' ORDER BY created_at DESC LIMIT ' + safeLimit(limit), violationLogRow, 'violation_log');
}

function queryGetViolationLog(dbPath, violationLogId) {
  var vid = toInt(violationLogId, 0);
  if (vid <= 0) {
    return queryErr('INVALID_VIOLATION_LOG_ID', 'violation_log id must be a positive integer', 'violationLogId');
  }
  return executeRows(dbPath, SQL_VIOLATION_LOG + ' WHERE id = ' + vid + ' LIMIT 1', violationLogRow, 'violation_log');
}

function querySearchMessages(dbPath, matchQuery, projectId, limit) {
  var q = toText(matchQuery, '');
  if (q.length === 0) {
    return queryErr('INVALID_FTS_QUERY', 'search text must be non-empty', 'matchQuery');
  }
  var pid = toInt(projectId, 0);
  var safe = textToSql(q).replace(/"/g, '\"');
  var cond = "WHERE messages_fts MATCH '" + safe + "'";
  if (pid > 0) {
    cond = cond + " AND s.project_id = " + pid;
  }

  var sql =
    "SELECT json_object(\"id\", m.id, \"message_id\", m.id, \"session_id\", m.session_id, \"role\", COALESCE(m.role, ''), \"content_preview\", substr(m.content, 1, 240), \"timestamp\", COALESCE(m.timestamp, ''), \"project_id\", COALESCE(s.project_id, 0), \"jsonl_path\", COALESCE(s.jsonl_path, ''), \"rank\", bm25(messages_fts)) as row " +
    'FROM messages_fts JOIN messages m ON m.id = messages_fts.rowid JOIN sessions s ON s.id = m.session_id ' +
    cond +
    ' ORDER BY rank LIMIT ' +
    safeLimit(limit);

  return executeRows(dbPath, sql, messageSearchRow, 'messages_fts');
}

function querySearchMessagesBySession(dbPath, sessionId, matchQuery, limit) {
  var sid = toInt(sessionId, 0);
  if (sid <= 0) {
    return queryErr('INVALID_SESSION_ID', 'session id must be a positive integer', 'sessionId');
  }
  var q = toText(matchQuery, '');
  if (q.length === 0) {
    return queryErr('INVALID_FTS_QUERY', 'search text must be non-empty', 'matchQuery');
  }
  var safe = textToSql(q).replace(/\"/g, '\\"');
  var sql =
    "SELECT json_object('id', m.id, 'message_id', m.id, 'session_id', m.session_id, 'role', COALESCE(m.role, ''), 'content_preview', substr(m.content, 1, 240), 'timestamp', COALESCE(m.timestamp, ''), 'project_id', COALESCE(s.project_id, 0), 'jsonl_path', COALESCE(s.jsonl_path, ''), 'rank', bm25(messages_fts)) as row " +
    'FROM messages_fts ' +
    'JOIN messages m ON m.id = messages_fts.rowid ' +
    'JOIN sessions s ON s.id = m.session_id ' +
    "WHERE messages_fts MATCH '" +
    safe +
    "' AND m.session_id = " +
    sid +
    ' ORDER BY rank LIMIT ' +
    safeLimit(limit);

  return executeRows(dbPath, sql, messageSearchRow, 'messages_fts');
}

// Optional extension point when sqlite-vec/embedding columns land.
// TODO(claude-stitch): add nearest-neighbor query helpers for M3A vector rows once an extension is exposed to DB.
