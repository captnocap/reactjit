function transcriptForSession(entries, sessionId) {
  var result = entries.filter(function(entry) {
    return entry.sessionId === sessionId;
  });

  if (result.length == 0) return [];
  return result;
}

function latestPromptForSession(prompts, sessionId) {
  var filtered = prompts.filter(function(prompt) {
    return prompt.sessionId === sessionId;
  });

  if (filtered.length == 0) return null;
  return filtered[filtered.length - 1];
}

function WorkerTile(props) {
  // Parent always provides session={...}; the previous fallback
  // (`|| mockCodeSessions[0]`) leaked a smith CONST_OA placeholder when
  // WorkerTile was inlined into the cockpit's sessions.map() iteration.
  var session = props.session;
  var workerMode = props.mode || session.mode || 'idle';
  var workerAffect = props.affect || getWorkerAffect(session.id) || session.affect || 'confident';

  if (props.mode == undefined) {
    if (session.status === 'running') workerMode = 'streaming';
    if (session.status === 'waiting_input') workerMode = 'thinking';
    if (session.status === 'starting') workerMode = 'tool-use';
    if (session.status === 'paused') workerMode = 'stuck';
    if (session.status === 'stopped') workerMode = 'idle';
  }

  var worker = {
    id: session.id,
    name: session.name || session.projectPath,
    model: session.model || 'unknown',
    mode: workerMode,
    affect: workerAffect,
    projectPath: session.projectPath,
    status: session.status,
    updatedAt: session.updatedAt,
  };

  var entries = props.entries || transcriptForSession(mockTranscriptEntries, session.id);

  var prompt = props.currentPrompt || latestPromptForSession(mockInputPrompts, session.id);

  return (
    <C.WorkerTile>
      <WorkerTileHeader worker={worker} showMode={props.showMode == 1 ? 1 : 0} pulse={props.pulse == 1 ? 1 : 0} />
      <WorkerTileTranscript entries={entries} />

      {prompt != null && props.showPrompt != 0 && (
        <C.WorkerTilePromptRow>
          <C.WorkerTilePromptLabel>
            Last prompt · {prompt.type}
          </C.WorkerTilePromptLabel>
          <C.WorkerTilePromptText>{prompt.message}</C.WorkerTilePromptText>
        </C.WorkerTilePromptRow>
      )}
    </C.WorkerTile>
  );
}

export {
  WorkerTile,
  mockCodeSessions,
  mockTranscriptEntries,
  mockInputPrompts,
};
