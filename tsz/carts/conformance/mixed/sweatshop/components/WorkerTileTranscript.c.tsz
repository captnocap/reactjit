// Worker tile transcript section — short recent worker-visible stream

function lineTheme(entryType) {
  if (entryType === 'user_input') {
    return {
      label: 'user',
      color: '#7ee787',
      bg: '#0f1f13',
      border: '#1f3f2c',
    };
  }

  if (entryType === 'assistant_output') {
    return {
      label: 'assistant',
      color: '#79c0ff',
      bg: '#0f1725',
      border: '#1f3f62',
    };
  }

  if (entryType === 'tool_call') {
    return {
      label: 'tool_call',
      color: '#d2a8ff',
      bg: '#190f33',
      border: '#422f7a',
    };
  }

  if (entryType === 'tool_result') {
    return {
      label: 'tool_result',
      color: '#ffa657',
      bg: '#2b1b08',
      border: '#6b4e18',
    };
  }

  if (entryType === 'file_edit') {
    return {
      label: 'file_edit',
      color: '#58a6ff',
      bg: '#101b2b',
      border: '#174ea0',
    };
  }

  if (entryType === 'compact_marker') {
    return {
      label: 'compact',
      color: '#8b949e',
      bg: '#0f1419',
      border: '#263445',
    };
  }

  return {
    label: 'system',
    color: '#9ca3af',
    bg: '#11161d',
    border: '#2a3139',
  };
}

function TranscriptLine(props) {
  var entry = props.entry || {};
  var stamp = entry.timestamp || '';
  var tone = lineTheme(entry.type || 'system_message');
  var label = tone.label;
  var text = entry.content || '';

  if (entry.type === 'tool_call' && entry.toolCall) {
    text = entry.toolCall.name + (entry.toolCall.input ? ': ' + JSON.stringify(entry.toolCall.input) : '');
  }

  if (entry.type === 'file_edit' && entry.fileEdit) {
    text = entry.fileEdit.path + (entry.fileEdit.operation ? ' (' + entry.fileEdit.operation + ')' : '');
    if (entry.fileEdit.additions !== undefined && entry.fileEdit.deletions !== undefined) {
      text = text + ' · +' + entry.fileEdit.additions + ' / -' + entry.fileEdit.deletions;
    }
  }

  return (
    <C.WorkerTileTranscriptLine style={{ backgroundColor: tone.bg, borderColor: tone.border }}>
      <C.WorkerTileTranscriptLineMeta>
        <C.WorkerTileTranscriptLineBadge style={{ color: tone.color, borderColor: tone.color }}>
          {label}
        </C.WorkerTileTranscriptLineBadge>
        {stamp && <C.WorkerTileTranscriptLineTime>{stamp}</C.WorkerTileTranscriptLineTime>}
      </C.WorkerTileTranscriptLineMeta>
      <C.WorkerTileTranscriptLineText>{text}</C.WorkerTileTranscriptLineText>
    </C.WorkerTileTranscriptLine>
  );
}

function WorkerTileTranscript(props) {
  var entries = props.entries || [];

  if (entries.length == 0) {
    return (
      <C.WorkerTileTranscript>
        <C.WorkerTileTranscriptHeader>
          <C.WorkerTileTranscriptTitle>Recent transcript</C.WorkerTileTranscriptTitle>
          <C.WorkerTileTranscriptMeta>No data</C.WorkerTileTranscriptMeta>
        </C.WorkerTileTranscriptHeader>
        <C.WorkerTileTranscriptList>
          <C.WorkerTileTranscriptEmpty>No transcript entries yet</C.WorkerTileTranscriptEmpty>
        </C.WorkerTileTranscriptList>
      </C.WorkerTileTranscript>
    );
  }

  var visible = entries;
  if (entries.length > 6) {
    visible = entries.slice(entries.length - 6);
  }

  return (
    <C.WorkerTileTranscript>
      <C.WorkerTileTranscriptHeader>
        <C.WorkerTileTranscriptTitle>Recent transcript</C.WorkerTileTranscriptTitle>
        <C.WorkerTileTranscriptMeta>{entries.length} lines</C.WorkerTileTranscriptMeta>
      </C.WorkerTileTranscriptHeader>

      <C.WorkerTileTranscriptList>
        {visible.map(function(entry) {
          return <TranscriptLine key={entry.id} entry={entry} />;
        })}
      </C.WorkerTileTranscriptList>
    </C.WorkerTileTranscript>
  );
}

export { WorkerTileTranscript };
