// State board tile — externalized supervisor memory for worker/plan state

import { sampleStateBoard, liveStateBoard } from '../data/state_board.mod';

function statusTheme(status) {
  var color = '#9ca3af';
  var bg = 'rgba(156, 163, 175, 0.08)';
  var border = '#475569';

  if (status === 'active') {
    color = '#7ee787';
    bg = 'rgba(126, 231, 135, 0.12)';
    border = '#2ea043';
  } else if (status === 'thinking' || status === 'idle') {
    color = '#79c0ff';
    bg = 'rgba(121, 192, 255, 0.12)';
    border = '#1f6feb';
  } else if (status === 'stuck') {
    color = '#ff7b72';
    bg = 'rgba(255, 123, 114, 0.12)';
    border = '#d85e58';
  } else if (status === 'tool-use') {
    color = '#d2a8ff';
    bg = 'rgba(210, 168, 255, 0.12)';
    border = '#a371f7';
  }

  return { color: color, bg: bg, border: border };
}

function sectionTheme(status) {
  var color = '#f0f6fc';
  var bg = 'rgba(240, 246, 252, 0.08)';
  var border = '#24334a';

  if (status === 'blocked') {
    color = '#f7aef8';
    bg = 'rgba(247, 174, 248, 0.12)';
    border = '#ae56bf';
  } else if (status === 'done' || status === 'complete' || status === 'completed') {
    color = '#7ee787';
    bg = 'rgba(126, 231, 135, 0.12)';
    border = '#2ea043';
  } else if (status === 'review') {
    color = '#79c0ff';
    bg = 'rgba(121, 192, 255, 0.10)';
    border = '#1f6feb';
  } else if (status === 'error' || status === 'failed') {
    color = '#ff7b72';
    bg = 'rgba(255, 123, 114, 0.12)';
    border = '#d85e58';
  }

  return { color: color, bg: bg, border: border };
}

function asPercent(done, total) {
  var td = total;
  var dd = done;
  if (td <= 0 || dd < 0) return 0;
  if (dd > td) dd = td;
  return Math.floor((dd / td) * 100);
}

function trustLabel(value) {
  var safe = value;
  if (safe < 0) safe = 0;
  if (safe > 1) safe = 1;
  return Math.round(safe * 100);
}

function formatRelative(isoText) {
  var now = Date.now();
  var parsed = Date.parse(isoText);
  if (Number.isNaN(parsed)) return 'never';

  var delta = Math.floor((now - parsed) / 1000);
  if (delta < 0) delta = 0;

  if (delta < 60) return delta + 's ago';
  if (delta < 3600) return Math.floor(delta / 60) + 'm ago';
  return Math.floor(delta / 3600) + 'h ago';
}

function workerListFromBoard(workers) {
  var out = [];
  if (!workers) return out;
  var names = Object.keys(workers);
  for (var i = 0; i < names.length; i++) {
    var name = names[i];
    var info = workers[name];
    if (!info || typeof info != 'object') continue;

    out.push({
      name: name,
      pane: info.pane,
      model: info.model || 'unknown',
      task: info.task || '',
      status: info.status || 'idle',
      trust: info.trust || 0,
      statusTheme: statusTheme(info.status || 'idle'),
    });
  }
  return out;
}

function sectionRowsFromBoard(sections) {
  var out = [];
  if (!sections) return out;
  var ids = Object.keys(sections);
  for (var i = 0; i < ids.length; i++) {
    var sectionId = ids[i];
    var info = sections[sectionId];
    if (!info || typeof info != 'object') continue;
    out.push({
      id: sectionId,
      worker: info.worker || 'unassigned',
      status: info.status || 'unknown',
      done: info.steps_done || 0,
      total: info.steps_total || 0,
      style: sectionTheme(info.status || 'unknown'),
      pct: asPercent(info.steps_done || 0, info.steps_total || 0),
    });
  }
  return out;
}

function workerSectionProgress(sections, name) {
  var result = { done: 0, total: 0 };
  if (!sections) return result;
  var ids = Object.keys(sections);
  for (var i = 0; i < ids.length; i++) {
    var sec = sections[ids[i]];
    if (sec && sec.worker === name) {
      result.done = sec.steps_done || 0;
      result.total = sec.steps_total || 0;
    }
  }
  return result;
}

function WorkerEntryCard(props) {
  var worker = props.worker;
  var sectionProgress = workerSectionProgress(props.sections, worker.name);
  var pct = asPercent(sectionProgress.done, sectionProgress.total);
  var trust = trustLabel(worker.trust);
  var status = worker.statusTheme;

  return (
    <C.StateBoardWorkerCard>
      <C.StateBoardWorkerHeader>
        <C.StateBoardWorkerName>
          {worker.name}
        </C.StateBoardWorkerName>
        <C.StateBoardBadge style={{ color: status.color, borderColor: status.border, backgroundColor: status.bg }}>
          {worker.status}
        </C.StateBoardBadge>
      </C.StateBoardWorkerHeader>

      <C.StateBoardLine>
        <C.StateBoardLineLabel>Pane {worker.pane}</C.StateBoardLineLabel>
        <C.StateBoardLineLabel>Model {worker.model}</C.StateBoardLineLabel>
        <C.StateBoardLineLabel>Trust {trust}%</C.StateBoardLineLabel>
      </C.StateBoardLine>

      <C.StateBoardTask>{worker.task}</C.StateBoardTask>
      <C.StateBoardTaskMeta>Progress {sectionProgress.done}/{sectionProgress.total}</C.StateBoardTaskMeta>
      <C.StateBoardProgressTrack>
        <C.StateBoardProgressFill style={{ width: pct + '%' }} />
      </C.StateBoardProgressTrack>
    </C.StateBoardWorkerCard>
  );
}

function SectionEntryCard(props) {
  var sec = props.section;
  var st = sec.style;

  return (
    <C.StateBoardSectionCard style={{ backgroundColor: st.bg, borderColor: st.border }}>
      <C.StateBoardSectionHeader>
        <C.StateBoardSectionId>{sec.id}</C.StateBoardSectionId>
        <C.StateBoardBadge style={{ color: st.color, borderColor: st.border, backgroundColor: st.bg }}>
          {sec.status}
        </C.StateBoardBadge>
      </C.StateBoardSectionHeader>
      <C.StateBoardLine>
        <C.StateBoardLineLabel>Assigned: {sec.worker}</C.StateBoardLineLabel>
        <C.StateBoardLineLabel>{sec.done}/{sec.total}</C.StateBoardLineLabel>
        <C.StateBoardLineLabel>{sec.pct}% done</C.StateBoardLineLabel>
      </C.StateBoardLine>
      <C.StateBoardProgressTrack>
        <C.StateBoardProgressFill style={{ width: sec.pct + '%' }} />
      </C.StateBoardProgressTrack>
    </C.StateBoardSectionCard>
  );
}

function StateBoardTile(props) {
  var board = props.board || liveStateBoard() || sampleStateBoard();
  var workers = workerListFromBoard(board.workers || {});
  var sections = sectionRowsFromBoard(board.sections || {});
  var loopStatus = board.loop_status || 'idle';
  var human = board.human_last_active || '';
  var audit = board.last_audit || '';

  if (workers.length == 0) workers = [
    { name: 'Claude Code', pane: 1, model: 'opus', task: 'Idle', status: 'idle', trust: 0.75, statusTheme: statusTheme('idle') },
    { name: 'Codex', pane: 4, model: 'gpt', task: 'Waiting', status: 'waiting', trust: 0.6, statusTheme: statusTheme('idle') },
    { name: 'Kimi', pane: 12, model: 'kimi', task: 'Unassigned', status: 'idle', trust: 0.7, statusTheme: statusTheme('idle') },
  ];

  if (sections.length == 0) sections = [
    { id: 'S1', worker: 'none', status: 'unknown', done: 0, total: 0, pct: 0, style: sectionTheme('unknown') },
  ];

  return (
    <C.StateBoardTile>
      <C.StateBoardHeader>
        <C.StateBoardHeaderLeft>
          <C.StateBoardTitle>State Board</C.StateBoardTitle>
          <C.StateBoardPlan>plan: {board.plan}</C.StateBoardPlan>
        </C.StateBoardHeaderLeft>
        <C.StateBoardHeaderRight>
          <C.StateBoardLoopStatus>loop: {loopStatus}</C.StateBoardLoopStatus>
        </C.StateBoardHeaderRight>
      </C.StateBoardHeader>

      <C.StateBoardMetaRow>
        <C.StateBoardMetaCell>
          <C.StateBoardMetaLabel>human last active</C.StateBoardMetaLabel>
          <C.StateBoardMetaValue>{formatRelative(human)} ({human})</C.StateBoardMetaValue>
        </C.StateBoardMetaCell>
        <C.StateBoardMetaCell>
          <C.StateBoardMetaLabel>last audit</C.StateBoardMetaLabel>
          <C.StateBoardMetaValue>{formatRelative(audit)} ({audit})</C.StateBoardMetaValue>
        </C.StateBoardMetaCell>
      </C.StateBoardMetaRow>

      <C.StateBoardSplit>
        <C.StateBoardPanel>
          <C.StateBoardSectionTitle>Active workers</C.StateBoardSectionTitle>
          <C.StateBoardScroll>
            {workers.map(function(worker) {
              return <WorkerEntryCard key={worker.name} worker={worker} sections={board.sections || {}} />;
            })}
          </C.StateBoardScroll>
        </C.StateBoardPanel>

        <C.StateBoardPanel>
          <C.StateBoardSectionTitle>Plan sections</C.StateBoardSectionTitle>
          <C.StateBoardScroll>
            {sections.map(function(section) {
              return <SectionEntryCard key={section.id} section={section} />;
            })}
          </C.StateBoardScroll>
        </C.StateBoardPanel>
      </C.StateBoardSplit>
    </C.StateBoardTile>
  );
}

export { StateBoardTile };
