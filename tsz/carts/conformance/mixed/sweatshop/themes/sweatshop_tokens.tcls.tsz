// Sweatshop theme-token vocabulary.
// Semantic names used by components/logic: worker status, affect state,
// tier flags, kernel blocks, and A19 cue moments.

theme('sweatshop_tokens', {
  // Core surfaces
  bg: '#0a0f17',
  surface: '#121826',
  panel: '#0f1725',
  panel_border: '#253349',
  panel_divider: '#1f2d43',
  text: '#d7deea',
  text_secondary: '#93a2ba',
  text_muted: '#6c7a8d',
  accent: '#58a6ff',
  success: '#2ea043',
  warning: '#f2cc60',
  error: '#f85149',
  danger: '#ff7b72',
  info: '#a371f7',

  // Tile primitives
  tile_bg: '#0b1220',
  tile_border: '#1f2a3e',
  tile_border_soft: '#202e44',
  tile_text: '#e5ebf5',
  tile_text_muted: '#7f8a99',
  tile_header_bg: '#101a2b',
  tile_shadow: 'rgba(0, 0, 0, 0.35)',

  // Worker tile family
  worker_tile_bg: '#0c121f',
  worker_tile_border: '#1d2940',
  worker_status_active: '#7ee787',
  worker_status_idle: '#7f8a99',
  worker_status_thinking: '#79c0ff',
  worker_status_tool_use: '#d29922',
  worker_status_stuck: '#f5a623',
  worker_status_rationalizing: '#f97316',
  worker_status_dead: '#ff7b72',
  worker_strip_bg: '#090e16',
  worker_strip_border: '#1f2a3a',
  worker_strip_text: '#cdd7e6',

  // Affect lanes
  affect_confident: '#7ee787',
  affect_uncertain: '#58a6ff',
  affect_frustrated: '#f85149',
  affect_stuck: '#f5a623',
  affect_rationalizing: '#c084fc',
  affect_text: '#d7deea',

  // Tiers
  tier_t2_flag: '#f2cc60',
  tier_t3_escalate: '#e4ad18',
  tier_t4_block: '#ff7b72',

  // Kernel block palette (Kernel tile / Tetris stack)
  kernel_block_spec: '#58a6ff',
  kernel_block_worker: '#2ea043',
  kernel_block_rationalization: '#f97316',
  kernel_block_wound: '#ff7b72',
  kernel_block_resonance: '#a371f7',
  kernel_block_anchor: '#8b5cf6',
  kernel_block_text: '#c3d3ec',

  // Memory tile layers
  memory_layer_river: '#7aa2f7',
  memory_layer_feeling: '#f5a623',
  memory_layer_echo: '#c084fc',
  memory_layer_wound: '#ff7b72',
  memory_layer_cooccurrence: '#34d399',

  // Queue / plan / git / autotest / screenshot surfaces
  queue_tile_bg: '#0d1422',
  queue_tile_border: '#1e2b41',
  queue_entry_bg: '#0e1825',
  queue_entry_border: '#2a3b56',
  plan_anchor_bg: '#0f1520',
  plan_section_bg: '#101826',
  plan_section_complete: '#2ea043',
  git_audit_bg: '#0b111c',
  autotest_tile_ok: '#2ea043',
  autotest_tile_warn: '#f2cc60',
  autotest_tile_bad: '#ff7b72',
  screenshot_tile_bg: '#101724',

  // A19 moment colors (visual cue classes)
  file_kill: '#ff7b72',
  fake_green_caught: '#ff5d5f',
  real_green_verified: '#2ea043',
  worker_resign_clean: '#58a6ff',
  worker_resign_dirty: '#f97316',
  worker_stuck: '#f5a623',
  dead_session: '#8b949e',
  tunnel_vision_warning: '#c084fc',
  ralph_injection: '#8b5cf6',
  trust_low: '#ff7b72',
  trust_medium: '#f2cc60',
  trust_high: '#2ea043',
  anti_achievement: '#a78bfa',
  combo_streak: '#22d3ee',
  combo_streak_text: '#d7deea',
  combo_streak_bg: '#172338',
  combo_streak_glow: '#06b6d4',

  // Mood palette (brainstorm / flow)
  mood_furious: '#ef4444',
  mood_frightened: '#f97316',
  mood_neutral: '#60a5fa',
  mood_satisfied: '#4ade80',
  mood_flow_state: '#22d3ee',
