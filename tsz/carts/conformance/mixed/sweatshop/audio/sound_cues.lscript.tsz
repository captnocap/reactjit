// Sweatshop sound cue bridge.
// Lua-backed playback path used for A19 game-feel cues.

// TODO(claude-stitch): wire to actual .wav files
// fake_green_caught -> audio/sweatshop/cues/fake_green_caught.wav
// real_green_verified -> audio/sweatshop/cues/real_green_verified.wav
// worker_resign_clean -> audio/sweatshop/cues/worker_resign_clean.wav
// worker_resign_dirty -> audio/sweatshop/cues/worker_resign_dirty.wav
// worker_stuck -> audio/sweatshop/cues/worker_stuck.wav
// dead_session -> audio/sweatshop/cues/dead_session.wav
// tunnel_vision_warning -> audio/sweatshop/cues/tunnel_vision_warning.wav
// ralph_injection -> audio/sweatshop/cues/ralph_injection.wav
// combo_streak -> audio/sweatshop/cues/combo_streak.wav
// file_kill -> audio/sweatshop/cues/file_kill.wav
// trust_low -> audio/sweatshop/cues/trust_low.wav
// trust_medium -> audio/sweatshop/cues/trust_medium.wav
// trust_high -> audio/sweatshop/cues/trust_high.wav
// anti_achievement -> audio/sweatshop/cues/anti_achievement.wav
// plan_section_complete -> audio/sweatshop/cues/plan_section_complete.wav
<lscript>
-- Cache and runtime state
local initialized = false
local audioReady = false
local backend = nil
local lastPlayedMs = {}
local sourceCache = {}

-- Cue catalog is semantic-first; path bindings are intentionally stubbed.
-- TODO(claude-stitch): wire to actual .wav files
local cueCatalog = {
  fake_green_caught = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/fake_green_caught.wav',
    gain = 0.95,
    cooldown_ms = 1400,
    loop = false,
  },
  real_green_verified = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/real_green_verified.wav',
    gain = 0.72,
    cooldown_ms = 500,
    loop = false,
  },
  worker_resign_clean = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/worker_resign_clean.wav',
    gain = 0.66,
    cooldown_ms = 900,
    loop = false,
  },
  worker_resign_dirty = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/worker_resign_dirty.wav',
    gain = 0.92,
    cooldown_ms = 1300,
    loop = false,
  },
  worker_stuck = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/worker_stuck.wav',
    gain = 0.9,
    cooldown_ms = 25000,
    loop = false,
  },
  dead_session = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/dead_session.wav',
    gain = 0.95,
    cooldown_ms = 2500,
    loop = false,
  },
  tunnel_vision_warning = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/tunnel_vision_warning.wav',
    gain = 0.68,
    cooldown_ms = 8000,
    loop = false,
  },
  ralph_injection = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/ralph_injection.wav',
    gain = 0.8,
    cooldown_ms = 1200,
    loop = false,
  },
  combo_streak = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/combo_streak.wav',
    gain = 0.78,
    cooldown_ms = 300,
    loop = false,
  },
  file_kill = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/file_kill.wav',
    gain = 0.84,
    cooldown_ms = 1100,
    loop = false,
  },
  trust_low = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/trust_low.wav',
    gain = 0.7,
    cooldown_ms = 1800,
    loop = false,
  },
  trust_medium = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/trust_medium.wav',
    gain = 0.66,
    cooldown_ms = 2100,
    loop = false,
  },
  trust_high = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/trust_high.wav',
    gain = 0.74,
    cooldown_ms = 1600,
    loop = false,
  },
  anti_achievement = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/anti_achievement.wav',
    gain = 0.8,
    cooldown_ms = 1800,
    loop = false,
  },
  plan_section_complete = {
    -- TODO(claude-stitch): wire to actual .wav files
    source = 'audio/sweatshop/cues/plan_section_complete.wav',
    gain = 0.84,
    cooldown_ms = 1600,
    loop = false,
  },
}

local function nowMs()
  return math.floor(os.clock() * 1000)
end

local function clamp01(value)
  if value < 0 then return 0 end
  if value > 1 then return 1 end
  return value
end

local function initAudio()
  if initialized then return audioReady end
  initialized = true

  local okLove, loveModule = pcall(require, 'love')
  if okLove and loveModule and loveModule.audio then
    backend = { kind = 'love', api = loveModule }
    audioReady = true
    return 1
  end

  local okEngine, engine = pcall(require, 'lua.audio.engine')
  if okEngine and engine then
    local okInit = pcall(function()
      engine.init({ bridge = nil })
    end)
    if okInit then
      backend = { kind = 'engine', api = engine }
      audioReady = true
      return 1
    end
  end

  return 0
end

local function loadSource(path)
  local cached = sourceCache[path]
  if cached then return cached end

  if not backend then return nil end
  if backend.kind == 'love' and backend.api then
    local ok, snd = pcall(backend.api.audio.newSource, backend.api.audio, path, 'static')
    if ok and snd then
      sourceCache[path] = snd
      return snd
    end
  end
  return nil
end

local function playWithLove(path, gain)
  local source = loadSource(path)
  if not source then return 0 end

  local g = clamp01(gain)
  if source.setVolume then source:setVolume(g) end
  if source.seek then source:seek(0) end
  if source.stop then source:stop() end
  if source.play then source:play() end
  return 1
end

local function playWithEngine(path, gain)
  if not backend or not backend.api then return 0 end
  local ok, hasPlayer = pcall(function()
    return backend.api.noteOn ~= nil
  end)
  if not ok or not hasPlayer then return 0 end
  -- Engine table does not expose clip playback directly; this is a compatibility stub.
  return 0
end

function sound_cues_play(cueName, opts)
  if not initAudio() then
    return { ok = 0, reason = 'audio_unavailable' }
  end
  if cueName == nil then
    return { ok = 0, reason = 'missing_cue' }
  end

  local cue = cueCatalog[cueName]
  if not cue then
    return { ok = 0, reason = 'unknown_cue' }
  end

  local now = nowMs()
  local last = lastPlayedMs[cueName]
  local cooldown = cue.cooldown_ms or 0
  if last ~= nil and (now - last) < cooldown then
    return { ok = 0, reason = 'cooldown' }
  end

  local gain = cue.gain
  if opts and opts.gain ~= nil then
    gain = gain * clamp01(opts.gain)
  end

  local played = 0
  if backend and backend.kind == 'love' then
    played = playWithLove(cue.source, gain)
  elseif backend and backend.kind == 'engine' then
    played = playWithEngine(cue.source, gain)
  end
  if played == 1 then
    lastPlayedMs[cueName] = now
    return { ok = 1, reason = 'played' }
  end
  return { ok = 0, reason = 'backend_failed' }
end

function sound_cues_has(cueName)
  return cueCatalog[cueName] ~= nil
end

function sound_cues_events()
  local out = {}
  for cueName in pairs(cueCatalog) do
    out[#out + 1] = cueName
  end
  return out
end

function sound_cues_path(cueName)
  if not cueName then return '' end
  if not cueCatalog[cueName] then return '' end
  return cueCatalog[cueName].source
end

</lscript>
