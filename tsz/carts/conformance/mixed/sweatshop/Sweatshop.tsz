// @borderless
// Sweatshop — cockpit landing surface.
// Built mixed-lane on top of cursor-ide. Chrome (TopBar/TabBar/StatusBar/CommandPalette)
// is reused from cursor-ide/. WorkspaceCanvas hosts the cockpit tile composition.

import { TopBar } from '../cursor-ide/TopBar.c';
import { TabBar } from '../cursor-ide/TabBar.c';
import { StatusBar } from '../cursor-ide/StatusBar.c';
import { ShellCommandPalette, CommandPaletteInput, CommandPaletteSection, CommandPaletteItem, CommandPaletteEmpty } from '../cursor-ide/ShellCommandPalette.c';
import {
  initData,
  activateTab,
  closeTab,
  openLandingPage,
  openSettingsSurface,
  refreshWorkspace,
  openTerminal,
  toggleCommandPalette,
} from './Sweatshop.script';
import {
  WindowFrame,
  WindowFrameMiddle,
  WindowResizeTop,
  WindowResizeBottom,
  WindowResizeLeft,
  WindowResizeRight,
  Shell,
  Workspace,
  TabDock,
  WorkspaceCanvas,
  CockpitCanvas,
  CockpitTopRow,
  CockpitLeftRail,
  CockpitCenterColumn,
  CockpitRightRail,
  CockpitWorkerGrid,
  CockpitWorkerCell,
  CockpitVizRow,
  CockpitVizCellLeft,
  CockpitVizCellRight,
  CockpitFooterRow,
  CockpitWorkerStripWrap,
} from './sweatshop_cls';
import {
  PaletteHint,
  PaletteMeta,
} from './style_cls';

// Tile components mounted in the cockpit canvas.
import { WorkerTile, mockCodeSessions } from './components/WorkerTile.c';
import { WorkerStrip, defaultWorkers } from './components/WorkerStrip.c';
import { QueueTile, defaultQueueEntries, sortedQueue } from './components/QueueTile.c';
import { SpecAnchorTile, defaultActiveSpec } from './components/SpecAnchorTile.c';
import { KernelTile, mockPayload } from './components/KernelTile.c';
import { MemoryTile, defaultMemoryPayload } from './components/MemoryTile.c';
import { GitAuditTile } from './components/GitAuditTile.c';
import { StateBoardTile } from './components/StateBoardTile.c';

// Named classifier imports — register all classifier vocabularies the tiles + chrome reference.
// Bare side-effect imports do NOT trigger smith's classifier collection — pull one named
// symbol from each cls file so smith inlines the whole classifier({...}) block.
import { WindowFrame as _cursorClsAnchor } from '../cursor-ide/cursor.cls';
import { WorkerTile as _workerTileClsAnchor } from './components/worker_tile_cls';
import { WorkerStrip as _workerStripClsAnchor } from './components/worker_strip_cls';
import { QueueTile as _queueClsAnchor } from './components/queue_tile_cls';
import { SpecAnchorTile as _specClsAnchor } from './components/spec_anchor_cls';
import { KernelTile as _kernelClsAnchor } from './components/kernel_tile_cls';
import { MemoryTile as _memoryClsAnchor } from './components/memory_tile_cls';
import { StateBoardTile as _stateBoardClsAnchor } from './components/state_board_cls';

// Side-effect imports — boot the event bridge + classifier subscriptions, register themes.
// (Stitcher plan step 7.)
import './events/event_subscribe.script';
import './themes/sweatshop_tokens.tcls';
import './themes/sweatshop_dusk.tcls';

function ChromeBar(props) {
  return <TopBar
    title={props.currentFilePath}
    displayTitle={props.title}
    workspaceName={props.workspaceName}
    workspaceTagline={props.workspaceTagline}
    gitBranch={props.gitBranch}
    changedCount={props.changedCount}
    stagedCount={props.stagedCount}
    widthBand={props.widthBand}
    settingsActive={props.settingsActive}
    searchActive={props.searchActive}
    chatActive={props.chatActive}
    terminalActive={props.terminalActive}
    style={props.style}
    onOpenHome={props.onOpenHome}
    onOpenSettings={props.onOpenSettings}
    onRefreshWorkspace={props.onRefreshWorkspace}
    onToggleChat={props.onToggleChat}
    onToggleTerminal={props.onToggleTerminal}
    onToggleSearch={props.onToggleSearch}
  />;
}

function CockpitWorkspace(props) {
  // TODO(claude-stitch): replace mockCodeSessions with workers data feed from data/database.mod
  // when the worker registry table reader lands.
  var sessions = props.sessions || mockCodeSessions || [];
  var queueEntries = sortedQueue(props.queueEntries || defaultQueueEntries());
  var spec = props.spec || defaultActiveSpec();
  var memoryPayload = props.memoryPayload || defaultMemoryPayload();
  var kernelPayload = props.kernelPayload || mockPayload();
  // TODO(claude-stitch): wire git_audit raw props from data/git_audit.mod once data feed is live.
  var gitRaw = props.gitRaw || {};
  // TODO(claude-stitch): wire onAction in QueueTile to events/supervisor_events.dispatchEvent.
  var onQueueAction = props.onQueueAction || function(action, entry) { return null; };

  return (
    <CockpitCanvas>
      <CockpitTopRow>
        <CockpitLeftRail>
          <SpecAnchorTile spec={spec} pinned={1} showHeader={1} />
        </CockpitLeftRail>
        <CockpitCenterColumn>
          <StateBoardTile />
        </CockpitCenterColumn>
        <CockpitRightRail>
          <QueueTile entries={queueEntries} onAction={onQueueAction} showHeader={1} />
        </CockpitRightRail>
      </CockpitTopRow>

      <CockpitWorkerGrid>
        {sessions.map(function(session, idx) {
          return (
            <CockpitWorkerCell key={session.id || idx}>
              <WorkerTile session={session} />
            </CockpitWorkerCell>
          );
        })}
      </CockpitWorkerGrid>

      <CockpitVizRow>
        <CockpitVizCellLeft>
          <KernelTile payload={kernelPayload} />
        </CockpitVizCellLeft>
        <CockpitVizCellRight>
          <MemoryTile payload={memoryPayload} showHeader={1} />
        </CockpitVizCellRight>
      </CockpitVizRow>

      <CockpitFooterRow>
        <GitAuditTile raw={gitRaw} />
      </CockpitFooterRow>
    </CockpitCanvas>
  );
}

export { App };

function widthBandForMetrics(windowWidth, windowHeight) {
  if (windowWidth <= 360 || windowHeight <= 250) return 'minimum';
  if (windowWidth <= 560 || windowHeight <= 360) return 'widget';
  if (windowWidth <= 920) return 'narrow';
  if (windowWidth <= 1260) return 'medium';
  return 'desktop';
}

function App() {
  const [ready, setReady] = useState(0);
  const [activeTabId, setActiveTabId] = useState('workspace');
  const [activeView, setActiveView] = useState('workbench');
  const [currentFilePath, setCurrentFilePath] = useState('workspace');
  const [openTabs, setOpenTabs] = useState([
    { id: 'workspace', name: 'Workspace', path: 'workspace', type: 'app', modified: 0, pinned: 1 },
    { id: 'workers', name: 'Workers', path: 'workers', type: 'app', modified: 0, pinned: 1 },
    { id: 'state', name: 'State', path: 'state', type: 'app', modified: 0, pinned: 1 },
  ]);
  const [workspaceName, setWorkspaceName] = useState('Sweatshop Cockpit');
  const [workspaceTagline, setWorkspaceTagline] = useState('Live supervision cockpit shell');
  const [workDir, setWorkDir] = useState('.');
  const [gitBranch, setGitBranch] = useState('main');
  const [gitRemote, setGitRemote] = useState('origin');
  const [branchAhead, setBranchAhead] = useState(0);
  const [branchBehind, setBranchBehind] = useState(0);
  const [changedCount, setChangedCount] = useState(0);
  const [stagedCount, setStagedCount] = useState(0);
  const [errors, setErrors] = useState(0);
  const [warnings, setWarnings] = useState(0);
  const [cursorLine, setCursorLine] = useState(1);
  const [cursorColumn, setCursorColumn] = useState(1);
  const [languageMode, setLanguageMode] = useState('Workspace');
  const [showCommandPalette, setShowCommandPalette] = useState(0);
  const [commandQuery, setCommandQuery] = useState('');
  const [modelDisplayName, setModelDisplayName] = useState('Sweatshop Model');
  const [agentStatusText, setAgentStatusText] = useState('idle');
  const [showDockedSearch, setShowDockedSearch] = useState(0);

  if (ready == 0) {
    initData();
    setWorkspaceName('Sweatshop Cockpit');
    setWorkspaceTagline('Live supervision cockpit shell');
    setReady(1);
  }

  var sys = __tel_system ? __tel_system() : null;
  var width = sys && sys.window_w ? sys.window_w : 1280;
  var height = sys && sys.window_h ? sys.window_h : 800;
  var widthBand = widthBandForMetrics(width, height);
  var compactMode = 0;
  var minimumMode = 0;
  var mediumMode = 0;
  var showStatusBar = 0;

  if (widthBand == "minimum") {
    compactMode = 1;
    minimumMode = 1;
  } else if (widthBand == "widget") {
    compactMode = 1;
  } else if (widthBand == "narrow") {
    compactMode = 1;
  } else if (widthBand == "medium") {
    mediumMode = 1;
  }

  if (minimumMode == 0 && height >= 250) showStatusBar = 1;

  var visibleCommands = [
    {
      label: 'Open Workspace',
      meta: 'open landing view',
      shortcut: '1',
      onPress: function() {
        openLandingPage();
        setShowCommandPalette(0);
        setCommandQuery('');
      },
    },
    {
      label: 'Refresh Workspace',
      meta: 're-scan repo surfaces',
      shortcut: 'R',
      onPress: function() {
        refreshWorkspace();
        setShowCommandPalette(0);
        setCommandQuery('');
      },
    },
    {
      label: 'Open Settings Shell',
      meta: 'future shell settings',
      shortcut: 'S',
      onPress: function() {
        openSettingsSurface();
        setShowCommandPalette(0);
        setCommandQuery('');
      },
    },
    {
      label: 'Open Terminal',
      meta: 'reserved for Spark 2',
      shortcut: 'T',
      onPress: function() {
        openTerminal();
        setShowCommandPalette(0);
        setCommandQuery('');
      },
    },
  ];

  if (commandQuery.length > 0) {
    var filtered = [];
    for (var i = 0; i < visibleCommands.length; i++) {
      if (visibleCommands[i].label.toLowerCase().indexOf(commandQuery.toLowerCase()) >= 0) {
        filtered.push(visibleCommands[i]);
      }
    }
    visibleCommands = filtered;
  }

  return (
    <WindowFrame>
      <WindowResizeTop />
      <WindowFrameMiddle>
        <WindowResizeLeft />
        <Shell>
          <ChromeBar
            currentFilePath={currentFilePath}
            title='Sweatshop Cockpit'
            workspaceName={workspaceName}
            workspaceTagline={workspaceTagline}
            gitBranch={gitBranch}
            changedCount={changedCount}
            stagedCount={stagedCount}
            widthBand={'desktop'}
            settingsActive={activeView == 'settings'}
            searchActive={showCommandPalette == 1}
            chatActive={showDockedSearch == 1}
            terminalActive={0}
            style={{}}
            onOpenHome={openLandingPage}
            onOpenSettings={openSettingsSurface}
            onRefreshWorkspace={refreshWorkspace}
            onToggleChat={function() {
              if (showDockedSearch == 1) {
                setShowDockedSearch(0);
              } else {
                setShowDockedSearch(1);
              }
            }}
            onToggleTerminal={function() {
              openTerminal();
            }}
            onToggleSearch={toggleCommandPalette}
          />

          <Workspace style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0 }}>
            <TabDock>
              <TabBar tabs={openTabs} activeId={activeTabId} compactMode={0} widthBand={'desktop'} />
            </TabDock>

            <CockpitWorkspace />
          </Workspace>

          <CockpitWorkerStripWrap>
            <WorkerStrip workers={defaultWorkers()} orientation='bottom' />
          </CockpitWorkerStripWrap>

          <StatusBar
            gitBranch={gitBranch}
            gitStatus={''}
            gitRemote={gitRemote}
            branchAhead={branchAhead}
            branchBehind={branchBehind}
            changedCount={changedCount}
            stagedCount={stagedCount}
            cursorLine={cursorLine}
            cursorColumn={cursorColumn}
            languageMode={languageMode}
            errors={errors}
            warnings={warnings}
            modified={0}
            fileName={currentFilePath}
            workDir={workDir}
            selectedModel={modelDisplayName}
            agentStatusText={agentStatusText}
            widthBand={'desktop'}
            compactMode={0}
            style={{}}
          />

          <ShellCommandPalette visible={showCommandPalette}>
            <CommandPaletteInput
              value={commandQuery}
              onChange={setCommandQuery}
              placeholder='Type a cockpit command...'
            />
            <CommandPaletteSection title='Quick Commands'>
              {visibleCommands.length == 0 && <CommandPaletteEmpty message='No commands found' />}
              {visibleCommands.map(function(cmd, idx) {
                return <CommandPaletteItem
                  key={idx}
                  label={cmd.label}
                  meta={cmd.meta}
                  shortcut={cmd.shortcut}
                  onPress={cmd.onPress}
                  selected={0}
                />;
              })}
            </CommandPaletteSection>
            <CommandPaletteSection title='Shell Tips'>
              <Box style={{ padding: 10, paddingTop: 4, paddingBottom: 6, gap: 6 }}>
                <PaletteMeta>Press F3 or click Search to re-open this palette.</PaletteMeta>
                <PaletteHint>Workspace canvas is intentionally empty; Spark 2 mounts worker tiles here.</PaletteHint>
              </Box>
            </CommandPaletteSection>
          </ShellCommandPalette>
      </Shell>
      <WindowResizeRight />
      </WindowFrameMiddle>
      <WindowResizeBottom />
    </WindowFrame>
  );
}
