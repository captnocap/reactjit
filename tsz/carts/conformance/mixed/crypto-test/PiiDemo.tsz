// PII Detection Demo — live privacy scanner
// Type text containing emails, SSNs, credit cards, phone numbers.
// Detection runs live on every keystroke.
//
// Build: ./zig-out/bin/zigos-compiler build carts/crypto-test/PiiDemo.tsz
// Run:   ./zig-out/bin/PiiDemo

import { pii_scan } from './pii_demo.script';
import { Page, Title, Subtitle, SectionLabel, ResultBox, RedactedText, MatchRow, Badge, EmailBadge, SsnBadge, CardBadge, PhoneBadge, MatchValue, StatusBar, StatusText } from './pii_demo_cls';

const [redactedText, setRedactedText] = useState('');
const [matchSummary, setMatchSummary] = useState('Type text above to scan for PII');
const [emailMatches, setEmailMatches] = useState('');
const [ssnMatches, setSsnMatches] = useState('');
const [cardMatches, setCardMatches] = useState('');
const [phoneMatches, setPhoneMatches] = useState('');

function App() {
  return (
    <C.Page>
      <C.Title>PII Scanner</C.Title>
      <C.Subtitle>Live privacy detection — type text with personal data below</C.Subtitle>

      <TextInput
        onChangeText={() => pii_scan()}
        placeholder="Try: alice@example.com SSN 123-45-6789 card 4111 1111 1111 1111"
        fontSize={14}
        color="#e6edf3"
        style={{ backgroundColor: '#161b22', borderWidth: 1, borderColor: '#30363d', borderRadius: 8, padding: 12, paddingLeft: 14, paddingRight: 14, height: 48 }}
      />

      <C.SectionLabel>REDACTED OUTPUT</C.SectionLabel>
      <C.ResultBox>
        <C.RedactedText>{redactedText}</C.RedactedText>
      </C.ResultBox>

      <C.SectionLabel>DETECTED PATTERNS</C.SectionLabel>
      <C.ResultBox>
        <C.MatchRow>
          <C.EmailBadge><C.Badge>EMAIL</C.Badge></C.EmailBadge>
          <C.MatchValue>{emailMatches}</C.MatchValue>
        </C.MatchRow>
        <C.MatchRow>
          <C.SsnBadge><C.Badge>SSN</C.Badge></C.SsnBadge>
          <C.MatchValue>{ssnMatches}</C.MatchValue>
        </C.MatchRow>
        <C.MatchRow>
          <C.CardBadge><C.Badge>CARD</C.Badge></C.CardBadge>
          <C.MatchValue>{cardMatches}</C.MatchValue>
        </C.MatchRow>
        <C.MatchRow>
          <C.PhoneBadge><C.Badge>PHONE</C.Badge></C.PhoneBadge>
          <C.MatchValue>{phoneMatches}</C.MatchValue>
        </C.MatchRow>
      </C.ResultBox>

      <C.StatusBar>
        <C.StatusText>{matchSummary}</C.StatusText>
      </C.StatusBar>
    </C.Page>
  );
}
