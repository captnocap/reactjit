// Classifiers for the crypto test cart.

classifier Page {
  flexDirection: 'column';
  gap: 8;
  padding: 16;
  backgroundColor: '#0d1117';
  width: '100%';
  height: '100%';
}

classifier Header {
  flexDirection: 'column';
  gap: 4;
  paddingBottom: 12;
  borderBottomWidth: 1;
  borderColor: '#30363d';
}

classifier Title {
  fontSize: 22;
  color: '#e6edf3';
}

classifier Subtitle {
  fontSize: 13;
  color: '#8b949e';
}

classifier Section {
  flexDirection: 'column';
  gap: 4;
  paddingTop: 8;
}

classifier SectionTitle {
  fontSize: 16;
  color: '#58a6ff';
}

classifier TestRow {
  flexDirection: 'row';
  gap: 8;
  paddingLeft: 12;
  alignItems: 'center';
}

classifier TestName {
  fontSize: 13;
  color: '#c9d1d9';
  flexGrow: 1;
}

classifier PassText {
  fontSize: 13;
  color: '#3fb950';
}

classifier FailText {
  fontSize: 13;
  color: '#f85149';
}

classifier Summary {
  flexDirection: 'row';
  gap: 8;
  paddingTop: 12;
  borderTopWidth: 1;
  borderColor: '#30363d';
  alignItems: 'center';
}

classifier SummaryLabel {
  fontSize: 16;
  color: '#e6edf3';
}

classifier SummaryCount {
  fontSize: 16;
  color: '#3fb950';
}
