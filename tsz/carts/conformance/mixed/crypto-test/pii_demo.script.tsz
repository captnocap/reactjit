// PII detection engine — runs in QuickJS on every keystroke.
// Uses getInputText(0) to read the TextInput content (input_id 0).

function pii_scan() {
  var text = getInputText(0) || '';
  if (text.length === 0) {
    setRedactedText('');
    setMatchSummary('Type text above to scan for PII');
    setEmailMatches('');
    setSsnMatches('');
    setCardMatches('');
    setPhoneMatches('');
    return;
  }

  var emails = text.match(/[\w.+\-]+@[\w.\-]+\.[a-zA-Z]{2,}/g) || [];
  var ssns = text.match(/\d{3}-\d{2}-\d{4}/g) || [];
  var cards = text.match(/\d{4}[\s\-]\d{4}[\s\-]\d{4}[\s\-]\d{4}/g) || [];
  var phones = text.match(/\+?1?[\s\-.]?\(?\d{3}\)?[\s\-.]?\d{3}[\s\-.]?\d{4}/g) || [];

  var redacted = text;
  var i;
  for (i = 0; i < emails.length; i++) {
    redacted = redacted.replace(emails[i], '[EMAIL]');
  }
  for (i = 0; i < ssns.length; i++) {
    redacted = redacted.replace(ssns[i], '[SSN]');
  }
  for (i = 0; i < cards.length; i++) {
    redacted = redacted.replace(cards[i], '[CARD]');
  }
  for (i = 0; i < phones.length; i++) {
    redacted = redacted.replace(phones[i], '[PHONE]');
  }

  setRedactedText(redacted);
  setEmailMatches(emails.join(', '));
  setSsnMatches(ssns.join(', '));
  setCardMatches(cards.join(', '));
  setPhoneMatches(phones.join(', '));

  var total = emails.length + ssns.length + cards.length + phones.length;
  if (total === 0) {
    setMatchSummary('No PII detected');
  } else {
    var parts = [];
    if (emails.length > 0) parts.push(emails.length + ' email' + (emails.length > 1 ? 's' : ''));
    if (ssns.length > 0) parts.push(ssns.length + ' SSN' + (ssns.length > 1 ? 's' : ''));
    if (cards.length > 0) parts.push(cards.length + ' card' + (cards.length > 1 ? 's' : ''));
    if (phones.length > 0) parts.push(phones.length + ' phone' + (phones.length > 1 ? 's' : ''));
    setMatchSummary(total + ' PII found: ' + parts.join(', '));
  }
}
