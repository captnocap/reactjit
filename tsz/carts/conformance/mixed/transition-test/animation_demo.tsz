// Animation System Demo
// Press buttons to see smooth transitions: color, expand/collapse, fade, spring bounce.

const [mode, setMode] = useState(0);

function App() {
  return (
    <Box style={{ width: "100%", height: "100%", padding: 24, backgroundColor: "#0f172a", gap: 20, flexDirection: "column" }}>
      <Text fontSize={22} color="#e2e8f0">Animation Demo</Text>
      <Text fontSize={12} color="#64748b">Press the button to toggle all animations simultaneously</Text>

      <Pressable onPress={() => { setMode(mode == 0 ? 1 : 0) }}>
        <Box style={{ padding: 14, backgroundColor: "#6366f1", borderRadius: 8, width: 200, alignItems: "center" }}>
          <Text color="#ffffff" fontSize={15}>{mode == 0 ? "Animate!" : "Reset"}</Text>
        </Box>
      </Pressable>

      <Text fontSize={13} color="#94a3b8">Width expand/collapse (easeInOut 500ms)</Text>
      <Box style={{
        width: mode ? 500 : 120,
        height: 44,
        backgroundColor: "#ef4444",
        borderRadius: 8,
        transition: { width: { duration: 500, easing: "easeInOut" } }
      }} />

      <Text fontSize={13} color="#94a3b8">Opacity fade (easeOut 400ms)</Text>
      <Box style={{
        width: 200,
        height: 44,
        opacity: mode ? 1.0 : 0.15,
        backgroundColor: "#22c55e",
        borderRadius: 8,
        transition: { opacity: { duration: 400, easing: "easeOut" } }
      }} />

      <Text fontSize={13} color="#94a3b8">Border radius morph (bounce 600ms)</Text>
      <Box style={{
        width: 80,
        height: 80,
        backgroundColor: "#a855f7",
        borderRadius: mode ? 40 : 4,
        transition: { borderRadius: { duration: 600, easing: "bounce" } }
      }} />

      <Text fontSize={13} color="#94a3b8">Scale spring (stiffness: 180, damping: 12)</Text>
      <Box style={{
        width: mode ? 240 : 120,
        height: 44,
        backgroundColor: "#f59e0b",
        borderRadius: 8,
        transition: { width: { type: "spring", stiffness: 180, damping: 12 } }
      }} />
    </Box>
  );
}
