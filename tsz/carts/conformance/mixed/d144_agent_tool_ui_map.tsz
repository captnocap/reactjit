// DEATH TEST 144: Map body computing 8-field derived objects with conditional branches
// Pattern from AgentTool/UI.tsx: renderGroupedAgentToolUse stats computation.

const [toolUses, setToolUses] = useState([]);

import { d144_data } from "./d144_agent_tool_ui_map.script";

<script>
function calculateAgentStats(progressMessages) {
  const toolUseCount = progressMessages.filter(msg => msg.type === 'tool_use').length;
  return { toolUseCount, tokens: 1234 };
}
function extractLastToolInfo(progressMessages, tools) {
  return progressMessages.length > 0 ? progressMessages[progressMessages.length - 1].name : null;
}
function userFacingName(input) {
  return input && input.subagent_type ? input.subagent_type : 'Agent';
}
function userFacingNameBackgroundColor(input) {
  return input && input.subagent_type ? 'suggestion' : undefined;
}
function getAgentColor(type) {
  return type === 'worker' ? 'warning' : 'success';
}
function inputSchema() {
  return {
    safeParse(input) {
      return { success: true, data: input };
    }
  };
}
</script>

function App() {
  const tools = [];
  const anyUnresolved = toolUses.some(t => !t.isResolved);
  const anyError = toolUses.some(t => t.isError);

  const agentStats = toolUses.map(({ param, isResolved, isError, progressMessages, result }) => {
    const stats = calculateAgentStats(progressMessages);
    const lastToolInfo = extractLastToolInfo(progressMessages, tools);
    const parsedInput = inputSchema().safeParse(param.input);

    const isTeammateSpawn = result && result.output && result.output.status === 'teammate_spawned';

    let agentType;
    let description;
    let color;
    let descriptionColor;
    let taskDescription;
    if (isTeammateSpawn && parsedInput.success && parsedInput.data.name) {
      agentType = `@${parsedInput.data.name}`;
      const subagentType = parsedInput.data.subagent_type;
      description = subagentType && subagentType !== 'general' ? subagentType : undefined;
      taskDescription = parsedInput.data.description;
      descriptionColor = subagentType && subagentType !== 'general' ? getAgentColor(subagentType) : undefined;
    } else {
      agentType = parsedInput.success ? userFacingName(parsedInput.data) : 'Agent';
      description = parsedInput.success ? parsedInput.data.description : undefined;
      color = parsedInput.success ? userFacingNameBackgroundColor(parsedInput.data) : undefined;
      taskDescription = undefined;
    }

    const launchedAsAsync = parsedInput.success && parsedInput.data.run_in_background === true;
    const outputStatus = result && result.output ? result.output.status : undefined;
    const backgroundedMidExecution = outputStatus === 'async_launched' || outputStatus === 'remote_launched';
    const isAsync = launchedAsAsync || backgroundedMidExecution || isTeammateSpawn;
    const name = parsedInput.success ? parsedInput.data.name : undefined;

    return {
      id: param.id,
      agentType,
      description,
      toolUseCount: stats.toolUseCount,
      tokens: stats.tokens,
      isResolved,
      isError,
      isAsync,
      color,
      descriptionColor,
      lastToolInfo,
      taskDescription,
      name
    };
  });

  const allSameType = agentStats.length > 0 && agentStats.every(stat => stat.agentType === agentStats[0].agentType);
  const commonType = allSameType && agentStats[0].agentType !== 'Agent' ? agentStats[0].agentType : null;
  const allComplete = !anyUnresolved;
  const allAsync = agentStats.every(stat => stat.isAsync);

  return (
    <Box style={{ width: "100%", height: "100%", backgroundColor: "#0d1117", padding: 16, gap: 8 }}>
      <Text fontSize={16} color="#e6edf3">AgentTool UI Map</Text>
      <Text fontSize={10} color="#8b949e">{`${agentStats.length} agents`}</Text>

      {agentStats.map((stat, index) => (
        <Box key={stat.id} style={{ backgroundColor: "#161b22", padding: 10, borderRadius: 6, gap: 4 }}>
          <Text fontSize={12} color={stat.isError ? '#f85149' : '#58a6ff'}>
            {`${stat.agentType} (${stat.toolUseCount} tools)`}
          </Text>
          <Text fontSize={10} color="#8b949e">{stat.description || 'No description'}</Text>
          <Text fontSize={10} color="#c9d1d9">{`Tokens: ${stat.tokens} | Async: ${stat.isAsync}`}</Text>
        </Box>
      ))}

      <Text fontSize={10} color="#7ee787">
        {allComplete ? (allAsync ? 'All backgrounded' : (commonType ? `${commonType} finished` : 'Done')) : 'Running...'}
      </Text>
    </Box>
  );
}
