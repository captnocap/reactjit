// CONFORMANCE TEST 128: Tool Execution Lifecycle
//
// Ported from: Claude Code BashTool + AgentTool + PermissionRequest system
//
// A tool runner dashboard where each tool goes through a multi-phase
// lifecycle: queued → permission → running → progress → complete/error.
// Each phase renders completely different UI. Tools can be approved,
// rejected, backgrounded, or cancelled at different phases.
//
// Patterns tested:
// - 5-state enum via numeric state (0=queued, 1=permission, 2=running, 3=complete, 4=error)
// - Per-item state transitions (each tool independent)
// - Conditional rendering with 5 mutually exclusive branches per item
// - Progress percentage in template literal
// - Map over tools with completely different JSX per state
// - Multi-action handlers (approve sets state + increments counter + logs)
// - Elapsed time / duration display
// - Nested conditional: error state has sub-types (timeout, rejected, crashed)
// - Components rendered 0 or 1 times based on global filter
// - Collapsible output sections (expanded state per tool)

const [tools, setTools] = useState([{ name: '', type: '', cmd: '', state: 0, progress: 0, output: '', errorType: 0, expanded: 0, duration: 0 }]);
const [queuedCount, setQueuedCount] = useState(0);
const [runningCount, setRunningCount] = useState(0);
const [completeCount, setCompleteCount] = useState(0);
const [errorCount, setErrorCount] = useState(0);
const [selectedTool, setSelectedTool] = useState(0);
const [autoApprove, setAutoApprove] = useState(0);
const [totalActions, setTotalActions] = useState(0);
const [lastAction, setLastAction] = useState('');
const [filterState, setFilterState] = useState(5);

<script>
var toolList = [
  { name: 'Bash: git status', type: 'bash', cmd: 'git status', state: 0, progress: 0, output: '', errorType: 0, expanded: 0, duration: 0 },
  { name: 'Read: package.json', type: 'read', cmd: 'package.json', state: 0, progress: 0, output: '', errorType: 0, expanded: 0, duration: 0 },
  { name: 'Bash: npm test', type: 'bash', cmd: 'npm test', state: 0, progress: 0, output: '', errorType: 0, expanded: 0, duration: 0 },
  { name: 'Agent: search codebase', type: 'agent', cmd: 'find auth handler', state: 0, progress: 0, output: '', errorType: 0, expanded: 0, duration: 0 },
  { name: 'Edit: src/app.ts', type: 'edit', cmd: 'line 42: fix typo', state: 0, progress: 0, output: '', errorType: 0, expanded: 0, duration: 0 },
  { name: 'Bash: rm -rf dist/', type: 'bash', cmd: 'rm -rf dist/', state: 0, progress: 0, output: '', errorType: 0, expanded: 0, duration: 0 },
  { name: 'Bash: docker build', type: 'bash', cmd: 'docker build -t app .', state: 0, progress: 0, output: '', errorType: 0, expanded: 0, duration: 0 },
  { name: 'Agent: review PR', type: 'agent', cmd: 'review PR #42', state: 0, progress: 0, output: '', errorType: 0, expanded: 0, duration: 0 }
];
setTools(toolList);
setQueuedCount(toolList.length);

function doAction(desc) {
  setTotalActions(totalActions + 1);
  setLastAction(desc);
}

function recount() {
  var qc = 0; var rc = 0; var cc = 0; var ec = 0;
  for (var i = 0; i < toolList.length; i++) {
    if (toolList[i].state === 0 || toolList[i].state === 1) qc++;
    if (toolList[i].state === 2) rc++;
    if (toolList[i].state === 3) cc++;
    if (toolList[i].state === 4) ec++;
  }
  setQueuedCount(qc);
  setRunningCount(rc);
  setCompleteCount(cc);
  setErrorCount(ec);
}

function requestPermission(idx) {
  toolList[idx].state = 1;
  setTools(toolList);
  recount();
  doAction('permission: ' + toolList[idx].name);
}

function approve(idx) {
  toolList[idx].state = 2;
  toolList[idx].progress = 0;
  setTools(toolList);
  recount();
  doAction('approved: ' + toolList[idx].name);
}

function reject(idx) {
  toolList[idx].state = 4;
  toolList[idx].errorType = 1;
  toolList[idx].output = 'Permission denied by user';
  setTools(toolList);
  recount();
  doAction('rejected: ' + toolList[idx].name);
}

function advanceProgress(idx) {
  var t = toolList[idx];
  if (t.state !== 2) return;
  t.progress = t.progress + 25;
  t.duration = t.duration + 500;
  if (t.progress >= 100) {
    t.state = 3;
    t.output = 'Completed successfully. ' + t.cmd;
    t.progress = 100;
  }
  setTools(toolList);
  recount();
  doAction('progress: ' + t.name + ' ' + t.progress + '%');
}

function failTool(idx) {
  toolList[idx].state = 4;
  toolList[idx].errorType = 2;
  toolList[idx].output = 'Process exited with code 1';
  setTools(toolList);
  recount();
  doAction('failed: ' + toolList[idx].name);
}

function timeoutTool(idx) {
  toolList[idx].state = 4;
  toolList[idx].errorType = 0;
  toolList[idx].output = 'Exceeded 120000ms timeout';
  setTools(toolList);
  recount();
  doAction('timeout: ' + toolList[idx].name);
}

function toggleExpand(idx) {
  toolList[idx].expanded = toolList[idx].expanded === 1 ? 0 : 1;
  setTools(toolList);
}

function runAll() {
  for (var i = 0; i < toolList.length; i++) {
    if (toolList[i].state === 0) {
      if (autoApprove === 1) {
        toolList[i].state = 2;
        toolList[i].progress = 0;
      } else {
        toolList[i].state = 1;
      }
    }
  }
  setTools(toolList);
  recount();
  doAction('run all');
}

function resetAll() {
  for (var i = 0; i < toolList.length; i++) {
    toolList[i].state = 0;
    toolList[i].progress = 0;
    toolList[i].output = '';
    toolList[i].errorType = 0;
    toolList[i].expanded = 0;
    toolList[i].duration = 0;
  }
  setTools(toolList);
  recount();
  doAction('reset');
}
</script>

function TypeIcon(type) {
  return (
    <Box style={{ width: 20, height: 20, borderRadius: 4, backgroundColor: type === "bash" ? "#1e40af" : type === "read" ? "#065f46" : type === "edit" ? "#7c2d12" : "#4a1d96", alignItems: "center", justifyContent: "center" }}>
      <Text fontSize={8} color="#ffffff">{type === "bash" ? "$" : type === "read" ? "R" : type === "edit" ? "E" : "A"}</Text>
    </Box>
  );
}

function StateIndicator(state, progress) {
  return (
    <Box style={{ flexDirection: "row", gap: 4, alignItems: "center" }}>
      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: state == 0 ? "#475569" : state == 1 ? "#f59e0b" : state == 2 ? "#3b82f6" : state == 3 ? "#22c55e" : "#ef4444" }} />
      {state == 0 && <Text fontSize={8} color="#475569">Queued</Text>}
      {state == 1 && <Text fontSize={8} color="#f59e0b">Awaiting Permission</Text>}
      {state == 2 && <Text fontSize={8} color="#3b82f6">{`Running ${progress}%`}</Text>}
      {state == 3 && <Text fontSize={8} color="#22c55e">Complete</Text>}
      {state == 4 && <Text fontSize={8} color="#ef4444">Error</Text>}
    </Box>
  );
}

function ProgressBar(progress) {
  return (
    <Box style={{ height: 4, backgroundColor: "#1e293b", borderRadius: 2, flexGrow: 1 }}>
      <Box style={{ height: 4, borderRadius: 2, backgroundColor: "#3b82f6", width: progress == 0 ? 0 : progress == 25 ? 40 : progress == 50 ? 80 : progress == 75 ? 120 : 160 }} />
    </Box>
  );
}

function ToolCard(t, idx) {
  return (
    <Box>
      {(filterState == 5 || filterState == t.state) && <Pressable onPress={() => { setSelectedTool(idx); toggleExpand(idx) }} style={{ padding: 10, backgroundColor: selectedTool == idx ? "#334155" : "#1e293b", borderRadius: 8, gap: 6, borderWidth: t.state == 4 ? 1 : 0, borderColor: "#ef4444" }}>
        <Box style={{ flexDirection: "row", gap: 8, alignItems: "center" }}>
          <TypeIcon type={t.type} />
          <Box style={{ flexGrow: 1, gap: 2 }}>
            <Text fontSize={10} color="#e2e8f0">{t.name}</Text>
            <Text fontSize={8} color="#475569">{t.cmd}</Text>
          </Box>
          <StateIndicator state={t.state} progress={t.progress} />
        </Box>

        {t.state == 1 && <Box style={{ flexDirection: "row", gap: 6, justifyContent: "flexEnd" }}>
          <Pressable onPress={() => { approve(idx) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: "#22c55e", borderRadius: 4 }}>
            <Text fontSize={8} color="#ffffff">Allow</Text>
          </Pressable>
          <Pressable onPress={() => { reject(idx) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: "#ef4444", borderRadius: 4 }}>
            <Text fontSize={8} color="#ffffff">Deny</Text>
          </Pressable>
        </Box>}

        {t.state == 2 && <Box style={{ gap: 4 }}>
          <ProgressBar progress={t.progress} />
          <Box style={{ flexDirection: "row", gap: 6, justifyContent: "flexEnd" }}>
            <Pressable onPress={() => { advanceProgress(idx) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: "#3b82f6", borderRadius: 4 }}>
              <Text fontSize={8} color="#ffffff">Advance</Text>
            </Pressable>
            <Pressable onPress={() => { failTool(idx) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: "#dc2626", borderRadius: 4 }}>
              <Text fontSize={8} color="#ffffff">Fail</Text>
            </Pressable>
            <Pressable onPress={() => { timeoutTool(idx) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: "#92400e", borderRadius: 4 }}>
              <Text fontSize={8} color="#ffffff">Timeout</Text>
            </Pressable>
          </Box>
        </Box>}

        {t.state == 0 && <Box style={{ flexDirection: "row", justifyContent: "flexEnd" }}>
          <Pressable onPress={() => { requestPermission(idx) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: "#334155", borderRadius: 4 }}>
            <Text fontSize={8} color="#94a3b8">Run</Text>
          </Pressable>
        </Box>}

        {t.expanded == 1 && t.output !== '' && <Box style={{ padding: 6, backgroundColor: "#0f172a", borderRadius: 4 }}>
          <Text fontSize={8} color={t.state == 4 ? "#fca5a5" : "#94a3b8"}>{t.output}</Text>
          {t.state == 4 && t.errorType == 0 && <Text fontSize={7} color="#92400e">timeout</Text>}
          {t.state == 4 && t.errorType == 1 && <Text fontSize={7} color="#ef4444">rejected</Text>}
          {t.state == 4 && t.errorType == 2 && <Text fontSize={7} color="#dc2626">crashed</Text>}
          {t.duration > 0 && <Text fontSize={7} color="#475569">{`${t.duration}ms`}</Text>}
        </Box>}
      </Pressable>}
    </Box>
  );
}

function App() {
  return (
    <Box style={{ backgroundColor: "#0f172a", padding: 16, width: "100%", height: "100%", flexDirection: "column", gap: 10 }}>
      <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center" }}>
        <Text fontSize={16} color="#e2e8f0">Tool Lifecycle</Text>
        <Box style={{ flexDirection: "row", gap: 6 }}>
          <Pressable onPress={() => { setAutoApprove(autoApprove == 0 ? 1 : 0) }} style={{ padding: 4, backgroundColor: autoApprove == 1 ? "#22c55e" : "#334155", borderRadius: 4 }}>
            <Text fontSize={8} color="#ffffff">{autoApprove == 1 ? "Auto ✓" : "Manual"}</Text>
          </Pressable>
          <Pressable onPress={() => { runAll() }} style={{ padding: 4, backgroundColor: "#3b82f6", borderRadius: 4 }}>
            <Text fontSize={8} color="#ffffff">Run All</Text>
          </Pressable>
          <Pressable onPress={() => { resetAll() }} style={{ padding: 4, backgroundColor: "#334155", borderRadius: 4 }}>
            <Text fontSize={8} color="#94a3b8">Reset</Text>
          </Pressable>
        </Box>
      </Box>

      <Box style={{ flexDirection: "row", gap: 6 }}>
        <Pressable onPress={() => { setFilterState(5) }} style={{ padding: 4, backgroundColor: filterState == 5 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">{`All (${queuedCount + runningCount + completeCount + errorCount})`}</Text>
        </Pressable>
        <Pressable onPress={() => { setFilterState(0) }} style={{ padding: 4, backgroundColor: filterState == 0 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">{`Queued (${queuedCount})`}</Text>
        </Pressable>
        <Pressable onPress={() => { setFilterState(2) }} style={{ padding: 4, backgroundColor: filterState == 2 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">{`Running (${runningCount})`}</Text>
        </Pressable>
        <Pressable onPress={() => { setFilterState(3) }} style={{ padding: 4, backgroundColor: filterState == 3 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">{`Done (${completeCount})`}</Text>
        </Pressable>
        <Pressable onPress={() => { setFilterState(4) }} style={{ padding: 4, backgroundColor: filterState == 4 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">{`Errors (${errorCount})`}</Text>
        </Pressable>
      </Box>

      <ScrollView style={{ flexGrow: 1, gap: 4 }}>
        {tools.map((t, i) => (
          <ToolCard t={t} idx={i} />
        ))}
      </ScrollView>

      <Text fontSize={9} color="#475569">{`${totalActions} actions · ${lastAction}`}</Text>
    </Box>
  );
}
