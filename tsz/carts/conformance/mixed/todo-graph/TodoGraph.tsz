        <C.Spacer />
        <Text fontSize={13} color="#4a5568">dependency flow</Text>
      </C.Toolbar>
      <Canvas type="todo-graph" style={{ flexGrow: 1 }} viewX={0} viewY={150} viewZoom={1}>
        <Canvas.Path d="M -130,25 C -130,60 -130,60 -130,90" stroke="#4ade80" strokeWidth={2} flowSpeed={1} />
