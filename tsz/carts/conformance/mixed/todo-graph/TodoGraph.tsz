        <Canvas.Node gx={-40} gy={410} gw={200} gh={50}>
          <Box style={{ width: '100%', height: '100%', padding: 8, backgroundColor: '#0d0f14', borderWidth: 1, borderColor: '#4a5568', borderRadius: 5, alignItems: 'center', justifyContent: 'center' }}>
            <Text fontSize={13} color="#8a90a0">Post-launch metrics</Text>
