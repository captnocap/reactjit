      <Box style={{ width: 1, height: 8, backgroundColor: '#5d5d5d' }} />
    </Box>
  );
}

function DotRow({ offset }) {
  return (
    <Box style={{ flexDirection: 'row', gap: 8, paddingLeft: offset }}>
      <Text fontSize={8} color="#8a8a8a">•</Text>
      <Text fontSize={8} color="#8a8a8a">•</Text>
      <Text fontSize={8} color="#8a8a8a">•</Text>
      <Text fontSize={8} color="#8a8a8a">•</Text>
      <Text fontSize={8} color="#8a8a8a">•</Text>
