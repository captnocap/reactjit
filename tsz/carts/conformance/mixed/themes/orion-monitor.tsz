function ThinPanel({ width, height, title, children }) {
  return (
    <Box style={{ width: width, height: height, borderWidth: 1, borderColor: '#6f6f6f', backgroundColor: '#1a1a1a', padding: 14, gap: 10 }}>
      {title != '' && <Text fontSize={10} color="#d6d6d6">{title}</Text>}
      {children}
    </Box>
  );
}

function HRuleBar({ width, fill }) {
  return (
    <Box style={{ width: width, height: 20, justifyContent: 'center' }}>
      <Box style={{ width: width, height: 1, backgroundColor: '#3a3a3a', position: 'absolute', left: 0, top: 9 }} />
      <Box style={{ width: fill, height: 10, backgroundColor: '#b9b9b9', position: 'absolute', right: 0, top: 4 }} />
    </Box>
  );
}

function TickStrip() {
  return (
    <Box style={{ flexDirection: 'row', justifyContent: 'spaceBetween', width: 320 }}>
      <Box style={{ width: 1, height: 10, backgroundColor: '#5d5d5d' }} />
      <Box style={{ width: 1, height: 8, backgroundColor: '#5d5d5d' }} />
      <Box style={{ width: 1, height: 10, backgroundColor: '#5d5d5d' }} />
      <Box style={{ width: 1, height: 8, backgroundColor: '#5d5d5d' }} />
      <Box style={{ width: 1, height: 10, backgroundColor: '#5d5d5d' }} />
      <Box style={{ width: 1, height: 8, backgroundColor: '#5d5d5d' }} />
      <Box style={{ width: 1, height: 10, backgroundColor: '#5d5d5d' }} />
      <Box style={{ width: 1, height: 8, backgroundColor: '#5d5d5d' }} />
      <Box style={{ width: 1, height: 10, backgroundColor: '#5d5d5d' }} />
      <Box style={{ width: 1, height: 8, backgroundColor: '#5d5d5d' }} />
