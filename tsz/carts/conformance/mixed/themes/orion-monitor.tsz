          <Box style={{ width: 338, alignItems: 'center', gap: 10 }}>
            <ThinPanel width={338} height={32} title="" />
            <Text fontSize={18} color="#d8d8d8">Loading</Text>
          </Box>
        </Box>

        <Box style={{ flexDirection: 'row', justifyContent: 'spaceBetween', alignItems: 'flexEnd' }}>
          <Box style={{ width: 244, paddingLeft: 8, paddingBottom: 22 }}>
            <Box style={{ width: 170, height: 62, borderWidth: 2, borderColor: '#ababab', borderRadius: 4, flexDirection: 'row', alignItems: 'center', paddingLeft: 12, gap: 4 }}>
              <Box style={{ width: 12, height: 44, borderWidth: 2, borderColor: '#ababab', borderRadius: 2, marginLeft: -22 }} />
              <BatteryCell />
              <BatteryCell />
              <BatteryCell />
            </Box>
          </Box>

          <Box style={{ width: 220, height: 220, position: 'relative', alignItems: 'center', justifyContent: 'center' }}>
            <Ring radius={106} />
            <Ring radius={96} />
            <Ring radius={86} />
            <Ring radius={76} />
            <Ring radius={66} />
            <Ring radius={56} />
            <Ring radius={46} />
            <Ring radius={36} />
            <Ring radius={26} />
            <Ring radius={16} />
            <Box style={{ position: 'absolute', left: 109, top: 0, width: 1, height: 220, backgroundColor: '#5d5d5d' }} />
            <Box style={{ position: 'absolute', left: 0, top: 109, width: 220, height: 1, backgroundColor: '#5d5d5d' }} />
            <Box style={{ position: 'absolute', left: 109, top: 26, width: 1, height: 58, backgroundColor: '#454545' }} />
            <Box style={{ position: 'absolute', left: 109, top: 136, width: 1, height: 58, backgroundColor: '#454545' }} />
            <Box style={{ position: 'absolute', left: 26, top: 109, width: 58, height: 1, backgroundColor: '#454545' }} />
            <Box style={{ position: 'absolute', left: 136, top: 109, width: 58, height: 1, backgroundColor: '#454545' }} />
            <Box style={{ width: 28, height: 28, backgroundColor: '#1b1b1b', borderRadius: 14 }} />
          </Box>

          <Box style={{ width: 318, paddingBottom: 24, alignItems: 'flexEnd', gap: 8 }}>
            <Text fontSize={16} color="#d8d8d8">SYSTEM INFORMATION</Text>
            <Text fontSize={16} color="#d8d8d8">OS: Alpine C.2</Text>
            <Text fontSize={16} color="#d8d8d8">MEMORY: 34000 MB</Text>
            <Text fontSize={16} color="#d8d8d8">CPU: Orion TX7+</Text>
            <Text fontSize={16} color="#d8d8d8">TASKS: 322 TOTAL (14 RUNNING)</Text>
            <Text fontSize={16} color="#d8d8d8">Uptime: 278 DAYS</Text>
          </Box>
        </Box>
