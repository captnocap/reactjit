// Minimal browser GPU test — boxes and text only
// No FFI, no effects, no scripts. Pure lean-tier.

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0d1117', padding: 16, gap: 8 }}>
      <Box style={{ height: 40, backgroundColor: '#161b22', padding: 12, justifyContent: 'center' }}>
        <Text fontSize={16} color="#58a6ff">CartridgeOS — tsz in browser</Text>
      </Box>
      <Box style={{ flexDirection: 'row', gap: 8, flexGrow: 1 }}>
        <Box style={{ flexGrow: 1, backgroundColor: '#238636', padding: 12 }}>
          <Text fontSize={14} color="#ffffff">GPU: virtio-gpu</Text>
        </Box>
        <Box style={{ flexGrow: 1, backgroundColor: '#1f6feb', padding: 12 }}>
          <Text fontSize={14} color="#ffffff">Render: DRM/KMS</Text>
        </Box>
        <Box style={{ flexGrow: 1, backgroundColor: '#8b949e', padding: 12 }}>
          <Text fontSize={14} color="#0d1117">SDL2 + wgpu</Text>
        </Box>
      </Box>
      <Box style={{ height: 24, backgroundColor: '#161b22', padding: 6 }}>
        <Text fontSize={10} color="#6e7681">tsz lean tier | Zig 0.15.2 | Alpine Linux x86_64</Text>
      </Box>
    </Box>
  )
}
