// Flex Wrap Torture Test
// Proves: flexWrap works with width:'100%' containers, fixed-width items,
// mixed sizes, gap, alignContent, and wrap_reverse.

function App() {
  return (
    <ScrollView style={{ backgroundColor: "#1a1a2e", width: '100%', height: '100%' }}>
      <Box style={{ padding: 24, gap: 32 }}>

        {/* === SECTION 1: Basic wrap — fixed-width items in a 100% container === */}
        <Box>
          <Text fontSize={20} color="#e94560">1. Fixed-width items in width:100% container</Text>
          <Text fontSize={12} color="#888888">16 boxes × 120px each, container is full width. They MUST wrap.</Text>
          <Box style={{ flexDirection: "row", flexWrap: "wrap", width: '100%', gap: 8, marginTop: 8, backgroundColor: "#16213e", padding: 12, borderRadius: 8 }}>
            <Box style={{ width: 120, height: 60, backgroundColor: "#e94560", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">1</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#0f3460", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">2</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#533483", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">3</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#e94560", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">4</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#0f3460", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">5</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#533483", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">6</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#e94560", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">7</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#0f3460", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">8</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#533483", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">9</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#e94560", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">10</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#0f3460", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">11</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#533483", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">12</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#e94560", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">13</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#0f3460", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">14</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#533483", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">15</Text></Box>
            <Box style={{ width: 120, height: 60, backgroundColor: "#e94560", borderRadius: 6, alignItems: "center", justifyContent: "center" }}><Text fontSize={14} color="#ffffff">16</Text></Box>
          </Box>
        </Box>

        {/* === SECTION 2: Mixed-size tag cloud === */}
        <Box>
          <Text fontSize={20} color="#e94560">2. Tag cloud — mixed widths wrapping naturally</Text>
          <Text fontSize={12} color="#888888">Various-width tags in a wrap container. Proves non-uniform items wrap correctly.</Text>
          <Box style={{ flexDirection: "row", flexWrap: "wrap", width: '100%', gap: 8, marginTop: 8 }}>
            <Box style={{ backgroundColor: "#e94560", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">Zig</Text></Box>
            <Box style={{ backgroundColor: "#0f3460", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">TypeScript</Text></Box>
