          </Box>
        </Box>

        {/* === SECTION 5: alignContent center === */}
        <Box>
          <Text fontSize={20} color="#e94560">5. alignContent: center — wrapped lines centered in cross axis</Text>
          <Box style={{ flexDirection: "row", flexWrap: "wrap", width: '100%', height: 300, gap: 8, marginTop: 8, backgroundColor: "#16213e", borderRadius: 8, padding: 12, alignContent: "center" }}>
