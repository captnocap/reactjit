        {/* === SECTION 6: alignContent spaceBetween === */}
        <Box>
          <Text fontSize={20} color="#e94560">6. alignContent: spaceBetween — lines pushed to edges</Text>
          <Box style={{ flexDirection: "row", flexWrap: "wrap", width: '100%', height: 250, gap: 8, marginTop: 8, backgroundColor: "#16213e", borderRadius: 8, padding: 12, alignContent: "spaceBetween" }}>
