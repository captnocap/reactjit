            <Box style={{ backgroundColor: "#e94560", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">SDL2</Text></Box>
            <Box style={{ backgroundColor: "#0f3460", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">FreeType</Text></Box>
            <Box style={{ backgroundColor: "#533483", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">QuickJS</Text></Box>
            <Box style={{ backgroundColor: "#e94560", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">Native Binary</Text></Box>
            <Box style={{ backgroundColor: "#0f3460", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">Self-Extracting</Text></Box>
            <Box style={{ backgroundColor: "#533483", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">Zero Deps</Text></Box>
            <Box style={{ backgroundColor: "#e94560", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">Compiler</Text></Box>
            <Box style={{ backgroundColor: "#0f3460", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">Codegen</Text></Box>
            <Box style={{ backgroundColor: "#533483", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">Flex Wrap</Text></Box>
            <Box style={{ backgroundColor: "#e94560", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">Canvas</Text></Box>
            <Box style={{ backgroundColor: "#0f3460", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">Graph</Text></Box>
            <Box style={{ backgroundColor: "#533483", borderRadius: 16, paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8 }}><Text fontSize={13} color="#ffffff">ScrollView</Text></Box>
          </Box>
        </Box>

        {/* === SECTION 3: Card grid with gap === */}
        <Box>
          <Text fontSize={20} color="#e94560">3. Card grid — wrap + gap + mixed heights</Text>
          <Text fontSize={12} color="#888888">Cards of different heights. Wrap should handle cross-axis per-line max.</Text>
          <Box style={{ flexDirection: "row", flexWrap: "wrap", width: '100%', gap: 16, marginTop: 8 }}>
            <Box style={{ width: 200, backgroundColor: "#16213e", borderRadius: 12, padding: 16 }}>
              <Text fontSize={16} color="#e94560">CPU</Text>
              <Text fontSize={32} color="#ffffff">87%</Text>
              <Text fontSize={12} color="#888888">4 cores active</Text>
            </Box>
            <Box style={{ width: 200, backgroundColor: "#16213e", borderRadius: 12, padding: 16 }}>
              <Text fontSize={16} color="#533483">Memory</Text>
              <Text fontSize={32} color="#ffffff">3.2GB</Text>
              <Text fontSize={12} color="#888888">of 16GB</Text>
              <Text fontSize={12} color="#888888">20% utilized</Text>
              <Box style={{ height: 4, backgroundColor: "#533483", borderRadius: 2, marginTop: 8, width: 40 }} />
            </Box>
            <Box style={{ width: 200, backgroundColor: "#16213e", borderRadius: 12, padding: 16 }}>
              <Text fontSize={16} color="#0f3460">Disk</Text>
              <Text fontSize={32} color="#ffffff">256GB</Text>
            </Box>
            <Box style={{ width: 200, backgroundColor: "#16213e", borderRadius: 12, padding: 16 }}>
              <Text fontSize={16} color="#e94560">Network</Text>
              <Text fontSize={32} color="#ffffff">1.2Gbps</Text>
              <Text fontSize={12} color="#888888">in: 840Mbps</Text>
              <Text fontSize={12} color="#888888">out: 360Mbps</Text>
            </Box>
            <Box style={{ width: 200, backgroundColor: "#16213e", borderRadius: 12, padding: 16 }}>
              <Text fontSize={16} color="#533483">GPU</Text>
              <Text fontSize={32} color="#ffffff">62%</Text>
              <Text fontSize={12} color="#888888">wgpu pipeline</Text>
              <Text fontSize={12} color="#888888">rect batches: 47</Text>
              <Text fontSize={12} color="#888888">text glyphs: 1204</Text>
            </Box>
            <Box style={{ width: 200, backgroundColor: "#16213e", borderRadius: 12, padding: 16 }}>
              <Text fontSize={16} color="#0f3460">Uptime</Text>
              <Text fontSize={32} color="#ffffff">14d</Text>
            </Box>
          </Box>
        </Box>

        {/* === SECTION 4: Tiny squares — stress test wrap line count === */}
        <Box>
          <Text fontSize={20} color="#e94560">4. 40px squares — maximum wrap lines</Text>
          <Text fontSize={12} color="#888888">Many small items force many wrap lines. Tests the MAX_LINES=64 limit.</Text>
          <Box style={{ flexDirection: "row", flexWrap: "wrap", width: '100%', gap: 4, marginTop: 8 }}>
            <Box style={{ width: 40, height: 40, backgroundColor: "#e94560", borderRadius: 4 }} />
            <Box style={{ width: 40, height: 40, backgroundColor: "#c23152", borderRadius: 4 }} />
