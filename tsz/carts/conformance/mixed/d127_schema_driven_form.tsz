// CONFORMANCE TEST 127: Schema-Driven Dynamic Form
//
// Ported from: Claude Code AskUserQuestionTool.tsx
//
// A dynamic question/answer form where the number of questions, number of
// options per question, and multi-select capability are all data-driven.
// Renders N questions x M options from array data, tracks selection state
// per question, collects answers, shows summary.
//
// Patterns tested:
// - Nested map: outer map over questions, inner map over options per question
// - Per-item selection state tracked in parallel array
// - Multi-select toggle vs single-select replace (conditional mutation)
// - Dynamic option count per question (not uniform)
// - Object with optional fields (description present or absent)
// - Conditional rendering based on selection state across questions
// - Template literals with 3+ interpolations
// - Handler captures both outer (question index) and inner (option index) loop vars
// - Summary computed from sparse answers object

const [questions, setQuestions] = useState([{ text: '', header: '', multiSelect: 0, options: '' }]);
const [options, setOptions] = useState([{ qIdx: 0, label: '', description: '', selected: 0 }]);
const [answers, setAnswers] = useState([{ qIdx: 0, answer: '' }]);
const [activeQuestion, setActiveQuestion] = useState(0);
const [answeredCount, setAnsweredCount] = useState(0);
const [totalQuestions, setTotalQuestions] = useState(0);
const [submitted, setSubmitted] = useState(0);
const [summaryText, setSummaryText] = useState('');

<script>
var qs = [
  { text: 'Which library should we use for date formatting?', header: 'Library', multiSelect: 0, options: 'date-fns|dayjs|luxon' },
  { text: 'Which features do you want to enable?', header: 'Features', multiSelect: 1, options: 'dark-mode|i18n|analytics|a11y' },
  { text: 'What auth method should we implement?', header: 'Auth', multiSelect: 0, options: 'JWT|OAuth2|Session|API-Key' },
  { text: 'Which test frameworks should we set up?', header: 'Testing', multiSelect: 1, options: 'vitest|playwright|storybook' }
];
setQuestions(qs);
setTotalQuestions(qs.length);

var opts = [];
var idx = 0;
for (var i = 0; i < qs.length; i++) {
  var parts = qs[i].options.split('|');
  for (var j = 0; j < parts.length; j++) {
    opts[idx] = { qIdx: i, label: parts[j], description: '', selected: 0 };
    idx++;
  }
}
// Add descriptions to some options
opts[0].description = 'Modern, tree-shakeable, immutable';
opts[1].description = '2KB, Moment-compatible API';
opts[2].description = 'Rich API, timezone support, by Moment team';
opts[3].description = 'System-aware theme switching';
opts[4].description = 'Multi-language content support';
opts[5].description = 'Usage tracking and metrics';
opts[6].description = 'Screen reader and keyboard nav';
opts[7].description = 'Stateless, scalable tokens';
opts[8].description = 'Delegated auth, third-party login';
opts[9].description = 'Server-side state, cookie-based';
opts[10].description = 'Simple header-based auth';
opts[11].description = 'Fast, ESM-native, Vite-powered';
opts[12].description = 'E2E browser testing';
opts[13].description = 'Component documentation and visual testing';
setOptions(opts);

var ans = [];
for (var k = 0; k < qs.length; k++) {
  ans[k] = { qIdx: k, answer: '' };
}
setAnswers(ans);

function selectOption(qIdx, optIdx) {
  var q = qs[qIdx];
  var optLabel = opts[optIdx].label;

  if (q.multiSelect === 1) {
    // Toggle: if already selected, deselect; otherwise select
    if (opts[optIdx].selected === 1) {
      opts[optIdx].selected = 0;
    } else {
      opts[optIdx].selected = 1;
    }
    // Rebuild answer from all selected options for this question
    var selected = '';
    for (var i = 0; i < opts.length; i++) {
      if (opts[i].qIdx === qIdx && opts[i].selected === 1) {
        if (selected !== '') selected = selected + ', ';
        selected = selected + opts[i].label;
      }
    }
    ans[qIdx].answer = selected;
  } else {
    // Single select: deselect all others in this question, select this one
    for (var j = 0; j < opts.length; j++) {
      if (opts[j].qIdx === qIdx) {
        opts[j].selected = 0;
      }
    }
    opts[optIdx].selected = 1;
    ans[qIdx].answer = optLabel;
  }

  setOptions(opts);
  setAnswers(ans);

  var ac = 0;
  for (var m = 0; m < ans.length; m++) {
    if (ans[m].answer !== '') ac++;
  }
  setAnsweredCount(ac);
}

function submitForm() {
  var summary = '';
  for (var i = 0; i < qs.length; i++) {
    if (ans[i].answer !== '') {
      summary = summary + qs[i].header + ': ' + ans[i].answer + ' | ';
    } else {
      summary = summary + qs[i].header + ': (skipped) | ';
    }
  }
  setSummaryText(summary);
  setSubmitted(1);
}

function resetForm() {
  for (var i = 0; i < opts.length; i++) {
    opts[i].selected = 0;
  }
  for (var j = 0; j < ans.length; j++) {
    ans[j].answer = '';
  }
  setOptions(opts);
  setAnswers(ans);
  setAnsweredCount(0);
  setSubmitted(0);
  setSummaryText('');
}
</script>

function QuestionChip(header, idx) {
  return (
    <Pressable onPress={() => { setActiveQuestion(idx) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, borderRadius: 12, backgroundColor: activeQuestion == idx ? "#3b82f6" : answers[idx].answer !== '' ? "#1e3a5f" : "#334155" }}>
      <Text fontSize={9} color="#ffffff">{header}</Text>
    </Pressable>
  );
}

function OptionCard(opt, optIdx) {
  return (
    <Pressable onPress={() => { selectOption(opt.qIdx, optIdx) }} style={{ flexDirection: "row", gap: 8, alignItems: "center", padding: 10, backgroundColor: opt.selected == 1 ? "#1e3a5f" : "#1e293b", borderRadius: 8, borderWidth: opt.selected == 1 ? 1 : 0, borderColor: "#3b82f6" }}>
      <Box style={{ width: 16, height: 16, borderRadius: 8, borderWidth: 2, borderColor: opt.selected == 1 ? "#3b82f6" : "#475569", backgroundColor: opt.selected == 1 ? "#3b82f6" : "transparent", alignItems: "center", justifyContent: "center" }}>
        {opt.selected == 1 && <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: "#ffffff" }} />}
      </Box>
      <Box style={{ flexGrow: 1, gap: 2 }}>
        <Text fontSize={11} color={opt.selected == 1 ? "#e2e8f0" : "#94a3b8"}>{opt.label}</Text>
        {opt.description !== '' && <Text fontSize={8} color="#475569">{opt.description}</Text>}
      </Box>
    </Pressable>
  );
}

function App() {
  return (
    <Box style={{ backgroundColor: "#0f172a", padding: 16, width: "100%", height: "100%", flexDirection: "column", gap: 12 }}>
      <Text fontSize={16} color="#e2e8f0">Schema-Driven Form</Text>

      <Box style={{ flexDirection: "row", gap: 6 }}>
        {questions.map((q, qi) => (
          <QuestionChip header={q.header} idx={qi} />
        ))}
      </Box>

      {submitted == 0 && <Box style={{ flexGrow: 1, flexDirection: "column", gap: 8 }}>
        {questions.map((q, qi) => (
          <Box>
            {activeQuestion == qi && <Box style={{ gap: 8 }}>
              <Box style={{ gap: 4 }}>
                <Text fontSize={12} color="#e2e8f0">{q.text}</Text>
                {q.multiSelect == 1 && <Text fontSize={8} color="#3b82f6">Select multiple</Text>}
                {q.multiSelect == 0 && <Text fontSize={8} color="#475569">Select one</Text>}
              </Box>
              <Box style={{ gap: 4 }}>
                {options.map((opt, oi) => (
                  <Box>
                    {opt.qIdx == qi && <OptionCard opt={opt} optIdx={oi} />}
                  </Box>
                ))}
              </Box>
              {answers[qi].answer !== '' && <Text fontSize={9} color="#22c55e">{`Selected: ${answers[qi].answer}`}</Text>}
            </Box>}
          </Box>
        ))}
      </Box>}

      {submitted == 1 && <Box style={{ flexGrow: 1, padding: 12, backgroundColor: "#1e293b", borderRadius: 8, gap: 8 }}>
        <Text fontSize={14} color="#22c55e">Submitted</Text>
        {answers.map((a, ai) => (
          <Box style={{ flexDirection: "row", gap: 6 }}>
            <Text fontSize={10} color="#475569">{questions[ai].header}:</Text>
            <Text fontSize={10} color={a.answer !== '' ? "#e2e8f0" : "#ef4444"}>{a.answer !== '' ? a.answer : "(skipped)"}</Text>
          </Box>
        ))}
        <Text fontSize={8} color="#475569">{summaryText}</Text>
      </Box>}

      <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center" }}>
        <Text fontSize={9} color="#475569">{`${answeredCount}/${totalQuestions} answered`}</Text>
        <Box style={{ flexDirection: "row", gap: 6 }}>
          {submitted == 0 && <Pressable onPress={() => { submitForm() }} style={{ padding: 6, backgroundColor: answeredCount == totalQuestions ? "#22c55e" : "#334155", borderRadius: 4 }}>
            <Text fontSize={9} color="#ffffff">Submit</Text>
          </Pressable>}
          {submitted == 1 && <Pressable onPress={() => { resetForm() }} style={{ padding: 6, backgroundColor: "#3b82f6", borderRadius: 4 }}>
            <Text fontSize={9} color="#ffffff">Reset</Text>
          </Pressable>}
        </Box>
      </Box>
    </Box>
  );
}
