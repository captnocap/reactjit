export const d122_data = 'init';

export function init(state) {
  state.pages = [
    { name: 'Home', active: 1 },
    { name: 'Inbox', active: 0 },
    { name: 'Settings', active: 0 },
  ];
  state.cards = [
    { title: 'Welcome', body: 'This panel adapts to window width and variant.' },
    { title: 'Notifications', body: 'Three unread messages from today.' },
  ];
}
