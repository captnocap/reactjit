// SOUP: Error Message Display
// From: Claude Code FallbackToolUseErrorMessage.tsx + SystemTextMessage.tsx
// Standard React error display with truncation, line counting,
// severity levels, and expandable detail. Multiple message types
// rendered from a type discriminant.

import React from 'react';

const ErrorDisplay = () => {
  const [errors, setErrors] = React.useState([
    { type: 'tool', message: 'Error: ENOENT: no such file or directory, open "src/missing.ts"\n  at Object.openSync (fs.js:498)\n  at readFileSync (fs.js:394)\n  at Module._compile (loader.js:401)', severity: 'error', expanded: false },
    { type: 'rate_limit', message: 'Rate limit exceeded. Please wait 30 seconds before retrying.', severity: 'warning', expanded: false },
    { type: 'validation', message: 'InputValidationError: parameter "path" is required but was not provided', severity: 'error', expanded: false },
    { type: 'network', message: 'Connection reset by peer.\nRetrying in 5 seconds...\nAttempt 2 of 3.\nBackoff: exponential\nNext retry: 10s', severity: 'warning', expanded: false },
    { type: 'api', message: 'Error: 529 API Overloaded\nThe API is temporarily overloaded. Please try again later.\nRequest ID: req_abc123\nRegion: us-east-1', severity: 'critical', expanded: false },
  ]);
  const [showAll, setShowAll] = React.useState(false);
  const [verboseMode, setVerboseMode] = React.useState(false);

  const MAX_LINES = 3;

  const toggleExpand = (index) => {
    const updated = [...errors];
    updated[index] = { ...updated[index], expanded: !updated[index].expanded };
    setErrors(updated);
  };

  const dismiss = (index) => {
    setErrors(errors.filter((_, i) => i !== index));
  };

  const getLineCount = (text) => text.split('\n').length;
  const truncateMessage = (text) => text.split('\n').slice(0, MAX_LINES).join('\n');

  const criticalCount = errors.filter(e => e.severity === 'critical').length;
  const errorCount = errors.filter(e => e.severity === 'error').length;
  const warningCount = errors.filter(e => e.severity === 'warning').length;

  return (
    <div style={{ backgroundColor: "#0f172a", width: "100%", height: "100%", padding: 16, gap: 12 }}>
      <div style={{ flexDirection: "row", justifyContent: "space-between", alignItems: "center" }}>
        <h2 style={{ fontSize: 16, color: "#e2e8f0" }}>Errors & Warnings</h2>
        <div style={{ flexDirection: "row", gap: 6 }}>
          <button
            onClick={() => setVerboseMode(!verboseMode)}
            style={{ padding: 4, backgroundColor: verboseMode ? "#7c3aed" : "#334155", borderRadius: 4 }}
          >
            <span style={{ fontSize: 8, color: "#ffffff" }}>{verboseMode ? "Verbose" : "Compact"}</span>
          </button>
        </div>
      </div>

      <div style={{ flexDirection: "row", gap: 8 }}>
        {criticalCount > 0 && <span style={{ fontSize: 9, color: "#ef4444" }}>{criticalCount} critical</span>}
        {errorCount > 0 && <span style={{ fontSize: 9, color: "#f59e0b" }}>{errorCount} errors</span>}
        {warningCount > 0 && <span style={{ fontSize: 9, color: "#3b82f6" }}>{warningCount} warnings</span>}
      </div>

      <div style={{ flexGrow: 1, gap: 6, overflow: "scroll" }}>
        {errors.map((err, i) => (
          <div
            key={i}
            style={{
              padding: 10,
              backgroundColor: err.severity === 'critical' ? "#450a0a" : err.severity === 'error' ? "#451a03" : "#1e293b",
              borderRadius: 8,
              gap: 6,
              borderWidth: err.severity === 'critical' ? 1 : 0,
              borderColor: "#ef4444"
            }}
          >
            <div style={{ flexDirection: "row", gap: 6, alignItems: "center", justifyContent: "space-between" }}>
              <div style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
                <div style={{
                  width: 8, height: 8, borderRadius: 4,
                  backgroundColor: err.severity === 'critical' ? "#ef4444" : err.severity === 'error' ? "#f59e0b" : "#3b82f6"
                }} />
                <span style={{
                  fontSize: 9,
                  color: err.severity === 'critical' ? "#ef4444" : err.severity === 'error' ? "#f59e0b" : "#3b82f6"
                }}>
                  {err.type}
                </span>
              </div>
              <button onClick={() => dismiss(i)} style={{ padding: 2 }}>
                <span style={{ fontSize: 8, color: "#475569" }}>dismiss</span>
              </button>
            </div>

            <pre style={{
              fontSize: 9,
              color: err.severity === 'critical' ? "#fca5a5" : err.severity === 'error' ? "#fbbf24" : "#94a3b8",
              fontFamily: "monospace"
            }}>
              {verboseMode || err.expanded ? err.message : truncateMessage(err.message)}
            </pre>

            {!verboseMode && !err.expanded && getLineCount(err.message) > MAX_LINES && (
              <button onClick={() => toggleExpand(i)} style={{ padding: 2 }}>
                <span style={{ fontSize: 8, color: "#475569" }}>
                  +{getLineCount(err.message) - MAX_LINES} more lines
                </span>
              </button>
            )}

            {err.expanded && !verboseMode && (
              <button onClick={() => toggleExpand(i)} style={{ padding: 2 }}>
                <span style={{ fontSize: 8, color: "#475569" }}>collapse</span>
              </button>
            )}
          </div>
        ))}
      </div>

      <p style={{ fontSize: 8, color: "#475569" }}>{errors.length} total · verbose: {verboseMode ? "on" : "off"}</p>
    </div>
  );
};

export default ErrorDisplay;
