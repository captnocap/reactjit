// SOUP: Agent Status Cards
// From: Claude Code AgentTool/UI.tsx + agentColorManager + BackgroundTasksDialog
// Standard React agent/task status cards with color assignment,
// model display, progress counts, and foreground/background toggle.

import React from 'react';

const AGENT_COLORS = ['#3b82f6', '#22c55e', '#f59e0b', '#ef4444', '#a855f7', '#ec4899', '#14b8a6', '#f97316'];

const AgentStatusCards = () => {
  const [agents, setAgents] = React.useState([
    { name: 'search-agent', model: 'sonnet', status: 'running', progress: 3, total: 5, foreground: true, description: 'Searching codebase for auth patterns' },
    { name: 'test-runner', model: 'haiku', status: 'running', progress: 12, total: 47, foreground: false, description: 'Running test suite' },
    { name: 'code-reviewer', model: 'opus', status: 'complete', progress: 8, total: 8, foreground: false, description: 'Reviewed PR #142' },
    { name: 'doc-writer', model: 'sonnet', status: 'error', progress: 2, total: 6, foreground: false, description: 'Generating API documentation' },
    { name: 'refactor-agent', model: 'opus', status: 'queued', progress: 0, total: 3, foreground: false, description: 'Queued: refactor auth middleware' },
  ]);
  const [selectedAgent, setSelectedAgent] = React.useState(0);
  const [expandedAgent, setExpandedAgent] = React.useState(null);

  const getColor = (index) => AGENT_COLORS[index % AGENT_COLORS.length];

  const toggleForeground = (index) => {
    const updated = agents.map((a, i) => ({
      ...a,
      foreground: i === index ? !a.foreground : (i === index ? true : false)
    }));
    // Only one foreground at a time
    if (!agents[index].foreground) {
      updated.forEach((a, i) => { if (i !== index) a.foreground = false; });
    }
    setAgents(updated);
  };

  const stopAgent = (index) => {
    const updated = [...agents];
    updated[index] = { ...updated[index], status: 'stopped' };
    setAgents(updated);
  };

  const runningCount = agents.filter(a => a.status === 'running').length;
  const backgroundCount = agents.filter(a => !a.foreground && a.status === 'running').length;

  return (
    <div style={{ backgroundColor: "#0f172a", width: "100%", height: "100%", padding: 16, gap: 12 }}>
      <div style={{ flexDirection: "row", justifyContent: "space-between", alignItems: "center" }}>
        <h2 style={{ fontSize: 16, color: "#e2e8f0" }}>Agent Tasks</h2>
        <span style={{ fontSize: 9, color: "#64748b" }}>{runningCount} running · {backgroundCount} background</span>
      </div>

      <div style={{ flexGrow: 1, gap: 6, overflow: "scroll" }}>
        {agents.map((agent, i) => (
          <div
            key={i}
            onClick={() => { setSelectedAgent(i); setExpandedAgent(expandedAgent === i ? null : i); }}
            style={{
              padding: 10,
              backgroundColor: selectedAgent === i ? "#334155" : "#1e293b",
              borderRadius: 8,
              gap: 6,
              borderLeftWidth: 3,
              borderLeftColor: getColor(i)
            }}
          >
            <div style={{ flexDirection: "row", gap: 8, alignItems: "center" }}>
              <div style={{
                width: 24, height: 24, borderRadius: 12,
                backgroundColor: getColor(i),
                alignItems: "center", justifyContent: "center"
              }}>
                <span style={{ fontSize: 10, color: "#ffffff" }}>{agent.name.charAt(0).toUpperCase()}</span>
              </div>

              <div style={{ flexGrow: 1, gap: 2 }}>
                <div style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
                  <span style={{ fontSize: 11, color: "#e2e8f0" }}>{agent.name}</span>
                  <span style={{ fontSize: 7, color: "#475569" }}>{agent.model}</span>
                  {agent.foreground && (
                    <div style={{ paddingLeft: 4, paddingRight: 4, backgroundColor: "#1e40af", borderRadius: 3 }}>
                      <span style={{ fontSize: 6, color: "#ffffff" }}>FG</span>
                    </div>
                  )}
                </div>
                <span style={{ fontSize: 8, color: "#64748b" }}>{agent.description}</span>
              </div>

              <div style={{ alignItems: "flex-end", gap: 4 }}>
                <div style={{
                  width: 8, height: 8, borderRadius: 4,
                  backgroundColor: agent.status === 'running' ? "#22c55e" : agent.status === 'complete' ? "#3b82f6" : agent.status === 'error' ? "#ef4444" : agent.status === 'queued' ? "#f59e0b" : "#475569"
                }} />
                <span style={{ fontSize: 7, color: "#475569" }}>{agent.progress}/{agent.total}</span>
              </div>
            </div>

            {agent.status === 'running' && (
              <div style={{ height: 3, backgroundColor: "#0f172a", borderRadius: 2 }}>
                <div style={{
                  height: 3, borderRadius: 2,
                  backgroundColor: getColor(i),
                  width: `${(agent.progress / agent.total) * 100}%`
                }} />
              </div>
            )}

            {expandedAgent === i && (
              <div style={{ flexDirection: "row", gap: 6, justifyContent: "flex-end" }}>
                {agent.status === 'running' && (
                  <button onClick={() => toggleForeground(i)} style={{ padding: 4, backgroundColor: "#334155", borderRadius: 4 }}>
                    <span style={{ fontSize: 8, color: "#94a3b8" }}>{agent.foreground ? "Background" : "Foreground"}</span>
                  </button>
                )}
                {(agent.status === 'running' || agent.status === 'queued') && (
                  <button onClick={() => stopAgent(i)} style={{ padding: 4, backgroundColor: "#dc2626", borderRadius: 4 }}>
                    <span style={{ fontSize: 8, color: "#ffffff" }}>Stop</span>
                  </button>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  );
};

export default AgentStatusCards;
