// SOUP: Permission Dialog
// From: Claude Code BashPermissionRequest.tsx
// Standard React permission dialog with Allow/Deny/Always Allow options,
// command display, destructive command warning, and classifier status.

import React from 'react';

const PermissionDialog = () => {
  const [commands, setCommands] = React.useState([
    { command: 'git status', description: 'Show working tree status', tool: 'Bash', dangerous: false, approved: null, classifying: false },
    { command: 'rm -rf node_modules/', description: 'Delete node_modules directory', tool: 'Bash', dangerous: true, approved: null, classifying: false },
    { command: 'cat src/auth.ts', description: 'Read auth module', tool: 'Bash', dangerous: false, approved: null, classifying: false },
    { command: 'npm install lodash', description: 'Install package dependencies', tool: 'Bash', dangerous: false, approved: null, classifying: false },
    { command: 'git push --force origin main', description: 'Force push to main branch', tool: 'Bash', dangerous: true, approved: null, classifying: false },
  ]);
  const [selectedIndex, setSelectedIndex] = React.useState(0);
  const [autoApproveCount, setAutoApproveCount] = React.useState(0);
  const [mode, setMode] = React.useState('default');

  const approve = (index) => {
    const updated = [...commands];
    updated[index] = { ...updated[index], approved: true };
    setCommands(updated);
  };

  const deny = (index) => {
    const updated = [...commands];
    updated[index] = { ...updated[index], approved: false };
    setCommands(updated);
  };

  const alwaysAllow = (index) => {
    const updated = [...commands];
    updated[index] = { ...updated[index], approved: true };
    setCommands(updated);
    setAutoApproveCount(autoApproveCount + 1);
  };

  const pendingCount = commands.filter(c => c.approved === null).length;
  const approvedCount = commands.filter(c => c.approved === true).length;
  const deniedCount = commands.filter(c => c.approved === false).length;

  return (
    <div style={{ backgroundColor: "#0f172a", width: "100%", height: "100%", padding: 16, gap: 12 }}>
      <div style={{ flexDirection: "row", justifyContent: "space-between", alignItems: "center" }}>
        <h2 style={{ fontSize: 16, color: "#e2e8f0" }}>Permission Requests</h2>
        <div style={{ flexDirection: "row", gap: 8 }}>
          <button
            onClick={() => setMode(mode === 'default' ? 'auto' : 'default')}
            style={{ padding: 6, backgroundColor: mode === 'auto' ? "#22c55e" : "#334155", borderRadius: 4 }}
          >
            <span style={{ fontSize: 9, color: "#ffffff" }}>{mode === 'auto' ? 'Auto-approve' : 'Manual'}</span>
          </button>
        </div>
      </div>

      <div style={{ flexDirection: "row", gap: 12 }}>
        <span style={{ fontSize: 9, color: "#f59e0b" }}>{pendingCount} pending</span>
        <span style={{ fontSize: 9, color: "#22c55e" }}>{approvedCount} approved</span>
        <span style={{ fontSize: 9, color: "#ef4444" }}>{deniedCount} denied</span>
        {autoApproveCount > 0 && <span style={{ fontSize: 9, color: "#3b82f6" }}>{autoApproveCount} auto-rules</span>}
      </div>

      <div style={{ flexGrow: 1, gap: 6, overflow: "scroll" }}>
        {commands.map((cmd, i) => (
          <div
            key={i}
            onClick={() => setSelectedIndex(i)}
            style={{
              padding: 10,
              backgroundColor: selectedIndex === i ? "#334155" : "#1e293b",
              borderRadius: 8,
              gap: 6,
              borderWidth: cmd.dangerous ? 1 : 0,
              borderColor: "#ef4444"
            }}
          >
            <div style={{ flexDirection: "row", gap: 8, alignItems: "center" }}>
              <div style={{
                paddingLeft: 5, paddingRight: 5, paddingTop: 2, paddingBottom: 2,
                backgroundColor: "#1e40af", borderRadius: 3
              }}>
                <span style={{ fontSize: 7, color: "#ffffff" }}>{cmd.tool}</span>
              </div>
              {cmd.dangerous && (
                <div style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 1, paddingBottom: 1, backgroundColor: "#dc2626", borderRadius: 3 }}>
                  <span style={{ fontSize: 7, color: "#ffffff" }}>DESTRUCTIVE</span>
                </div>
              )}
              <div style={{
                width: 8, height: 8, borderRadius: 4,
                backgroundColor: cmd.approved === true ? "#22c55e" : cmd.approved === false ? "#ef4444" : "#f59e0b"
              }} />
            </div>

            <p style={{ fontSize: 11, color: cmd.dangerous ? "#fca5a5" : "#e2e8f0", fontFamily: "monospace" }}>$ {cmd.command}</p>
            <p style={{ fontSize: 8, color: "#64748b" }}>{cmd.description}</p>

            {cmd.approved === null && (
              <div style={{ flexDirection: "row", gap: 6, justifyContent: "flex-end" }}>
                <button onClick={() => approve(i)} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: "#22c55e", borderRadius: 4 }}>
                  <span style={{ fontSize: 8, color: "#ffffff" }}>Allow</span>
                </button>
                <button onClick={() => alwaysAllow(i)} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: "#1e40af", borderRadius: 4 }}>
                  <span style={{ fontSize: 8, color: "#ffffff" }}>Always</span>
                </button>
                <button onClick={() => deny(i)} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: "#ef4444", borderRadius: 4 }}>
                  <span style={{ fontSize: 8, color: "#ffffff" }}>Deny</span>
                </button>
              </div>
            )}

            {cmd.approved === true && <p style={{ fontSize: 8, color: "#22c55e" }}>Approved</p>}
            {cmd.approved === false && <p style={{ fontSize: 8, color: "#ef4444" }}>Denied</p>}
          </div>
        ))}
      </div>

      <p style={{ fontSize: 8, color: "#475569" }}>mode: {mode} · selected: {selectedIndex}</p>
    </div>
  );
};

export default PermissionDialog;
