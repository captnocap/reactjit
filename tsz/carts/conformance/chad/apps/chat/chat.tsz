// CONFORMANCE: Chat — Slack/Discord-style app.
// Proves: app structure, websocket <during connected>, components with callbacks, cross-lib state.

from '../../theme.cls'
from '../../icons.glyphs'
from '../../libs/net/net'

<chat app>
  <var>
    pages is page array
    set_active is 'channels'
    set_connected is false
    set_username is 'user'
  </var>

  <pages>
    channels
    direct
  </pages>
  <functions>
    boot:
      net.socket.connect('wss://chat.example.com')
      set_connected is true

    shutdown:
      net.socket.disconnect

    goTo requires item:
      set_active is item
  </functions>

  return(
    <C.PageRow>
      <C.Sidebar>
        <C.Title>:send: Chat</C.Title>
        <C.Hint>
          <if connected>
            :check: Connected
          </if>
          <else>
            :error: Disconnected
          </else>
        </C.Hint>
        <C.Divider />
        <for pages>
          <Pressable onPress=goTo>
            <if item exact active>
              <C.NavItemActive><C.NavLabelActive>{item}</C.NavLabelActive></C.NavItemActive>
            </if>
            <else>
              <C.NavItem><C.NavLabel>{item}</C.NavLabel></C.NavItem>
            </else>
          </Pressable>
        </for>
        <C.Divider />
        <C.Hint>{username}</C.Hint>
      </C.Sidebar>
      <C.Main>
        <active page />
      </C.Main>
    </C.PageRow>
  )
</chat>
