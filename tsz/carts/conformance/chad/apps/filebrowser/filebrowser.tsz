// CONFORMANCE: File Browser — Finder/Nautilus-style app.
// Proves: fs lib integration, tree structure, <switch> on file type, breadcrumbs, components.

<fileBrowser app>
  <var>
    pages is page array
    set_active
  </var>

  <pages>
    browse
    preview
  </pages>
  <functions>
    boot:
      set_active is browse

    goTo requires item:
      set_active is item
  </functions>

  return(
    <C.PageRow>
      <C.Sidebar>
        <C.Title>:folder: Files</C.Title>
        <C.Divider />
        <for pages>
          <C.Button goTo>
            <if item exact active>
              <C.NavItemActive><C.NavLabelActive>{item}</C.NavLabelActive></C.NavItemActive>
            </if>
            <else>
              <C.NavItem><C.NavLabel>{item}</C.NavLabel></C.NavItem>
            </else>
          </C.Button>
        </for>
        <C.Spacer />
        <C.Hint>{sys.os + ' ' + sys.kernel}</C.Hint>
      </C.Sidebar>
      <C.Main>
        <active page />
      </C.Main>
    </C.PageRow>
  )
</fileBrowser>
