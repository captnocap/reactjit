function Button({label}) {
  return (
    <Pressable style={{ padding: 12, backgroundColor: '#3b82f6', borderRadius: 8 }}>
      <Text color="#ffffff">{label}</Text>
    </Pressable>
  );
}

function App() {
  const [count, setCount] = useState(0);
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1a1a2e', justifyContent: 'center', alignItems: 'center', gap: 16 }}>
      <Text fontSize={48} color="#ffffff">{count}</Text>
      <Button label="Click me" />
    </Box>
  );
}
