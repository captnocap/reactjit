const [count, setCount] = useState(0);
const [name, setName] = useState('World');

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1a1a2e', justifyContent: 'center', alignItems: 'center', gap: 16 }}>
      <Text fontSize={24} color="#ffffff">{`Hello ${name}! Count: ${count}`}</Text>
      <Pressable onPress={() => setCount(count + 1)} style={{ padding: 16, backgroundColor: '#e94560', borderRadius: 8 }}>
        <Text color="#ffffff">+1</Text>
      </Pressable>
    </Box>
  );
}
