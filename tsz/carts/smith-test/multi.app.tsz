function App() {
  const [count, setCount] = useState(0);
  const [name, setName] = useState('World');
  const [active, setActive] = useState(true);

  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1a1a2e', flexDirection: 'column', justifyContent: 'center', alignItems: 'center', gap: 20 }}>
      <Text fontSize={32} color="#e94560">Hello {name}!</Text>
      <Text fontSize={48} color="#ffffff">{count}</Text>
      <Box style={{ flexDirection: 'row', gap: 8 }}>
        <Pressable onPress={() => setCount(count + 1)} style={{ padding: 16, backgroundColor: '#0f3460', borderRadius: 8 }}>
          <Text color="#ffffff">+1</Text>
        </Pressable>
        <Pressable onPress={() => setActive(false)} style={{ padding: 16, backgroundColor: '#533483', borderRadius: 8 }}>
          <Text color="#ffffff">Disable</Text>
        </Pressable>
      </Box>
    </Box>
  );
}
