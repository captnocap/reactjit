classifier Page {
  flexDirection: 'column';
  gap: 12;
  padding: 20;
  backgroundColor: '#0d1117';
  width: '100%';
  height: '100%';
}

classifier Title {
  fontSize: 24;
  color: '#e6edf3';
}

classifier Subtitle {
  fontSize: 13;
  color: '#8b949e';
}

classifier InputBox {
  type: 'TextInput';
  fontSize: 14;
  color: '#e6edf3';
  style: {
    backgroundColor: '#161b22';
    borderWidth: 1;
    borderColor: '#30363d';
    borderRadius: 8;
    padding: 12;
    paddingLeft: 14;
    paddingRight: 14;
    height: 48;
  };
}

classifier SectionLabel {
  fontSize: 12;
  color: '#8b949e';
}

classifier ResultBox {
  flexDirection: 'column';
  gap: 4;
  padding: 12;
  backgroundColor: '#161b22';
  borderWidth: 1;
  borderColor: '#30363d';
  borderRadius: 8;
}

classifier RedactedText {
  fontSize: 14;
  color: '#f0883e';
}

classifier MatchRow {
  flexDirection: 'row';
  gap: 8;
  alignItems: 'center';
  paddingTop: 2;
  paddingBottom: 2;
}

classifier Badge {
  fontSize: 11;
  color: '#0d1117';
}

classifier EmailBadge {
  backgroundColor: '#58a6ff';
  borderRadius: 4;
  paddingLeft: 6;
  paddingRight: 6;
  paddingTop: 2;
  paddingBottom: 2;
}

classifier SsnBadge {
  backgroundColor: '#f85149';
  borderRadius: 4;
  paddingLeft: 6;
  paddingRight: 6;
  paddingTop: 2;
  paddingBottom: 2;
}

classifier CardBadge {
  backgroundColor: '#d2992a';
  borderRadius: 4;
  paddingLeft: 6;
  paddingRight: 6;
  paddingTop: 2;
  paddingBottom: 2;
}

classifier PhoneBadge {
  backgroundColor: '#3fb950';
  borderRadius: 4;
  paddingLeft: 6;
  paddingRight: 6;
  paddingTop: 2;
  paddingBottom: 2;
}

classifier MatchValue {
  fontSize: 13;
  color: '#c9d1d9';
}

classifier StatusBar {
  flexDirection: 'row';
  gap: 12;
  paddingTop: 8;
  borderTopWidth: 1;
  borderColor: '#30363d';
  alignItems: 'center';
}

classifier StatusText {
  fontSize: 14;
  color: '#3fb950';
}

classifier CountText {
  fontSize: 13;
  color: '#8b949e';
}
