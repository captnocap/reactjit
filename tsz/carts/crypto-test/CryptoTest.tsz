// Crypto Test Suite — exercises every function in framework/crypto.zig.
// Build: ./zig-out/bin/zigos-compiler build carts/crypto-test/CryptoTest.tsz
// Run:   ./zig-out/bin/CryptoTest
//
// The FFI function crypto_run_all_tests() runs all known-answer vectors,
// prints green/red per-test results to the terminal, and returns the
// pass count. The visual UI shows the summary.

// @ffi <crypto_test.h>
declare function crypto_run_all_tests(): number;

import { Page, Header, Title, Subtitle, Section, SectionTitle, TestRow, TestName, PassText, Summary, SummaryLabel, SummaryCount } from './crypto_test_cls';

const [passed] = useFFI(crypto_run_all_tests, 1);

function App() {
  return (
    <C.Page>
      <C.Header>
        <C.Title>Crypto Test Suite</C.Title>
        <C.Subtitle>RFC known-answer vectors — see terminal for per-test results</C.Subtitle>
      </C.Header>

      <C.Section>
        <C.SectionTitle>HMAC-SHA256 (RFC 4231)</C.SectionTitle>
        <C.TestRow>
          <C.TestName>HMAC("key", "The quick brown fox...")</C.TestName>
          <C.PassText>vector</C.PassText>
        </C.TestRow>
      </C.Section>

      <C.Section>
        <C.SectionTitle>HKDF-SHA256 (RFC 5869)</C.SectionTitle>
        <C.TestRow><C.TestName>Test case 1 — standard inputs</C.TestName><C.PassText>vector</C.PassText></C.TestRow>
        <C.TestRow><C.TestName>Test case 2 — long inputs</C.TestName><C.PassText>vector</C.PassText></C.TestRow>
        <C.TestRow><C.TestName>Test case 3 — empty salt/info</C.TestName><C.PassText>vector</C.PassText></C.TestRow>
        <C.TestRow><C.TestName>Reject overlong output</C.TestName><C.PassText>negative</C.PassText></C.TestRow>
      </C.Section>

      <C.Section>
        <C.SectionTitle>Shamir Secret Sharing (GF256)</C.SectionTitle>
        <C.TestRow><C.TestName>GF(256) polynomial evaluation</C.TestName><C.PassText>vector</C.PassText></C.TestRow>
        <C.TestRow><C.TestName>Combine hex API</C.TestName><C.PassText>vector</C.PassText></C.TestRow>
      </C.Section>

      <C.Section>
        <C.SectionTitle>Envelope Encryption (XChaCha20-Poly1305)</C.SectionTitle>
        <C.TestRow><C.TestName>Encrypt/decrypt round trip</C.TestName><C.PassText>roundtrip</C.PassText></C.TestRow>
        <C.TestRow><C.TestName>Reject wrong KEK</C.TestName><C.PassText>negative</C.PassText></C.TestRow>
        <C.TestRow><C.TestName>Fresh randomness per encrypt</C.TestName><C.PassText>invariant</C.PassText></C.TestRow>
      </C.Section>

      <C.Section>
        <C.SectionTitle>PII Detection + Sanitization</C.SectionTitle>
        <C.TestRow><C.TestName>Detect email + SSN boundaries</C.TestName><C.PassText>pattern</C.PassText></C.TestRow>
        <C.TestRow><C.TestName>Redact PII from text</C.TestName><C.PassText>pattern</C.PassText></C.TestRow>
        <C.TestRow><C.TestName>HTML sanitization prevents XSS</C.TestName><C.PassText>escape</C.PassText></C.TestRow>
      </C.Section>

      <C.Summary>
        <C.SummaryLabel>{`Tests passed:`}</C.SummaryLabel>
        <C.SummaryCount>{`${passed} / 13`}</C.SummaryCount>
      </C.Summary>
    </C.Page>
  );
}
