              <C.Card><C.CardName>ElementsPage</C.CardName><C.CardPath>inspector/ElementsPage.c.tsz</C.CardPath><C.CardTag>DOM elements</C.CardTag></C.Card>
              <C.Card><C.CardName>ConsolePage</C.CardName><C.CardPath>inspector/ConsolePage.c.tsz</C.CardPath><C.CardTag>console output</C.CardTag></C.Card>
              <C.Card><C.CardName>NetworkPage</C.CardName><C.CardPath>inspector/NetworkPage.c.tsz</C.CardPath><C.CardTag>network requests</C.CardTag></C.Card>
              <C.Card><C.CardName>PerfPage</C.CardName><C.CardPath>inspector/PerfPage.c.tsz</C.CardPath><C.CardTag>performance panel</C.CardTag></C.Card>
              <C.Card><C.CardName>SourcePage</C.CardName><C.CardPath>inspector/SourcePage.c.tsz</C.CardPath><C.CardTag>source viewer</C.CardTag></C.Card>
              <C.Card><C.CardName>LogsPage</C.CardName><C.CardPath>inspector/LogsPage.c.tsz</C.CardPath><C.CardTag>log viewer</C.CardTag></C.Card>
              <C.Card><C.CardName>GraphLegend</C.CardName><C.CardPath>inspector/GraphLegend.c.tsz</C.CardPath><C.CardTag>constraint graph legend</C.CardTag></C.Card>
            </C.Grid>
