              <C.Card><C.CardName>VideoTest</C.CardName><C.CardPath>video-test/VideoTest.tsz</C.CardPath><C.CardTag>video playback</C.CardTag></C.Card>
              <C.Card><C.CardName>AudioTest</C.CardName><C.CardPath>effect-bench/AudioTest.tsz</C.CardPath><C.CardTag>audio subsystem</C.CardTag></C.Card>
              <C.Card><C.CardName>StressEverything</C.CardName><C.CardPath>stress-test/stress-everything.tsz</C.CardPath><C.CardTag>full stress test</C.CardTag></C.Card>
              <C.Card><C.CardName>3D Dashboard</C.CardName><C.CardPath>3d-ui-experiment/dashboard.tsz</C.CardPath><C.CardTag>3D UI experiment</C.CardTag></C.Card>
              <C.Card><C.CardName>Cube</C.CardName><C.CardPath>scene3d-demo/cube.tsz</C.CardPath><C.CardTag>3D cube render</C.CardTag></C.Card>
            </C.Grid>
          </C.Section>}

        </C.BodyInner>
      </C.Body>
    </C.Shell>
  );
}
