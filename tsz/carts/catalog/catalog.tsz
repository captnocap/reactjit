import { Shell, Header, Title, Subtitle, Count, Body, BodyInner, Section, SectionHeader, SectionTitle, SectionCount, Grid, Card, CardName, CardPath, CardTag, FilterBar, FilterPill, FilterPillActive, FilterLabel, FilterLabelActive } from './catalog_cls';

const [filter, setFilter] = useState(0);

// ── Component Registry ──
// Each entry: [name, relative_path, tag]
// tag: "component" | "chart" | "app" | "tile" | "test" | "theme" | "tool"

// 0=all, 1=components, 2=charts, 3=apps, 4=tiles, 5=tools, 6=themes, 7=tests

function App() {
  return (
    <C.Shell>
      <C.Header>
        <C.Title>Component Catalog</C.Title>
        <C.Subtitle>Every component across all carts</C.Subtitle>
        <C.Count>registry v1</C.Count>
      </C.Header>

      <C.FilterBar>
        {filter == 0 && <C.FilterPillActive onPress={() => { setFilter(0) }}><C.FilterLabelActive>All</C.FilterLabelActive></C.FilterPillActive>}
        {filter != 0 && <C.FilterPill onPress={() => { setFilter(0) }}><C.FilterLabel>All</C.FilterLabel></C.FilterPill>}
        {filter == 1 && <C.FilterPillActive onPress={() => { setFilter(1) }}><C.FilterLabelActive>Components</C.FilterLabelActive></C.FilterPillActive>}
        {filter != 1 && <C.FilterPill onPress={() => { setFilter(1) }}><C.FilterLabel>Components</C.FilterLabel></C.FilterPill>}
        {filter == 2 && <C.FilterPillActive onPress={() => { setFilter(2) }}><C.FilterLabelActive>Charts</C.FilterLabelActive></C.FilterPillActive>}
        {filter != 2 && <C.FilterPill onPress={() => { setFilter(2) }}><C.FilterLabel>Charts</C.FilterLabel></C.FilterPill>}
        {filter == 3 && <C.FilterPillActive onPress={() => { setFilter(3) }}><C.FilterLabelActive>Apps</C.FilterLabelActive></C.FilterPillActive>}
        {filter != 3 && <C.FilterPill onPress={() => { setFilter(3) }}><C.FilterLabel>Apps</C.FilterLabel></C.FilterPill>}
        {filter == 4 && <C.FilterPillActive onPress={() => { setFilter(4) }}><C.FilterLabelActive>Tiles</C.FilterLabelActive></C.FilterPillActive>}
        {filter != 4 && <C.FilterPill onPress={() => { setFilter(4) }}><C.FilterLabel>Tiles</C.FilterLabel></C.FilterPill>}
        {filter == 5 && <C.FilterPillActive onPress={() => { setFilter(5) }}><C.FilterLabelActive>Tools</C.FilterLabelActive></C.FilterPillActive>}
        {filter != 5 && <C.FilterPill onPress={() => { setFilter(5) }}><C.FilterLabel>Tools</C.FilterLabel></C.FilterPill>}
        {filter == 6 && <C.FilterPillActive onPress={() => { setFilter(6) }}><C.FilterLabelActive>Themes</C.FilterLabelActive></C.FilterPillActive>}
        {filter != 6 && <C.FilterPill onPress={() => { setFilter(6) }}><C.FilterLabel>Themes</C.FilterLabel></C.FilterPill>}
        {filter == 7 && <C.FilterPillActive onPress={() => { setFilter(7) }}><C.FilterLabelActive>Tests</C.FilterLabelActive></C.FilterPillActive>}
        {filter != 7 && <C.FilterPill onPress={() => { setFilter(7) }}><C.FilterLabel>Tests</C.FilterLabel></C.FilterPill>}
      </C.FilterBar>

      <C.Body>
        <C.BodyInner>

          {/* ════════════════════ CHARTS ════════════════════ */}
          {(filter == 0 || filter == 2) && <C.Section>
            <C.SectionHeader>
              <C.SectionTitle>Charts</C.SectionTitle>
              <C.SectionCount>10 components</C.SectionCount>
            </C.SectionHeader>
            <C.Grid>
              <C.Card><C.CardName>LineChart</C.CardName><C.CardPath>charts/line_chart.tsz</C.CardPath><C.CardTag>Graph.Path cubic bezier</C.CardTag></C.Card>
              <C.Card><C.CardName>BarChart</C.CardName><C.CardPath>charts/bar_chart.tsz</C.CardPath><C.CardTag>Graph.Path vertical bars</C.CardTag></C.Card>
              <C.Card><C.CardName>AreaChart</C.CardName><C.CardPath>charts/area_chart.tsz</C.CardPath><C.CardTag>Graph.Path filled area</C.CardTag></C.Card>
              <C.Card><C.CardName>PieChart</C.CardName><C.CardPath>charts/pie_chart.tsz</C.CardPath><C.CardTag>Graph.Path arc segments</C.CardTag></C.Card>
              <C.Card><C.CardName>DonutChart</C.CardName><C.CardPath>charts/donut_chart.tsz</C.CardPath><C.CardTag>Graph.Path ring</C.CardTag></C.Card>
              <C.Card><C.CardName>RadarChart</C.CardName><C.CardPath>charts/radar_chart.tsz</C.CardPath><C.CardTag>Graph.Path polygon</C.CardTag></C.Card>
              <C.Card><C.CardName>CandlestickChart</C.CardName><C.CardPath>charts/candlestick_chart.tsz</C.CardPath><C.CardTag>Graph.Path OHLC</C.CardTag></C.Card>
              <C.Card><C.CardName>DepthChart</C.CardName><C.CardPath>charts/depth_chart.tsz</C.CardPath><C.CardTag>Graph.Path order book</C.CardTag></C.Card>
              <C.Card><C.CardName>HorizontalBarChart</C.CardName><C.CardPath>charts/horizontal_bar_chart.tsz</C.CardPath><C.CardTag>Graph.Path horizontal</C.CardTag></C.Card>
              <C.Card><C.CardName>StackedBarChart</C.CardName><C.CardPath>charts/stacked_bar_chart.tsz</C.CardPath><C.CardTag>Graph.Path stacked</C.CardTag></C.Card>
            </C.Grid>
          </C.Section>}

          {/* ════════════════════ DASHBOARD ════════════════════ */}
          {(filter == 0 || filter == 1) && <C.Section>
            <C.SectionHeader>
              <C.SectionTitle>Dashboard</C.SectionTitle>
              <C.SectionCount>3 components</C.SectionCount>
            </C.SectionHeader>
            <C.Grid>
              <C.Card><C.CardName>Dashboard</C.CardName><C.CardPath>dashboard/Dashboard.tsz</C.CardPath><C.CardTag>FFI metrics + live telemetry</C.CardTag></C.Card>
              <C.Card><C.CardName>StatCard</C.CardName><C.CardPath>dashboard/StatCard.c.tsz</C.CardPath><C.CardTag>label + value + color</C.CardTag></C.Card>
              <C.Card><C.CardName>MetricRow</C.CardName><C.CardPath>dashboard/MetricRow.c.tsz</C.CardPath><C.CardTag>horizontal metric strip</C.CardTag></C.Card>
            </C.Grid>
          </C.Section>}

          {/* ════════════════════ INSPECTOR ════════════════════ */}
          {(filter == 0 || filter == 1) && <C.Section>
            <C.SectionHeader>
              <C.SectionTitle>Inspector</C.SectionTitle>
              <C.SectionCount>20 components</C.SectionCount>
            </C.SectionHeader>
            <C.Grid>
              <C.Card><C.CardName>Inspector</C.CardName><C.CardPath>inspector/Inspector.tsz</C.CardPath><C.CardTag>devtools shell</C.CardTag></C.Card>
              <C.Card><C.CardName>Badge</C.CardName><C.CardPath>inspector/Badge.c.tsz</C.CardPath><C.CardTag>status badge</C.CardTag></C.Card>
              <C.Card><C.CardName>Tree</C.CardName><C.CardPath>inspector/Tree.c.tsz</C.CardPath><C.CardTag>node tree view</C.CardTag></C.Card>
              <C.Card><C.CardName>TreeLine</C.CardName><C.CardPath>inspector/TreeLine.c.tsz</C.CardPath><C.CardTag>tree row</C.CardTag></C.Card>
              <C.Card><C.CardName>TreeHybridView</C.CardName><C.CardPath>inspector/TreeHybridView.c.tsz</C.CardPath><C.CardTag>tree hybrid render</C.CardTag></C.Card>
              <C.Card><C.CardName>TreeJsxView</C.CardName><C.CardPath>inspector/TreeJsxView.c.tsz</C.CardPath><C.CardTag>JSX source view</C.CardTag></C.Card>
