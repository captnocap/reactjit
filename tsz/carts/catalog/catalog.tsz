              <C.Card><C.CardName>EffectsTile</C.CardName><C.CardPath>storybook/tiles/EffectsTile_c.tsz</C.CardPath><C.CardTag>effects demo</C.CardTag></C.Card>
              <C.Card><C.CardName>FormTile</C.CardName><C.CardPath>storybook/tiles/FormTile_c.tsz</C.CardPath><C.CardTag>form inputs</C.CardTag></C.Card>
              <C.Card><C.CardName>GameTile</C.CardName><C.CardPath>storybook/tiles/GameTile_c.tsz</C.CardPath><C.CardTag>game demo</C.CardTag></C.Card>
              <C.Card><C.CardName>Hyperlinks</C.CardName><C.CardPath>storybook/tiles/Hyperlinks_c.tsz</C.CardPath><C.CardTag>link handling</C.CardTag></C.Card>
