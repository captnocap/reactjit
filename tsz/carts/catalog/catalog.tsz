              <C.Card><C.CardName>PropertyRow</C.CardName><C.CardPath>inspector/PropertyRow.c.tsz</C.CardPath><C.CardTag>key-value row</C.CardTag></C.Card>
              <C.Card><C.CardName>MetricCard</C.CardName><C.CardPath>inspector/MetricCard.c.tsz</C.CardPath><C.CardTag>perf metric</C.CardTag></C.Card>
