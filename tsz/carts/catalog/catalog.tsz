              <C.Card><C.CardName>Terminal</C.CardName><C.CardPath>terminal/terminal.tsz</C.CardPath><C.CardTag>terminal emulator</C.CardTag></C.Card>
              <C.Card><C.CardName>SemanticTerminal</C.CardName><C.CardPath>semantic-terminal/semantic-terminal.tsz</C.CardPath><C.CardTag>AI terminal</C.CardTag></C.Card>
              <C.Card><C.CardName>RemoteChat</C.CardName><C.CardPath>remote-chat/remote-chat.tsz</C.CardPath><C.CardTag>PTY remote chat</C.CardTag></C.Card>
              <C.Card><C.CardName>FlatWorld</C.CardName><C.CardPath>flatworld/flatworld.tsz</C.CardPath><C.CardTag>2D world</C.CardTag></C.Card>
              <C.Card><C.CardName>Polygons</C.CardName><C.CardPath>polygons/polygons.tsz</C.CardPath><C.CardTag>polygon renderer</C.CardTag></C.Card>
              <C.Card><C.CardName>World3D</C.CardName><C.CardPath>world3d-demo/world.tsz</C.CardPath><C.CardTag>3D world</C.CardTag></C.Card>
              <C.Card><C.CardName>Physics3D</C.CardName><C.CardPath>world3d-demo/physics.tsz</C.CardPath><C.CardTag>3D physics</C.CardTag></C.Card>
              <C.Card><C.CardName>ControlPanel</C.CardName><C.CardPath>control-panel/control-panel.tsz</C.CardPath><C.CardTag>system controls</C.CardTag></C.Card>
              <C.Card><C.CardName>WindowPaths</C.CardName><C.CardPath>window-paths/window-paths.tsz</C.CardPath><C.CardTag>window manager</C.CardTag></C.Card>
            </C.Grid>
          </C.Section>}

          {/* ════════════════════ ANIMATIONS & EFFECTS ════════════════════ */}
          {(filter == 0 || filter == 1) && <C.Section>
            <C.SectionHeader>
              <C.SectionTitle>Animations & Effects</C.SectionTitle>
              <C.SectionCount>5 components</C.SectionCount>
            </C.SectionHeader>
            <C.Grid>
              <C.Card><C.CardName>AnimationDemo</C.CardName><C.CardPath>animations/animation_demo.tsz</C.CardPath><C.CardTag>animation showcase</C.CardTag></C.Card>
              <C.Card><C.CardName>BouncingBalls</C.CardName><C.CardPath>animations/bouncing_balls.tsz</C.CardPath><C.CardTag>physics balls</C.CardTag></C.Card>
              <C.Card><C.CardName>Plasma</C.CardName><C.CardPath>effects/plasma.tsz</C.CardPath><C.CardTag>plasma effect</C.CardTag></C.Card>
              <C.Card><C.CardName>Rings</C.CardName><C.CardPath>effects/rings.tsz</C.CardPath><C.CardTag>ring effect</C.CardTag></C.Card>
              <C.Card><C.CardName>Spirograph</C.CardName><C.CardPath>effects/spirograph.tsz</C.CardPath><C.CardTag>spirograph</C.CardTag></C.Card>
            </C.Grid>
          </C.Section>}

          {/* ════════════════════ CRYPTO ════════════════════ */}
          {(filter == 0 || filter == 1) && <C.Section>
            <C.SectionHeader>
              <C.SectionTitle>Crypto & Security</C.SectionTitle>
              <C.SectionCount>2 components</C.SectionCount>
            </C.SectionHeader>
            <C.Grid>
              <C.Card><C.CardName>CryptoTest</C.CardName><C.CardPath>crypto-test/CryptoTest.tsz</C.CardPath><C.CardTag>crypto primitives</C.CardTag></C.Card>
              <C.Card><C.CardName>PiiDemo</C.CardName><C.CardPath>crypto-test/PiiDemo.tsz</C.CardPath><C.CardTag>PII detection</C.CardTag></C.Card>
            </C.Grid>
          </C.Section>}

          {/* ════════════════════ TESTS ════════════════════ */}
          {(filter == 0 || filter == 7) && <C.Section>
            <C.SectionHeader>
              <C.SectionTitle>Tests & Benchmarks</C.SectionTitle>
              <C.SectionCount>8 components</C.SectionCount>
            </C.SectionHeader>
            <C.Grid>
              <C.Card><C.CardName>RenderTest</C.CardName><C.CardPath>render-test/RenderTest.tsz</C.CardPath><C.CardTag>render verification</C.CardTag></C.Card>
              <C.Card><C.CardName>EffectTest</C.CardName><C.CardPath>effect-test/EffectTest.tsz</C.CardPath><C.CardTag>effect lifecycle</C.CardTag></C.Card>
