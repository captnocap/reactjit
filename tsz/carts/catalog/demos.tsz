// TSZ Demo Cartridge Register
// Form DC-2026-A — Application Showcase Index
// For official use. Refer to cart ID when filing defect reports.

const [active, setActive] = useState('');

const [parity, setParity] = useState([{ id: '', name: '', s: '' }]);
const [themes, setThemes] = useState([{ id: '', name: '', s: '' }]);
const [effects, setEffects] = useState([{ id: '', name: '', s: '' }]);
const [threeD, setThreeD] = useState([{ id: '', name: '', s: '' }]);
const [infra, setInfra] = useState([{ id: '', name: '', s: '' }]);
const [misc, setMisc] = useState([{ id: '', name: '', s: '' }]);

<script>
setParity([
  { id: 'todomvc', name: 'TodoMVC', s: '' },
  { id: 'kanban-clone', name: 'Kanban Clone', s: '' },
  { id: 'hackernews', name: 'Hacker News', s: '' },
  { id: 'calendar-app', name: 'Calendar App', s: '' },
  { id: 'dashboard-analytics', name: 'Dashboard Analytics', s: '' },
  { id: 'ecommerce-shop', name: 'Ecommerce Shop', s: '' },
  { id: 'email-client', name: 'Email Client', s: '' },
  { id: 'figma-clone', name: 'Figma Clone', s: '' },
  { id: 'github-issues', name: 'GitHub Issues', s: '' },
  { id: 'notion-clone', name: 'Notion Clone', s: '' },
  { id: 'reddit-clone', name: 'Reddit Clone', s: '' },
  { id: 'slack-clone', name: 'Slack Clone', s: '' },
  { id: 'spotify', name: 'Spotify Clone', s: '' },
  { id: 'twitter-clone', name: 'Twitter Clone', s: '' },
  { id: 'vscode-clone', name: 'VS Code Clone', s: '' }
]);

setThemes([
  { id: 'aptio-setup', name: 'Aptio Setup (BIOS)', s: '' },
  { id: 'ngarden-retro-classic', name: 'N-Garden Retro Classic', s: '' },
  { id: 'orion-monitor', name: 'Orion Monitor', s: '' },
  { id: 'theme-creator', name: 'Theme Creator', s: '' }
]);

setEffects([
  { id: 'plasma', name: 'Plasma', s: '' },
  { id: 'polygons', name: 'Polygons', s: '' },
  { id: 'flatworld', name: 'Flatworld', s: '' },
  { id: 'synth', name: 'Synth (Audio UI)', s: '' }
]);

setThreeD([
  { id: 'dashboard', name: '3D Dashboard', s: '' },
  { id: 'taskboard', name: '3D Taskboard', s: '' },
  { id: 'world', name: 'World 3D', s: '' }
]);

setInfra([
  { id: 'inspector', name: 'Inspector', s: '' },
  { id: 'storybook', name: 'Storybook', s: '' },
  { id: 'multi-terminal', name: 'Multi Terminal', s: '' },
  { id: 'task-board', name: 'Task Board', s: '' },
  { id: 'Tools', name: 'Tools', s: '' },
  { id: 'catalog', name: 'Catalog', s: '' },
  { id: 'control-panel', name: 'Control Panel', s: '' },
  { id: 'semantic-terminal', name: 'Semantic Terminal', s: '' },
  { id: 'window-paths', name: 'Window Paths', s: '' }
]);

setMisc([
  { id: 'browser-test', name: 'Browser Test', s: '' },
  { id: 'claude-canvas', name: 'Claude Canvas', s: '' },
  { id: 'counter', name: 'Counter (Hot Reload)', s: '' },
  { id: 'colors', name: 'Colors (Hot Reload)', s: '' },
  { id: 'host', name: 'Cartridge Host', s: '' },
  { id: 'remote-chat', name: 'Remote Chat', s: '' }
]);
</script>

function SectionHeader(props: { number: string, title: string, count: string }) {
  return (
    <Box style={{ borderBottomWidth: 1, borderColor: '#444444', paddingBottom: 6, marginBottom: 4, marginTop: 16 }}>
      <Text fontSize={11} color="#888888">{`SECTION ${props.number}`}</Text>
      <Text fontSize={13} color="#cccccc">{props.title}</Text>
      <Text fontSize={9} color="#666666">{`${props.count} cart(s) registered`}</Text>
    </Box>
  );
}

function DemoRow(props: { id: string, name: string, s: string }) {
  return (
    <Pressable onPress={() => { setActive(props.id + '.so') }} style={{ flexDirection: "row", alignItems: "center", paddingTop: 5, paddingBottom: 5, paddingLeft: 8, borderBottomWidth: 1, borderColor: '#2a2a2a' }}>
      <Text fontSize={10} color={props.s === 'P' ? "#4a9" : props.s === 'F' ? "#c44" : "#444"} style={{ width: 34 }}>{props.s === 'P' ? "PASS" : props.s === 'F' ? "FAIL" : "----"}</Text>
      <Text fontSize={10} color="#cccccc" style={{ marginLeft: 8 }}>{props.name}</Text>
    </Pressable>
  );
}

function App() {
  return (
    <Box style={{ width: "100%", height: "100%", backgroundColor: "#111111" }}>
      {active !== '' && <Box style={{ width: "100%", height: "100%" }}>
        <Box style={{ flexDirection: "row", alignItems: "center", padding: 8, backgroundColor: "#1a1a1a", borderBottomWidth: 1, borderColor: '#333333' }}>
          <Pressable onPress={() => { setActive('') }} style={{ paddingLeft: 10, paddingRight: 10, paddingTop: 4, paddingBottom: 4, backgroundColor: "#222222", borderWidth: 1, borderColor: '#444444' }}>
            <Text fontSize={9} color="#999999">RETURN TO INDEX</Text>
          </Pressable>
          <Text fontSize={9} color="#666666" style={{ marginLeft: 12 }}>{active}</Text>
        </Box>
        <Box style={{ flexGrow: 1 }}>
          <Cartridge src={active} style={{ width: "100%", height: "100%" }} />
        </Box>
      </Box>}

      {active === '' && <Box style={{ width: "100%", height: "100%" }}>
        <Box style={{ padding: 20, borderBottomWidth: 2, borderColor: '#333333' }}>
          <Text fontSize={9} color="#666666">FORM DC-2026-A</Text>
          <Text fontSize={16} color="#cccccc">Demo Cartridge Register</Text>
          <Text fontSize={9} color="#666666">TSZ Application Showcase — 43 carts enrolled</Text>
          <Text fontSize={8} color="#555555" style={{ marginTop: 8 }}>Select a cart to load its compiled cartridge (.so).</Text>
          <Text fontSize={8} color="#555555">Cartridges must be pre-built. Refer to cart ID when filing reports.</Text>
        </Box>

        <ScrollView style={{ flexGrow: 1 }}>
          <Box style={{ padding: 16, paddingBottom: 40 }}>

            <SectionHeader number="I" title="Parity Tests — Real-World App Clones" count="15" />
            {parity.map((t, i) => (
              <DemoRow id={t.id} name={t.name} s={t.s} />
            ))}

            <SectionHeader number="II" title="Themes — Visual Identity" count="4" />
            {themes.map((t, i) => (
              <DemoRow id={t.id} name={t.name} s={t.s} />
            ))}

            <SectionHeader number="III" title="Effects — Visual & Audio" count="4" />
            {effects.map((t, i) => (
              <DemoRow id={t.id} name={t.name} s={t.s} />
            ))}

            <SectionHeader number="IV" title="3D — Scene & Spatial" count="3" />
            {threeD.map((t, i) => (
              <DemoRow id={t.id} name={t.name} s={t.s} />
            ))}

            <SectionHeader number="V" title="Infrastructure — Dev Tools" count="9" />
            {infra.map((t, i) => (
              <DemoRow id={t.id} name={t.name} s={t.s} />
            ))}

            <SectionHeader number="VI" title="Miscellaneous" count="6" />
            {misc.map((t, i) => (
              <DemoRow id={t.id} name={t.name} s={t.s} />
            ))}

            <Box style={{ marginTop: 24, borderTopWidth: 1, borderColor: '#333333', paddingTop: 12 }}>
              <Text fontSize={8} color="#555555">END OF REGISTER</Text>
              <Text fontSize={8} color="#444444">Document generated for internal showcase purposes only.</Text>
              <Text fontSize={8} color="#444444">Not for distribution. Retain for compliance records.</Text>
            </Box>
          </Box>
        </ScrollView>
      </Box>}
    </Box>
  );
}
