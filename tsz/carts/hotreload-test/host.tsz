    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0f172a' }}>
      <Box style={{ padding: 12, backgroundColor: '#1e293b' }}>
        <Text style={{ fontSize: 20, color: '#e2e8f0' }}>CartridgeOS Host</Text>
