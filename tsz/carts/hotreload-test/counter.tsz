function App() {
  const [count, setCount] = useState(0);
  const [label, setLabel] = useState("Hello Hot Reload!");

  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0a1628', padding: 20, gap: 16 }}>
      <Text style={{ fontSize: 32, color: '#90cdf4' }}>{label}</Text>
      <Text style={{ fontSize: 96, color: '#63b3ed' }}>{`${count}`}</Text>
      <Box style={{ flexDirection: 'row', gap: 12 }}>
        <Pressable onPress={() => { setCount(count + 1) }}>
          <Box style={{ backgroundColor: '#22543d', padding: 16, borderRadius: 12 }}>
            <Text style={{ fontSize: 22, color: '#9ae6b4' }}>UP</Text>
          </Box>
        </Pressable>
        <Pressable onPress={() => { setCount(count - 1) }}>
          <Box style={{ backgroundColor: '#742a2a', padding: 16, borderRadius: 12 }}>
            <Text style={{ fontSize: 22, color: '#feb2b2' }}>DOWN</Text>
          </Box>
        </Pressable>
      </Box>
      <Box style={{ marginTop: 20, padding: 16, backgroundColor: '#1c4532', borderRadius: 12 }}>
        <Text style={{ fontSize: 18, color: '#9ae6b4' }}>HOT RELOAD IS LIVE</Text>
        <Text style={{ fontSize: 12, color: '#68d391' }}>186ms rebuild - no restart needed</Text>
      </Box>
    </Box>
  );
}
