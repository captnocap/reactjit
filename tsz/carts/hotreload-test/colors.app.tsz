function App() {
  const [hue, setHue] = useState(0);
  const [size, setSize] = useState(100);

  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#111827', padding: 20, gap: 16, alignItems: 'center', justifyContent: 'center' }}>
      <Text style={{ fontSize: 28, color: '#e2e8f0' }}>Color Mixer</Text>
      <Box style={{ width: size, height: size, backgroundColor: '#3b82f6', borderRadius: 12 }} />
      <Box style={{ flexDirection: 'row', gap: 12 }}>
        <Pressable onPress={() => { setHue(hue + 1) }}>
          <Box style={{ backgroundColor: '#1e40af', padding: 12, borderRadius: 8 }}>
            <Text style={{ fontSize: 16, color: '#93c5fd' }}>Next Color</Text>
          </Box>
        </Pressable>
        <Pressable onPress={() => { setSize(size + 20) }}>
          <Box style={{ backgroundColor: '#065f46', padding: 12, borderRadius: 8 }}>
            <Text style={{ fontSize: 16, color: '#6ee7b7' }}>Grow</Text>
          </Box>
        </Pressable>
        <Pressable onPress={() => { setSize(100) }}>
          <Box style={{ backgroundColor: '#7f1d1d', padding: 12, borderRadius: 8 }}>
            <Text style={{ fontSize: 16, color: '#fca5a5' }}>Reset</Text>
          </Box>
        </Pressable>
      </Box>
    </Box>
  );
}
