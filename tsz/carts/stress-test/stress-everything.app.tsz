// STRESS EVERYTHING — Progressive load test
// Slams all subsystems simultaneously: state, layout, map, conditionals, styles
// Ramps from level 1→10 every 2s. Watch FPS decay to find the breaking point.

import { stress } from './stress.script';

// --- Telemetry state ---
const [fps, setFps] = useState(0);
const [tickUs, setTickUs] = useState(0);
const [layoutUs, setLayoutUs] = useState(0);
const [paintUs, setPaintUs] = useState(0);
const [frameCount, setFrameCount] = useState(0);
const [level, setLevel] = useState(1);
const [itemCount, setItemCount] = useState(25);

// --- Style cycling state ---
const [styleCycle, setStyleCycle] = useState(0);

// --- Conditional toggle ---
const [showExtra, setShowExtra] = useState(1);

// --- 24 rapid-fire state slots ---
const [s0, setS0] = useState(0);
const [s1, setS1] = useState(0);
const [s2, setS2] = useState(0);
const [s3, setS3] = useState(0);
const [s4, setS4] = useState(0);
const [s5, setS5] = useState(0);
const [s6, setS6] = useState(0);
const [s7, setS7] = useState(0);
const [s8, setS8] = useState(0);
const [s9, setS9] = useState(0);
const [s10, setS10] = useState(0);
const [s11, setS11] = useState(0);
const [s12, setS12] = useState(0);
const [s13, setS13] = useState(0);
const [s14, setS14] = useState(0);
const [s15, setS15] = useState(0);
const [s16, setS16] = useState(0);
const [s17, setS17] = useState(0);
const [s18, setS18] = useState(0);
const [s19, setS19] = useState(0);
const [s20, setS20] = useState(0);
const [s21, setS21] = useState(0);
const [s22, setS22] = useState(0);
const [s23, setS23] = useState(0);

// --- Map items (dynamic array from script) ---
const [mapItems, setMapItems] = useState([{ label: '', value: 0, color: 0x58a6ff }]);


// --- Deep nesting component (10 levels) ---
function Nest10(label, val, depth) {
  return (
    <Box style={{ paddingLeft: 2, backgroundColor: '#0f172a' }}>
      <Box style={{ paddingLeft: 2, backgroundColor: '#111827' }}>
        <Box style={{ paddingLeft: 2, backgroundColor: '#1e1b4b' }}>
          <Box style={{ paddingLeft: 2, backgroundColor: '#172554' }}>
            <Box style={{ paddingLeft: 2, backgroundColor: '#0c4a6e' }}>
              <Box style={{ paddingLeft: 2, backgroundColor: '#164e63' }}>
                <Box style={{ paddingLeft: 2, backgroundColor: '#134e4a' }}>
                  <Box style={{ paddingLeft: 2, backgroundColor: '#14532d' }}>
                    <Box style={{ paddingLeft: 2, backgroundColor: '#1a2e05' }}>
                      <Box style={{ paddingLeft: 2 }}>
                        <Text fontSize={7} color="#94a3b8">{`${label}:${val}`}</Text>
                      </Box>
                    </Box>
                  </Box>
                </Box>
              </Box>
            </Box>
          </Box>
        </Box>
      </Box>
    </Box>
  );
}

// --- State slot display ---
function SlotGrid() {
  return (
    <Box style={{ flexDirection: 'row', flexWrap: 'wrap', gap: 2 }}>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#3b82f6">{`${s0}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#22c55e">{`${s1}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#f59e0b">{`${s2}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#ef4444">{`${s3}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#8b5cf6">{`${s4}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#ec4899">{`${s5}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#14b8a6">{`${s6}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#f97316">{`${s7}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#3b82f6">{`${s8}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#22c55e">{`${s9}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#f59e0b">{`${s10}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#ef4444">{`${s11}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#8b5cf6">{`${s12}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#ec4899">{`${s13}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#14b8a6">{`${s14}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#f97316">{`${s15}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#3b82f6">{`${s16}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#22c55e">{`${s17}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#f59e0b">{`${s18}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#ef4444">{`${s19}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#8b5cf6">{`${s20}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#ec4899">{`${s21}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#14b8a6">{`${s22}`}</Text>
      </Box>
      <Box style={{ width: 36, height: 14, backgroundColor: '#1e293b', padding: 1 }}>
        <Text fontSize={6} color="#f97316">{`${s23}`}</Text>
      </Box>
    </Box>
  );
}

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0d1117', padding: 8, gap: 4 }}>

      {/* Header: FPS + telemetry */}
      <Box style={{ flexDirection: 'row', gap: 12, alignItems: 'center' }}>
        <Text fontSize={18} color="#e6edf3">{`STRESS LV${level}/10`}</Text>
        <Text fontSize={16} color="#3fb950">{`${fps} fps`}</Text>
        <Text fontSize={10} color="#d2992a">{`tick:${tickUs}us`}</Text>
        <Text fontSize={10} color="#58a6ff">{`layout:${layoutUs}us`}</Text>
        <Text fontSize={10} color="#f78166">{`paint:${paintUs}us`}</Text>
        <Text fontSize={10} color="#6e7681">{`frame:${frameCount}`}</Text>
      </Box>

      {/* Progress bar — level indicator */}
      <Box style={{ flexDirection: 'row', gap: 2, height: 6 }}>
        <Box style={{ flexGrow: level, backgroundColor: '#3fb950', borderRadius: 2 }} />
        <Box style={{ flexGrow: 10 - level, backgroundColor: '#1e293b', borderRadius: 2 }} />
      </Box>

      <Box style={{ flexDirection: 'row', flexGrow: 1, gap: 4 }}>

        {/* Left column: state slots + deep nesting */}
        <Box style={{ width: 320, gap: 4 }}>
          <Text fontSize={9} color="#94a3b8">{`24 state slots (${8 + level * 2} active)`}</Text>
          <SlotGrid />

          <Text fontSize={9} color="#94a3b8">Deep nesting (10 levels x4)</Text>
          <Box style={{ backgroundColor: '#0f172a', padding: 4, borderRadius: 4 }}>
            <Nest10 label="A" val={s0} depth={10} />
            <Nest10 label="B" val={s1} depth={10} />
            <Nest10 label="C" val={s2} depth={10} />
            <Nest10 label="D" val={s3} depth={10} />
          </Box>

          {/* Conditional rendering — flips on/off */}
          {showExtra === 1 ? (
            <Box style={{ backgroundColor: '#14532d', padding: 6, borderRadius: 4 }}>
              <Text fontSize={9} color="#4ade80">Conditional: VISIBLE</Text>
              <Box style={{ flexDirection: 'row', gap: 2 }}>
                <Box style={{ width: 20, height: 20, backgroundColor: '#22c55e', borderRadius: 10 }} />
                <Box style={{ width: 20, height: 20, backgroundColor: '#16a34a', borderRadius: 10 }} />
                <Box style={{ width: 20, height: 20, backgroundColor: '#15803d', borderRadius: 10 }} />
                <Box style={{ width: 20, height: 20, backgroundColor: '#166534', borderRadius: 10 }} />
              </Box>
            </Box>
          ) : (
            <Box style={{ backgroundColor: '#7f1d1d', padding: 6, borderRadius: 4 }}>
              <Text fontSize={9} color="#fca5a5">Conditional: HIDDEN</Text>
            </Box>
          )}
        </Box>

        {/* Right column: map items grid */}
        <Box style={{ flexGrow: 1, gap: 4 }}>
          <Text fontSize={9} color="#94a3b8">{`Map items: ${itemCount}`}</Text>
          <ScrollView style={{ flexGrow: 1, backgroundColor: '#0f172a', borderRadius: 4, padding: 2 }}>
            <Box style={{ flexDirection: 'row', flexWrap: 'wrap', gap: 2 }}>
              {mapItems.map((item) => (
                <Box style={{ width: 40, height: 14, backgroundColor: '#161b22', borderRadius: 2, padding: 1 }}>
                  <Text fontSize={6} color={item.color}>{item.label}</Text>
                </Box>
              ))}
            </Box>
          </ScrollView>
        </Box>

      </Box>
    </Box>
  );
}
