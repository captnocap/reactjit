// test_ifttt.tsz — smoke test for useIFTTT in all three tiers
//
// Tests:
//   1. mount trigger → log
//   2. timer:every:1000 → increment counter state
//   3. key:32 (space) → toggle paused state
//   4. condition trigger → log when count > 5

const [count, setCount] = useState(0);
const [paused, setPaused] = useState(false);

<script>
  // 1. Mount → log
  useIFTTT('mount', 'log:IFTTT mounted!')

  // 2. Timer → increment count every second
  useIFTTT('timer:every:1000', function() {
    setCount(count + 1)
  })

  // 3. Space key → toggle paused (SDL_SCANCODE_SPACE = 44)
  useIFTTT('key:44', 'state:toggle:1')

  // 4. Condition → log when count passes 5
  useIFTTT(function() { return count > 5 }, 'log:Count passed 5!')
</script>

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1e1e2e', padding: 20, flexDirection: 'column', gap: 10 }}>
      <Text style={{ color: '#cdd6f4', fontSize: 24 }}>IFTTT Test</Text>
      <Text style={{ color: '#a6adc8', fontSize: 18 }}>{`Count: ${count}`}</Text>
      <Text style={{ color: paused ? '#f38ba8' : '#a6e3a1', fontSize: 18 }}>{paused ? 'PAUSED' : 'RUNNING'}</Text>
      <Text style={{ color: '#585b70', fontSize: 14 }}>Press SPACE to toggle pause</Text>
    </Box>
  );
}
