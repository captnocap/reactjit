function App() {
  const [count, setCount] = useState(0);
  return (
    <Box style={{ width: '100%', height: '100%', padding: 32, backgroundColor: '#1e1e2a', justifyContent: 'center', alignItems: 'center' }}>
      <Text fontSize={32} color="#ffffff">{`Count: ${count}`}</Text>
      <Pressable onPress={() => setCount(count + 1)} style={{ padding: 16, backgroundColor: '#4ec9b0', borderRadius: 8, marginTop: 16 }}>
        <Text fontSize={18} color="#ffffff">Click Me</Text>
      </Pressable>
    </Box>
  );
}
