/**
 * Agent Dashboard Example
 * 
 * A complete example of building a Claude Code-style dashboard
 * using the @reactjit/agent APIs.
 * 
 * Features:
 * - Multi-model support (OpenAI, Anthropic, local)
 * - Tool execution with progress monitoring
 * - Fork subagents for parallel work
 * - File browser integration
 */

import { useState, useEffect } from 'react';
import { useAgentSession, forkAgent, createAgentPool } from '@reactjit/agent';
import { bash, readFile, writeFile, fileEdit, glob, grep } from '@reactjit/tools';
import { Box, Text, Pressable, ScrollView, TextInput } from '@reactjit/ui';

// ═════════════════════════════════════════════════════════════════════════════
// Main App
// ═════════════════════════════════════════════════════════════════════════════

const [selectedProvider, setSelectedProvider] = useState<'openai' | 'anthropic'>('openai');
const [apiKey, setApiKey] = useState(env.OPENAI_API_KEY || '');
const [workDir, setWorkDir] = useState('/home/user/project');

// Main agent session
const session = useAgentSession({
  provider: selectedProvider,
  model: selectedProvider === 'openai' ? 'gpt-4o' : 'claude-3-sonnet',
  apiKey: apiKey,
  systemPrompt: `You are a helpful coding assistant. You can use bash, read files, write files, and search.
Work in the directory: ${workDir}
Always explain what you're doing before making changes.`,
  tools: [bash, readFile, writeFile, fileEdit, glob, grep],
  workDir: workDir,
  maxToolRounds: 10,
});

// Agent pool for managing subagents
const agentPool = createAgentPool();

// Track forked agents
const [activeAgents, setActiveAgents] = useState<ForkedAgent[]>([]);

// ═════════════════════════════════════════════════════════════════════════════
// Event Handlers
// ═════════════════════════════════════════════════════════════════════════════

// Stream handling
session.onStreamChunk = (text: string) => {
  // UI updates automatically via reactive state
  console.log('Stream:', text.slice(0, 50) + '...');
};

// Tool execution tracking
session.onToolStart = (exec: ToolExecution) => {
  console.log(`Tool started: ${exec.toolName}`);
};

session.onToolEnd = (exec: ToolExecution) => {
  console.log(`Tool completed: ${exec.toolName} (${exec.status})`);
};

// Error handling
session.onError = (error: string) => {
  console.error('Session error:', error);
  alert(`Error: ${error}`);
};

// Send message to main agent
function sendMessage(content: string) {
  session.send(content);
}

// Fork a subagent for parallel work
function spawnAnalyzer(targetPath: string) {
  const agent = forkAgent({
    directive: `Analyze ${targetPath} for code quality issues, security problems, and performance bottlenecks. Provide a concise report.`,
    inheritsContext: true,
    model: 'gpt-4o-mini', // Use cheaper model for analysis
    workDir: workDir,
    maxTurns: 50,
  });

  agent.onComplete = (report: string) => {
    console.log('Analyzer completed:', report);
    // Add to UI
  };

  agent.onError = (error: string) => {
    console.error('Analyzer error:', error);
  };

  setActiveAgents(prev => [...prev, agent]);
  return agent;
}

// Spawn multiple agents in parallel
async function analyzeMultiple(paths: string[]) {
  const agents = await forkAgents(paths.map(p => ({
    directive: `Analyze ${p} and summarize key findings`,
    inheritsContext: true,
    model: 'gpt-4o-mini',
    workDir: workDir,
  })));

  // Wait for all to complete
  Promise.all(agents.map(a => new Promise<void>(resolve => {
    a.onComplete = () => resolve();
  }))).then(() => {
    console.log('All analyses complete');
  });
}

// ═════════════════════════════════════════════════════════════════════════════
// UI Components
// ═════════════════════════════════════════════════════════════════════════════

function MessageBubble({ message }: { message: Message }) {
  const isUser = message.role === 'user';
  const isTool = message.role === 'tool';
  
  return (
    <Box style={{
      padding: 12,
      marginVertical: 4,
      backgroundColor: isUser ? '#1e40af' : isTool ? '#065f46' : '#1f2937',
      borderRadius: 8,
      alignSelf: isUser ? 'flex-end' : 'flex-start',
      maxWidth: '80%',
    }}>
      <Text style={{ 
        color: isUser ? '#ffffff' : '#e5e7eb',
        fontSize: 14,
      }}>
        {message.content}
      </Text>
      {message.toolCalls && (
        <Box style={{ marginTop: 8 }}>
          {message.toolCalls.map(tc => (
            <Text key={tc.id} style={{ 
              color: '#60a5fa', 
              fontSize: 12,
              fontFamily: 'monospace',
            }}>
              → {tc.name}({tc.arguments.slice(0, 50)}...)
            </Text>
          ))}
        </Box>
      )}
    </Box>
  );
}

function ToolMonitor() {
  return (
    <Box style={{
      position: 'absolute',
      right: 16,
      top: 16,
      width: 280,
      backgroundColor: '#111827',
      borderRadius: 8,
      padding: 12,
      border: '1px solid #374151',
    }}>
      <Text style={{ color: '#f3f4f6', fontWeight: 'bold', marginBottom: 8 }}>
        Active Tools
      </Text>
      {session.activeExecutions.map(exec => (
        <Box key={exec.id} style={{
          flexDirection: 'row',
          alignItems: 'center',
          padding: 8,
          backgroundColor: '#1f2937',
          borderRadius: 4,
          marginBottom: 4,
        }}>
          <Box style={{
            width: 8,
            height: 8,
            borderRadius: 4,
            backgroundColor: exec.status === 'running' ? '#fbbf24' : 
                            exec.status === 'completed' ? '#34d399' : '#ef4444',
            marginRight: 8,
          }} />
          <Text style={{ color: '#e5e7eb', fontSize: 12, flex: 1 }}>
            {exec.toolName}
          </Text>
          {exec.status === 'running' && (
            <Text style={{ color: '#9ca3af', fontSize: 10 }}>
              {((Date.now() - exec.startTime) / 1000).toFixed(1)}s
            </Text>
          )}
        </Box>
      ))}
      {session.activeExecutions.length === 0 && (
        <Text style={{ color: '#6b7280', fontSize: 12, fontStyle: 'italic' }}>
          No active tools
        </Text>
      )}
    </Box>
  );
}

function AgentPoolPanel() {
  return (
    <Box style={{
      position: 'absolute',
      right: 16,
      bottom: 80,
      width: 280,
      backgroundColor: '#111827',
      borderRadius: 8,
      padding: 12,
      border: '1px solid #374151',
    }}>
      <Text style={{ color: '#f3f4f6', fontWeight: 'bold', marginBottom: 8 }}>
        Forked Agents
      </Text>
      {activeAgents.map(agent => (
        <Box key={agent.id} style={{
          padding: 8,
          backgroundColor: '#1f2937',
          borderRadius: 4,
          marginBottom: 4,
        }}>
          <Box style={{ flexDirection: 'row', justifyContent: 'space-between' }}>
            <Text style={{ color: '#e5e7eb', fontSize: 12 }}>
              {agent.id.slice(0, 8)}...
            </Text>
            <Text style={{ 
              color: agent.status === 'running' ? '#fbbf24' : 
                     agent.status === 'completed' ? '#34d399' : '#ef4444',
              fontSize: 10,
            }}>
              {agent.status}
            </Text>
          </Box>
          <Pressable 
            onPress={() => agent.terminate()}
            style={{
              marginTop: 4,
              padding: 4,
              backgroundColor: '#dc2626',
              borderRadius: 4,
            }}
          >
            <Text style={{ color: '#ffffff', fontSize: 10, textAlign: 'center' }}>
              Terminate
            </Text>
          </Pressable>
        </Box>
      ))}
      <Pressable 
        onPress={() => spawnAnalyzer('src/')}
        style={{
          marginTop: 8,
          padding: 8,
          backgroundColor: '#2563eb',
          borderRadius: 4,
        }}
      >
        <Text style={{ color: '#ffffff', fontSize: 12, textAlign: 'center' }}>
          + Spawn Analyzer
        </Text>
      </Pressable>
    </Box>
  );
}

// ═════════════════════════════════════════════════════════════════════════════
// Main Layout
// ═════════════════════════════════════════════════════════════════════════════

const [inputText, setInputText] = useState('');

function App() {
  return (
    <Box style={{
      width: '100%',
      height: '100%',
      backgroundColor: '#0f172a',
      padding: 16,
    }}>
      {/* Header */}
      <Box style={{
        flexDirection: 'row',
        alignItems: 'center',
        padding: 12,
        backgroundColor: '#1e293b',
        borderRadius: 8,
        marginBottom: 16,
      }}>
        <Text style={{ color: '#f3f4f6', fontSize: 18, fontWeight: 'bold', flex: 1 }}>
          Agent Dashboard
        </Text>
        <Box style={{ flexDirection: 'row', gap: 8 }}>
          <Pressable 
            onPress={() => setSelectedProvider('openai')}
            style={{
              padding: 8,
              backgroundColor: selectedProvider === 'openai' ? '#2563eb' : '#374151',
              borderRadius: 4,
            }}
          >
            <Text style={{ color: '#ffffff', fontSize: 12 }}>OpenAI</Text>
          </Pressable>
          <Pressable 
            onPress={() => setSelectedProvider('anthropic')}
            style={{
              padding: 8,
              backgroundColor: selectedProvider === 'anthropic' ? '#2563eb' : '#374151',
              borderRadius: 4,
            }}
          >
            <Text style={{ color: '#ffffff', fontSize: 12 }}>Anthropic</Text>
          </Pressable>
        </Box>
      </Box>

      {/* Main content */}
      <Box style={{ flex: 1, flexDirection: 'row' }}>
        {/* Chat area */}
        <Box style={{ flex: 1, marginRight: 16 }}>
          <ScrollView style={{
            flex: 1,
            backgroundColor: '#1e293b',
            borderRadius: 8,
            padding: 12,
          }}>
            {session.messages.map((msg, idx) => (
              <MessageBubble key={idx} message={msg} />
            ))}
            {session.isStreaming && (
              <Text style={{ color: '#6b7280', fontSize: 12, marginTop: 8 }}>
                ● Streaming...
              </Text>
            )}
          </ScrollView>

          {/* Input area */}
          <Box style={{
            flexDirection: 'row',
            marginTop: 12,
            gap: 8,
          }}>
            <TextInput
              value={inputText}
              onChange={setInputText}
              placeholder="Enter a task..."
              style={{
                flex: 1,
                padding: 12,
                backgroundColor: '#334155',
                color: '#f3f4f6',
                borderRadius: 8,
                fontSize: 14,
              }}
              onSubmit={() => {
                if (inputText.trim()) {
                  sendMessage(inputText);
                  setInputText('');
                }
              }}
            />
            <Pressable
              onPress={() => {
                if (inputText.trim()) {
                  sendMessage(inputText);
                  setInputText('');
                }
              }}
              style={{
                padding: 12,
                backgroundColor: '#2563eb',
                borderRadius: 8,
              }}
            >
              <Text style={{ color: '#ffffff' }}>Send</Text>
            </Pressable>
          </Box>
        </Box>
      </Box>

      {/* Floating panels */}
      <ToolMonitor />
      <AgentPoolPanel />
    </Box>
  );
}

export default App;
