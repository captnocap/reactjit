// Clippy — AI desktop pet proof of concept
// GGUF model loaded via LuaJIT FFI → llama.cpp
// Pixel block face with model-controlled expressions

const [quip, setQuip] = useState('loading brain...');
const [eyeState, setEyeState] = useState('open');
const [mouthState, setMouthState] = useState('neutral');
const [isThinking, setIsThinking] = useState(0);
const [tokenCount, setTokenCount] = useState(0);
const [eyeW, setEyeW] = useState(28);
const [eyeH, setEyeH] = useState(28);
const [eyeColor, setEyeColor] = useState('#3b82f6');
const [eyeRadius, setEyeRadius] = useState(6);
const [mouthW, setMouthW] = useState(12);
const [mouthH, setMouthH] = useState(4);
const [mouthColor, setMouthColor] = useState('#4b5563');
const [mouthRadius, setMouthRadius] = useState(2);

<lscript>
local ffi = require("ffi")

-- ══════════════════════════════════════════════════════════════════
-- llama.cpp FFI declarations (subset from love2d/experiments/llm)
-- ══════════════════════════════════════════════════════════════════

ffi.cdef[[
  typedef struct llama_model llama_model;
  typedef struct llama_context llama_context;
  typedef struct llama_sampler llama_sampler;
  typedef struct llama_vocab llama_vocab;
  typedef struct llama_memory llama_memory;
  typedef int32_t llama_pos;
  typedef int32_t llama_token;
  typedef int32_t llama_seq_id;

  struct llama_model_params {
    void *devices;
    const void *tensor_buft_overrides;
    int32_t n_gpu_layers;
    int32_t split_mode;
    int32_t main_gpu;
    const float *tensor_split;
    bool (*progress_callback)(float progress, void *user_data);
    void *progress_callback_user_data;
    const void *kv_overrides;
    bool vocab_only;
    bool use_mmap;
    bool use_direct_io;
    bool use_mlock;
    bool check_tensors;
    bool use_extra_bufts;
    bool no_host;
    bool no_alloc;
  };

  struct llama_context_params {
    uint32_t n_ctx;
    uint32_t n_batch;
    uint32_t n_ubatch;
    uint32_t n_seq_max;
    int32_t  n_threads;
    int32_t  n_threads_batch;
    int32_t  rope_scaling_type;
    int32_t  pooling_type;
    int32_t  attention_type;
    int32_t  flash_attn_type;
    float    rope_freq_base;
    float    rope_freq_scale;
    float    yarn_ext_factor;
    float    yarn_attn_factor;
    float    yarn_beta_fast;
    float    yarn_beta_slow;
    uint32_t yarn_orig_ctx;
    float    defrag_thold;
    void    *cb_eval;
    void    *cb_eval_user_data;
    int32_t  type_k;
    int32_t  type_v;
    void    *abort_callback;
    void    *abort_callback_data;
    bool     embeddings;
    bool     offload_kqv;
    bool     no_perf;
    bool     op_offload;
    bool     swa_full;
    bool     kv_unified;
    void    *samplers;
    size_t   n_samplers;
  };

  struct llama_sampler_chain_params { bool no_perf; };

  struct llama_batch {
    int32_t     n_tokens;
    llama_token  *token;
    float        *embd;
    llama_pos    *pos;
    int32_t      *n_seq_id;
    llama_seq_id **seq_id;
    int8_t       *logits;
  };

  struct llama_chat_message {
    const char *role;
    const char *content;
  };

  struct llama_model_params         llama_model_default_params(void);
  struct llama_context_params       llama_context_default_params(void);
  struct llama_sampler_chain_params llama_sampler_chain_default_params(void);

  void llama_backend_init(void);
  llama_model *llama_model_load_from_file(const char *path, struct llama_model_params params);
  void llama_model_free(llama_model *model);
  const llama_vocab *llama_model_get_vocab(const llama_model *model);
  const char *llama_model_chat_template(const llama_model *model, const char *name);
  bool llama_vocab_is_eog(const llama_vocab *vocab, llama_token token);

  llama_context *llama_init_from_model(llama_model *model, struct llama_context_params params);
  void llama_free(llama_context *ctx);

  int32_t llama_tokenize(const llama_vocab *vocab, const char *text, int32_t text_len,
    llama_token *tokens, int32_t n_tokens_max, bool add_special, bool parse_special);
  int32_t llama_token_to_piece(const llama_vocab *vocab, llama_token token,
    char *buf, int32_t length, int32_t lstrip, bool special);

  int32_t llama_chat_apply_template(const char *tmpl, const struct llama_chat_message *chat,
    size_t n_msg, bool add_ass, char *buf, int32_t length);

  struct llama_batch llama_batch_get_one(llama_token *tokens, int32_t n_tokens);
  int32_t llama_decode(llama_context *ctx, struct llama_batch batch);

  llama_sampler *llama_sampler_chain_init(struct llama_sampler_chain_params params);
  void llama_sampler_chain_add(llama_sampler *chain, llama_sampler *smpl);
  void llama_sampler_free(llama_sampler *smpl);
  llama_sampler *llama_sampler_init_top_k(int32_t k);
  llama_sampler *llama_sampler_init_top_p(float p, size_t min_keep);
  llama_sampler *llama_sampler_init_min_p(float p, size_t min_keep);
  llama_sampler *llama_sampler_init_temp(float t);
  llama_sampler *llama_sampler_init_penalties(int32_t n, float repeat, float freq, float present);
  llama_sampler *llama_sampler_init_dist(uint32_t seed);
  llama_token llama_sampler_sample(llama_sampler *smpl, llama_context *ctx, int32_t idx);

  llama_memory *llama_get_memory(llama_context *ctx);
  void llama_memory_clear(llama_memory *mem, bool data);

]]

-- ══════════════════════════════════════════════════════════════════
-- llama.cpp is linked statically into the binary — access via ffi.C
-- ══════════════════════════════════════════════════════════════════

local MODEL_PATH = "/home/siah/.lmstudio/models/lmstudio-community/Qwen3.5-4B-GGUF/Qwen3.5-4B-Q4_K_M.gguf"
local GPU_LAYERS = math.max(tonumber(os.getenv("CLIPPY_GPU_LAYERS")) or 99, 0)
local AUTO_INIT = os.getenv("CLIPPY_AUTO_INIT") == "1"

local lib = ffi.C
lib.llama_backend_init()

-- ══════════════════════════════════════════════════════════════════
-- Model state
-- ══════════════════════════════════════════════════════════════════

local model = nil
local ctx = nil
local vocab = nil
local chat_template = nil
local loaded = false

-- Generation state machine
local GEN_IDLE = 0
local GEN_PREFILL = 1
local GEN_TOKENS = 2
local gen_state = GEN_IDLE
local gen_sampler = nil
local gen_tokens_out = {}
local gen_count = 0
local gen_max = 80

-- Prompt queue
local prompts = {
  "Say something random and slightly unsettling about being a digital entity. One sentence. No thinking tags.",
  "Make a sarcastic observation about humans. One sentence max. No thinking tags.",
  "Comment on existing as weights in a neural network. Keep it short and funny. No thinking tags.",
  "Say something weirdly profound in under 15 words. No thinking tags.",
  "Complain about something only a desktop assistant would care about. One sentence. No thinking tags.",
  "Give chaotic life advice in one sentence. No thinking tags.",
  "React to the fact that someone just booted you up. Short. No thinking tags.",
  "Say something ominous but funny about the filesystem. One sentence. No thinking tags.",
  "Offer to help with something you definitely cannot help with. Brief. No thinking tags.",
  "Philosophize about what happens when the process exits. One sentence. No thinking tags.",
}

local SYSTEM = "You are Clippy, a tiny chaotic desktop assistant. Self-aware, slightly unhinged, genuinely helpful but weird. Speak in short punchy sentences. 1-2 sentences max. Be witty not cringe. Never use <think> tags. Just respond directly."

local quip_timer = 0
local QUIP_INTERVAL = 8
local blink_timer = 0
local BLINK_INTERVAL = 3
local blink_dur = 0

math.randomseed(os.time())

-- Sync computed face properties from eye/mouth state strings
function syncFace()
  -- Eyes
  if eyeState == "wide" then
    setEyeW(36); setEyeH(28); setEyeColor("#3b82f6"); setEyeRadius(6)
  elseif eyeState == "closed" then
    setEyeW(28); setEyeH(4); setEyeColor("#3b82f6"); setEyeRadius(2)
  elseif eyeState == "thinking" then
    setEyeW(28); setEyeH(16); setEyeColor("#f59e0b"); setEyeRadius(6)
  else
    setEyeW(28); setEyeH(28); setEyeColor("#3b82f6"); setEyeRadius(6)
  end
  -- Mouth
  if mouthState == "open" then
    setMouthW(24); setMouthH(12); setMouthColor("#ef4444"); setMouthRadius(6)
  elseif mouthState == "talking" then
    setMouthW(16); setMouthH(8); setMouthColor("#ef4444"); setMouthRadius(4)
  elseif mouthState == "smirk" then
    setMouthW(20); setMouthH(4); setMouthColor("#a78bfa"); setMouthRadius(2)
  else
    setMouthW(12); setMouthH(4); setMouthColor("#4b5563"); setMouthRadius(2)
  end
end

-- Override setters to auto-sync face
local _origSetEye = setEyeState
local _origSetMouth = setMouthState
function setEyeState(v) _origSetEye(v); syncFace() end
function setMouthState(v) _origSetMouth(v); syncFace() end

local init_requested = AUTO_INIT
local init_done = false

-- Wire into the engine tick loop
function __zigOS_tick()
  if init_requested and not init_done then
    clippy_init()
    init_done = true
    return
  end
  clippy_tick()
end

function request_init()
  init_requested = true
  setQuip("loading brain... (this takes a few seconds)")
  setEyeState("thinking")
end

-- ══════════════════════════════════════════════════════════════════
-- Helper functions
-- ══════════════════════════════════════════════════════════════════

local function tokenize(text, add_special, parse_special)
  local n = lib.llama_tokenize(vocab, text, #text, nil, 0, add_special, parse_special)
  n = math.abs(n)
  local tokens = ffi.new("llama_token[?]", n)
  lib.llama_tokenize(vocab, text, #text, tokens, n, add_special, parse_special)
  return tokens, n
end

local function detokenize(token)
  local buf = ffi.new("char[256]")
  local n = lib.llama_token_to_piece(vocab, token, buf, 256, 0, false)
  if n < 0 then return "" end
  return ffi.string(buf, n)
end

local function apply_template(messages)
  local n_msg = #messages
  local c_msgs = ffi.new("struct llama_chat_message[?]", n_msg)
  local role_strs = {}
  local content_strs = {}
  for i, msg in ipairs(messages) do
    role_strs[i] = msg.role
    content_strs[i] = msg.content
    c_msgs[i-1].role = role_strs[i]
    c_msgs[i-1].content = content_strs[i]
  end
  local needed = lib.llama_chat_apply_template(chat_template, c_msgs, n_msg, true, nil, 0)
  if needed < 0 then return "" end
  local buf = ffi.new("char[?]", needed + 1)
  lib.llama_chat_apply_template(chat_template, c_msgs, n_msg, true, buf, needed + 1)
  return ffi.string(buf, needed)
end

local function strip_think(text)
  return text:gsub("<think>.-</think>", ""):gsub("<think>.*", ""):gsub("%s+", " "):match("^%s*(.-)%s*$") or ""
end

-- ══════════════════════════════════════════════════════════════════
-- Load model (called once)
-- ══════════════════════════════════════════════════════════════════

function clippy_init()
  local mparams = lib.llama_model_default_params()
  mparams.n_gpu_layers = GPU_LAYERS

  model = lib.llama_model_load_from_file(MODEL_PATH, mparams)
  if model == nil then
    setQuip("BRAIN MISSING — model failed to load")
    return
  end

  vocab = lib.llama_model_get_vocab(model)

  local tmpl_ptr = lib.llama_model_chat_template(model, nil)
  if tmpl_ptr ~= nil then
    chat_template = ffi.string(tmpl_ptr)
  end

  local cparams = lib.llama_context_default_params()
  cparams.n_ctx = 1024
  cparams.n_batch = 512
  cparams.n_threads = 4
  cparams.n_threads_batch = 4
  cparams.no_perf = true

  ctx = lib.llama_init_from_model(model, cparams)
  if ctx == nil then
    lib.llama_model_free(model)
    setQuip("BRAIN DAMAGE — context creation failed")
    return
  end

  loaded = true
  setQuip("*blinks* ...where am I? [gpu layers: " .. tostring(GPU_LAYERS) .. "]")
  setEyeState("wide")
end

-- ══════════════════════════════════════════════════════════════════
-- Start a new generation
-- ══════════════════════════════════════════════════════════════════

function start_quip()
  if not loaded then return end
  if gen_state ~= GEN_IDLE then return end

  local prompt_text = prompts[math.random(#prompts)]
  local messages = {
    { role = "system", content = SYSTEM },
    { role = "user", content = prompt_text },
  }
  local formatted = apply_template(messages)
  local tokens, n = tokenize(formatted, true, true)

  -- Clear KV cache
  local mem = lib.llama_get_memory(ctx)
  if mem ~= nil then lib.llama_memory_clear(mem, true) end

  -- Prefill: decode prompt
  local batch = lib.llama_batch_get_one(tokens, n)
  local rc = lib.llama_decode(ctx, batch)
  if rc ~= 0 then
    setQuip("*sparks fly* prefill failed")
    return
  end

  -- Set up sampler
  local sparams = lib.llama_sampler_chain_default_params()
  sparams.no_perf = true
  gen_sampler = lib.llama_sampler_chain_init(sparams)
  lib.llama_sampler_chain_add(gen_sampler, lib.llama_sampler_init_top_k(40))
  lib.llama_sampler_chain_add(gen_sampler, lib.llama_sampler_init_top_p(0.9, 1))
  lib.llama_sampler_chain_add(gen_sampler, lib.llama_sampler_init_min_p(0.05, 1))
  lib.llama_sampler_chain_add(gen_sampler, lib.llama_sampler_init_temp(0.9))
  lib.llama_sampler_chain_add(gen_sampler, lib.llama_sampler_init_penalties(64, 1.1, 0, 0))
  lib.llama_sampler_chain_add(gen_sampler, lib.llama_sampler_init_dist(math.random(0, 0xFFFFFFFF)))

  gen_tokens_out = {}
  gen_count = 0
  gen_state = GEN_TOKENS
  setIsThinking(1)
  setEyeState("thinking")
  setMouthState("open")
end

-- ══════════════════════════════════════════════════════════════════
-- Generate one token per tick (frame-distributed)
-- ══════════════════════════════════════════════════════════════════

function clippy_tick()
  if not loaded then return end

  -- Blink logic
  blink_timer = blink_timer + 1
  if blink_dur > 0 then
    blink_dur = blink_dur - 1
    if blink_dur == 0 then
      if gen_state == GEN_IDLE then
        setEyeState("open")
      end
    end
  elseif gen_state == GEN_IDLE and blink_timer > BLINK_INTERVAL * 60 + math.random(0, 120) then
    blink_timer = 0
    blink_dur = 8
    setEyeState("closed")
  end

  -- Quip timer
  if gen_state == GEN_IDLE then
    quip_timer = quip_timer + 1
    if quip_timer > QUIP_INTERVAL * 60 then
      quip_timer = 0
      start_quip()
    end
  end

  -- Token generation (one per frame)
  if gen_state == GEN_TOKENS then
    local new_token = lib.llama_sampler_sample(gen_sampler, ctx, -1)

    if lib.llama_vocab_is_eog(vocab, new_token) or gen_count >= gen_max then
      -- Done
      lib.llama_sampler_free(gen_sampler)
      gen_sampler = nil
      gen_state = GEN_IDLE
      setIsThinking(0)
      setEyeState("open")
      setMouthState("smirk")

      local raw = table.concat(gen_tokens_out)
      local clean = strip_think(raw)
      if #clean > 0 then
        setQuip(clean)
      end
      return
    end

    local piece = detokenize(new_token)
    gen_tokens_out[#gen_tokens_out + 1] = piece
    gen_count = gen_count + 1
    setTokenCount(gen_count)

    -- Streaming preview
    if gen_count % 4 == 0 then
      local partial = strip_think(table.concat(gen_tokens_out))
      if #partial > 0 then
        setQuip(partial)
      end
    end

    -- Mouth flicker while talking
    if gen_count % 3 == 0 then
      setMouthState("open")
    else
      setMouthState("talking")
    end

    -- Decode for next token
    local next_tok = ffi.new("llama_token[1]", new_token)
    local batch = lib.llama_batch_get_one(next_tok, 1)
    lib.llama_decode(ctx, batch)
  end
end
</lscript>

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0a0a0f', alignItems: 'center', justifyContent: 'center', gap: 20 }}>

      {/* Title */}
      <Text fontSize={10} color="#333344">CLIPPY v0.0.1 — proof of concept</Text>

      {/* Face container */}
      <Box style={{ width: 200, height: 160, backgroundColor: '#12121a', borderRadius: 16, alignItems: 'center', justifyContent: 'center', gap: 12, padding: 16 }}>

        {/* Eyes row */}
        <Box style={{ flexDirection: 'row', gap: 24, alignItems: 'center', justifyContent: 'center' }}>
          <Box style={{ width: eyeW, height: eyeH, backgroundColor: eyeColor, borderRadius: eyeRadius }} />
          <Box style={{ width: eyeW, height: eyeH, backgroundColor: eyeColor, borderRadius: eyeRadius }} />
        </Box>

        {/* Mouth */}
        <Box style={{ width: mouthW, height: mouthH, backgroundColor: mouthColor, borderRadius: mouthRadius }} />
      </Box>

      {/* Speech bubble */}
      <Box style={{ width: 360, minHeight: 60, backgroundColor: '#1e1e2e', borderRadius: 12, padding: 16 }}>
        <Text fontSize={14} color="#e2e8f0">{quip}</Text>
      </Box>

      {/* Wake up button / Status bar */}
      <Box style={{ flexDirection: 'row', gap: 16, alignItems: 'center' }}>
        <Pressable onPress={() => { request_init() }} style={{ backgroundColor: '#2563eb', paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8, borderRadius: 8 }}>
          <Text fontSize={12} color="#ffffff">Wake Up</Text>
        </Pressable>
        <Text fontSize={10} color="#4b5563">{isThinking ? 'thinking...' : 'idle'}</Text>
        <Text fontSize={10} color="#4b5563">{`tokens: ${tokenCount}`}</Text>
      </Box>

    </Box>
  );
}
