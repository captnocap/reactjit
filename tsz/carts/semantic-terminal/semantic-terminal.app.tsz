// Semantic Terminal — structured data layer for CLI output.
// Runs a real shell via <Terminal>, classifies every row into semantic
// tokens (prompt, command, output, error, tool, thinking, etc.) and
// exposes that structure in a sidebar. Any CLI piped through here
// becomes machine-readable structured data.
//
// Pipeline: PTY → vterm → classifier → semantic graph → this UI
// Port of: love2d/lua/capabilities/semantic_terminal.lua

const [modeName, setModeName] = useState('idle');
const [streaming, setStreaming] = useState(0);
const [turnCount, setTurnCount] = useState(0);
const [nodeCount, setNodeCount] = useState(0);
const [cacheCount, setCacheCount] = useState(0);
const [semFrame, setSemFrame] = useState(0);
const [classMode, setClassMode] = useState(0);
const [streamKind, setStreamKind] = useState('output');
const [awaitInput, setAwaitInput] = useState(0);
const [showTree, setShowTree] = useState(0);
const [treeText, setTreeText] = useState('(no graph yet)');

// 10 classified rows: kind + text + color
const [k0, setK0] = useState('');
const [t0, setT0] = useState('');
const [c0, setC0] = useState('#e2e8f0');
const [k1, setK1] = useState('');
const [t1, setT1] = useState('');
const [c1, setC1] = useState('#e2e8f0');
const [k2, setK2] = useState('');
const [t2, setT2] = useState('');
const [c2, setC2] = useState('#e2e8f0');
const [k3, setK3] = useState('');
const [t3, setT3] = useState('');
const [c3, setC3] = useState('#e2e8f0');
const [k4, setK4] = useState('');
const [t4, setT4] = useState('');
const [c4, setC4] = useState('#e2e8f0');
const [k5, setK5] = useState('');
const [t5, setT5] = useState('');
const [c5, setC5] = useState('#e2e8f0');
const [k6, setK6] = useState('');
const [t6, setT6] = useState('');
const [c6, setC6] = useState('#e2e8f0');
const [k7, setK7] = useState('');
const [t7, setT7] = useState('');
const [c7, setC7] = useState('#e2e8f0');
const [k8, setK8] = useState('');
const [t8, setT8] = useState('');
const [c8, setC8] = useState('#e2e8f0');
const [k9, setK9] = useState('');
const [t9, setT9] = useState('');
const [c9, setC9] = useState('#e2e8f0');

<script>
// Token color map (matches classifier.zig tokenColor)
var TC = {
  output: '#e2e8f0', command: '#60a5fa', error: '#f87171',
  success: '#4ade80', heading: '#e2e8f0', separator: '#334155',
  progress: '#f97316', user_prompt: '#60a5fa', user_text: '#e2e8f0',
  assistant_text: '#e2e8f0', thinking: '#a78bfa', thought_complete: '#94a3b8',
  tool: '#eab308', result: '#94a3b8', diff: '#4ade80',
  banner: '#94a3b8', status_bar: '#64748b', box_drawing: '#334155',
  input_border: '#334155', input_zone: '#e2e8f0', permission: '#f97316',
  menu_title: '#e2e8f0', menu_option: '#e2e8f0', menu_desc: '#94a3b8',
  hint: '#94a3b8', task_done: '#4ade80', task_active: '#f97316',
  task_open: '#94a3b8', task_summary: '#60a5fa', text: '#e2e8f0'
};

function tc(kind) { return TC[kind] || '#e2e8f0'; }

// Poll semantic state
setInterval(function() {
  var s = __sem_state();
  if (!s) return;
  setModeName(s.mode_name);
  setStreaming(s.streaming ? 1 : 0);
  setStreamKind(s.streaming_kind_name);
  setTurnCount(s.turn_count);
  setNodeCount(s.node_count);
  setAwaitInput(s.awaiting_input ? 1 : 0);
  setCacheCount(__sem_cache_count());
  setSemFrame(__sem_frame());

  // Last 10 classified rows
  var cc = __sem_cache_count();
  var start = cc > 10 ? cc - 10 : 0;
  var sK = [setK0,setK1,setK2,setK3,setK4,setK5,setK6,setK7,setK8,setK9];
  var sT = [setT0,setT1,setT2,setT3,setT4,setT5,setT6,setT7,setT8,setT9];
  var sC = [setC0,setC1,setC2,setC3,setC4,setC5,setC6,setC7,setC8,setC9];
  var i = 0;
  while (10 > i) {
    var ci = start + i;
    if (cc > ci) {
      var e = __sem_cache_entry(ci);
      if (e) {
        sK[i](e.kind);
        var txt = e.text;
        if (txt.length > 50) txt = txt.substring(0, 47) + '...';
        sT[i](txt);
        sC[i](tc(e.kind));
      }
    } else {
      sK[i]('');
      sT[i]('');
      sC[i]('#e2e8f0');
    }
    i = i + 1;
  }
}, 200);

// Poll tree less often
setInterval(function() {
  if (showTree) { setTreeText(__sem_tree()); }
}, 500);

function toggleClassifier() {
  // 0=none, 1=basic, 2=claude_code
  var next = classMode === 0 ? 1 : classMode === 1 ? 2 : 0;
  setClassMode(next);
  __sem_set_mode(next);
}

function toggleTree() {
  setShowTree(showTree ? 0 : 1);
}
</script>

function CRow(kind, text, color) {
  return (
    <Box style={{ flexDirection: 'row', paddingLeft: 4, paddingRight: 4, paddingTop: 1, paddingBottom: 1, alignItems: 'center' }}>
      <Box style={{ backgroundColor: color, borderRadius: 2, paddingLeft: 3, paddingRight: 3, paddingTop: 1, paddingBottom: 1, minWidth: 80 }}>
        <Text fontSize={9} color="#0f172a">{kind}</Text>
      </Box>
      <Text fontSize={9} color={color} style={{ paddingLeft: 4 }}>{text}</Text>
    </Box>
  );
}

function TreePanel() {
  return (
    <Box style={{ flexGrow: 1, backgroundColor: '#0f172a', borderTopWidth: 1, borderColor: '#1e293b', flexDirection: 'column' }}>
      <Box style={{ paddingLeft: 6, paddingTop: 4, paddingBottom: 4, backgroundColor: '#1e293b' }}>
        <Text fontSize={10} color="#64748b">SEMANTIC GRAPH</Text>
      </Box>
      <ScrollView style={{ flexGrow: 1 }}>
        <Text fontSize={9} color="#94a3b8" style={{ padding: 4 }}>{treeText}</Text>
      </ScrollView>
    </Box>
  );
}

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#0f172a', flexDirection: 'column' }}>
      <Box style={{ flexDirection: 'row', paddingLeft: 8, paddingRight: 8, paddingTop: 6, paddingBottom: 6, backgroundColor: '#1e293b', alignItems: 'center', gap: 12 }}>
        <Text fontSize={13} color="#e2e8f0" bold>Semantic Terminal</Text>
        <Pressable onPress={() => { toggleClassifier() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#94a3b8">{classMode === 0 ? 'none' : classMode === 1 ? 'basic' : 'claude_code'}</Text>
          </Box>
        </Pressable>
        <Pressable onPress={() => { toggleTree() }}>
          <Box style={{ backgroundColor: '#334155', borderRadius: 3, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Text fontSize={10} color="#94a3b8">{showTree ? 'hide tree' : 'show tree'}</Text>
          </Box>
        </Pressable>
        <Text fontSize={10} color={modeName === 'idle' ? '#4ade80' : modeName === 'thinking' ? '#a78bfa' : '#f97316'}>{modeName}</Text>
        <Text fontSize={10} color="#64748b">{`t:${turnCount} n:${nodeCount} r:${cacheCount} f:${semFrame}`}</Text>
        {streaming == 1 && <Text fontSize={10} color="#a78bfa">{streamKind}</Text>}
        {awaitInput == 1 && <Text fontSize={10} color="#4ade80">awaiting input</Text>}
      </Box>

      <Box style={{ flexGrow: 1, flexDirection: 'row' }}>
        <Box style={{ flexGrow: 1, flexBasis: 0 }}>
          <Terminal fontSize={13} style={{ flexGrow: 1 }} />
        </Box>

        <Box style={{ width: 300, backgroundColor: '#0f172a', borderLeftWidth: 1, borderColor: '#1e293b', flexDirection: 'column' }}>
          <Box style={{ paddingLeft: 6, paddingTop: 4, paddingBottom: 4, backgroundColor: '#1e293b' }}>
            <Text fontSize={10} color="#64748b">CLASSIFIED ROWS (last 10)</Text>
          </Box>
          <ScrollView style={{ flexGrow: 1 }}>
            {k0 != '' && <CRow kind={k0} text={t0} color={c0} />}
            {k1 != '' && <CRow kind={k1} text={t1} color={c1} />}
            {k2 != '' && <CRow kind={k2} text={t2} color={c2} />}
            {k3 != '' && <CRow kind={k3} text={t3} color={c3} />}
            {k4 != '' && <CRow kind={k4} text={t4} color={c4} />}
            {k5 != '' && <CRow kind={k5} text={t5} color={c5} />}
            {k6 != '' && <CRow kind={k6} text={t6} color={c6} />}
            {k7 != '' && <CRow kind={k7} text={t7} color={c7} />}
            {k8 != '' && <CRow kind={k8} text={t8} color={c8} />}
            {k9 != '' && <CRow kind={k9} text={t9} color={c9} />}
          </ScrollView>

          {showTree == 1 && <TreePanel />}
        </Box>
      </Box>
    </Box>
  );
}
