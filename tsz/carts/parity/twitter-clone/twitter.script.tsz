    { user: 'Elon Musk', handle: 'elonmusk', avatar: 'EM', avatarBg: 0x1da1f2, time: '2h', text: 'Just mass-produced the 10 millionth Cybertruck. Still no turn signals though.', replies: 4200, retweets: 18700, likes: 95400, hasImage: 0, imageBg: 0 },
