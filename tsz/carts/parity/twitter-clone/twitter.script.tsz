    { user: 'Taylor Swift', handle: 'taylorswift13', avatar: 'TS', avatarBg: 0xc71585, time: '8h', text: 'Surprise! New album drops at midnight. It is called "Segmentation Fault" and every song is about debugging.', replies: 45000, retweets: 120000, likes: 890000, hasImage: 1, imageBg: 0x1a0a1a },
    { user: 'Kelsey Hightower', handle: 'kelseyhightower', avatar: 'KH', avatarBg: 0x326ce5, time: '9h', text: 'YAML is not a programming language. Stop writing 4000-line YAML files and calling it infrastructure as code.', replies: 1200, retweets: 8900, likes: 34500, hasImage: 0, imageBg: 0 },
    { user: 'MIT Tech Review', handle: 'techreview', avatar: 'MT', avatarBg: 0xe60000, time: '10h', text: 'Breaking: researchers achieve quantum error correction below the threshold needed for useful computation. This is a big deal.', replies: 670, retweets: 12000, likes: 45000, hasImage: 1, imageBg: 0x1a1a2e },
    { user: 'Pieter Levels', handle: 'levelsio', avatar: 'PL', avatarBg: 0xf59e0b, time: '11h', text: 'Built a new SaaS in 48 hours. Already at $2k MRR. Stack: one PHP file and vibes.', replies: 2300, retweets: 4500, likes: 31200, hasImage: 0, imageBg: 0 },
    { user: 'Mozilla', handle: 'mozilla', avatar: 'MZ', avatarBg: 0xff6611, time: '12h', text: 'Firefox 140 is here. We added nothing new but removed three things you loved. You are welcome.', replies: 3400, retweets: 7800, likes: 19500, hasImage: 0, imageBg: 0 },
