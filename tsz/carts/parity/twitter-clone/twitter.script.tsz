  ];

  var tl = [];
  for (var i = 0; tweets.length > i; i = i + 1) {
    var t = tweets[i];
    var replyStr = '';
    var rtStr = '';
    var likeStr = '';
    if (t.replies > 999) {
      replyStr = Math.floor(t.replies / 100) / 10 + 'K';
    } else {
      replyStr = '' + t.replies;
    }
    if (t.retweets > 999) {
      rtStr = Math.floor(t.retweets / 100) / 10 + 'K';
    } else {
      rtStr = '' + t.retweets;
    }
    if (t.likes > 999) {
      likeStr = Math.floor(t.likes / 100) / 10 + 'K';
    } else {
      likeStr = '' + t.likes;
    }
    tl.push({
      user: t.user,
      handle: '@' + t.handle,
      avatar: t.avatar,
      avatarBg: t.avatarBg,
      time: t.time,
      text: t.text,
      replyStr: replyStr,
      rtStr: rtStr,
      likeStr: likeStr,
      hasImage: t.hasImage,
      imageBg: t.imageBg
    });
  }
  setTweets(tl);
}

loadData();
