// Inspector — polls node tree via __tel_* (in-process) or JSON dump (cross-process).
// The dev shell writes inspector-dump.json when telemetry export is enabled.

var DUMP_PATH = '/run/user/1000/claude-sessions/reactjit/inspector-dump.json';
var _inspScrollOffset = 0;
var _inspSelectedIdx = 0;
var _inspSource = 'auto';

function tagColor(tag) {
  if (tag === 'Box') return 0x8fabef;
  if (tag === 'Text') return 0xa5d6a7;
  if (tag === 'Pressable') return 0xffcc80;
  if (tag === 'ScrollView') return 0x80deea;
  if (tag === 'TextInput') return 0xce93d8;
  if (tag === 'Image') return 0xef9a9a;
  if (tag === 'Terminal') return 0xb0bec5;
  if (tag === 'Cartridge') return 0xfff59d;
  return 0x8fabef;
}

function pollTreeFromTel() {
  var count = __tel_node_count();
  if (!count || count === 0) return false;

  setInspNodeCount(count);
  var rows = [];
  var windowSize = 80;
  var end = _inspScrollOffset + windowSize;
  if (end > count) end = count;

  for (var i = _inspScrollOffset; end > i; i = i + 1) {
    var n = __tel_node(i);
    if (n) {
      var indent = '';
      for (var d = 0; n.depth > d; d = d + 1) indent = indent + '  ';
      var marker = n.child_count > 0 ? '▸ ' : '  ';
      rows.push({
        idx: i,
        caret: indent + marker,
        tag: n.tag,
        dim: Math.round(n.w) + 'x' + Math.round(n.h),
        pos: Math.round(n.x) + ',' + Math.round(n.y),
        kids: n.child_count,
        depth: n.depth,
        tagColor: tagColor(n.tag),
        selected: i === _inspSelectedIdx ? 1 : 0
      });
    }
  }
  setInspTreeNodes(rows);
  updateDetailFromTel();
  setInspSource('telemetry');
  return true;
}

function updateDetailFromTel() {
  var n = __tel_node(_inspSelectedIdx);
  if (!n) return;

  setInspDetTag(n.tag);
  setInspDetDim(Math.round(n.w) + ' x ' + Math.round(n.h));
  setInspDetPos(Math.round(n.x) + ', ' + Math.round(n.y));
  setInspDetKids(n.child_count);
  setInspDetDepth(n.depth);

  var style = __tel_node_style(_inspSelectedIdx);
  if (style) {
    setInspDetGrow(Math.round(style.flex_grow));
    setInspDetDir(style.flex_direction === 0 ? 'column' : 'row');
    setInspDetOverflow(style.overflow === 0 ? 'visible' : style.overflow === 1 ? 'hidden' : 'scroll');
  }

  var box = __tel_node_box_model(_inspSelectedIdx);
  if (box) {
    setInspDetPadTop(Math.round(box.pad_top));
    setInspDetPadRight(Math.round(box.pad_right));
    setInspDetPadBottom(Math.round(box.pad_bottom));
    setInspDetPadLeft(Math.round(box.pad_left));
    setInspDetMarTop(Math.round(box.margin_top));
    setInspDetMarRight(Math.round(box.margin_right));
    setInspDetMarBottom(Math.round(box.margin_bottom));
    setInspDetMarLeft(Math.round(box.margin_left));
    setInspDetContentW(Math.round(box.content_w));
    setInspDetContentH(Math.round(box.content_h));
  }
}

function pollTreeFromDump() {
  var raw = __fs_readfile(DUMP_PATH);
  if (!raw || raw.length === 0) {
    setInspSource('no data');
    return;
  }

  try {
    var data = JSON.parse(raw);
    var nodes = data.nodes || [];
    setInspNodeCount(nodes.length);

    // Frame telemetry
    if (data.frame) {
      setInspFps(data.frame.fps || 0);
      setInspLayoutUs(data.frame.layout_us || 0);
      setInspPaintUs(data.frame.paint_us || 0);
    }
    if (data.gpu) {
      setInspRects(data.gpu.rect_count || 0);
      setInspGlyphs(data.gpu.glyph_count || 0);
    }

    var rows = [];
    var windowSize = 80;
    var end = _inspScrollOffset + windowSize;
    if (end > nodes.length) end = nodes.length;

    for (var i = _inspScrollOffset; end > i; i = i + 1) {
      var n = nodes[i];
      var indent = '';
      for (var d = 0; (n.depth || 0) > d; d = d + 1) indent = indent + '  ';
      var marker = (n.child_count || 0) > 0 ? '▸ ' : '  ';
      rows.push({
        idx: i,
        caret: indent + marker,
        tag: n.tag || 'Box',
        dim: Math.round(n.w || 0) + 'x' + Math.round(n.h || 0),
        pos: Math.round(n.x || 0) + ',' + Math.round(n.y || 0),
        kids: n.child_count || 0,
        depth: n.depth || 0,
        tagColor: tagColor(n.tag || 'Box'),
        selected: i === _inspSelectedIdx ? 1 : 0
      });
    }
    setInspTreeNodes(rows);

    // Update detail from dump
    if (_inspSelectedIdx >= 0 && nodes.length > _inspSelectedIdx) {
      var sel = nodes[_inspSelectedIdx];
      setInspDetTag(sel.tag || 'Box');
      setInspDetDim(Math.round(sel.w || 0) + ' x ' + Math.round(sel.h || 0));
      setInspDetPos(Math.round(sel.x || 0) + ', ' + Math.round(sel.y || 0));
      setInspDetKids(sel.child_count || 0);
      setInspDetDepth(sel.depth || 0);
      setInspDetGrow(sel.flex_grow || 0);
      setInspDetDir(sel.flex_direction === 1 ? 'row' : 'column');
      setInspDetOverflow(sel.overflow === 1 ? 'hidden' : sel.overflow === 2 ? 'scroll' : 'visible');
      setInspDetPadTop(sel.pad_top || 0);
      setInspDetPadRight(sel.pad_right || 0);
      setInspDetPadBottom(sel.pad_bottom || 0);
      setInspDetPadLeft(sel.pad_left || 0);
      setInspDetMarTop(sel.margin_top || 0);
      setInspDetMarRight(sel.margin_right || 0);
      setInspDetMarBottom(sel.margin_bottom || 0);
      setInspDetMarLeft(sel.margin_left || 0);
      setInspDetContentW(sel.content_w || 0);
      setInspDetContentH(sel.content_h || 0);
    }
    setInspSource('dump');
  } catch (e) {
    setInspSource('parse error');
  }
}

function inspSelectNode(idx) {
  _inspSelectedIdx = idx;
  // Re-mark selection in current rows
  var rows = [];
  var current = inspTreeNodes;
  for (var i = 0; current.length > i; i = i + 1) {
    var r = current[i];
    rows.push({
      idx: r.idx,
      caret: r.caret,
      tag: r.tag,
      dim: r.dim,
      pos: r.pos,
      kids: r.kids,
      depth: r.depth,
      tagColor: r.tagColor,
      selected: r.idx === idx ? 1 : 0
    });
  }
  setInspTreeNodes(rows);
}

function inspScrollUp() {
  _inspScrollOffset = _inspScrollOffset - 20;
  if (0 > _inspScrollOffset) _inspScrollOffset = 0;
}

function inspScrollDown() {
  _inspScrollOffset = _inspScrollOffset + 20;
}

function pollInspector() {
  // Try in-process telemetry first
  var hasTel = false;
  try {
    hasTel = pollTreeFromTel();
  } catch (e) {
    hasTel = false;
  }
  // Fall back to JSON dump
  if (!hasTel) {
    pollTreeFromDump();
  }
}

pollInspector();
setInterval(pollInspector, 500);
