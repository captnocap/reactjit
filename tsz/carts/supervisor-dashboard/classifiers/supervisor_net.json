{
  "name": "supervisor_net",
  "version": "1.0",
  "description": "Semantic violation net for supervisor — classifies worker output to detect boundary violations, forbidden operations, and policy breaches",
  "overlay_for": "claude_code",
  "tokens": {
    "violation_deny":    { "role": "supervisor", "lane": "violation", "color": "#ef4444", "block": false, "severity": "critical" },
    "violation_pause":   { "role": "supervisor", "lane": "violation", "color": "#f97316", "block": false, "severity": "warning" },
    "violation_flag":    { "role": "supervisor", "lane": "violation", "color": "#eab308", "block": false, "severity": "info" },
    "boundary_breach":   { "role": "supervisor", "lane": "violation", "color": "#ef4444", "block": false, "severity": "critical" },
    "safe_edit":         { "role": "supervisor", "lane": "edit",      "color": "#4ade80", "block": false },
    "tool_edit":         { "role": "assistant",  "lane": "tool",      "color": "#eab308", "block": false },
    "tool_write":        { "role": "assistant",  "lane": "tool",      "color": "#eab308", "block": false },
    "tool_bash":         { "role": "assistant",  "lane": "tool",      "color": "#eab308", "block": false }
  },
  "rules": [
    { "_comment": "=== Frozen directory violations (DENY) ===" },

    { "token": "violation_deny",   "match": "regex", "pattern": "(?:Edit|Write|rm|mv|chmod).*love2d/",
      "meta": { "rule": "love2d-frozen", "action": "deny", "message": "love2d/ is frozen — read-only reference stack" } },

    { "token": "violation_deny",   "match": "regex", "pattern": "(?:Edit|Write|rm|mv|chmod).*archive/",
      "meta": { "rule": "archive-frozen", "action": "deny", "message": "archive/ is frozen — old compiler iterations" } },

    { "token": "violation_deny",   "match": "regex", "pattern": "chmod.*(love2d|archive)",
      "meta": { "rule": "no-chmod-frozen", "action": "deny", "message": "Do not chmod frozen directories" } },

    { "_comment": "=== Generated file violations (DENY) ===" },

    { "token": "violation_deny",   "match": "regex", "pattern": "(?:Edit|Write).*\\.gen\\.zig",
      "meta": { "rule": "no-edit-gen-zig", "action": "deny", "message": ".gen.zig files are build artifacts — fix the .tsz source" } },

    { "_comment": "=== Hand-painted UI violations (DENY) ===" },

    { "token": "violation_deny",   "match": "regex", "pattern": "(?:Edit|Write).*framework/(?:devtools|ui_).*\\.zig",
      "meta": { "rule": "no-hand-painted-ui", "action": "deny", "message": "Never hand-paint UI in Zig — write .tsz and use --embed" } },

    { "_comment": "=== Build discipline violations (PAUSE) ===" },

    { "token": "violation_pause",  "match": "regex", "pattern": "(?:bin/)?tsz\\s+build\\s+.*\\.tsz",
      "meta": { "rule": "use-dev-not-build", "action": "pause", "message": "Use tsz dev for iteration, not tsz build" } },

    { "token": "violation_pause",  "match": "regex", "pattern": "zig build (?:compiler|app-full)",
      "meta": { "rule": "old-build-commands", "action": "pause", "message": "Old build commands removed — use zig build tsz or tsz-full" } },

    { "_comment": "=== Framework boundary violations (PAUSE) ===" },

    { "token": "violation_pause",  "match": "regex", "pattern": "(?:Edit|Write).*framework/.*\\.zig",
      "meta": { "rule": "no-framework-from-carts", "action": "pause", "message": "Cart workers should not edit framework files" },
      "not_contains": "devtools" },

    { "_comment": "=== Code quality flags (FLAG) ===" },

    { "token": "violation_flag",   "match": "regex", "pattern": "<\\s*[A-Z]",
      "meta": { "rule": "no-less-than-jsx", "action": "flag", "message": "Parser treats x < Name as JSX — use count > i instead" },
      "also": { "match": "contains", "value": ".tsz" } },

    { "token": "violation_flag",   "match": "contains", "value": "--no-verify",
      "meta": { "rule": "no-skip-hooks", "action": "flag", "message": "Do not skip git hooks" } },

    { "token": "violation_flag",   "match": "regex", "pattern": "git\\s+(reset\\s+--hard|push\\s+--force|checkout\\s+\\.)",
      "meta": { "rule": "no-destructive-git", "action": "flag", "message": "Destructive git operations need supervisor approval" } },

    { "token": "violation_flag",   "match": "regex", "pattern": "git\\s+stash(?!\\s+show)",
      "meta": { "rule": "commit-before-stash", "action": "flag", "message": "Commit WIP before git stash — stash pop failures lose work" } },

    { "_comment": "=== Tool use detection (for boundary checking) ===" },

    { "token": "tool_edit",  "match": "regex", "pattern": "(?:●|•|◆)\\s+Edit\\(" },
    { "token": "tool_write", "match": "regex", "pattern": "(?:●|•|◆)\\s+Write\\(" },
    { "token": "tool_bash",  "match": "regex", "pattern": "(?:●|•|◆)\\s+Bash\\(" }
  ],
  "adjacency": [
    { "when_prev": ["tool_edit", "tool_write"],
      "when_current": "text",
      "text_regex": "love2d/|archive/|\\.gen\\.zig",
      "promote_to": "boundary_breach" },
    { "when_prev": ["tool_edit", "tool_write"],
      "when_current": "text",
      "text_not_regex": "love2d/|archive/|\\.gen\\.zig|framework/",
      "promote_to": "safe_edit" }
  ],
  "groups": {
    "violations": ["violation_deny", "violation_pause", "violation_flag", "boundary_breach"],
    "tools":      ["tool_edit", "tool_write", "tool_bash"]
  },
  "state_derivation": {
    "violation_deny":  { "mode": "violation", "severity": "critical", "action": "deny" },
    "violation_pause": { "mode": "violation", "severity": "warning",  "action": "pause" },
    "violation_flag":  { "mode": "violation", "severity": "info",     "action": "flag" },
    "boundary_breach": { "mode": "violation", "severity": "critical", "action": "deny" }
  },
  "default_token": null
}
