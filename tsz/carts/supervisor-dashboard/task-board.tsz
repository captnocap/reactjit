// Task Board — project management for multi-worker Claude Code sessions.
// Reads from SQLite via JSON files written by db/tasks.sh refresh.
// Kanban: Backlog | In Progress | Review | Done (+Blocked)

// @ffi <supervisor_shim.h>
declare function sv_refresh(): number;

import { Page, Sidebar, SideSection, SideHeader, FilterBtn,
         FilterDot, FilterText, FilterCount,
         Board, KanbanCol, ColHeader, ColDot, ColTitle, ColCount,
         Card, CardTitle, CardRow, PriBadge, PriText, CardMeta,
         Detail, DetailHeader, DetailTitle, DetailId, SectionTitle, SpecText,
         StepRow, StepCheck, StepCheckDone, StepTitle, StepTitleDone,
         NoteRow, NoteAuthor, NoteContent, NoteTime,
         EditRow, EditFile, EditSummary, EditDiff, EditTime } from './task-board.cls';
import { loadBoard, loadDetail } from './task-board.script';

const [refreshTick] = useFFI(sv_refresh, 3000);

// Board data — object arrays for .map()
const [backlogList, setBacklogList] = useState([{ title: '', tid: '', pane: '', stepsLabel: '', lastEdit: '', priBg: 0 }]);
const [progressList, setProgressList] = useState([{ title: '', tid: '', pane: '', stepsLabel: '', lastEdit: '', priBg: 0 }]);
const [reviewList, setReviewList] = useState([{ title: '', tid: '', pane: '', stepsLabel: '', lastEdit: '', priBg: 0 }]);
const [doneList, setDoneList] = useState([{ title: '', tid: '', pane: '', stepsLabel: '', lastEdit: '', priBg: 0 }]);
const [blockedList, setBlockedList] = useState([{ title: '', tid: '', pane: '', stepsLabel: '', lastEdit: '', priBg: 0 }]);

const [backlogCount, setBacklogCount] = useState(0);
const [progressCount, setProgressCount] = useState(0);
const [reviewCount, setReviewCount] = useState(0);
const [doneCount, setDoneCount] = useState(0);
const [blockedCount, setBlockedCount] = useState(0);
const [totalCount, setTotalCount] = useState(0);

// Workers
const [workerList, setWorkerList] = useState([{ pane: '', status: '', taskLabel: '', dotColor: 0 }]);

// Detail panel
const [selectedTask, setSelectedTask] = useState(0);
const [detTitle, setDetTitle] = useState('');
const [detId, setDetId] = useState('');
const [detStatus, setDetStatus] = useState('');
const [detPriority, setDetPriority] = useState(0);
const [detPriBg, setDetPriBg] = useState(0x21262d);
const [detSpec, setDetSpec] = useState('');
const [detPane, setDetPane] = useState('');
const [detSteps, setDetSteps] = useState([{ title: '', isDone: 0 }]);
const [detNotes, setDetNotes] = useState([{ author: '', content: '', time: '' }]);
const [detEdits, setDetEdits] = useState([{ file: '', summary: '', diff: '', time: '' }]);

<script>
function selectTask(id) {
  setSelectedTask(id);
  loadDetail(id);
}

function closeDetail() {
  setSelectedTask(0);
}
</script>

function App() {
  return (
    <C.Page>
      <C.Sidebar>
        <Text fontSize={14} color="#e6edf3" bold>Task Board</Text>
        <Text fontSize={10} color="#484f58">{`${totalCount} tasks`}</Text>

        <C.SideSection>
          <C.SideHeader>STATUS</C.SideHeader>
          <C.FilterBtn><C.FilterDot style={{ backgroundColor: 0x8b949e }} /><C.FilterText>Backlog</C.FilterText><C.FilterCount>{`${backlogCount}`}</C.FilterCount></C.FilterBtn>
          <C.FilterBtn><C.FilterDot style={{ backgroundColor: 0xd29922 }} /><C.FilterText>In Progress</C.FilterText><C.FilterCount>{`${progressCount}`}</C.FilterCount></C.FilterBtn>
          <C.FilterBtn><C.FilterDot style={{ backgroundColor: 0x58a6ff }} /><C.FilterText>Review</C.FilterText><C.FilterCount>{`${reviewCount}`}</C.FilterCount></C.FilterBtn>
          <C.FilterBtn><C.FilterDot style={{ backgroundColor: 0xf85149 }} /><C.FilterText>Blocked</C.FilterText><C.FilterCount>{`${blockedCount}`}</C.FilterCount></C.FilterBtn>
          <C.FilterBtn><C.FilterDot style={{ backgroundColor: 0x3fb950 }} /><C.FilterText>Done</C.FilterText><C.FilterCount>{`${doneCount}`}</C.FilterCount></C.FilterBtn>
        </C.SideSection>

        <C.SideSection>
          <C.SideHeader>WORKERS</C.SideHeader>
          {workerList.map((w) => (
            <C.FilterBtn>
              <C.FilterDot style={{ backgroundColor: w.dotColor }} />
              <C.FilterText>{w.pane}</C.FilterText>
            </C.FilterBtn>
          ))}
        </C.SideSection>
      </C.Sidebar>

      <C.Board>
        <C.KanbanCol>
          <C.ColHeader><C.ColDot style={{ backgroundColor: 0x8b949e }} /><C.ColTitle>BACKLOG</C.ColTitle><C.ColCount>{`${backlogCount}`}</C.ColCount></C.ColHeader>
          <ScrollView style={{ flexGrow: 1 }}>
            {backlogList.map((task) => (
              <C.Card>
                <Box style={{ flexDirection: 'row', justifyContent: 'spaceBetween', alignItems: 'center' }}>
                  <C.CardTitle>{task.title}</C.CardTitle>
                  <C.CardMeta>{task.tid}</C.CardMeta>
                </Box>
                <C.CardRow>
                  <C.PriBadge style={{ backgroundColor: task.priBg }}><C.PriText>{task.stepsLabel}</C.PriText></C.PriBadge>
                  <C.CardMeta>{task.pane}</C.CardMeta>
                </C.CardRow>
                {task.lastEdit != '' && <C.CardMeta>{task.lastEdit}</C.CardMeta>}
              </C.Card>
            ))}
          </ScrollView>
        </C.KanbanCol>

        <C.KanbanCol>
          <C.ColHeader><C.ColDot style={{ backgroundColor: 0xd29922 }} /><C.ColTitle>IN PROGRESS</C.ColTitle><C.ColCount>{`${progressCount}`}</C.ColCount></C.ColHeader>
          <ScrollView style={{ flexGrow: 1 }}>
            {progressList.map((task) => (
              <C.Card>
                <Box style={{ flexDirection: 'row', justifyContent: 'spaceBetween', alignItems: 'center' }}>
                  <C.CardTitle>{task.title}</C.CardTitle>
                  <C.CardMeta>{task.tid}</C.CardMeta>
                </Box>
                <C.CardRow>
                  <C.PriBadge style={{ backgroundColor: task.priBg }}><C.PriText>{task.stepsLabel}</C.PriText></C.PriBadge>
                  <C.CardMeta>{task.pane}</C.CardMeta>
                </C.CardRow>
                {task.lastEdit != '' && <C.CardMeta>{task.lastEdit}</C.CardMeta>}
              </C.Card>
            ))}
          </ScrollView>
        </C.KanbanCol>

        <C.KanbanCol>
          <C.ColHeader><C.ColDot style={{ backgroundColor: 0x58a6ff }} /><C.ColTitle>REVIEW</C.ColTitle><C.ColCount>{`${reviewCount}`}</C.ColCount></C.ColHeader>
          <ScrollView style={{ flexGrow: 1 }}>
            {reviewList.map((task) => (
              <C.Card>
                <Box style={{ flexDirection: 'row', justifyContent: 'spaceBetween', alignItems: 'center' }}>
                  <C.CardTitle>{task.title}</C.CardTitle>
                  <C.CardMeta>{task.tid}</C.CardMeta>
                </Box>
                <C.CardRow>
                  <C.PriBadge style={{ backgroundColor: task.priBg }}><C.PriText>{task.stepsLabel}</C.PriText></C.PriBadge>
                  <C.CardMeta>{task.pane}</C.CardMeta>
                </C.CardRow>
              </C.Card>
            ))}
          </ScrollView>
        </C.KanbanCol>

        <C.KanbanCol>
          <C.ColHeader><C.ColDot style={{ backgroundColor: 0xf85149 }} /><C.ColTitle>BLOCKED</C.ColTitle><C.ColCount>{`${blockedCount}`}</C.ColCount></C.ColHeader>
          <ScrollView style={{ flexGrow: 1 }}>
            {blockedList.map((task) => (
              <C.Card>
                <Box style={{ flexDirection: 'row', justifyContent: 'spaceBetween', alignItems: 'center' }}>
                  <C.CardTitle>{task.title}</C.CardTitle>
                  <C.CardMeta>{task.tid}</C.CardMeta>
                </Box>
                <C.CardRow>
                  <C.PriBadge style={{ backgroundColor: task.priBg }}><C.PriText>{task.stepsLabel}</C.PriText></C.PriBadge>
                  <C.CardMeta>{task.pane}</C.CardMeta>
                </C.CardRow>
              </C.Card>
            ))}
          </ScrollView>
        </C.KanbanCol>

        <C.KanbanCol>
          <C.ColHeader><C.ColDot style={{ backgroundColor: 0x3fb950 }} /><C.ColTitle>DONE</C.ColTitle><C.ColCount>{`${doneCount}`}</C.ColCount></C.ColHeader>
          <ScrollView style={{ flexGrow: 1 }}>
            {doneList.map((task) => (
              <C.Card>
                <Box style={{ flexDirection: 'row', justifyContent: 'spaceBetween', alignItems: 'center' }}>
                  <C.CardTitle>{task.title}</C.CardTitle>
                  <C.CardMeta>{task.tid}</C.CardMeta>
                </Box>
                <C.CardRow>
                  <C.PriBadge style={{ backgroundColor: task.priBg }}><C.PriText>{task.stepsLabel}</C.PriText></C.PriBadge>
                  <C.CardMeta>{task.pane}</C.CardMeta>
                </C.CardRow>
              </C.Card>
            ))}
          </ScrollView>
        </C.KanbanCol>
      </C.Board>

      {selectedTask > 0 && <C.Detail>
        <C.DetailHeader>
          <C.DetailTitle>{detTitle}</C.DetailTitle>
          <Pressable onPress={() => { closeDetail() }}>
            <Box style={{ padding: 4 }}><Text fontSize={14} color="#8b949e">X</Text></Box>
          </Pressable>
        </C.DetailHeader>
        <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
          <C.DetailId>{detId}</C.DetailId>
          <C.PriBadge style={{ backgroundColor: detPriBg }}><C.PriText>{`P${detPriority}`}</C.PriText></C.PriBadge>
          <C.CardMeta>{detStatus}</C.CardMeta>
          <C.CardMeta>{detPane}</C.CardMeta>
        </Box>
        <ScrollView style={{ flexGrow: 1 }}>
          <Box style={{ flexDirection: 'column', gap: 12 }}>
            <Box style={{ flexDirection: 'column', gap: 4 }}>
              <C.SectionTitle>SPEC</C.SectionTitle>
              <C.SpecText>{detSpec}</C.SpecText>
            </Box>
            <Box style={{ flexDirection: 'column', gap: 4 }}>
              <C.SectionTitle>STEPS</C.SectionTitle>
              {detSteps.map((s) => (
                <C.StepRow>
                  {s.isDone == 1 && <C.StepCheckDone><Text fontSize={9} color="#ffffff">v</Text></C.StepCheckDone>}
                  {s.isDone != 1 && <C.StepCheck />}
                  <C.StepTitle>{s.title}</C.StepTitle>
                </C.StepRow>
              ))}
            </Box>
            <Box style={{ flexDirection: 'column', gap: 4 }}>
              <C.SectionTitle>NOTES</C.SectionTitle>
              {detNotes.map((n) => (
                <C.NoteRow>
                  <C.NoteAuthor>{n.author}</C.NoteAuthor>
                  <C.NoteContent>{n.content}</C.NoteContent>
                  <C.NoteTime>{n.time}</C.NoteTime>
                </C.NoteRow>
              ))}
            </Box>
            <Box style={{ flexDirection: 'column', gap: 4 }}>
              <C.SectionTitle>RECENT EDITS</C.SectionTitle>
              {detEdits.map((e) => (
                <C.EditRow>
                  <C.EditFile>{e.file}</C.EditFile>
                  <C.EditSummary>{e.summary}</C.EditSummary>
                  <C.EditTime>{e.time}</C.EditTime>
                </C.EditRow>
              ))}
            </Box>
          </Box>
        </ScrollView>
      </C.Detail>}
    </C.Page>
  );
}
