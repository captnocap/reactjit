// Violations feed — reads from violations.sh json output.
// Polls JSON dump written by the supervisor hook pipeline.

var VIOLATIONS_SH = '/home/siah/creative/reactjit/tsz/carts/supervisor-dashboard/db/violations.sh';
var VIOLATIONS_JSON = '/run/user/1000/claude-sessions/reactjit/violations.json';

function actionColor(action) {
  if (action === 'deny') return 0xef4444;
  if (action === 'pause') return 0xf97316;
  if (action === 'flag') return 0xeab308;
  return 0x6b7280;
}

function actionBg(action) {
  if (action === 'deny') return 0x7f1d1d;
  if (action === 'pause') return 0x7c2d12;
  if (action === 'flag') return 0x713f12;
  return 0x1f2937;
}

function actionDot(action) {
  if (action === 'deny') return 0xef4444;
  if (action === 'pause') return 0xf97316;
  if (action === 'flag') return 0xeab308;
  return 0x484f58;
}

function pollViolations() {
  // Try reading pre-generated JSON first
  var raw = __fs_readfile(VIOLATIONS_JSON);
  if (!raw || raw.length === 0) {
    // Fall back to running the script
    raw = __exec(VIOLATIONS_SH + ' json');
  }
  if (!raw || raw.length === 0) {
    setVioTotal(0);
    setVioOpen(0);
    return;
  }

  try {
    var data = JSON.parse(raw);

    // Process rules
    var rules = data.rules || [];
    var rl = [];
    var totalHits = 0;
    var openHits = 0;
    for (var i = 0; rules.length > i; i = i + 1) {
      var r = rules[i];
      totalHits = totalHits + (r.total_hits || 0);
      openHits = openHits + (r.open_hits || 0);
      rl.push({
        id: r.id || 0,
        name: r.name || '',
        pattern: r.pattern || '',
        action: r.action || 'flag',
        description: r.description || '',
        enabled: r.enabled || 0,
        totalHits: r.total_hits || 0,
        openHits: r.open_hits || 0,
        actionColor: actionColor(r.action),
        actionBg: actionBg(r.action)
      });
    }
    setVioRules(rl);
    setVioRuleCount(rl.length);
    setVioTotal(totalHits);
    setVioOpen(openHits);

    // Process recent violations
    var recent = data.recent_violations || [];
    var vl = [];
    var denyCount = 0;
    var pauseCount = 0;
    var flagCount = 0;
    for (var j = 0; recent.length > j; j = j + 1) {
      var v = recent[j];
      var action = v.action_taken || 'flag';
      if (action === 'deny') denyCount = denyCount + 1;
      else if (action === 'pause') pauseCount = pauseCount + 1;
      else flagCount = flagCount + 1;

      var timeStr = v.created_at || '';
      if (timeStr.length > 16) timeStr = timeStr.substring(11, 16);

      vl.push({
        id: v.id || 0,
        rule: v.rule || '?',
        action: action,
        matched: v.matched_text || '',
        resolved: v.resolved || 0,
        time: timeStr,
        dotColor: actionDot(action),
        actionBg: actionBg(action),
        actionColor: actionColor(action)
      });
    }
    setVioFeed(vl);
    setVioDenyCount(denyCount);
    setVioPauseCount(pauseCount);
    setVioFlagCount(flagCount);
  } catch (e) {
    console.log('Violations parse error: ' + e.message);
  }
}

pollViolations();
setInterval(pollViolations, 3000);
