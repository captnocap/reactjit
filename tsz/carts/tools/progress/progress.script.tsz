// Progress cart script — git history, filesystem births, conformance db, and runner control
// Host functions: __exec, __db_query

var REPO_ROOT = '/home/siah/creative/reactjit';
var TSZ_DIR = REPO_ROOT + '/tsz';
var CONF_DB = TSZ_DIR + '/conformance.db';
var CONF_V4_DB = TSZ_DIR + '/conformance-v4.db';
var CONF_DIR = TSZ_DIR + '/carts/conformance';

var MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

function shellQuote(value) {
  return "'" + value.split("'").join("'\"'\"'") + "'";
}

function endsWithStr(value, suffix) {
  if (!value) return 0;
  if (suffix.length > value.length) return 0;
  return value.substring(value.length - suffix.length) === suffix;
}

function normalizeRepoPath(path) {
  if (!path) return '';
  if (path.indexOf(REPO_ROOT + '/') === 0) return path.substring(REPO_ROOT.length + 1);
  if (path.indexOf(TSZ_DIR + '/') === 0) return 'tsz/' + path.substring(TSZ_DIR.length + 1);
  if (path.indexOf('tsz/') === 0) return path;
  if (path.indexOf('carts/') === 0 || path.indexOf('compiler/') === 0 || path.indexOf('framework/') === 0 || path.indexOf('scripts/') === 0 || path.indexOf('docs/') === 0) {
    return 'tsz/' + path;
  }
  return path;
}

function shortDay(day) {
  if (!day || day.length < 10) return day;
  var month = parseInt(day.substring(5, 7), 10) - 1;
  var date = parseInt(day.substring(8, 10), 10);
  if (month < 0 || month >= MONTHS.length) return day;
  return MONTHS[month] + ' ' + date;
}

function dayFromEpoch(epochSec) {
  var dt = new Date(epochSec * 1000);
  var y = dt.getFullYear();
  var m = dt.getMonth() + 1;
  var d = dt.getDate();
  return y + '-' + (m < 10 ? '0' : '') + m + '-' + (d < 10 ? '0' : '') + d;
}

function dayKeyToday() {
  return dayFromEpoch(Math.floor(Date.now() / 1000));
}

function nextDay(day) {
  var dt = new Date(day + 'T00:00:00');
  dt.setDate(dt.getDate() + 1);
  return dayFromEpoch(Math.floor(dt.getTime() / 1000));
}

function inc(map, key, amount) {
  if (map[key] === undefined) map[key] = 0;
  map[key] = map[key] + (amount === undefined ? 1 : amount);
}

function areaColor(area) {
  if (area === 'compiler') return '#5568e6';
  if (area === 'framework') return '#2a72d8';
  if (area === 'conformance') return '#0f8a5f';
  if (area === 'tools') return '#c27c00';
  if (area === 'scripts') return '#7c89ff';
  if (area === 'docs') return '#7b809a';
  if (area === 'tests') return '#1146c7';
  if (area === 'experiments') return '#b24b71';
  if (area === 'support') return '#5467b9';
  if (area === 'carts') return '#ba4b20';
  if (area === 'root') return '#64748b';
  return '#5d6891';
}

function laneColor(lane) {
  if (lane === 'mixed') return '#2a72d8';
  if (lane === 'chad') return '#c27c00';
  if (lane === 'soup') return '#0f8a5f';
  if (lane === 'lscript') return '#7c89ff';
  if (lane === 'wpt-flex') return '#b22222';
  if (lane === 'parity') return '#d94a69';
  if (lane === 'root') return '#7b809a';
  return '#64748b';
}

function typeColor(prefix) {
  if (prefix === 'fix') return '#b22222';
  if (prefix === 'feat') return '#0f8a5f';
  if (prefix === 'docs') return '#6d728e';
  if (prefix === 'refactor') return '#2a72d8';
  if (prefix === 'test') return '#c27c00';
  if (prefix === 'perf') return '#8f6500';
  return '#5d6891';
}

function typeBadgeBg(prefix) {
  if (prefix === 'fix') return '#f2d8dd';
  if (prefix === 'feat') return '#d9f0e6';
  if (prefix === 'docs') return '#dde2ef';
  if (prefix === 'refactor') return '#dde9ff';
  if (prefix === 'test') return '#f1e6c0';
  if (prefix === 'perf') return '#eedfc6';
  return '#e3e5ef';
}

function parseCommitType(msg) {
  var paren = msg.indexOf('(');
  var colon = msg.indexOf(':');
  if (colon > 0 && colon < 18) {
    if (paren > 0 && paren < colon) return msg.substring(0, paren);
    return msg.substring(0, colon);
  }
  return 'chore';
}

function isIgnoredPath(path) {
  var p = normalizeRepoPath(path);
  if (!p) return 1;
  if (p.indexOf('tsz/carts/conformance/.verified/') === 0) return 1;
  if (p.indexOf('/.verified/') >= 0) return 1;
  if (p.indexOf('/.zig-cache/') >= 0) return 1;
  if (p.indexOf('/.zig-global-cache/') >= 0) return 1;
  if (p.indexOf('/.tsz-preflight/') >= 0) return 1;
  if (p.indexOf('/zig-cache/') >= 0) return 1;
  if (p.indexOf('/zig-out/') >= 0) return 1;
  if (p.indexOf('tsz/tests/screenshots/') === 0) return 1;
  if (p.indexOf('tsz/screenshots/') === 0) return 1;
  if (p.indexOf('tsz/.claude/') === 0) return 1;
  if (endsWithStr(p, '.gen.zig')) return 1;
  return 0;
}

function bucketArea(path) {
  var p = normalizeRepoPath(path);
  if (p.indexOf('tsz/compiler/') === 0) return 'compiler';
  if (p.indexOf('tsz/framework/') === 0) return 'framework';
  if (p.indexOf('tsz/carts/conformance/') === 0) return 'conformance';
  if (p.indexOf('tsz/carts/tools/') === 0) return 'tools';
  if (p.indexOf('tsz/carts/') === 0) return 'carts';
  if (p.indexOf('tsz/scripts/') === 0) return 'scripts';
  if (p.indexOf('tsz/docs/') === 0) return 'docs';
  if (p.indexOf('tsz/tests/') === 0) return 'tests';
  if (p.indexOf('tsz/experiments/') === 0) return 'experiments';
  if (p.indexOf('tsz/plans/') === 0 || p.indexOf('tsz/research/') === 0 || p.indexOf('tsz/stb/') === 0 || p.indexOf('tsz/tsz/') === 0 || p.indexOf('tsz/web/') === 0 || p.indexOf('tsz/wgpu_web/') === 0 || p.indexOf('tsz/witnesses/') === 0 || p.indexOf('tsz/screenshots/') === 0) return 'support';
  if (p.indexOf('tsz/') === 0 && p.indexOf('/', 4) < 0) return 'root';
  return 'other';
}

function isBuildableConformancePath(path) {
  var p = normalizeRepoPath(path);
  if (p.indexOf('tsz/carts/conformance/') !== 0) return 0;
  if (isIgnoredPath(p)) return 0;
  if (!endsWithStr(p, '.tsz')) return 0;
  if (endsWithStr(p, '.script.tsz')) return 0;
  if (endsWithStr(p, '.cls.tsz')) return 0;
  if (endsWithStr(p, '.mod.tsz')) return 0;
  if (endsWithStr(p, '.c.tsz')) return 0;
  if (endsWithStr(p, '.effects.tsz')) return 0;
  if (endsWithStr(p, '.glyphs.tsz')) return 0;
  if (endsWithStr(p, '.tcls.tsz')) return 0;
  if (endsWithStr(p, '.vcls.tsz')) return 0;
  if (endsWithStr(p, '.cmod.tsz')) return 0;
  if (endsWithStr(p, '.lscript.tsz')) return 0;
  return 1;
}

function laneFromConformancePath(path) {
  var p = normalizeRepoPath(path);
  var prefix = 'tsz/carts/conformance/';
  var rel = p.indexOf(prefix) === 0 ? p.substring(prefix.length) : p;
  var slash = rel.indexOf('/');
  if (slash < 0) return 'root';
  return rel.substring(0, slash);
}

function conformanceNameFromPath(path) {
  var p = normalizeRepoPath(path);
  var prefix = 'tsz/carts/conformance/';
  var rel = p.indexOf(prefix) === 0 ? p.substring(prefix.length) : p;
  var slash = rel.indexOf('/');
  var rest = slash >= 0 ? rel.substring(slash + 1) : rel;
  if (endsWithStr(rest, '.app.tsz')) rest = rest.substring(0, rest.length - 8);
  else if (endsWithStr(rest, '.tsz')) rest = rest.substring(0, rest.length - 4);
  return rest;
}

function ensureArea(areaMap, name) {
  if (!areaMap[name]) {
    areaMap[name] = {
      name: name,
      color: areaColor(name),
      gitAdds: 0,
      diskNow: 0,
      fresh7d: 0,
      firstGitDay: '',
      lastGitDay: '',
      lastDiskDay: '',
      pct: 0
    };
  }
  return areaMap[name];
}

function ensureLane(laneMap, name) {
  if (!laneMap[name]) {
    laneMap[name] = {
      name: name,
      color: laneColor(name),
      diskTotal: 0,
      seenCurrent: 0,
      compiledCurrent: 0,
      failedCurrent: 0,
      verifiedCurrent: 0,
      testsAdded: 0,
      firstAddDay: '',
      lastAddDay: '',
      compilePct: 0,
      verifyPct: 0,
      untested: 0
    };
  }
  return laneMap[name];
}

function collectConformanceDisk() {
  var tests = [];
  var laneDisk = {};
  try {
    var raw = __exec("cd " + TSZ_DIR + " && find carts/conformance -name \"*.tsz\" ! -name \"*.script.tsz\" ! -name \"*.cls.tsz\" ! -name \"*.mod.tsz\" ! -name \"*.c.tsz\" ! -name \"*.effects.tsz\" ! -name \"*.glyphs.tsz\" ! -name \"*.tcls.tsz\" ! -name \"*.vcls.tsz\" ! -name \"*.cmod.tsz\" ! -name \"*.lscript.tsz\" -type f | sort 2>/dev/null");
    var lines = raw.split('\n');
    var i = 0;
    while (i < lines.length) {
      var path = lines[i].trim();
      if (path.length > 0) {
        var repoPath = normalizeRepoPath(path);
        var lane = laneFromConformancePath(repoPath);
        var name = conformanceNameFromPath(repoPath);
        tests.push({ path: path, repoPath: repoPath, name: name, lane: lane });
        inc(laneDisk, lane);
      }
      i = i + 1;
    }
  } catch (e) {
    console.log('collect conformance disk error: ' + e);
  }
  return { tests: tests, laneDisk: laneDisk };
}

function latestConformanceMapForDb(dbPath, includeFailures) {
  var map = {};
  var latestBuildDay = '';
  var failures = [];
  try {
    var latestRaw = __db_query(dbPath,
      "SELECT b.test_name, b.lane, b.status, substr(b.built_at, 1, 10), COALESCE(v.verified_at, ''), COALESCE(b.source_sha, '') " +
      "FROM builds b " +
      "LEFT JOIN verified_sources v ON v.test_name = b.test_name " +
      "WHERE b.id IN (SELECT MAX(id) FROM builds GROUP BY test_name) " +
      "ORDER BY b.lane, b.test_name;"
    );
    var lines = latestRaw.split('\n');
    var i = 0;
    while (i < lines.length) {
      var line = lines[i];
      if (line.length > 0) {
        var parts = line.split('|');
        if (parts.length > 5) {
          map[parts[0]] = {
            name: parts[0],
            lane: parts[1],
            status: parts[2],
            builtDay: parts[3],
            verified: parts[4],
            sourceSha: parts[5]
          };
          if (parts[3] > latestBuildDay) latestBuildDay = parts[3];
        }
      }
      i = i + 1;
    }

    if (includeFailures) {
      var failRaw = __db_query(dbPath,
        "SELECT test_name, status, substr(error_log, 1, 120) " +
        "FROM builds " +
        "WHERE id IN (SELECT MAX(id) FROM builds GROUP BY test_name) AND status != 'compiled' " +
        "ORDER BY lane, test_name LIMIT 24;"
      );
      var failLines = failRaw.split('\n');
      var f = 0;
      while (f < failLines.length) {
        var failLine = failLines[f];
        if (failLine.length > 0) {
          var fp = failLine.split('|');
          if (fp.length > 1) {
            failures.push({
              name: fp[0],
              status: fp[1],
              error: fp.length > 2 ? fp[2] : ''
            });
          }
        }
        f = f + 1;
      }
    }
  } catch (e) {
    console.log('latest conformance map error (' + dbPath + '): ' + e);
  }
  return { map: map, latestBuildDay: latestBuildDay, failures: failures };
}

function latestConformanceMap() {
  return latestConformanceMapForDb(CONF_DB, 1);
}

function dayField(prefix, name) {
  if (!prefix || prefix.length === 0) return name;
  return prefix + name.substring(0, 1).toUpperCase() + name.substring(1);
}

function loadProgressData(mode) {
  try {
    return __exec('bash ' + shellQuote(TSZ_DIR + '/carts/tools/progress/progress_data.sh') + ' ' + shellQuote(mode) + ' ' + shellQuote(REPO_ROOT) + ' 2>/dev/null');
  } catch (e) {
    console.log('progress data error (' + mode + '): ' + e);
  }
  return '';
}

function summarizeConformanceDb(dbPath, prefix, includeFailures, dayRows, firstDay) {
  var latest = latestConformanceMapForDb(dbPath, includeFailures);
  var latestMap = latest.map;
  var compiledCurrent = 0;
  var failedCurrent = 0;
  var verifiedCurrent = 0;
  var currentSeen = 0;
  var totalTests = 0;
  var buildAttemptCount = 0;
  var rollingByDay = {};
  var deltaByDay = {};

  for (var testName in latestMap) {
    currentSeen = currentSeen + 1;
    var row = latestMap[testName];
    if (row.status === 'compiled') compiledCurrent = compiledCurrent + 1;
    else failedCurrent = failedCurrent + 1;
    if (row.verified && row.verified.length > 0) verifiedCurrent = verifiedCurrent + 1;
  }

  try {
    var totalRaw = __db_query(dbPath,
      "SELECT COUNT(*) FROM (" +
      "SELECT test_name FROM builds " +
      "UNION " +
      "SELECT test_name FROM verified_sources" +
      ");"
    );
    totalTests = parseInt(totalRaw.trim().split('\n')[0], 10) || 0;
  } catch (e0) {
    console.log('db total error (' + dbPath + '): ' + e0);
  }
  if (totalTests <= 0) totalTests = currentSeen;

  var buildAttemptsField = dayField(prefix, 'buildAttempts');
  var buildPassesField = dayField(prefix, 'buildPasses');
  var buildFailsField = dayField(prefix, 'buildFails');
  var compileAddsField = dayField(prefix, 'compileAdds');
  var verifyAddsField = dayField(prefix, 'verifyAdds');

  try {
    var buildRaw = __db_query(dbPath,
      "SELECT substr(built_at, 1, 10), COUNT(*), " +
      "SUM(CASE WHEN status = 'compiled' THEN 1 ELSE 0 END), " +
      "SUM(CASE WHEN status != 'compiled' THEN 1 ELSE 0 END) " +
      "FROM builds GROUP BY substr(built_at, 1, 10) ORDER BY substr(built_at, 1, 10) ASC;"
    );
    var buildLines = buildRaw.split('\n');
    var bi = 0;
    while (bi < buildLines.length) {
      var bl = buildLines[bi];
      if (bl.length > 0) {
        var bp = bl.split('|');
        if (bp.length > 3) {
          var bday = bp[0];
          var attempts = parseInt(bp[1], 10) || 0;
          var passes = parseInt(bp[2], 10) || 0;
          var fails = parseInt(bp[3], 10) || 0;
          if (!firstDay || bday < firstDay) firstDay = bday;
          if (!dayRows[bday]) dayRows[bday] = {};
          inc(dayRows[bday], buildAttemptsField, attempts);
          inc(dayRows[bday], buildPassesField, passes);
          inc(dayRows[bday], buildFailsField, fails);
          buildAttemptCount = buildAttemptCount + attempts;
        }
      }
      bi = bi + 1;
    }
  } catch (e1) {
    console.log('db build history error (' + dbPath + '): ' + e1);
  }

  try {
    var seenRaw = __db_query(dbPath,
      "SELECT first_day, COUNT(*) FROM (" +
      "SELECT test_name, MIN(substr(built_at, 1, 10)) AS first_day FROM builds GROUP BY test_name" +
      ") GROUP BY first_day ORDER BY first_day ASC;"
    );
    var seenLines = seenRaw.split('\n');
    var si = 0;
    while (si < seenLines.length) {
      var sl = seenLines[si];
      if (sl.length > 0) {
        var sp = sl.split('|');
        if (sp.length > 1) {
          var seenDay = sp[0];
          var seenAdds = parseInt(sp[1], 10) || 0;
          if (!firstDay || seenDay < firstDay) firstDay = seenDay;
          if (!deltaByDay[seenDay]) deltaByDay[seenDay] = {};
          inc(deltaByDay[seenDay], 'seenDelta', seenAdds);
        }
      }
      si = si + 1;
    }
  } catch (e2) {
    console.log('db seen history error (' + dbPath + '): ' + e2);
  }

  try {
    var passDeltaRaw = __db_query(dbPath,
      "WITH ordered AS (" +
      "SELECT test_name, substr(built_at, 1, 10) AS day, status, " +
      "LAG(status) OVER (PARTITION BY test_name ORDER BY id ASC) AS prev_status " +
      "FROM builds" +
      "), deltas AS (" +
      "SELECT day, SUM(CASE " +
      "WHEN status = 'compiled' AND (prev_status IS NULL OR prev_status != 'compiled') THEN 1 " +
      "WHEN status != 'compiled' AND prev_status = 'compiled' THEN -1 " +
      "ELSE 0 END) AS passing_delta " +
      "FROM ordered GROUP BY day" +
      ") SELECT day, COALESCE(passing_delta, 0) FROM deltas ORDER BY day ASC;"
    );
    var passLines = passDeltaRaw.split('\n');
    var pi = 0;
    while (pi < passLines.length) {
      var pl = passLines[pi];
      if (pl.length > 0) {
        var pp = pl.split('|');
        if (pp.length > 1) {
          var passDay = pp[0];
          var passDelta = parseInt(pp[1], 10) || 0;
          if (!firstDay || passDay < firstDay) firstDay = passDay;
          if (!deltaByDay[passDay]) deltaByDay[passDay] = {};
          inc(deltaByDay[passDay], 'passingDelta', passDelta);
        }
      }
      pi = pi + 1;
    }
  } catch (e3) {
    console.log('db passing history error (' + dbPath + '): ' + e3);
  }

  try {
    var compileRaw = __db_query(dbPath,
      "SELECT first_day, COUNT(*) FROM (" +
      "SELECT test_name, MIN(substr(built_at, 1, 10)) AS first_day FROM builds WHERE status = 'compiled' GROUP BY test_name" +
      ") GROUP BY first_day ORDER BY first_day ASC;"
    );
    var compileLines = compileRaw.split('\n');
    var ci = 0;
    while (ci < compileLines.length) {
      var cl = compileLines[ci];
      if (cl.length > 0) {
        var cp = cl.split('|');
        if (cp.length > 1) {
          var compileDay = cp[0];
          var compileAdds = parseInt(cp[1], 10) || 0;
          if (!firstDay || compileDay < firstDay) firstDay = compileDay;
          if (!dayRows[compileDay]) dayRows[compileDay] = {};
          inc(dayRows[compileDay], compileAddsField, compileAdds);
        }
      }
      ci = ci + 1;
    }
  } catch (e4) {
    console.log('db first compile history error (' + dbPath + '): ' + e4);
  }

  try {
    var verifyRaw = __db_query(dbPath,
      "SELECT substr(verified_at, 1, 10), COUNT(*) FROM verified_sources GROUP BY substr(verified_at, 1, 10) ORDER BY substr(verified_at, 1, 10) ASC;"
    );
    var verifyLines = verifyRaw.split('\n');
    var vi = 0;
    while (vi < verifyLines.length) {
      var vl = verifyLines[vi];
      if (vl.length > 0) {
        var vp = vl.split('|');
        var vday = vp[0];
        var verifyAdds = vp.length > 1 ? (parseInt(vp[1], 10) || 0) : 0;
        if (vday && vday.length > 0) {
          if (!firstDay || vday < firstDay) firstDay = vday;
          if (!dayRows[vday]) dayRows[vday] = {};
          inc(dayRows[vday], verifyAddsField, verifyAdds);
        }
      }
      vi = vi + 1;
    }
  } catch (e5) {
    console.log('db verify history error (' + dbPath + '): ' + e5);
  }

  var deltaDays = [];
  for (var deltaDay in deltaByDay) deltaDays.push(deltaDay);
  deltaDays.sort();
  var carryPassing = 0;
  var carrySeen = 0;
  var di = 0;
  while (di < deltaDays.length) {
    var day = deltaDays[di];
    var delta = deltaByDay[day];
    carrySeen = carrySeen + (delta.seenDelta || 0);
    carryPassing = carryPassing + (delta.passingDelta || 0);
    rollingByDay[day] = { currentPassing: carryPassing, currentSeen: carrySeen };
    di = di + 1;
  }

  return {
    firstDay: firstDay,
    map: latestMap,
    latestBuildDay: latest.latestBuildDay,
    failures: latest.failures,
    currentSeen: currentSeen,
    compiledCurrent: compiledCurrent,
    failedCurrent: failedCurrent,
    verifiedCurrent: verifiedCurrent,
    totalTests: totalTests,
    buildAttemptCount: buildAttemptCount,
    rollingByDay: rollingByDay
  };
}

function loadLineageMeta(dayRows, firstDay) {
  var stats = {
    firstDay: firstDay,
    engineHashCount: 0,
    engineBlessCount: 0,
    compilerHashCount: 0,
    compilerBlessCount: 0,
    v4EngineHashCount: 0,
    v4EngineBlessCount: 0
  };

  try {
    var engineRaw = __db_query(CONF_DB,
      "SELECT substr(built_at, 1, 10), COALESCE(substr(blessed_at, 1, 10), '') FROM engine_builds ORDER BY built_at ASC, id ASC;"
    );
    var engineLines = engineRaw.split('\n');
    var ei = 0;
    while (ei < engineLines.length) {
      var el = engineLines[ei];
      if (el.length > 0) {
        var ep = el.split('|');
        var buildDay = ep.length > 0 ? ep[0] : '';
        var blessDay = ep.length > 1 ? ep[1] : '';
        if (buildDay && buildDay.length > 0) {
          if (!stats.firstDay || buildDay < stats.firstDay) stats.firstDay = buildDay;
          if (!dayRows[buildDay]) dayRows[buildDay] = {};
          inc(dayRows[buildDay], 'engineHashChanges');
          stats.engineHashCount = stats.engineHashCount + 1;
        }
        if (blessDay && blessDay.length > 0) {
          if (!stats.firstDay || blessDay < stats.firstDay) stats.firstDay = blessDay;
          if (!dayRows[blessDay]) dayRows[blessDay] = {};
          inc(dayRows[blessDay], 'engineBlessings');
          stats.engineBlessCount = stats.engineBlessCount + 1;
        }
      }
      ei = ei + 1;
    }
  } catch (e1) {
    console.log('engine lineage error: ' + e1);
  }

  try {
    var compilerRaw = __db_query(CONF_DB,
      "SELECT substr(built_at, 1, 10), COALESCE(substr(blessed_at, 1, 10), '') FROM compiler_builds ORDER BY built_at ASC, id ASC;"
    );
    var compilerLines = compilerRaw.split('\n');
    var ci = 0;
    while (ci < compilerLines.length) {
      var cl = compilerLines[ci];
      if (cl.length > 0) {
        var cp = cl.split('|');
        var compilerBuildDay = cp.length > 0 ? cp[0] : '';
        var compilerBlessDay = cp.length > 1 ? cp[1] : '';
        if (compilerBuildDay && compilerBuildDay.length > 0) {
          if (!stats.firstDay || compilerBuildDay < stats.firstDay) stats.firstDay = compilerBuildDay;
          if (!dayRows[compilerBuildDay]) dayRows[compilerBuildDay] = {};
          inc(dayRows[compilerBuildDay], 'compilerHashChanges');
          stats.compilerHashCount = stats.compilerHashCount + 1;
        }
        if (compilerBlessDay && compilerBlessDay.length > 0) {
          if (!stats.firstDay || compilerBlessDay < stats.firstDay) stats.firstDay = compilerBlessDay;
          if (!dayRows[compilerBlessDay]) dayRows[compilerBlessDay] = {};
          inc(dayRows[compilerBlessDay], 'compilerBlessings');
          stats.compilerBlessCount = stats.compilerBlessCount + 1;
        }
      }
      ci = ci + 1;
    }
  } catch (e2) {
    console.log('compiler lineage error: ' + e2);
  }

  try {
    var v4EngineRaw = __db_query(CONF_V4_DB,
      "SELECT substr(built_at, 1, 10), COALESCE(substr(blessed_at, 1, 10), '') FROM engine_builds ORDER BY built_at ASC, id ASC;"
    );
    var v4EngineLines = v4EngineRaw.split('\n');
    var vi = 0;
    while (vi < v4EngineLines.length) {
      var vl = v4EngineLines[vi];
      if (vl.length > 0) {
        var vp = vl.split('|');
        var v4BuildDay = vp.length > 0 ? vp[0] : '';
        var v4BlessDay = vp.length > 1 ? vp[1] : '';
        if (v4BuildDay && v4BuildDay.length > 0) {
          if (!stats.firstDay || v4BuildDay < stats.firstDay) stats.firstDay = v4BuildDay;
          if (!dayRows[v4BuildDay]) dayRows[v4BuildDay] = {};
          inc(dayRows[v4BuildDay], 'v4EngineHashChanges');
          stats.v4EngineHashCount = stats.v4EngineHashCount + 1;
        }
        if (v4BlessDay && v4BlessDay.length > 0) {
          if (!stats.firstDay || v4BlessDay < stats.firstDay) stats.firstDay = v4BlessDay;
          if (!dayRows[v4BlessDay]) dayRows[v4BlessDay] = {};
          inc(dayRows[v4BlessDay], 'v4EngineBlessings');
          stats.v4EngineBlessCount = stats.v4EngineBlessCount + 1;
        }
      }
      vi = vi + 1;
    }
  } catch (e3) {
    console.log('v4 engine lineage error: ' + e3);
  }

  return stats;
}

function loadProgressMeta() {
  try {
    var dayRows = {};
    var recent = [];
    var areaMap = {};
    var laneMap = {};
    var totalCommits = 0;
    var gitBornCount = 0;
    var repoFileCount = 0;
    var fresh7dCount = 0;
    var firstDay = '';
    var freshFiles = [];
    var freshCutoff = Math.floor(Date.now() / 1000) - (7 * 24 * 60 * 60);

    var commitRaw = loadProgressData('commits');
    var commitLines = commitRaw.split('\n');
    var ci = 0;
    while (ci < commitLines.length) {
      var cl = commitLines[ci];
      if (cl.length > 0) {
        var cp = cl.split('\t');
        if (cp[0] === 'DAY' && cp.length > 2) {
          var cday = cp[1];
          var ccount = parseInt(cp[2], 10) || 0;
          if (!firstDay || cday < firstDay) firstDay = cday;
          if (!dayRows[cday]) dayRows[cday] = {};
          inc(dayRows[cday], 'commitCount', ccount);
        } else if (cp[0] === 'FIRST' && cp.length > 1) {
          if (!firstDay || cp[1] < firstDay) firstDay = cp[1];
        } else if (cp[0] === 'TOTAL' && cp.length > 1) {
          totalCommits = parseInt(cp[1], 10) || 0;
        } else if (cp[0] === 'RECENT' && cp.length > 4) {
          var ctype = parseCommitType(cp[4]);
          recent.push({
            hash: cp[1],
            day: cp[2],
            shortDay: shortDay(cp[2]),
            author: cp[3],
            msg: cp[4],
            metaText: cp[3] + ' | ' + shortDay(cp[2]),
            ctype: ctype,
            dotColor: typeColor(ctype),
            badgeBg: typeBadgeBg(ctype)
          });
        }
      }
      ci = ci + 1;
    }

    var addRaw = loadProgressData('adds');
    var addLines = addRaw.split('\n');
    var ai = 0;
    while (ai < addLines.length) {
      var al = addLines[ai];
      if (al.length > 0) {
        var ap = al.split('\t');
        if (ap[0] === 'DAY' && ap.length > 3) {
          var addDay = ap[1];
          if (!firstDay || addDay < firstDay) firstDay = addDay;
          if (!dayRows[addDay]) dayRows[addDay] = {};
          inc(dayRows[addDay], 'fileAdds', parseInt(ap[2], 10) || 0);
          inc(dayRows[addDay], 'conformanceAdds', parseInt(ap[3], 10) || 0);
        } else if (ap[0] === 'TOTAL' && ap.length > 1) {
          gitBornCount = parseInt(ap[1], 10) || 0;
        } else if (ap[0] === 'AREA' && ap.length > 4) {
          var areaRow = ensureArea(areaMap, ap[1]);
          areaRow.gitAdds = parseInt(ap[2], 10) || 0;
          areaRow.firstGitDay = ap[3] && ap[3].length > 0 ? ap[3] : areaRow.firstGitDay;
          areaRow.lastGitDay = ap[4] && ap[4].length > 0 ? ap[4] : areaRow.lastGitDay;
        } else if (ap[0] === 'LANE' && ap.length > 4) {
          var laneRow = ensureLane(laneMap, ap[1]);
          laneRow.testsAdded = parseInt(ap[2], 10) || 0;
          laneRow.firstAddDay = ap[3] && ap[3].length > 0 ? ap[3] : laneRow.firstAddDay;
          laneRow.lastAddDay = ap[4] && ap[4].length > 0 ? ap[4] : laneRow.lastAddDay;
        }
      }
      ai = ai + 1;
    }

    var diskRaw = loadProgressData('disk');
    var diskLines = diskRaw.split('\n');
    var si = 0;
    while (si < diskLines.length) {
      var sl = diskLines[si];
      if (sl.length > 0) {
        var sp = sl.split('\t');
        if (sp[0] === 'TOTAL' && sp.length > 1) {
          repoFileCount = parseInt(sp[1], 10) || 0;
        } else if (sp[0] === 'FRESH' && sp.length > 1) {
          fresh7dCount = parseInt(sp[1], 10) || 0;
        } else if (sp[0] === 'AREA' && sp.length > 4) {
          var areaDiskRow = ensureArea(areaMap, sp[1]);
          areaDiskRow.diskNow = parseInt(sp[2], 10) || 0;
          areaDiskRow.fresh7d = parseInt(sp[3], 10) || 0;
          areaDiskRow.lastDiskDay = sp[4] && sp[4].length > 0 ? sp[4] : areaDiskRow.lastDiskDay;
        } else if (sp[0] === 'FILE' && sp.length > 4) {
          freshFiles.push({
            area: sp[1],
            color: areaColor(sp[1]),
            day: sp[2],
            epoch: parseInt(sp[3], 10) || 0,
            path: normalizeRepoPath(sp[4]).substring(4),
            metaText: sp[1] + ' | ' + sp[2]
          });
        }
      }
      si = si + 1;
    }
    freshFiles.sort(function(a, b) { return b.epoch - a.epoch; });
    if (freshFiles.length > 14) freshFiles = freshFiles.slice(0, 14);

    var disk = collectConformanceDisk();
    var currentSummary = summarizeConformanceDb(CONF_DB, '', 1, dayRows, firstDay);
    firstDay = currentSummary.firstDay;
    var latestMap = currentSummary.map;
    var compiledCurrent = currentSummary.compiledCurrent;
    var failedCurrent = currentSummary.failedCurrent;
    var verifiedCurrent = currentSummary.verifiedCurrent;
    var currentSeen = currentSummary.currentSeen;
    var lt = currentSummary.latestBuildDay;

    var v4Summary = summarizeConformanceDb(CONF_V4_DB, 'v4', 0, dayRows, firstDay);
    firstDay = v4Summary.firstDay;

    var lineage = loadLineageMeta(dayRows, firstDay);
    firstDay = lineage.firstDay;

    // Witness replay stats per day
    var witnessTotal = 0;
    var witnessPassTotal = 0;
    try {
      var witnessRaw = __db_query(CONF_DB,
        "SELECT substr(replayed_at,1,10), COUNT(*), " +
        "SUM(CASE WHEN status='pass' THEN 1 ELSE 0 END), " +
        "SUM(CASE WHEN status='fail' THEN 1 ELSE 0 END), " +
        "SUM(CASE WHEN status='crash' THEN 1 ELSE 0 END) " +
        "FROM witness_replays GROUP BY substr(replayed_at,1,10) ORDER BY substr(replayed_at,1,10) ASC;"
      );
      var witnessLines = witnessRaw.split('\n');
      var wi = 0;
      while (wi < witnessLines.length) {
        var wl = witnessLines[wi];
        if (wl.length > 0) {
          var wp = wl.split('|');
          if (wp.length > 4) {
            var wday = wp[0];
            var wcount = parseInt(wp[1], 10) || 0;
            var wpass = parseInt(wp[2], 10) || 0;
            var wfail = parseInt(wp[3], 10) || 0;
            var wcrash = parseInt(wp[4], 10) || 0;
            if (!firstDay || wday < firstDay) firstDay = wday;
            if (!dayRows[wday]) dayRows[wday] = {};
            inc(dayRows[wday], 'witnessReplays', wcount);
            inc(dayRows[wday], 'witnessPass', wpass);
            inc(dayRows[wday], 'witnessFail', wfail);
            inc(dayRows[wday], 'witnessCrash', wcrash);
            witnessTotal = witnessTotal + wcount;
            witnessPassTotal = witnessPassTotal + wpass;
          }
        }
        wi = wi + 1;
      }
    } catch (ew) {
      console.log('witness replay error: ' + ew);
    }

    // Per-day build perf averages
    try {
      var perfDayRaw = __db_query(CONF_DB,
        "SELECT substr(built_at,1,10), ROUND(AVG(total_ms)), ROUND(AVG(forge_ms)), " +
        "ROUND(AVG(zig_ms)), COUNT(*) " +
        "FROM build_perf GROUP BY substr(built_at,1,10) ORDER BY substr(built_at,1,10) ASC;"
      );
      var perfDayLines = perfDayRaw.split('\n');
      var pdi = 0;
      while (pdi < perfDayLines.length) {
        var pdl = perfDayLines[pdi];
        if (pdl.length > 0) {
          var pdp = pdl.split('|');
          if (pdp.length > 4) {
            var pday = pdp[0];
            if (!firstDay || pday < firstDay) firstDay = pday;
            if (!dayRows[pday]) dayRows[pday] = {};
            inc(dayRows[pday], 'perfAvgMs', parseInt(pdp[1], 10) || 0);
            inc(dayRows[pday], 'perfForgeMs', parseInt(pdp[2], 10) || 0);
            inc(dayRows[pday], 'perfZigMs', parseInt(pdp[3], 10) || 0);
            inc(dayRows[pday], 'perfSamples', parseInt(pdp[4], 10) || 0);
          }
        }
        pdi = pdi + 1;
      }
    } catch (ep) {
      console.log('perf per day error: ' + ep);
    }

    // Hourly activity heatmap
    var hourlyActivity = [];
    try {
      var hourlyRaw = __db_query(CONF_DB,
        "SELECT CAST(substr(built_at,12,2) AS INTEGER) as hr, COUNT(*) " +
        "FROM builds GROUP BY hr ORDER BY hr;"
      );
      var hourlyLines = hourlyRaw.split('\n');
      var maxHourly = 1;
      var hourMap = {};
      var hi = 0;
      while (hi < hourlyLines.length) {
        var hl = hourlyLines[hi];
        if (hl.length > 0) {
          var hp = hl.split('|');
          if (hp.length > 1) {
            var hour = parseInt(hp[0], 10) || 0;
            var hcount = parseInt(hp[1], 10) || 0;
            hourMap[hour] = hcount;
            if (hcount > maxHourly) maxHourly = hcount;
          }
        }
        hi = hi + 1;
      }
      var hh = 0;
      while (hh < 24) {
        var hval = hourMap[hh] || 0;
        hourlyActivity.push({ hour: hh, count: hval, color: tone(hval, maxHourly, '#e8eaf0', '#a7c8ff', '#5796f5', '#1146c7') });
        hh = hh + 1;
      }
    } catch (eh) {
      console.log('hourly activity error: ' + eh);
    }

    for (var testName in latestMap) {
      var row = latestMap[testName];
      var laneCell = ensureLane(laneMap, row.lane);
      laneCell.seenCurrent = laneCell.seenCurrent + 1;
      if (row.status === 'compiled') laneCell.compiledCurrent = laneCell.compiledCurrent + 1;
      else laneCell.failedCurrent = laneCell.failedCurrent + 1;
      if (row.verified && row.verified.length > 0) laneCell.verifiedCurrent = laneCell.verifiedCurrent + 1;
    }

    for (var laneName in disk.laneDisk) {
      var laneDiskRow = ensureLane(laneMap, laneName);
      laneDiskRow.diskTotal = disk.laneDisk[laneName];
    }

    var buildAttemptCount = currentSummary.buildAttemptCount;
    var rollingByDay = currentSummary.rollingByDay;
    var verifyCumulative = 0;
    var v4BuildAttemptCount = v4Summary.buildAttemptCount;
    var v4RollingByDay = v4Summary.rollingByDay;
    var v4CarryPassing = 0;
    var v4CarrySeen = 0;
    var v4VerifyCumulative = 0;

    if (!firstDay) firstDay = dayKeyToday();
    var endDay = dayKeyToday();
    var timeline = [];
    var cursor = firstDay;
    var cumulativeFiles = 0;
    var cumulativeConformance = 0;
    var carryPassing = 0;
    var carrySeen = 0;

    while (cursor <= endDay) {
      var src = dayRows[cursor] || {};
      cumulativeFiles = cumulativeFiles + (src.fileAdds || 0);
      cumulativeConformance = cumulativeConformance + (src.conformanceAdds || 0);
      verifyCumulative = verifyCumulative + (src.verifyAdds || 0);
      v4VerifyCumulative = v4VerifyCumulative + (src.v4VerifyAdds || 0);

      if (rollingByDay[cursor]) {
        carryPassing = rollingByDay[cursor].currentPassing;
        carrySeen = rollingByDay[cursor].currentSeen;
      }
      if (v4RollingByDay[cursor]) {
        v4CarryPassing = v4RollingByDay[cursor].currentPassing;
        v4CarrySeen = v4RollingByDay[cursor].currentSeen;
      }

      timeline.push({
        day: cursor,
        shortDay: shortDay(cursor),
        commitCount: src.commitCount || 0,
        fileAdds: src.fileAdds || 0,
        conformanceAdds: src.conformanceAdds || 0,
        compileAdds: src.compileAdds || 0,
        verifyAdds: src.verifyAdds || 0,
        buildAttempts: src.buildAttempts || 0,
        buildPasses: src.buildPasses || 0,
        buildFails: src.buildFails || 0,
        v4BuildAttempts: src.v4BuildAttempts || 0,
        v4BuildPasses: src.v4BuildPasses || 0,
        v4BuildFails: src.v4BuildFails || 0,
        engineHashChanges: src.engineHashChanges || 0,
        engineBlessings: src.engineBlessings || 0,
        compilerHashChanges: src.compilerHashChanges || 0,
        compilerBlessings: src.compilerBlessings || 0,
        v4EngineHashChanges: src.v4EngineHashChanges || 0,
        v4EngineBlessings: src.v4EngineBlessings || 0,
        totalFiles: cumulativeFiles,
        totalConformance: cumulativeConformance,
        currentPassing: carryPassing,
        currentSeen: carrySeen,
        currentVerified: verifyCumulative,
        v4CurrentPassing: v4CarryPassing,
        v4CurrentSeen: v4CarrySeen,
        v4CurrentVerified: v4VerifyCumulative,
        witnessReplays: src.witnessReplays || 0,
        witnessPass: src.witnessPass || 0,
        witnessFail: src.witnessFail || 0,
        witnessCrash: src.witnessCrash || 0,
        perfAvgMs: src.perfAvgMs || 0,
        perfSamples: src.perfSamples || 0
      });

      cursor = nextDay(cursor);
    }

    var areaRows = [];
    var maxAreaFiles = 1;
    for (var areaKey in areaMap) {
      if (areaMap[areaKey].diskNow > maxAreaFiles) maxAreaFiles = areaMap[areaKey].diskNow;
    }
    for (var areaName2 in areaMap) {
      var areaOut = areaMap[areaName2];
      areaOut.pct = maxAreaFiles > 0 ? Math.round((areaOut.diskNow * 100) / maxAreaFiles) : 0;
      areaOut.restPct = areaOut.pct < 100 ? (100 - areaOut.pct) : 0;
      if (!areaOut.firstGitDay || areaOut.firstGitDay.length === 0) areaOut.firstGitDay = '--';
      if (!areaOut.lastGitDay || areaOut.lastGitDay.length === 0) areaOut.lastGitDay = '--';
      if (!areaOut.lastDiskDay || areaOut.lastDiskDay.length === 0) areaOut.lastDiskDay = '--';
      areaOut.gitText = 'git +' + areaOut.gitAdds;
      areaOut.freshText = '7d ' + areaOut.fresh7d;
      areaOut.firstText = 'first ' + areaOut.firstGitDay;
      areaOut.lastGitText = 'last git ' + areaOut.lastGitDay;
      areaOut.lastDiskText = 'last disk ' + areaOut.lastDiskDay;
      areaRows.push(areaOut);
    }
    areaRows.sort(function(a, b) {
      if (b.diskNow !== a.diskNow) return b.diskNow - a.diskNow;
      return a.name < b.name ? -1 : 1;
    });

    var laneRows = [];
    for (var laneName2 in laneMap) {
      var laneOut = laneMap[laneName2];
      laneOut.untested = laneOut.diskTotal - laneOut.seenCurrent;
      if (laneOut.untested < 0) laneOut.untested = 0;
      laneOut.compilePct = laneOut.diskTotal > 0 ? Math.round((laneOut.compiledCurrent * 100) / laneOut.diskTotal) : 0;
      laneOut.verifyPct = laneOut.diskTotal > 0 ? Math.round((laneOut.verifiedCurrent * 100) / laneOut.diskTotal) : 0;
      laneOut.restPct = laneOut.compilePct < 100 ? (100 - laneOut.compilePct) : 0;
      if (!laneOut.firstAddDay || laneOut.firstAddDay.length === 0) laneOut.firstAddDay = '--';
      laneOut.diskText = laneOut.diskTotal + ' disk';
      laneOut.addedText = 'added ' + laneOut.firstAddDay;
      laneOut.compileText = laneOut.compilePct + '% compile';
      laneOut.verifyText = laneOut.verifyPct + '% verify';
      laneRows.push(laneOut);
    }
    laneRows.sort(function(a, b) {
      if (b.diskTotal !== a.diskTotal) return b.diskTotal - a.diskTotal;
      return a.name < b.name ? -1 : 1;
    });

    setTimelineDays(timeline);
    setTimelineCount(timeline.length);
    setProjectStartDay(firstDay);
    setProjectEndDay(endDay);
    setCommitCount(totalCommits);
    setRecentCommits(recent);
    setRepoFileCount(repoFileCount);
    setGitBornCount(gitBornCount);
    setActiveDays(timeline.length);
    setFresh7dCount(fresh7dCount);
    setAreaRows(areaRows);
    setAreaCount(areaRows.length);
    setLaneRows(laneRows);
    setLaneCount(laneRows.length);
    setFreshFiles(freshFiles);
    setFreshFileCount(freshFiles.length);
    setConfCompiled(compiledCurrent);
    setConfFailed(failedCurrent);
    setConfVerified(verifiedCurrent);
    setConfTotal(disk.tests.length);
    setConfUntested(disk.tests.length - currentSeen > 0 ? (disk.tests.length - currentSeen) : 0);
    setConfPassRate(disk.tests.length > 0 ? Math.round((compiledCurrent * 100) / disk.tests.length) : 0);
    setConfFailures(currentSummary.failures);
    setConfFailureCount(currentSummary.failures.length);
    setCompileBacklog(disk.tests.length - compiledCurrent > 0 ? (disk.tests.length - compiledCurrent) : 0);
    setVerifyBacklog(compiledCurrent - verifiedCurrent > 0 ? (compiledCurrent - verifiedCurrent) : 0);
    setCurrentSeen(currentSeen);
    setBuildAttemptCount(buildAttemptCount);
    setLatestBuildDay(lt && lt.length > 0 ? lt : '--');
    setV4Compiled(v4Summary.compiledCurrent);
    setV4Failed(v4Summary.failedCurrent);
    setV4Verified(v4Summary.verifiedCurrent);
    setV4Total(v4Summary.totalTests);
    setV4PassRate(v4Summary.totalTests > 0 ? Math.round((v4Summary.compiledCurrent * 100) / v4Summary.totalTests) : 0);
    setV4BuildAttemptCount(v4BuildAttemptCount);
    setV4LatestBuildDay(v4Summary.latestBuildDay && v4Summary.latestBuildDay.length > 0 ? v4Summary.latestBuildDay : '--');
    setEngineHashCount(lineage.engineHashCount);
    setEngineBlessCount(lineage.engineBlessCount);
    setCompilerHashCount(lineage.compilerHashCount);
    setCompilerBlessCount(lineage.compilerBlessCount);
    setV4EngineHashCount(lineage.v4EngineHashCount);
    setV4EngineBlessCount(lineage.v4EngineBlessCount);
    setWitnessTotal(witnessTotal);
    setWitnessPassRate(witnessTotal > 0 ? Math.round((witnessPassTotal * 100) / witnessTotal) : 0);
    setHourlyActivity(hourlyActivity);
    setHourlyActivityCount(hourlyActivity.length);
  } catch (e) {
    console.log('progress meta error: ' + e);
  }
}

function loadTestList() {
  try {
    var disk = collectConformanceDisk();
    var latest = latestConformanceMap().map;
    var keepName = selTestName;
    var tests = [];
    var i = 0;
    while (i < disk.tests.length) {
      var base = disk.tests[i];
      var latestRow = latest[base.name];
      var status = latestRow ? latestRow.status : 'untested';
      var verified = latestRow ? latestRow.verified : '';
      var builtDay = latestRow && latestRow.builtDay && latestRow.builtDay.length > 0 ? latestRow.builtDay : '--';
      var sourceSha = latestRow && latestRow.sourceSha && latestRow.sourceSha.length > 0 ? latestRow.sourceSha : '--';
      var priority = 3;
      var dotColor = '#475569';
      var displayStatus = 'untested';
      var statusColor = '#94a3b8';
      var isError = 0;

      if (verified && verified.length > 0) {
        priority = 4;
        dotColor = '#60a5fa';
        displayStatus = 'verified';
        statusColor = '#60a5fa';
      } else if (status === 'compiled') {
        priority = 0;
        dotColor = '#34d399';
        displayStatus = 'compiled';
        statusColor = '#34d399';
      } else if (status === 'untested') {
        priority = 2;
        dotColor = '#94a3b8';
        displayStatus = 'untested';
        statusColor = '#94a3b8';
      } else {
        priority = 1;
        dotColor = '#f87171';
        displayStatus = status;
        statusColor = '#f87171';
        isError = 1;
      }

      tests.push({
        tidx: 0,
        path: base.path,
        repoPath: base.repoPath,
        name: base.name,
        lane: base.lane,
        builtMeta: base.lane + ' | ' + builtDay,
        status: status,
        displayStatus: displayStatus,
        statusColor: statusColor,
        isError: isError,
        verified: verified,
        builtDay: builtDay,
        sourceSha: sourceSha,
        priority: priority,
        dotColor: dotColor
      });
      i = i + 1;
    }

    tests.sort(function(a, b) {
      if (a.priority !== b.priority) return a.priority - b.priority;
      if (a.lane !== b.lane) return a.lane < b.lane ? -1 : 1;
      return a.name < b.name ? -1 : 1;
    });

    var t = 0;
    while (t < tests.length) {
      tests[t].tidx = t;
      t = t + 1;
    }

    setTestList(tests);
    setTestCount(tests.length);

    var focus = 0;
    if (keepName && keepName.length > 0) {
      var k = 0;
      while (k < tests.length) {
        if (tests[k].name === keepName) {
          focus = k;
          break;
        }
        k = k + 1;
      }
    }

    if (tests.length > 0) {
      var picked = tests[focus];
      setSelectedTest(focus);
      setSelTestName(picked.name);
      setSelTestLane(picked.lane);
      setSelTestStatus(picked.status);
      setSelTestDisplayStatus(picked.displayStatus);
      setSelTestDisplayColor(picked.statusColor);
      setSelTestIsError(picked.isError);
      setSelTestVerified(picked.verified);
      setSelTestBuiltDay(picked.builtDay);
      setSelTestSourceSha(picked.sourceSha);
      setSelTestHasVerified(picked.verified.length > 0 ? 1 : 0);
    } else {
      setSelectedTest(0);
      setSelTestName('--');
      setSelTestLane('--');
      setSelTestStatus('untested');
      setSelTestDisplayStatus('untested');
      setSelTestDisplayColor('#94a3b8');
      setSelTestIsError(0);
      setSelTestVerified('');
      setSelTestBuiltDay('--');
      setSelTestSourceSha('--');
      setSelTestHasVerified(0);
    }
  } catch (e) {
    console.log('test list error: ' + e);
  }
}

function loadPerfData() {
  try {
    var laneAvgRaw = __db_query(CONF_DB,
      "SELECT lane, ROUND(AVG(total_ms)), ROUND(AVG(forge_ms)), ROUND(AVG(zig_ms)), ROUND(AVG(lines_per_sec), 1), ROUND(AVG(bytes_per_line), 1), COUNT(*) " +
      "FROM build_perf GROUP BY lane ORDER BY AVG(total_ms) DESC;"
    );
    var laneLines = laneAvgRaw.split('\n');
    var perfLaneRows = [];
    var perfMax = 1;
    var li = 0;
    while (li < laneLines.length) {
      var laneLine = laneLines[li];
      if (laneLine.length > 0) {
        var lp = laneLine.split('|');
        if (lp.length > 6) {
          var laneAvgMs = parseInt(lp[1], 10) || 0;
          if (laneAvgMs > perfMax) perfMax = laneAvgMs;
          perfLaneRows.push({
            name: lp[0],
            avgMs: laneAvgMs,
            avgForge: parseInt(lp[2], 10) || 0,
            avgZig: parseInt(lp[3], 10) || 0,
            avgLps: parseFloat(lp[4]) || 0,
            avgBpl: parseFloat(lp[5]) || 0,
            buildCount: parseInt(lp[6], 10) || 0,
            avgText: laneAvgMs + 'ms',
            forgeText: 'forge ' + (parseInt(lp[2], 10) || 0),
            zigText: 'zig ' + (parseInt(lp[3], 10) || 0),
            lpsText: (parseFloat(lp[4]) || 0) + ' l/s',
            color: laneColor(lp[0])
          });
        }
      }
      li = li + 1;
    }
    var p = 0;
    while (p < perfLaneRows.length) {
      var fillPct = perfMax > 0 ? Math.round((perfLaneRows[p].avgMs * 100) / perfMax) : 0;
      perfLaneRows[p].fillPct = fillPct;
      perfLaneRows[p].restPct = fillPct < 100 ? (100 - fillPct) : 0;
      p = p + 1;
    }
    setPerfLanes(perfLaneRows);
    setPerfLaneCount(perfLaneRows.length);

    var overallRaw = __db_query(CONF_DB,
      "SELECT ROUND(AVG(total_ms)), ROUND(AVG(forge_ms)), ROUND(AVG(zig_ms)), ROUND(AVG(lines_per_sec), 1), ROUND(AVG(bytes_per_line), 1), COUNT(*), ROUND(AVG(source_lines)), ROUND(AVG(generated_bytes)) FROM build_perf;"
    );
    var ov = overallRaw.trim().split('|');
    if (ov.length > 7) {
      setPerfAvgTotal(parseInt(ov[0], 10) || 0);
      setPerfAvgForge(parseInt(ov[1], 10) || 0);
      setPerfAvgZig(parseInt(ov[2], 10) || 0);
      setPerfAvgLps(parseFloat(ov[3]) || 0);
      setPerfAvgBpl(parseFloat(ov[4]) || 0);
      setPerfBuildCount(parseInt(ov[5], 10) || 0);
      setPerfAvgLines(parseInt(ov[6], 10) || 0);
      setPerfAvgBytes(parseInt(ov[7], 10) || 0);
    }

    var slowRaw = __db_query(CONF_DB,
      "SELECT test_name, lane, total_ms, forge_ms, zig_ms, source_lines, lines_per_sec FROM build_perf ORDER BY total_ms DESC LIMIT 8;"
    );
    var slowLines = slowRaw.split('\n');
    var slowBuilds = [];
    var si = 0;
    while (si < slowLines.length) {
      var sl = slowLines[si];
      if (sl.length > 0) {
        var sp = sl.split('|');
        if (sp.length > 6) {
          slowBuilds.push({
            name: sp[0],
            lane: sp[1],
            totalMs: parseInt(sp[2], 10) || 0,
            forgeMs: parseInt(sp[3], 10) || 0,
            zigMs: parseInt(sp[4], 10) || 0,
            lines: parseInt(sp[5], 10) || 0,
            lps: parseFloat(sp[6]) || 0
          });
        }
      }
      si = si + 1;
    }
    setPerfSlowest(slowBuilds);
    setPerfSlowestCount(slowBuilds.length);

    var bigRaw = __db_query(CONF_DB,
      "SELECT test_name, lane, source_lines, generated_bytes, bytes_per_line FROM build_perf ORDER BY source_lines DESC LIMIT 8;"
    );
    var bigLines = bigRaw.split('\n');
    var bigSources = [];
    var bi = 0;
    while (bi < bigLines.length) {
      var bl = bigLines[bi];
      if (bl.length > 0) {
        var bp = bl.split('|');
        if (bp.length > 4) {
          bigSources.push({
            name: bp[0],
            lane: bp[1],
            lines: parseInt(bp[2], 10) || 0,
            bytes: parseInt(bp[3], 10) || 0,
            bpl: parseFloat(bp[4]) || 0
          });
        }
      }
      bi = bi + 1;
    }
    setPerfLargest(bigSources);
    setPerfLargestCount(bigSources.length);
  } catch (e) {
    console.log('perf data error: ' + e);
  }
}

var _childPid = '';

function buildAndLaunchTest(testPath) {
  setIpcStatus('building...');
  try {
    var buildOut = __exec('cd ' + TSZ_DIR + ' && ./scripts/build ' + shellQuote(testPath) + ' 2>&1');

    var parts = testPath.split('/');
    var filename = parts[parts.length - 1];
    var binName = filename.replace('.app.tsz', '').replace('.tsz', '');
    var relBin = 'zig-out/bin/' + binName;
    var binCheck = __exec('cd ' + TSZ_DIR + ' && test -x ' + shellQuote(relBin) + ' && echo ok || echo missing');
    if (binCheck.trim() !== 'ok') {
      setIpcStatus('build missing binary');
      setIpcLog(buildOut.substring(0, 320));
      return;
    }

    if (_childPid.length > 0) {
      __exec('kill ' + _childPid + ' 2>/dev/null');
      _childPid = '';
    }

    var binPath = TSZ_DIR + '/' + relBin;
    var pidOut = __exec(shellQuote(binPath) + ' >/dev/null 2>&1 & echo $!');
    _childPid = pidOut.trim();
    setIpcStatus('running ' + binName + ' pid ' + _childPid);
    setIpcLog(buildOut.substring(0, 220));

    loadProgressMeta();
    loadTestList();
    loadPerfData();
  } catch (e) {
    setIpcStatus('build failed');
    setIpcLog(('' + e).substring(0, 320));
  }
}

function killTestProcess() {
  if (_childPid.length > 0) {
    __exec('kill ' + _childPid + ' 2>/dev/null');
    _childPid = '';
    setIpcStatus('stopped');
    setIpcLog('process killed');
  }
}

loadProgressMeta();
loadTestList();
loadPerfData();
