// Terminal Hero — live PTY with semantic classifier sidebar showing token types.
// Demonstrates Terminal primitive + real-time semantic state.

import { Card, CardHeader, CardBody, Heading, Subheading, Body, Label, Divider, Row } from './base_cls';
import { StoryHeader, StoryTitle, StoryDescription, Section, SectionTitle, SectionBody, ContentInner } from './storybook_cls';

function TerminalHero() {
  return (
    <C.ContentInner>
      <C.StoryHeader>
        <C.StoryTitle>Terminal</C.StoryTitle>
        <C.StoryDescription>Native PTY with VT100 parsing and semantic classification — not an emulation layer.</C.StoryDescription>
      </C.StoryHeader>

      <C.Divider />

      <C.Section>
        <C.SectionTitle>Hero: Live Shell + Classifier</C.SectionTitle>
        <C.SectionBody>
          <C.Card>
            <C.CardBody>
              <Box style={{ flexDirection: 'row', gap: 0 }}>

                {/* Classifier sidebar */}
                <Box style={{ width: 200, flexDirection: 'column', backgroundColor: '#161b22', padding: 10, gap: 8, borderRadius: 8 }}>
                  <Text fontSize={12} color="#e6edf3" bold>Semantic Tokens</Text>
                  <Box style={{ height: 1, backgroundColor: '#30363d' }} />

                  <Box style={{ flexDirection: 'column', gap: 6 }}>
                    <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
                      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: '#4ade80' }} />
                      <Text fontSize={10} color="#e6edf3">idle</Text>
                      <Text fontSize={9} color="#484f58">Shell prompt</Text>
                    </Box>
                    <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
                      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: '#a78bfa' }} />
                      <Text fontSize={10} color="#e6edf3">thinking</Text>
                      <Text fontSize={9} color="#484f58">AI reasoning</Text>
                    </Box>
                    <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
                      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: '#f97316' }} />
                      <Text fontSize={10} color="#e6edf3">tool_use</Text>
                      <Text fontSize={9} color="#484f58">File edit/bash</Text>
                    </Box>
                    <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
                      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: '#60a5fa' }} />
                      <Text fontSize={10} color="#e6edf3">output</Text>
                      <Text fontSize={9} color="#484f58">Command output</Text>
                    </Box>
                    <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
                      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: '#f87171' }} />
                      <Text fontSize={10} color="#e6edf3">error</Text>
                      <Text fontSize={9} color="#484f58">Stderr/failure</Text>
                    </Box>
                  </Box>

                  <Box style={{ height: 1, backgroundColor: '#30363d' }} />

                  <Box style={{ flexDirection: 'column', gap: 4 }}>
                    <Text fontSize={10} color="#484f58">Token Distribution</Text>
                    <Box style={{ flexDirection: 'row', gap: 2 }}>
                      <Box style={{ flexGrow: 3, height: 6, backgroundColor: '#4ade80', borderRadius: 2 }} />
                      <Box style={{ flexGrow: 2, height: 6, backgroundColor: '#a78bfa', borderRadius: 2 }} />
                      <Box style={{ flexGrow: 4, height: 6, backgroundColor: '#f97316', borderRadius: 2 }} />
                      <Box style={{ flexGrow: 1, height: 6, backgroundColor: '#60a5fa', borderRadius: 2 }} />
                    </Box>
                  </Box>

                  <Box style={{ flexDirection: 'column', gap: 4 }}>
                    <Text fontSize={10} color="#484f58">How it works</Text>
                    <Text fontSize={9} color="#6e7681">The classifier scans VT100 output in real-time, matching patterns to semantic tokens. Each line gets a colored sidebar indicator. The mode drives the status dot color.</Text>
                  </Box>
                </Box>

                {/* Terminal */}
                <Box style={{ flexGrow: 1, flexDirection: 'column' }}>
                  <Box style={{ flexDirection: 'row', paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: '#1e293b', alignItems: 'center', gap: 8 }}>
                    <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: '#4ade80' }} />
                    <Text fontSize={11} color="#e2e8f0">Shell</Text>
                    <Text fontSize={9} color="#475569">bash</Text>
                  </Box>
                  <Terminal fontSize={12} style={{ flexGrow: 1, height: 300 }} />
                </Box>
              </Box>
            </C.CardBody>
          </C.Card>

          <C.Card>
            <C.CardBody>
              <C.Body>This is a real PTY — type commands, see output. The semantic classifier runs on every frame, pattern-matching VT100 sequences to identify what the terminal is doing. No polling, no IPC — the classifier reads the same ring buffer the GPU reads for rendering.</C.Body>
            </C.CardBody>
          </C.Card>
        </C.SectionBody>
      </C.Section>
    </C.ContentInner>
  );
}
