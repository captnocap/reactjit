              {hpTogA == 0 && <Text fontSize={10} color="#6c7086">Off</Text>}
              <Pressable style={{ width: 36, height: 20, borderRadius: 10 }} onPress={() => { setHpTogB(hpTogB == 0 ? 1 : 0) }}>
