            <Text fontSize={20} color="#e0def4">Heading</Text>
            <Text fontSize={14} color="#908caa">Subheading text</Text>
            <Text fontSize={12} color="#6e6a86">Body paragraph — Rose Pine</Text>
            <Text fontSize={10} color="#524f67">Caption · Meta</Text>
            <Text fontSize={11} color="#c4a7e7">const x = 42</Text>
          </Box>
        </Canvas.Node>

        <Canvas.Node gx={-140} gy={-50} gw={260} gh={0}>
