              <Box style={{ width: 50, height: 18, backgroundColor: '#6c71c4', borderRadius: 3 }} />
            </Box>
          </Box>
        </Canvas.Node>

        <Canvas.Node gx={-500} gy={-600} gw={260} gh={0}>
          <Box style={{ backgroundColor: '#191724', borderWidth: 1, borderColor: '#26233a', borderRadius: 8, padding: 12, flexDirection: 'column', gap: 4 }}>
            <Text fontSize={11} color="#908caa">Rose Pine Palette</Text>
            <Box style={{ flexDirection: 'row', gap: 3 }}>
              <Box style={{ flexGrow: 1, height: 24, backgroundColor: '#eb6f92', borderRadius: 3 }} />
              <Box style={{ flexGrow: 1, height: 24, backgroundColor: '#f6c177', borderRadius: 3 }} />
              <Box style={{ flexGrow: 1, height: 24, backgroundColor: '#31748f', borderRadius: 3 }} />
              <Box style={{ flexGrow: 1, height: 24, backgroundColor: '#c4a7e7', borderRadius: 3 }} />
              <Box style={{ flexGrow: 1, height: 24, backgroundColor: '#9ccfd8', borderRadius: 3 }} />
            </Box>
          </Box>
        </Canvas.Node>

        <Canvas.Node gx={250} gy={550} gw={260} gh={0}>
          <Box style={{ backgroundColor: '#2e3440', borderWidth: 1, borderColor: '#434c5e', borderRadius: 8, padding: 12, flexDirection: 'column', gap: 4 }}>
            <Text fontSize={11} color="#4c566a">Nord · Shapes</Text>
            <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
              <Box style={{ width: 36, height: 36, backgroundColor: '#bf616a', borderRadius: 0 }} />
              <Box style={{ width: 36, height: 36, backgroundColor: '#ebcb8b', borderRadius: 6 }} />
              <Box style={{ width: 36, height: 36, backgroundColor: '#a3be8c', borderRadius: 12 }} />
              <Box style={{ width: 36, height: 36, backgroundColor: '#88c0d0', borderRadius: 18 }} />
            </Box>
          </Box>
        </Canvas.Node>

        {/* ═══ EASTER EGGS — far corners ═══ */}

        <Canvas.Node gx={-1200} gy={-800} gw={260} gh={0}>
          <Box style={{ backgroundColor: '#1e1e2e', borderWidth: 1, borderColor: '#313244', borderRadius: 8, padding: 12, flexDirection: 'column', gap: 4 }}>
            <Text fontSize={11} color="#cba6f7">You found me!</Text>
            <Text fontSize={9} color="#6c7086">Catppuccin outpost — NW corner</Text>
          </Box>
        </Canvas.Node>

        <Canvas.Node gx={1100} gy={700} gw={260} gh={0}>
          <Box style={{ backgroundColor: '#282a36', borderWidth: 1, borderColor: '#44475a', borderRadius: 8, padding: 12, flexDirection: 'column', gap: 4 }}>
            <Text fontSize={11} color="#ff79c6">Edge of the world</Text>
            <Text fontSize={9} color="#6272a4">Dracula outpost — SE corner</Text>
          </Box>
        </Canvas.Node>

        <Canvas.Node gx={1000} gy={-700} gw={260} gh={0}>
          <Box style={{ backgroundColor: '#1a1b26', borderWidth: 1, borderColor: '#292e42', borderRadius: 8, padding: 12, flexDirection: 'column', gap: 4 }}>
            <Text fontSize={11} color="#7dcfff">Neon outpost</Text>
            <Text fontSize={9} color="#565f89">Tokyo Night — NE reaches</Text>
          </Box>
        </Canvas.Node>

        <Canvas.Node gx={-1100} gy={650} gw={260} gh={0}>
          <Box style={{ backgroundColor: '#282828', borderWidth: 1, borderColor: '#504945', borderRadius: 8, padding: 12, flexDirection: 'column', gap: 4 }}>
            <Text fontSize={11} color="#d79921">Warm frontier</Text>
            <Text fontSize={9} color="#928374">Gruvbox outpost — SW corner</Text>
          </Box>
        </Canvas.Node>

      </Canvas>
  );
}
