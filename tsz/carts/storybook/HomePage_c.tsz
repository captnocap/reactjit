// Storybook Homepage — infinite canvas of theme-randomized tiles.
// Dense center cluster visible at default zoom, sparser outward. Pan to explore.
// Each tile gets a randomly assigned theme — visual diversity, not grouped columns.

import { Transitions } from './tiles/Transitions_c';
import { ThreeDScene } from './tiles/ThreeDScene_c';
import { ScrollDemo } from './tiles/ScrollDemo_c';
import { Hyperlinks } from './tiles/Hyperlinks_c';
import { OpacityDemo } from './tiles/OpacityDemo_c';
import { TextAreaDemo } from './tiles/TextAreaDemo_c';
import { AnimationTile } from './tiles/AnimationTile_c';
import { CanvasTile } from './tiles/CanvasTile_c';
import { ChartsTile } from './tiles/ChartsTile_c';
import { ColorPaletteTile } from './tiles/ColorPaletteTile_c';
import { FormTile } from './tiles/FormTile_c';
import { NetworkTile } from './tiles/NetworkTile_c';
import { PhysicsTile } from './tiles/PhysicsTile_c';
import { TerminalTile } from './tiles/TerminalTile_c';
import { ThreeDTile } from './tiles/ThreeDTile_c';
import { TypographyTile } from './tiles/TypographyTile_c';
import { ClockTile } from './tiles/ClockTile_c';
import { CounterTile } from './tiles/CounterTile_c';
import { TodoTile } from './tiles/TodoTile_c';
import { StopwatchTile } from './tiles/StopwatchTile_c';
import { TabsTile } from './tiles/TabsTile_c';
import { StateTile } from './tiles/StateTile_c';
import { GameTile } from './tiles/GameTile_c';
import { ColorMixTile } from './tiles/ColorMixTile_c';

const [hpClicks, setHpClicks] = useState(0);
const [hpTogA, setHpTogA] = useState(1);
const [hpTogB, setHpTogB] = useState(0);

function HomePage() {
  return (
      <Canvas style={{ flexGrow: 1, flexBasis: 0 }} viewX={0} viewY={0} viewZoom={0.8} driftX={-8} driftY={-5}>

        {/* ═══ DENSE CENTER — 4-6 tiles visible at default zoom ═══ */}

        <Canvas.Node gx={-280} gy={-200} gw={260} gh={0}>
          <Box style={{ backgroundColor: '#1a1b26', borderWidth: 1, borderColor: '#292e42', borderRadius: 8, padding: 12, flexDirection: 'column', gap: 6 }}>
            <Text fontSize={11} color="#7aa2f7">Tokyo Night · Bar Chart</Text>
            <Box style={{ flexDirection: 'row', alignItems: 'end', gap: 3 }}>
              <Box style={{ flexGrow: 1, height: 20, backgroundColor: '#9ece6a', borderRadius: 2 }} />
              <Box style={{ flexGrow: 1, height: 45, backgroundColor: '#7aa2f7', borderRadius: 2 }} />
              <Box style={{ flexGrow: 1, height: 30, backgroundColor: '#7dcfff', borderRadius: 2 }} />
              <Box style={{ flexGrow: 1, height: 65, backgroundColor: '#bb9af7', borderRadius: 2 }} />
              <Box style={{ flexGrow: 1, height: 50, backgroundColor: '#f7768e', borderRadius: 2 }} />
              <Box style={{ flexGrow: 1, height: 80, backgroundColor: '#9ece6a', borderRadius: 2 }} />
              <Box style={{ flexGrow: 1, height: 55, backgroundColor: '#e0af68', borderRadius: 2 }} />
              <Box style={{ flexGrow: 1, height: 90, backgroundColor: '#7aa2f7', borderRadius: 2 }} />
