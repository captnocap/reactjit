// Creative Concepts — impossible-seeming compositions that showcase
// what happens when a compiler owns the full stack from JSX to GPU.

import { Card, CardHeader, CardBody, Row, Column, Wrap, Spacer, Heading, Subheading, Body, Label, Code, Divider, Surface, SurfaceAlt } from './base_cls';
import { StoryHeader, StoryTitle, StoryDescription, Section, SectionTitle, SectionBody, ContentInner } from './storybook_cls';

// ── Concept 1: 3D Terminal Workspace ──
const [termCam, setTermCam] = useState(0);

// ── Concept 2: Supervisor Control Room ──
const [crMode, setCrMode] = useState('idle');
const [crTurns, setCrTurns] = useState(0);
const [crDot, setCrDot] = useState(0x4ade80);
const [crIncidents, setCrIncidents] = useState(0);

// ── Concept 3: Living Interface ──
const [lifePhase, setLifePhase] = useState(0);
const [lifePressCount, setLifePressCount] = useState(0);

<script>
var _crTick = 0;
setInterval(function() {
  _crTick = _crTick + 1;
  setCrTurns(_crTick);
  if (_crTick % 7 === 0) {
    setCrMode('tool_use');
    setCrDot(0xf97316);
  } else if (_crTick % 5 === 0) {
    setCrMode('thinking');
    setCrDot(0xa78bfa);
  } else {
    setCrMode('idle');
    setCrDot(0x4ade80);
  }
  if (_crTick % 11 === 0) {
    setCrIncidents(crIncidents + 1);
  }
}, 1500);

// Living interface evolves based on interaction count
function evolve() {
  var n = lifePressCount + 1;
  setLifePressCount(n);
  if (n > 8) setLifePhase(3);
  else if (n > 4) setLifePhase(2);
  else if (n > 1) setLifePhase(1);
}
</script>

function CreativeConcepts() {
  return (
    <C.ContentInner>
      <C.StoryHeader>
        <C.StoryTitle>Creative Concepts</C.StoryTitle>
        <C.StoryDescription>Compositions that couldn't be comfortably expressed in a normal stack. Each mixes capabilities that live in separate worlds elsewhere: 3D rendering, live terminals, self-modifying layout, GPU text — unified under one compiler.</C.StoryDescription>
      </C.StoryHeader>

      <C.Divider />

      <C.Section>
        <C.SectionTitle>1. 3D Terminal Workspace</C.SectionTitle>
        <C.SectionBody>
          <C.Card>
            <C.CardHeader>
              <C.Subheading>PTY + Scene3D — one render pass</C.Subheading>
              <C.Label>A live terminal sits beside a 3D scene. Both are native primitives, not iframes or WebGL hacks.</C.Label>
            </C.CardHeader>
            <C.CardBody>
              <Box style={{ flexDirection: 'row', gap: 8 }}>
                <Box style={{ flexDirection: 'column', flexGrow: 1, gap: 4 }}>
                  <Box style={{ flexDirection: 'row', gap: 4, alignItems: 'center' }}>
                    <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: '#4ade80' }} />
                    <Text fontSize={10} color="theme-textDim">live terminal</Text>
                  </Box>
                  <Terminal fontSize={10} style={{ height: 200, borderRadius: 6, borderWidth: 1, borderColor: 'theme-border' }} />
                </Box>
                <Box style={{ flexDirection: 'column', width: 320, gap: 4 }}>
                  <Box style={{ flexDirection: 'row', gap: 4 }}>
                    <Pressable onPress={() => { setTermCam(0) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 3, paddingBottom: 3, borderRadius: 4, backgroundColor: 'theme-surface' }}>
                      <Text fontSize={9} color="theme-text">Front</Text>
                    </Pressable>
                    <Pressable onPress={() => { setTermCam(1) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 3, paddingBottom: 3, borderRadius: 4, backgroundColor: 'theme-surface' }}>
                      <Text fontSize={9} color="theme-text">Top</Text>
                    </Pressable>
                    <Pressable onPress={() => { setTermCam(2) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 3, paddingBottom: 3, borderRadius: 4, backgroundColor: 'theme-surface' }}>
                      <Text fontSize={9} color="theme-text">Orbit</Text>
                    </Pressable>
                  </Box>
                  <Scene3D style={{ width: 320, height: 200 }}>
                    {termCam == 0 && <3D.Camera position={[0, 2, 8]} lookAt={[0, 1, 0]} fov={50} />}
                    {termCam == 1 && <3D.Camera position={[0, 12, 2]} lookAt={[0, 0, 0]} fov={45} />}
                    {termCam == 2 && <3D.Camera position={[6, 4, 6]} lookAt={[0, 1, 0]} fov={50} />}
                    <3D.Light position={[5, 8, 5]} color="#ffffff" intensity={1.2} />
                    <3D.Light position={[-3, 4, -2]} color="#58a6ff" intensity={0.4} />
                    <3D.Mesh shape="box" position={[0, 0.5, 0]} scale={[3, 1, 2]} color="#161b22" />
                    <3D.Mesh shape="box" position={[0, 1.05, 0]} scale={[2.8, 0.02, 1.8]} color="#58a6ff" />
                    <3D.Mesh shape="cylinder" position={[-1.2, 0, 1.2]} scale={[0.05, 1, 0.05]} color="#484f58" />
                    <3D.Mesh shape="cylinder" position={[1.2, 0, 1.2]} scale={[0.05, 1, 0.05]} color="#484f58" />
                    <3D.Mesh shape="cylinder" position={[-1.2, 0, -1.2]} scale={[0.05, 1, 0.05]} color="#484f58" />
                    <3D.Mesh shape="cylinder" position={[1.2, 0, -1.2]} scale={[0.05, 1, 0.05]} color="#484f58" />
                    <3D.Mesh shape="sphere" position={[0, 2.5, 0]} scale={[0.3, 0.3, 0.3]} color="#3fb950" />
                  </Scene3D>
                </Box>
              </Box>
            </C.CardBody>
          </C.Card>
          <C.Card>
            <C.CardBody>
              <C.Body>Why this couldn't be comfortably expressed in a normal stack: a live PTY, a wgpu 3D viewport, and 2D UI all share one event loop, one layout pass, and one GPU submission — no IPC, no iframe boundaries, no separate rendering contexts to synchronize.</C.Body>
            </C.CardBody>
          </C.Card>
        </C.SectionBody>
      </C.Section>

      <C.Divider />

      <C.Section>
        <C.SectionTitle>2. Supervisor Control Room</C.SectionTitle>
        <C.SectionBody>
          <C.Card>
            <C.CardHeader>
              <C.Subheading>Logs + Workers + Incidents — one surface</C.Subheading>
              <C.Label>Live semantic state, scrolling log, and incident counter — all polled from runtime APIs in the same frame.</C.Label>
            </C.CardHeader>
            <C.CardBody>
              <Box style={{ flexDirection: 'row', gap: 8 }}>
                <Box style={{ flexDirection: 'column', flexGrow: 1, backgroundColor: 'theme-bgAlt', borderRadius: 8, padding: 10, gap: 6 }}>
                  <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
                    <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: crDot }} />
                    <Text fontSize={12} color="theme-text">Worker Alpha</Text>
                    <Box style={{ borderRadius: 4, paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2, backgroundColor: 'theme-surface' }}>
                      <Text fontSize={9} color="theme-accent">{crMode}</Text>
                    </Box>
                    <Text fontSize={9} color="theme-textDim">{`t:${crTurns}`}</Text>
                  </Box>
                  <Terminal fontSize={9} style={{ height: 120, borderRadius: 4 }} />
                </Box>
                <Box style={{ flexDirection: 'column', width: 200, gap: 8 }}>
                  <Box style={{ flexDirection: 'column', backgroundColor: 'theme-bgAlt', borderRadius: 8, padding: 10, gap: 4 }}>
                    <Text fontSize={10} color="theme-textDim">INCIDENTS</Text>
                    <Text fontSize={24} color="#f85149">{`${crIncidents}`}</Text>
                    <Box style={{ height: 2, backgroundColor: '#f85149', borderRadius: 1 }} />
                  </Box>
                  <Box style={{ flexDirection: 'column', backgroundColor: 'theme-bgAlt', borderRadius: 8, padding: 10, gap: 4 }}>
                    <Text fontSize={10} color="theme-textDim">UPTIME</Text>
                    <Text fontSize={14} color="#3fb950">{`${crTurns}s`}</Text>
                  </Box>
                  <Box style={{ flexDirection: 'column', backgroundColor: 'theme-bgAlt', borderRadius: 8, padding: 10, gap: 4 }}>
                    <Text fontSize={10} color="theme-textDim">STATUS</Text>
                    <Box style={{ flexDirection: 'row', gap: 4, alignItems: 'center' }}>
                      <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: crDot }} />
                      <Text fontSize={12} color="theme-text">{crMode}</Text>
                    </Box>
                  </Box>
                </Box>
              </Box>
            </C.CardBody>
          </C.Card>
          <C.Card>
            <C.CardBody>
              <C.Body>Why this couldn't be comfortably expressed in a normal stack: a pseudo-terminal with VT100 parsing, semantic mode classification, and real-time metric cards all update in the same 16ms frame — no web sockets, no polling layers, no state synchronization protocol.</C.Body>
            </C.CardBody>
          </C.Card>
        </C.SectionBody>
      </C.Section>

      <C.Divider />

      <C.Section>
        <C.SectionTitle>3. Living Interface</C.SectionTitle>
        <C.SectionBody>
          <C.Card>
            <C.CardHeader>
              <C.Subheading>Self-modifying layout</C.Subheading>
              <C.Label>The UI evolves as you interact with it. Press the button — the interface restructures itself.</C.Label>
            </C.CardHeader>
            <C.CardBody>
              <Box style={{ flexDirection: 'column', gap: 8 }}>
                <Pressable onPress={() => { evolve() }} style={{ alignSelf: 'flexStart', paddingLeft: 16, paddingRight: 16, paddingTop: 8, paddingBottom: 8, borderRadius: 6, backgroundColor: 'theme-primary' }}>
                  <Text fontSize={12} color="theme-bg">{`Evolve (${lifePressCount})`}</Text>
                </Pressable>

                {lifePhase == 0 && <Box style={{ flexDirection: 'column', gap: 6, padding: 12, backgroundColor: 'theme-bgAlt', borderRadius: 8 }}>
                  <Text fontSize={14} color="theme-text">Phase 0: Seed</Text>
                  <Text fontSize={11} color="theme-textDim">A single column. Minimal. Waiting to grow.</Text>
                  <Box style={{ height: 40, backgroundColor: 'theme-surface', borderRadius: 4, justifyContent: 'center', alignItems: 'center' }}>
                    <Text fontSize={10} color="theme-textDim">one box</Text>
                  </Box>
                </Box>}

                {lifePhase == 1 && <Box style={{ flexDirection: 'row', gap: 6, padding: 12, backgroundColor: 'theme-bgAlt', borderRadius: 8 }}>
                  <Box style={{ flexGrow: 1, flexDirection: 'column', gap: 4 }}>
                    <Text fontSize={14} color="theme-text">Phase 1: Split</Text>
                    <Text fontSize={11} color="theme-textDim">Column became row. Interaction spawned structure.</Text>
                  </Box>
                  <Box style={{ flexGrow: 1, height: 60, backgroundColor: 'theme-primary', borderRadius: 4, justifyContent: 'center', alignItems: 'center', opacity: 0.6 }}>
                    <Text fontSize={10} color="theme-bg">panel A</Text>
                  </Box>
                  <Box style={{ flexGrow: 1, height: 60, backgroundColor: 'theme-accent', borderRadius: 4, justifyContent: 'center', alignItems: 'center', opacity: 0.6 }}>
                    <Text fontSize={10} color="theme-bg">panel B</Text>
                  </Box>
                </Box>}

                {lifePhase == 2 && <Box style={{ flexDirection: 'column', gap: 6, padding: 12, backgroundColor: 'theme-bgAlt', borderRadius: 8 }}>
                  <Text fontSize={14} color="theme-text">Phase 2: Nest</Text>
                  <Text fontSize={11} color="theme-textDim">Panels bred children. The tree deepens.</Text>
                  <Box style={{ flexDirection: 'row', gap: 6 }}>
                    <Box style={{ flexGrow: 1, flexDirection: 'column', gap: 4 }}>
                      <Box style={{ height: 30, backgroundColor: 'theme-primary', borderRadius: 4, opacity: 0.5 }} />
                      <Box style={{ flexDirection: 'row', gap: 4 }}>
                        <Box style={{ flexGrow: 1, height: 30, backgroundColor: 'theme-success', borderRadius: 4, opacity: 0.5 }} />
                        <Box style={{ flexGrow: 1, height: 30, backgroundColor: 'theme-warning', borderRadius: 4, opacity: 0.5 }} />
                      </Box>
                    </Box>
                    <Box style={{ flexGrow: 1, flexDirection: 'column', gap: 4 }}>
                      <Box style={{ flexDirection: 'row', gap: 4 }}>
                        <Box style={{ flexGrow: 1, height: 30, backgroundColor: 'theme-accent', borderRadius: 4, opacity: 0.5 }} />
                        <Box style={{ flexGrow: 1, height: 30, backgroundColor: 'theme-error', borderRadius: 4, opacity: 0.5 }} />
                      </Box>
                      <Box style={{ height: 30, backgroundColor: 'theme-info', borderRadius: 4, opacity: 0.5 }} />
                    </Box>
                  </Box>
                </Box>}

                {lifePhase == 3 && <Box style={{ flexDirection: 'column', gap: 6, padding: 12, backgroundColor: 'theme-bgAlt', borderRadius: 8, borderWidth: 2, borderColor: 'theme-primary' }}>
                  <Text fontSize={14} color="theme-primary">Phase 3: Aware</Text>
                  <Text fontSize={11} color="theme-textDim">The interface knows its own history. It shows you what it became.</Text>
                  <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
                    <Box style={{ width: 60, height: 60, borderRadius: 30, backgroundColor: 'theme-primary', justifyContent: 'center', alignItems: 'center', opacity: 0.8 }}>
                      <Text fontSize={9} color="theme-bg">seed</Text>
                    </Box>
                    <Box style={{ width: 60, height: 60, borderRadius: 8, backgroundColor: 'theme-accent', justifyContent: 'center', alignItems: 'center', opacity: 0.8 }}>
                      <Text fontSize={9} color="theme-bg">split</Text>
                    </Box>
                    <Box style={{ width: 60, height: 60, borderRadius: 4, backgroundColor: 'theme-success', justifyContent: 'center', alignItems: 'center', opacity: 0.8 }}>
                      <Text fontSize={9} color="theme-bg">nest</Text>
                    </Box>
                    <Box style={{ width: 60, height: 60, borderRadius: 4, backgroundColor: 'theme-warning', borderWidth: 2, borderColor: 'theme-primary', justifyContent: 'center', alignItems: 'center' }}>
                      <Text fontSize={9} color="theme-text">you</Text>
                    </Box>
                  </Box>
                  <Text fontSize={10} color="theme-accent">{`${lifePressCount} interactions shaped this layout`}</Text>
                </Box>}
              </Box>
            </C.CardBody>
          </C.Card>
          <C.Card>
            <C.CardBody>
              <C.Body>Why this couldn't be comfortably expressed in a normal stack: the layout tree itself mutates based on interaction history — not just styling, but structural topology. In a web framework this requires unmounting/remounting component trees with reconciliation overhead. Here the compiler statically knows all four phase shapes at build time.</C.Body>
            </C.CardBody>
          </C.Card>
        </C.SectionBody>
      </C.Section>
    </C.ContentInner>
  );
}
