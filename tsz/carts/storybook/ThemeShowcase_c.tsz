                <Box style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 3, paddingBottom: 3, borderRadius: 3, backgroundColor: '#83a598' }}><Text fontSize={9} color="#282828">Active</Text></Box>
                <Box style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 3, paddingBottom: 3, borderRadius: 3, backgroundColor: '#3c3836' }}><Text fontSize={9} color="#ebdbb2">Settings</Text></Box>
              </Box>
            </Box>

          </Box>
        </C.SectionBody>
      </C.Section>

      <C.Divider />

      <C.Section>
        <C.SectionTitle>How It Works</C.SectionTitle>
        <C.SectionBody>
          <C.Card>
            <C.CardBody>
              <C.Body>Every theme is a Palette (18 semantic colors) + StylePalette (radii, spacing, borders, fonts). The same JSX structure maps to completely different visual output. Swap at runtime via Theme.setPalette(). The compiler resolves theme-* color references to palette lookups — zero runtime overhead for themed components.</C.Body>
            </C.CardBody>
          </C.Card>
        </C.SectionBody>
      </C.Section>
    </C.ContentInner>
  );
}
