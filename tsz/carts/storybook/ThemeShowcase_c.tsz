                </Box>
                <Box style={{ flexGrow: 1, backgroundColor: '#24283b', borderRadius: 6, padding: 8, flexDirection: 'column', gap: 2 }}>
                  <Text fontSize={9} color="#565f89">Revenue</Text>
                  <Text fontSize={16} color="#bb9af7">$48k</Text>
                </Box>
              </Box>
              <Box style={{ height: 8, backgroundColor: '#24283b', borderRadius: 4 }}><Box style={{ width: 180, height: 8, backgroundColor: '#9ece6a', borderRadius: 4 }} /></Box>
              <Box style={{ flexDirection: 'row', gap: 4 }}>
                <Box style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 3, paddingBottom: 3, borderRadius: 3, backgroundColor: '#7aa2f7' }}><Text fontSize={9} color="#1a1b26">Active</Text></Box>
                <Box style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 3, paddingBottom: 3, borderRadius: 3, backgroundColor: '#24283b' }}><Text fontSize={9} color="#c0caf5">Settings</Text></Box>
              </Box>
            </Box>

            {/* Rose Pine */}
            <Box style={{ width: 280, backgroundColor: '#191724', borderWidth: 1, borderColor: '#26233a', borderRadius: 8, padding: 12, flexDirection: 'column', gap: 6 }}>
              <Text fontSize={13} color="#e0def4" bold>Dashboard</Text>
              <Text fontSize={10} color="#6e6a86">Rose Pine</Text>
              <Box style={{ height: 1, backgroundColor: '#26233a' }} />
              <Box style={{ flexDirection: 'row', gap: 8 }}>
                <Box style={{ flexGrow: 1, backgroundColor: '#1f1d2e', borderRadius: 6, padding: 8, flexDirection: 'column', gap: 2 }}>
                  <Text fontSize={9} color="#6e6a86">Users</Text>
                  <Text fontSize={16} color="#31748f">1,247</Text>
                </Box>
                <Box style={{ flexGrow: 1, backgroundColor: '#1f1d2e', borderRadius: 6, padding: 8, flexDirection: 'column', gap: 2 }}>
                  <Text fontSize={9} color="#6e6a86">Revenue</Text>
                  <Text fontSize={16} color="#c4a7e7">$48k</Text>
                </Box>
              </Box>
              <Box style={{ height: 8, backgroundColor: '#1f1d2e', borderRadius: 4 }}><Box style={{ width: 180, height: 8, backgroundColor: '#31748f', borderRadius: 4 }} /></Box>
              <Box style={{ flexDirection: 'row', gap: 4 }}>
