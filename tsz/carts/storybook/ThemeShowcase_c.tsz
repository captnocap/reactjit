                <Box style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 3, paddingBottom: 3, borderRadius: 3, backgroundColor: '#1f1d2e' }}><Text fontSize={9} color="#e0def4">Settings</Text></Box>
              </Box>
            </Box>

            {/* Gruvbox */}
            <Box style={{ width: 280, backgroundColor: '#282828', borderWidth: 1, borderColor: '#504945', borderRadius: 8, padding: 12, flexDirection: 'column', gap: 6 }}>
              <Text fontSize={13} color="#ebdbb2" bold>Dashboard</Text>
              <Text fontSize={10} color="#928374">Gruvbox Dark</Text>
              <Box style={{ height: 1, backgroundColor: '#504945' }} />
              <Box style={{ flexDirection: 'row', gap: 8 }}>
                <Box style={{ flexGrow: 1, backgroundColor: '#3c3836', borderRadius: 6, padding: 8, flexDirection: 'column', gap: 2 }}>
                  <Text fontSize={9} color="#928374">Users</Text>
                  <Text fontSize={16} color="#b8bb26">1,247</Text>
                </Box>
                <Box style={{ flexGrow: 1, backgroundColor: '#3c3836', borderRadius: 6, padding: 8, flexDirection: 'column', gap: 2 }}>
                  <Text fontSize={9} color="#928374">Revenue</Text>
