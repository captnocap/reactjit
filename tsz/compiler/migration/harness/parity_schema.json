{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parity Check Result",
  "type": "object",
  "properties": {
    "cart_path": {
      "type": "string",
      "description": "Path to the cart being tested"
    },
    "lane": {
      "type": "string",
      "enum": ["soup", "mixed", "chad", "other"],
      "description": "Surface tier of the cart"
    },
    "legacy_hash": {
      "type": "string",
      "description": "Hash of monolithic emit output"
    },
    "atom_hash": {
      "type": "string",
      "description": "Hash of atom-based emit output"
    },
    "diff_status": {
      "type": "string",
      "enum": ["MATCH", "DIFF", "ERROR"],
      "description": "Parity check result"
    },
    "first_diff_hunk": {
      "type": "string",
      "description": "First differing section if DIFF"
    },
    "split_output": {
      "type": "boolean",
      "description": "Whether cart uses split emit"
    },
    "backend_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Backend markers (lua_map, zig_map, etc.)"
    },
    "predicted_atoms": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Predicted atom usage from preflight"
    },
    "verification_time": {
      "type": "string",
      "description": "ISO 8601 timestamp of verification"
    }
  },
  "required": ["cart_path", "lane", "legacy_hash", "atom_hash", "diff_status", "verification_time"]
}
