// style_ternary.mod.fart — style ternary branch parsing
//
// Self-host of: smith/parse/attrs/style_ternary.js
// Parses nested ternary branches inside style blocks and lowers them into
// zig_expr branch records when needed.

<style_ternary module>
  <functions>
    parseTernaryBranch(c, key):
      parseTernaryBranchHost(c, key)

    // ── Host delegates ──
    parseTernaryBranchHost(c, key):
      parseTernaryBranch_host(c, key)
  </functions>
</style_ternary>
