// parse_style_block.mod.fart — style block parser
//
// Self-host of: smith/parse/attrs/style_block.js
// Parses double-brace style payloads into style fields, node field hoists,
// dynamic style registrations, and map-aware inline expressions.

<parse_style_block module>
  <functions>
    parseStyleBlock(c):
      parseStyleBlockHost(c)

    // ── Host delegates ──
    parseStyleBlockHost(c):
      parseStyleBlock_host(c)
  </functions>
</parse_style_block>
