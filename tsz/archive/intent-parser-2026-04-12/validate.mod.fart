// validate.mod.fart — Post-parse validation
//
// Self-host of: smith/validate.js
// Validates compiler context after parsing, detects Class A/B errors.

<validate module>
  <types>
    <ValidationResult>
      ok is bool
      errors is array
      warnings is array
      lane is string
      intents is object
      plan is object
    </ValidationResult>
  </types>

  <functions>
    validate(ctx):
      errors is array
      warnings is array
      intents is derivePreflightIntents(ctx)
      scan is buildPreflightScanState(ctx, intents)
      <if ctx._routePlan and ctx._routePlan.ambiguous.length above 0>
        <for ctx._routePlan.ambiguous as amb>
          errors.push('ROUTE: ' + amb)
        </for>
      </if>
      <if globalThis.__strict exact 1 and warnings.length above 0>
        <for warnings as w>
          errors.push('STRICT: ' + w)
        </for>
      </if>
      result is ValidationResult
      result.ok is errors.length exact 0
      result.errors is errors
      result.warnings is warnings
      result.lane is scan.lane
      result.intents is intents
      result.plan is ctx._routePlan or null
      result

    validateErrorZig(result, file):
      out is '//! VALIDATE BLOCKED: tsz compiler detected errors in ' + file + '\n'
      <for result.errors as err>
        out is out + '//! FATAL: ' + err + '\n'
      </for>
      <for result.warnings as warn>
        out is out + '//! WARN: ' + warn + '\n'
      </for>
      out is out + 'comptime { @compileError("Smith validate failed — ' + result.errors.length + ' error(s). See diagnostics above."); }\n'
      out

    // Individual validation check functions
    // These are called by validate() to perform specific checks

    checkEmptyHandlers(ctx, warnings):
      // Warn on handlers with no body

    checkMapHandlerDispatch(ctx, warnings):
      // Validate map handler dispatch patterns

    checkDuplicateHandlerNames(ctx, errors):
      // Error on duplicate handler names

    checkColorPlaceholders(ctx, scan, errors, warnings):
      // Validate color placeholder usage

    checkMapObjectArrays(ctx, errors):
      // Validate map object array configurations

    checkScriptHandlerCalls(ctx, scan, errors):
      // Validate script handler call patterns

    checkLuaSyntaxLeaks(ctx, scan, errors):
      // Detect Lua syntax leaking into output

    checkHandlerReferences(scan, errors):
      // Validate all handler references resolve

    checkObjectArrayFieldReferences(ctx, scan, warnings):
      // Validate OA field references

    checkUnresolvedDynTexts(ctx, errors):
      // Error on unresolved dynamic text

    warnOnUnusedMapLuaPtrs(ctx, warnings):
      // Warn on unused map Lua pointers

    warnOnUnreadStateSlots(ctx, scan, warnings):
      // Warn on state slots that are never read

    checkTagLeakTextNodes(scan, errors):
      // Check for text node leakage

    checkJSSyntaxLeaks(scan, errors):
      // Detect JS syntax leaking into output

    checkItemReferenceLeaks(ctx, scan, errors, warnings):
      // Check for item reference leaks

    checkUnresolvedClassifierComponents(ctx, errors):
      // Error on unresolved classifier components

    checkDroppedExpressions(ctx, errors):
      // Error on expressions that were dropped

    warnOnUnknownSubsystemTags(ctx, warnings):
      // Warn on unknown subsystem tags

    checkIgnoredModuleBlocks(ctx, errors):
      // Error on ignored module blocks

    checkUndefinedJSCalls(ctx, errors):
      // Error on undefined JS calls

    checkDuplicateJSVars(ctx, errors):
      // Error on duplicate JS variable declarations

    checkUnimplementedJSXBlocks(ctx, errors):
      // Error on unimplemented JSX blocks

    derivePreflightIntents(ctx):
      preflight_context.derivePreflightIntents(ctx)

    buildPreflightScanState(ctx, intents):
      preflight_context.buildPreflightScanState(ctx, intents)
  </functions>
</validate>
