// strict_validator.mod.fart — intent source intake validator
//
// Self-host of: smith/intent_strict_validator.js
// Runs as the very first pass of the intent intake, before tokenization.
// Hard-fails on drift patterns forbidden by the Intent Dictionary.
// Catches models (including Claude) slipping TypeScript/C-family habits
// into intent source.
//
// Forbidden characters (none appear in intent source):
//   = ; \ |
//
// NOTE:
//   `[` and `]` are not blanket-banned here. They can appear in bare
//   display text / payload text inside data blocks. Real array-literal
//   or subscript drift needs a parser-aware rule rather than a raw
//   character scan.
//
// Forbidden sequences:
//   ..              — no range sigil
//   <for 0 to ...>  — no zero-indexed ranges
//
// Block type rule:
//   Last token of <namespace thing> is ALWAYS lowercase.
//
// Outermost file-type rule:
//   First real tag must be: app, widget, page, component, module, lib, cli.
//
// Composition patterns used throughout:
//   slice(pos-1, pos)            = charAt(pos)
//   split(char).first.length     = indexOf(char)
//   slice(0, index).split('\n')  = lines up to offset

<strict_validator module>
  <types>
    <FileType>
      app
      widget
      page
      component
      module
      lib
      cli
    </FileType>

    <Violation>
      code is string
      line is 0
      message is string
      hint is string
      snippet is string
    </Violation>

    <Result>
      ok is true
      violations is Violation array
    </Result>

    <StructuralHead>
      if
      else
      for
      while
      during
      switch
      case
      zscript
      lscript
      script
    </StructuralHead>
  </types>

  <var>
    bans is objects
  </var>

  <bans>
    ch: '=', code: forbidden-equals, msg: 'Use `is` for assignment and `exact` / `not exact` for comparison.', hint: 'e.g. `count is 0`, `ready exact true`'
    ch: ';', code: forbidden-semicolon, msg: 'Statements are newline-separated.', hint: 'Remove the semicolon.'
    ch: '\', code: forbidden-backslash, msg: 'No escape sequences, no path separators.', hint: ''
    ch: '|', code: forbidden-pipe, msg: 'No union-type syntax or bitwise pipes.', hint: 'Use a `<types>` block with named variants.'
  </bans>

  <functions>
    // ── String masking ──
    // Walk source char by char. Replace comment and string content
    // with spaces, preserving positions and line structure.
    // slice(pos-1, pos) is charAt. <while> with manual pos is the iterator.
    maskStringsAndComments(source):
      out is ''
      pos is 1
      <while pos exact or below source.length>
        ch is source.slice(pos - 1, pos)

        // Line comment: //...\n — blank to end of line
        <if ch exact '/' and pos below source.length and source.slice(pos, pos + 1) exact '/'>
          out is out + '  '
          pos is pos + 2
          <while pos exact or below source.length and source.slice(pos - 1, pos) not exact '\n'>
            out is out + ' '
            pos is pos + 1
          </while>
          skip
        </if>

        // Double-quoted string: keep delimiters, blank content
        <if ch exact '"'>
          out is out + '"'
          pos is pos + 1
          <while pos exact or below source.length and source.slice(pos - 1, pos) not exact '"'>
            <if source.slice(pos - 1, pos) exact '\n'>
              out is out + '\n'
            </if>
            <else>
              out is out + ' '
            </else>
            pos is pos + 1
          </while>
          <if pos exact or below source.length>
            out is out + '"'
            pos is pos + 1
          </if>
          skip
        </if>

        // Single-quoted string: keep delimiters, blank content
        <if ch exact "'">
          out is out + "'"
          pos is pos + 1
          <while pos exact or below source.length and source.slice(pos - 1, pos) not exact "'">
            <if source.slice(pos - 1, pos) exact '\n'>
              out is out + '\n'
            </if>
            <else>
              out is out + ' '
            </else>
            pos is pos + 1
          </while>
          <if pos exact or below source.length>
            out is out + "'"
            pos is pos + 1
          </if>
          skip
        </if>

        // Normal character: pass through
        out is out + ch
        pos is pos + 1
      </while>
      out

    // ── Line number from source offset ──
    // slice(0, index) gives the prefix. split('\n').length counts lines.
    lineNumber(source, index):
      source.slice(0, index).split('\n').length

    // ── Extract the line containing an offset ──
    // Split into lines, find which line the offset falls on, return it.
    lineText(source, index):
      lines is source.split('\n')
      lineNum is source.slice(0, index).split('\n').length
      lines.drop(lineNum - 1).first

    // ── Push a violation with deduplication ──
    pushViolation(violations, seen, source, index, code, message, hint):
      line is lineNumber(source, index)
      rawLine is lineText(source, index)
      trimmed is rawLine.trim
      // Skip comment lines
      <if trimmed.startsWith('//')>
        stop
      </if>
      // Deduplicate by code + line
      key is code + '|' + line
      <if seen.has(key)>
        stop
      </if>
      seen.set(key, true)
      violations is violations.concat(code + ':' + line + ' ' + message + ' ' + hint)

    // ── Scan for forbidden characters ──
    // For each ban, check if the character exists in the masked source.
    // split(char).first.length gives the position of the first occurrence.
    scanForbiddenChars(masked, source, violations, seen):
      <for bans as ban>
        parts is masked.split(ban.ch)
        <if parts.length above 1>
          position is parts.first.length
          pushViolation(violations, seen, source, position, ban.code, ban.msg, ban.hint)
        </if>
      </for>

    // ── Scan for double-dot range sigil ──
    // split('..').first.length gives position of first occurrence.
    scanDoubleDot(masked, source, violations, seen):
      parts is masked.split('..')
      <if parts.length above 1>
        position is parts.first.length
        pushViolation(violations, seen, source, position, 'forbidden-range-sigil', 'Range sigil `..` is forbidden. Use `<for N as i>` or `<for A to B as i>`.', 'Inclusive, 1-indexed.')
      </if>

    // ── Scan for zero-start ranges ──
    scanZeroStartRange(masked, source, violations, seen):
      parts is masked.split('<for 0 to')
      <if parts.length above 1>
        position is parts.first.length
        pushViolation(violations, seen, source, position, 'forbidden-zero-start-range', 'Range iteration is 1-indexed, inclusive.', 'Use `<for N as i>` for 1..N or `<for A to B as i>` with A >= 1.')
      </if>

    // ── Scan for JS strict equality operators ──
    // === and !== are JS operators. Intent uses `exact` and `not exact`.
    scanStrictEquality(masked, source, violations, seen):
      parts is masked.split('===')
      <if parts.length above 1>
        position is parts.first.length
        pushViolation(violations, seen, source, position, 'forbidden-strict-eq', '`===` is forbidden. Use `exact` for strict equality.', 'e.g. `a exact b`')
      </if>
      parts is masked.split('!==')
      <if parts.length above 1>
        position is parts.first.length
        pushViolation(violations, seen, source, position, 'forbidden-strict-neq', '`!==` is forbidden. Use `not exact` for strict inequality.', 'e.g. `a not exact b`')
      </if>

    // ── Scan for JS logical operators ──
    scanJSLogicalOps(masked, source, violations, seen):
      parts is masked.split('&&')
      <if parts.length above 1>
        position is parts.first.length
        pushViolation(violations, seen, source, position, 'forbidden-ampamp', '`&&` is forbidden. Use `and`.', '')
      </if>
      parts is masked.split('||')
      <if parts.length above 1>
        position is parts.first.length
        pushViolation(violations, seen, source, position, 'forbidden-pipepipe', '`||` is forbidden. Use `or`.', '')
      </if>

    // ── Scan for JS object literals ──
    // Bare { followed by key: value pattern outside string content.
    scanObjectLiterals(masked, source, violations, seen):
      <if masked.search('{ ') and masked.search(': ')>
        // Check for JS-style { key: val, key: val } pattern
        // split on '{ ' then check if the segment has ': ' before '}'
        parts is masked.split('{ ')
        <for parts.rest as segment>
          <if segment.search(': ') and segment.split('}').first.length below segment.length>
            // Could be a JS object literal — but also could be Zig struct init .{ ... }
            // Only flag if it does NOT start with . (Zig struct init uses .{ .field = val })
            <if not segment.startsWith('.')>
              position is parts.first.length
              pushViolation(violations, seen, source, position, 'drift-object-literal', 'Possible JS object literal. Use `is object` data block or `<var>` declarations.', 'Intent syntax uses named data blocks, not inline {key: val} objects.')
              stop
            </if>
          </if>
        </for>
      </if>

    // ── Extract tag inner text ──
    // Walk the masked source to find the first opening tag.
    // Returns the text between < and > (the inner content).
    // Skips closing tags (</), comments (<!), processing (<?).
    extractFirstTag(masked):
      pos is 1
      <while pos exact or below masked.length>
        ch is masked.slice(pos - 1, pos)
        <if ch exact '<'>
          // Check what follows the <
          <if pos below masked.length>
            next is masked.slice(pos, pos + 1)
            // Skip closing tags, comments, processing instructions
            <if next exact '/' or next exact '!' or next exact '?'>
              pos is pos + 1
              skip
            </if>
          </if>
          // Found an opening tag — extract inner text up to >
          inner is ''
          pos is pos + 1
          <while pos exact or below masked.length and masked.slice(pos - 1, pos) not exact '>'>
            inner is inner + masked.slice(pos - 1, pos)
            pos is pos + 1
          </while>
          inner.trim
        </if>
        pos is pos + 1
      </while>
      ''

    // ── Collect all opening tags ──
    // Returns a collection of inner-text strings for every opening tag.
    collectOpeningTags(masked):
      tags is array
      pos is 1
      <while pos exact or below masked.length>
        ch is masked.slice(pos - 1, pos)
        <if ch exact '<'>
          <if pos below masked.length>
            next is masked.slice(pos, pos + 1)
            <if next exact '/' or next exact '!' or next exact '?'>
              pos is pos + 1
              skip
            </if>
          </if>
          inner is ''
          pos is pos + 1
          <while pos exact or below masked.length and masked.slice(pos - 1, pos) not exact '>'>
            inner is inner + masked.slice(pos - 1, pos)
            pos is pos + 1
          </while>
          trimmed is inner.trim
          <if trimmed.length above 0>
            tags is tags.concat(trimmed)
          </if>
        </if>
        pos is pos + 1
      </while>
      tags

    // ── Scan outermost file type ──
    scanOutermostFileType(masked, source, violations, seen):
      fileTypes is 'app widget page component module lib cli'
      inner is extractFirstTag(masked)
      <if not inner or inner.length exact 0>
        stop
      </if>
      // Strip trailing self-close slash
      <if inner.endsWith('/')>
        inner is inner.slice(0, inner.length - 1).trim
      </if>
      words is inner.split(' ').where(item.length above 0)
      <if words.length below 2>
        // Find position of the tag for error reporting
        position is masked.split('<').first.length
        pushViolation(violations, seen, source, position, 'missing-file-type', 'The outermost tag must be `<namespace type>` (two tokens minimum).', 'Recognized: app, widget, page, component, module, lib, cli.')
        stop
      </if>
      type is words.last
      <if not fileTypes.search(type)>
        position is masked.split('<').first.length
        pushViolation(violations, seen, source, position, 'unknown-file-type', 'Outermost tag type `' + type + '` is not a recognized file type.', 'Recognized: app, widget, page, component, module, lib, cli.')
      </if>

    // ── Scan uppercase block types ──
    scanUppercaseBlockTypes(masked, source, violations, seen):
      structuralHeads is 'if else for while during switch case zscript lscript jscript script'
      tags is collectOpeningTags(masked)
      <for tags as inner>
        // Strip trailing self-close slash
        cleaned is inner
        <if cleaned.endsWith('/')>
          cleaned is cleaned.slice(0, cleaned.length - 1).trim
        </if>
        words is cleaned.split(' ').where(item.length above 0)
        // Single-word: ambiguous without parse context, skip
        <if words.length below 2>
          skip
        </if>
        // Skip classifier refs (C.Name)
        <if words.first.search('.')>
          skip
        </if>
        // Skip structural heads
        <if structuralHeads.search(words.first)>
          skip
        </if>
        // Skip `is` / `as` patterns
        <if words.search('is') or words.search('as')>
          skip
        </if>
        // Skip 3+ word tags except `<name has props>`
        <if words.length above 2>
          <if not (words.length exact 3 and words.rest.first exact 'has' and words.last exact 'props')>
            skip
          </if>
        </if>
        type is words.last
        <if type not exact type.lower>
          pushViolation(violations, seen, source, 0, 'forbidden-uppercase-block-type', 'Block types must be lowercase. Found `' + type + '`.', 'Block types are always lowercase. Namespace before the type may be any case.')
        </if>
      </for>

    // ── Main entry point ──
    validate(source, file):
      violations is array
      seen is object
      masked is maskStringsAndComments(source)
      scanOutermostFileType(masked, source, violations, seen)
      scanForbiddenChars(masked, source, violations, seen)
      scanDoubleDot(masked, source, violations, seen)
      scanZeroStartRange(masked, source, violations, seen)
      scanStrictEquality(masked, source, violations, seen)
      scanJSLogicalOps(masked, source, violations, seen)
      scanObjectLiterals(masked, source, violations, seen)
      scanUppercaseBlockTypes(masked, source, violations, seen)
      ok is violations.length exact 0
  </functions>
</strict_validator>
