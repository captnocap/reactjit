// ── cursor.mod.fart ───────────────────────────────────────────────
// Intent port of parse/cursor.js — cursor helpers for token navigation.
// Consolidated from parse/utils.js and parse/children/brace_util.js.

<cursor module>
  <types>
    // Token kind identifiers — matched against compiler's TK constants
    <TokenKind>
      eof
      identifier
      number
      lparen
      rparen
      lbracket
      rbracket
      lbrace
      rbrace
      amp_amp
      dot
    </TokenKind>
  </types>

  <var>
  </var>

  <functions>
    // Return offset of last token (for error reporting).
    // Uses ternary: if pos above 0 use pos-1, else use 0.
    lastTokenOffset(c):
      idx is (c.pos above 0) ? (c.pos - 1) : 0
      c.starts.drop(idx).first

    // Skip balanced braces starting from current position.
    // Advances cursor past the matching closing brace.
    skipBraces(c):
      depth is 1
      c.advance
      <while depth above 0 and c.kind != TokenKind.eof>
        <if c.kind exact TokenKind.lbrace>
          depth is depth + 1
        </if>
        <else if c.kind exact TokenKind.rbrace>
          depth is depth - 1
        </else>
        <if depth above 0>
          c.advance
        </if>
      </while>
      <if c.kind exact TokenKind.rbrace>
        c.advance
      </if>

    // Convert byte offset to line number (1-indexed).
    // Iterates through source counting newline characters.
    offsetToLine(source, offset):
      line is 1
      i is 0
      <while i exact or below offset and i below source.length>
        <if source.drop(i).first exact '\n'>
          line is line + 1
        </if>
        i is i + 1
      </while>
      line

    // Join text of tokens from start to end index.
    // Collects token texts and joins with spaces.
    joinTokenText(c, start, end):
      parts is array
      ti is start
      <while ti below end>
        parts is parts.concat(c.textAt(ti))
        ti is ti + 1
      </while>
      parts.join(' ')

    // Find last top-level && operator between start and end.
    // Tracks nesting depth to find top-level operators only.
    findLastTopLevelAmpAmp(c, start, end):
      depthParen is 0
      depthBracket is 0
      depthBrace is 0
      last is -1
      ti is start
      <while ti below end>
        kind is c.kindAt(ti)
        <if kind exact TokenKind.lparen>
          depthParen is depthParen + 1
        </if>
        <else if kind exact TokenKind.rparen>
          <if depthParen above 0>
            depthParen is depthParen - 1
          </if>
        </else>
        <else if kind exact TokenKind.lbracket>
          depthBracket is depthBracket + 1
        </else>
        <else if kind exact TokenKind.rbracket>
          <if depthBracket above 0>
            depthBracket is depthBracket - 1
          </if>
        </else>
        <else if kind exact TokenKind.lbrace>
          depthBrace is depthBrace + 1
        </else>
        <else if kind exact TokenKind.rbrace>
          <if depthBrace above 0>
            depthBrace is depthBrace - 1
          </if>
        </else>
        <else if kind exact TokenKind.amp_amp>
          <if depthParen exact 0 and depthBracket exact 0 and depthBrace exact 0>
            last is ti
          </if>
        </else>
        ti is ti + 1
      </while>
      last

    // Normalize joined JS expression (fix spacing around operators).
    // Replaces spaced-out operators with their compact forms.
    normalizeJoinedJsExpr(expr):
      expr is expr.replace('!\\s*=\\s*=', '!==')
      expr is expr.replace('=\\s*=\\s*=', '===')
      expr is expr.replace('!\\s*=(?!=)', '!=')
      expr is expr.replace('=\\s*=(?!=)', '==')
      expr is expr.replace('>\\s*=', '>=')
      expr is expr.replace('<\\s*=', '<=')
      expr is expr.replace('&\\s*&', '&&')
      expr is expr.replace('\\|\\s*\\|', '||')
      expr is expr.replace('\\bexact\\b', '===')
      expr
  </functions>
</cursor>
