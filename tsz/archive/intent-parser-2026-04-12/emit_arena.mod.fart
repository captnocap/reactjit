// emit_arena.mod.fart — Arena allocator declaration emitter
//
// Self-host of: emit_ops/emit_arena.js
// Emits Zig code for the pool arena allocator.

<emit_arena module>
  <functions>
    emitArenaDecl():
      // Emit the arena allocator declaration
      // Returns Zig variable declaration as string
      'var _pool_arena: std.heap.ArenaAllocator = std.heap.ArenaAllocator.init(std.heap.page_allocator);\n'
  </functions>
</emit_arena>
