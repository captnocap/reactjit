// lua_text_eval.mod.fart — Lua text emit: __eval fallback for dynamic JS expressions
// Source: emit_atoms/maps_lua/lua_text_eval.js

<lua text eval module>
  <var>
    LUA_TEXT_BUILTINS exact 'tostring,tonumber,type,pairs,ipairs,print,pcall,math,string,table,unpack,__eval'
  </var>

  <functions>
    // ── True if expr has non-builtin function calls ──
    needsLuaTextEval(expr):
      <if not expr>
        false
      </if>
      <if (expr + '').search('__eval(')>
        false
      </if>
      // Scan for function call patterns: name(
      builtins is LUA_TEXT_BUILTINS.split(',')
      parts is (expr + '').split('(')
      <for parts as part, i>
        <if i exact 1>
          continue
        </if>
        // Find the identifier before the (
        trimmed is part.trim
        <if trimmed.length exact 0>
          continue
        </if>
        // Extract last word
        words is trimmed.split(' ')
        lastWord is words.last
        // Strip dots to get function name
        dotParts is lastWord.split('.')
        funcName is dotParts.last
        <if funcName.length above 0 and funcName.regex('^[A-Za-z_]\\w*$')>
          isBuiltin is false
          <for builtins as b>
            <if b exact funcName>
              isBuiltin is true
              stop
            </if>
          </for>
          <if not isBuiltin>
            true
          </if>
        </if>
      </for>
      false

    // ── Wrap expr in __eval("...") ──
    jsEvalExpr(expr):
      normalized is normalizeJsEvalPayload(expr)
      escaped is escapeDoubleQuotedString(normalized)
      '__eval("' + escaped + '")'

    // ── Normalize JS payload string for Lua eval ──
    normalizeJsEvalPayload(expr):
      <if not expr>
        ''
      </if>
      out is expr + ''
      out is out.replace('\\n', '\n')
      out is out.replace('\\r', '\r')
      out is out.replace('\\"', '"')
      out is out.replace('\\\\', '\')
      out is out.replace(' and ', ' && ')
      out is out.replace(' or ', ' || ')
      out is out.replace(' not ', ' !')
      out is out.replace('~=', '!=')
      out is out.replace('.len', '.length')
      out.trim

    // ── Re-process embedded __eval markers ──
    normalizeEmbeddedJsEval(expr):
      <if not expr or not (expr + '').search('__eval("')>
        expr
      </if>
      // Find and re-wrap each __eval occurrence
      out is expr + ''
      <while out.search('__eval("')>
        startIdx is out.search('__eval("')
        endIdx is out.search('")', startIdx + 8)
        <if endIdx>
          inner is out.slice(startIdx + 8, endIdx)
          rewrapped is jsEvalExpr(inner)
          out is out.slice(0, startIdx) + rewrapped + out.slice(endIdx + 2)
        <else>
          stop
        </else>
      </while>
      out

    // ── Try to inline simple __eval without runtime bridge ──
    maybeInlineJsEvalExpr(expr, itemParam, indexParam, luaIdxExpr, currentOaIdx):
      <if not expr>
        null
      </if>
      exprStr is expr + ''
      <if not exprStr.startsWith('__eval("')>
        null
      </if>
      <if not exprStr.endsWith('")')>
        null
      </if>
      // Extract inner JS expression
      inner is exprStr.slice(8, exprStr.length - 2)
      jsExpr is normalizeJsEvalPayload(inner)

      // Strip false-branch wrapper: (0==1)&&...?x:y → y
      <if jsExpr.startsWith('(0==1)')>
        colonIdx is jsExpr.search(':')
        <if colonIdx>
          jsExpr.slice(colonIdx + 1).trim
        </if>
      </if>
      // Strip true-branch wrapper: (1==1)&&cond?x:y → (cond)?x:y
      <if jsExpr.startsWith('(1==1)&&')>
        jsExpr is jsExpr.slice(8)
      </if>
      // Direct item field access
      <if jsExpr.startsWith('_item.') and jsExpr.regex('^_item\\.\\w+$')>
        jsExpr
      </if>
      <else if jsExpr.startsWith('_nitem.') and jsExpr.regex('^_nitem\\.\\w+$')>
        jsExpr
      </else>
      // Numeric literal
      <else if jsExpr.regex('^-?\\d+(\\.\\d+)?$')>
        jsExpr
      </else>
      // String literal
      <else if jsExpr.startsWith("'") and jsExpr.endsWith("'")>
        luaStringLiteral(jsExpr.slice(1, jsExpr.length - 1))
      <else if jsExpr.startsWith('"') and jsExpr.endsWith('"')>
        luaStringLiteral(jsExpr.slice(1, jsExpr.length - 1))
      </else>
      // OA bracket access → try full conversion
      <else if jsExpr.search('[') and jsExpr.search(']')>
        converted is _jsExprToLua(jsExpr, itemParam, indexParam, luaIdxExpr, currentOaIdx)
        <if converted>
          converted
        <else>
          null
        </else>
      </else>
      <else>
        null
      </else>
  </functions>

</lua text eval>
