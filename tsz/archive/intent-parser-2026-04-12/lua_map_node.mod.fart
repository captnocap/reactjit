// lua_map_node.mod.fart — Lua node tree emitter
// Source: emit_atoms/maps_lua/lua_map_node.js (645 lines)
//
// THE core Lua tree emitter. _nodeToLua() converts a luaNode contract
// object into a Lua table string. Consumed by lua_tree_nodes.js (App()
// function) and by lua map rebuilders.
//
// 28 functions handle every aspect of Lua node emission:
//   Style, text, glyphs, font size, text color, handler, canvas fields,
//   scroll fields, terminal/input flags, conditional children, ternary
//   children, nested maps, map loops, and the recursive node builder.

<lua map node module>

  <functions>
    // ── Style emission ──
    _emitNodeStyle(node, itemParam, indexParam, luaIdxExpr, currentOaIdx):
      <if not node>
        null
      </if>
      <if node._variantStyles and node._variantStyles.length above 1>
        parts is array
        i is 1
        <while i below node._variantStyles.length>
          parts.push('(__variant == ' + i + ') and ' +
            _styleToLua(node._variantStyles.get(i), itemParam, indexParam, luaIdxExpr, currentOaIdx))
          i is i + 1
        </while>
        parts.push(_styleToLua(node._variantStyles.get(0), itemParam, indexParam, luaIdxExpr, currentOaIdx))
        'style = (' + parts.join(' or ') + ')'
      </if>
      <if node.style and node.style.keys.length above 0>
        'style = ' + _styleToLua(node.style, itemParam, indexParam, luaIdxExpr, currentOaIdx)
      </if>
      null

    // ── Text emission ──
    _emitNodeText(node, itemParam, indexParam, luaIdxExpr, currentOaIdx):
      <if not node or node.text exact undefined or node.text exact null>
        null
      </if>
      'text = ' + _textToLua(node.text, itemParam, indexParam, luaIdxExpr, currentOaIdx)

    // ── Glyph emission ──
    _emitNodeInlineGlyphs(node):
      <if not node or not node.inline_glyphs or node.inline_glyphs.length exact 0>
        null
      </if>
      glyphParts is array
      i is 0
      <while i below node.inline_glyphs.length>
        glyphParts.push(_inlineGlyphToLua(node.inline_glyphs.get(i)))
        i is i + 1
      </while>
      parts is array
      <if node.text exact undefined or node.text exact null or node.text exact ''>
        parts.push('text = ' + _inlineGlyphSentinelText(node.inline_glyphs))
      </if>
      parts.push('inline_glyphs = { ' + glyphParts.join(', ') + ' }')
      parts.join(', ')

    _inlineGlyphColorToLua(val):
      <if val exact undefined or val exact null or val exact ''>
        '"transparent"'
      </if>
      <if val is number>
        String(val)
      </if>
      asString is String(val)
      <if asString exact 'transparent'>
        '"transparent"'
      </if>
      zigHex is _zigColorToLuaHex(asString)
      <if zigHex>
        zigHex
      </if>
      hexVal is _hexToLua(asString)
      <if hexVal and hexVal.regex('^0x[0-9a-f]+$')>
        hexVal
      </if>
      luaStringLiteral(asString)

    _inlineGlyphToLua(glyph):
      <if not glyph>
        '{ d = "" }'
      </if>
      parts is array
      parts.push('d = ' + luaStringLiteral(String(glyph.d or '')))
      parts.push('fill = ' + _inlineGlyphColorToLua(glyph.fill))
      parts.push('stroke = ' + _inlineGlyphColorToLua(glyph.stroke))
      parts.push('stroke_width = ' + (glyph.stroke_width not exact undefined ? glyph.stroke_width : 0))
      parts.push('scale = ' + (glyph.scale not exact undefined ? glyph.scale : 1.0))
      <if glyph.fill_effect>
        parts.push('fill_effect = ' + luaStringLiteral(String(glyph.fill_effect)))
      </if>
      '{ ' + parts.join(', ') + ' }'

    _inlineGlyphSentinelText(glyphs):
      <if not glyphs or glyphs.length below or exact 0>
        '"\\x01"'
      </if>
      sentinels is ''
      i is 0
      <while i below glyphs.length>
        sentinels is sentinels + '\\x01'
        i is i + 1
      </while>
      '"' + sentinels + '"'

    // ── Node field emission ──
    _emitNodeFontSize(node):
      <if not node or not node.fontSize>
        null
      </if>
      'font_size = ' + node.fontSize

    _emitNodeTextColor(node):
      <if not node or not node.color>
        null
      </if>
      cv is node.color
      <if cv is string and (cv.startsWith('if ') or cv.contains('@') or cv.contains('state.get') or cv.contains(' and ') or cv.matches(/\b[A-Za-z_]\w*\s*\(/))>
        _emitComplexTextColor(node)
      </if>
      colorLua is _zigColorToLuaHex(cv) or _hexToLua(cv)
      <if colorLua>
