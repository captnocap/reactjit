      </if>
      null

    _emitComplexTextColor(node):
      cv is node.color
      oaMatch is cv.match(/_oa\d+_(\w+)\[_i\]/)
      <if oaMatch>
        'text_color = _item.' + oaMatch.get(1)
      </if>
      js is cv.replace(/Color\.rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*\d+)?\)/g, function(_, r, g, b) {
        return '0x' + ((+r << 16) | (+g << 8) | +b).toString(16).padStart(6, '0')
      })
      i is 0
      <while i below 5>
        js is js.replace(/@as\([^,]+,\s*([^)]*)\)/g, '$1')
        i is i + 1
      </while>
      js is js.replace(/@intCast\(/g, '(')
      js is js.replace(/qjs_runtime\.evalToString\("String\(([^"]+)\)"[^)]*\)/g, '$1')
      js is js.replace(/qjs_runtime\.evalToString\("([^"]+)"[^)]*\)/g, '$1')
      js is js.replace(/,\s*&_eval_buf_\d+/g, '')
      js is js.replace(/&_eval_buf_\d+/g, '')
      js is js.replace(/state\.getSlot(?:Int|Float|Bool|String)?\((\d+)\)/g, function(_, idx) {
        return (ctx and ctx.stateSlots and ctx.stateSlots.get(+idx)) ? ctx.stateSlots.get(+idx).getter : '_slot' + idx
      })
      js is js.replace(/_oa\d+_(\w+)\[_i\]/g, '_item.$1')
      js is js.replace(/([A-Za-z_]\w*(?:\.[A-Za-z_]\w+)*)\.len\b/g, '#$1')
      iter is 0
      <while iter below 10>
        ifPos is js.indexOf('if (')
        <if ifPos below 0>
          break
        </if>
        depth is 0
        ci is ifPos + 3
        <while ci below js.length>
          <if js.charAt(ci) exact '('>
            depth is depth + 1
          </if>
          <if js.charAt(ci) exact ')'>
            depth is depth - 1
            <if depth exact 0>
              break
            </if>
          </if>
          ci is ci + 1
        </while>
        <if depth not exact 0>
          break
        </if>
        cond is js.substring(ifPos + 4, ci)
        rest is js.substring(ci + 1).trim()
        elseIdx is rest.indexOf(' else ')
        <if elseIdx below 0>
          break
        </if>
        trueVal is rest.substring(0, elseIdx).trim()
        prefix is js.substring(0, ifPos)
        suffix is rest.substring(elseIdx + 6).trim()
        js is prefix + '(' + cond + ') and ' + trueVal + ' or ' + suffix
        iter is iter + 1
      </while>
      openCount is (js.match(/\(/g) or array).length
      closeCount is (js.match(/\)/g) or array).length
      <while closeCount above openCount and js.endsWith(')')>
        js is js.slice(0, js.length - 1)
        closeCount is closeCount - 1
      </while>
      <if js.matches(/\band\b/) and not js.contains('?') and not js.contains(':') and not js.matches(/\bif\b/)>
        'text_color = ' + js
      </if>
      <else if js.matches(/^0x[0-9a-f]+$/i) or js.matches(/^_item\.\w+$/)>
        'text_color = ' + js
      </else>
      'text_color = __eval(' + zigStringLiteral(js) + ')'

    _emitNodeTerminalFlags(node):
      <if not node>
