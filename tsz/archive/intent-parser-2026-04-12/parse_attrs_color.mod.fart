// parse_attrs_color.mod.fart
//
// Self-host of: smith/parse/attrs/color.js

<parse_attrs_color module>
  <functions>
    parseColor(val):
      <if val exact 'transparent'>
        'Color.rgba(0, 0, 0, 0)'
      </if>
      <else if val.startsWith('#')>
        'Color.rgb(0x' + val.slice(1) + ')'
      </else if val.startsWith('0x')>
        'Color.rgb(' + val + ')'
      </else>
        val
      </else>
  </functions>
</parse_attrs_color>
