// lua_text_plain.mod.fart — Lua text emission: plain strings
//
// Self-host of: emit_atoms/maps_lua/lua_text_plain.js
// Simple literal strings with no dynamic content.
// No semantic reparsing — direct Lua string emission.

<lua_text_plain module>
  <functions>
    _luaTextPlain(text):
      luaStringLiteral(text)

    _luaTextFieldRef(fieldName):
      'tostring(_item.' + fieldName + ')'
  </functions>
</lua_text_plain>
