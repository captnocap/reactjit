// eval_builder.mod.fart — QuickJS eval string construction
//
// Self-host of: smith/resolve/eval_builder.js (96 lines)
// Single source of truth for building and parsing QuickJS eval strings.
// No other module should construct evalToString() calls directly.

<eval_builder module>
  <uses>
    core
  </uses>

  <var>
    // Eval buffer counter — monotonically increasing
    set_jsEvalCount is 0
  </var>

  <functions>
    // Allocate the next eval buffer index
    allocBuf:
      id is jsEvalCount
      set_jsEvalCount is jsEvalCount + 1
      id

    // Build a string eval: returns the JS value as a string
    // qjs_runtime.evalToString("String(jsExpr)", &_eval_buf_N)
    buildEval(jsExpr):
      bufId is allocBuf
      'qjs_runtime.evalToString(' + zigStringLiteral('String(' + jsExpr + ')') + ', &_eval_buf_' + bufId + ')'

    // Build a boolean eval: returns 'T' for truthy, '' for falsy
    buildBoolEval(jsExpr):
      bufId is allocBuf
      'qjs_runtime.evalToString(' + zigStringLiteral('(' + jsExpr + ") ? 'T' : ''") + ', &_eval_buf_' + bufId + ')'

    // Build a comparison eval: does the comparison in JS, returns 'T' or ''
    buildComparisonEval(jsExpr, op, rhs):
      bufId is allocBuf
      'qjs_runtime.evalToString(' + zigStringLiteral('(' + jsExpr + ') ' + op + ' ' + rhs + " ? 'T' : ''") + ', &_eval_buf_' + bufId + ')'

    // Build a field access eval: evaluates expr.field in JS
    buildFieldEval(jsExpr, field):
      bufId is allocBuf
      'qjs_runtime.evalToString(' + zigStringLiteral('String((' + jsExpr + ').' + field + ')') + ', &_eval_buf_' + bufId + ')'

    // Build a var-decl eval: assigns to a named JS variable then returns as string
    buildVarEval(varName, jsExpr):
      bufId is allocBuf
      'qjs_runtime.evalToString(' + zigStringLiteral('var ' + varName + ' = ' + jsExpr + '; String(' + varName + ')') + ', &_eval_buf_' + bufId + ')'

    // Check if a string is a qjs eval expression
    isEval(expr):
      <if expr and expr.search('qjs_runtime.evalToString')>
        true
      </if>
      <else>
        false
      </else>

    // Extract the inner JS expression from an eval string.
    // Handles: "String(expr)" → expr
    // Uses split composition: find evalToString(", extract between markers.
    extractInner(evalStr):
      <if not evalStr>
        ''
      </if>
      <else if not evalStr.search('evalToString')>
        ''
      </else>
      <else>
        // Find the content between evalToString(" and ", &)
        // split on 'evalToString("' → rest starts with the JS string content
        afterMarker is evalStr.split('evalToString("').rest.first
        <if not afterMarker>
          ''
        </if>
        <else>
          // Extract up to the closing '", &'
          jsContent is afterMarker.split('", &').first
          <if not jsContent>
            ''
          </if>
          <else>
            // Now extract from String(...)
            <if jsContent.startsWith('String(') and jsContent.endsWith(')')>
              jsContent.slice(7, jsContent.length - 1)
            </if>
            // Bool eval: (expr) ? 'T' : ''
            <else if jsContent.search("? 'T' : ''")>
              inner is jsContent.split("? 'T'").first.trim
              // Strip surrounding parens
              <if inner.startsWith('(') and inner.endsWith(')')>
                inner.slice(1, inner.length - 1)
              </if>
              <else>
                inner
              </else>
            </else>
            // Var-decl: var X = expr; String(X)
            <else if jsContent.startsWith('var ')>
              // Extract between 'var X = ' and '; String(X)'
              afterVar is jsContent.slice(4, jsContent.length)
              eqPos is afterVar.split(' = ').first.length
              semiPos is afterVar.split('; String(').first.length
              afterVar.slice(eqPos + 3, semiPos)
            </else>
            <else>
              jsContent
            </else>
          </else>
        </else>
      </else>
  </functions>
</eval_builder>
