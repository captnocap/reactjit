// Bitwise operators test
function App() {
  const [flags, setFlags] = useState(0);

  return (
    <Box style={{ width: '100%', height: '100%', padding: 32, flexDirection: 'column', gap: 16, backgroundColor: '#1e1e2a' }}>
      <Text fontSize={28} color="#ffffff">Bitwise Ops</Text>
      <Text fontSize={48} color="#ff79c6">{`${flags}`}</Text>

      <Pressable onPress={() => setFlags(flags | 1)} style={{ padding: 16, backgroundColor: '#4ec9b0' }}>
        <Text fontSize={16} color="#ffffff">flags | 1 (set bit 0)</Text>
      </Pressable>

      <Pressable onPress={() => setFlags(flags | 2)} style={{ padding: 16, backgroundColor: '#6c5ce7' }}>
        <Text fontSize={16} color="#ffffff">flags | 2 (set bit 1)</Text>
      </Pressable>

      <Pressable onPress={() => setFlags(flags & 1)} style={{ padding: 16, backgroundColor: '#e17055' }}>
        <Text fontSize={16} color="#ffffff">flags & 1 (mask bit 0)</Text>
      </Pressable>

      <Pressable onPress={() => setFlags(flags ^ 3)} style={{ padding: 16, backgroundColor: '#fdcb6e' }}>
        <Text fontSize={16} color="#1e1e2a">flags ^ 3 (toggle bits 0-1)</Text>
      </Pressable>

      <Pressable onPress={() => setFlags(1 << 4)} style={{ padding: 16, backgroundColor: '#00b894' }}>
        <Text fontSize={16} color="#ffffff">1 << 4 (= 16)</Text>
      </Pressable>

      <Pressable onPress={() => setFlags(0)} style={{ padding: 12, backgroundColor: '#282838' }}>
        <Text fontSize={14} color="#78788c">Reset</Text>
      </Pressable>
    </Box>
  );
}
