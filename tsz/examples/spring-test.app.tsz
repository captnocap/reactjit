function App() {
  const [pressed, setPressed] = useState(0);
  const scale = useSpring(pressed ? 0.85 : 1.0, { stiffness: 300, damping: 15 });

  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%' }}>
      <Text fontSize={20} color="#ffffff">Spring Test</Text>
      <Text fontSize={14} color="#808080">useSpring drives scale via compositor</Text>

      <Pressable onPress={() => setPressed(pressed == 1 ? 0 : 1)} style={{ padding: 24, backgroundColor: '#ff79c6', borderRadius: 12, marginTop: 24, scaleX: scale, scaleY: scale }}>
        <Text fontSize={18} color="#ffffff">Press Me (Spring)</Text>
        <Text fontSize={12} color="#d4d4d4">stiffness: 300, damping: 15</Text>
      </Pressable>
    </Box>
  );
}
