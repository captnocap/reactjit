function App() {
  const [hash, setHash] = useState("");
  const [token, setToken] = useState("");

  return (
    <Box style={{ padding: 32, backgroundColor: '#1a1a2e', width: '100%', height: '100%' }}>
      <Text fontSize={28} color="#e94560">Crypto Test</Text>

      <Pressable onPress={() => setHash(sha256("hello world"))} style={{ padding: 16, marginTop: 16, backgroundColor: '#0f3460', borderRadius: 8 }}>
        <Text fontSize={16} color="#ffffff">SHA-256 Hash</Text>
      </Pressable>

      <Text fontSize={14} color="#16213e" style={{ marginTop: 8 }}>{`Hash: ${hash}`}</Text>

      <Pressable onPress={() => setToken(randomToken(16))} style={{ padding: 16, marginTop: 16, backgroundColor: '#533483', borderRadius: 8 }}>
        <Text fontSize={16} color="#ffffff">Generate Token</Text>
      </Pressable>

      <Text fontSize={14} color="#16213e" style={{ marginTop: 8 }}>{`Token: ${token}`}</Text>
    </Box>
  );
}
