function App() {
  const [count, setCount] = useState(0);
  const doubled = count * 2;
  const tripled = count * 3;
  const isHigh = count > 5;
  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%' }}>
      <Text fontSize={20} color="#ffffff">Local Variables Test</Text>
      <Text fontSize={16} color="#aaaaaa">{`Count: ${count}`}</Text>
      <Text fontSize={16} color="#4ec9b0">{`Doubled: ${doubled}`}</Text>
      <Text fontSize={16} color="#569cd6">{`Tripled: ${tripled}`}</Text>
      {isHigh && <Text fontSize={16} color="#ff79c6">Count is high!</Text>}

      <Pressable onPress={() => setCount(count + 1)} style={{ padding: 16, backgroundColor: '#4ec9b0', borderRadius: 8, marginTop: 16 }}>
        <Text fontSize={14} color="#ffffff">+1</Text>
      </Pressable>
      <Pressable onPress={() => setCount(0)} style={{ padding: 16, backgroundColor: '#569cd6', borderRadius: 8, marginTop: 8 }}>
        <Text fontSize={14} color="#ffffff">Reset</Text>
      </Pressable>
    </Box>
  );
}
