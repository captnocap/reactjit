function App() {
  const [count, setCount] = useState(0);
  const doubled = count * 2;
  const status = count > 10 ? 'HIGH' : 'LOW';
  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%' }}>
      <Text fontSize={20} color="#ffffff">Conditional Locals Test</Text>
      <Text fontSize={16} color="#aaaaaa">{`Count: ${count}`}</Text>
      <Text fontSize={16} color="#4ec9b0">{`Doubled: ${doubled}`}</Text>
      <Text fontSize={16} color="#ff79c6">{`Status: ${status}`}</Text>

      <Pressable onPress={() => setCount(count + 1)} style={{ padding: 16, backgroundColor: '#4ec9b0', borderRadius: 8, marginTop: 16 }}>
        <Text fontSize={14} color="#ffffff">+1</Text>
      </Pressable>
    </Box>
  );
}
