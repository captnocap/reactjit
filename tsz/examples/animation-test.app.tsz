function App() {
  const [show, setShow] = useState(1);
  const opacity = useTransition(show ? 1.0 : 0.0, { duration: 500, easing: 'easeOut' });

  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%' }}>
      <Text fontSize={20} color="#ffffff">Animation Test</Text>
      <Text fontSize={14} color="#808080">useTransition drives opacity via compositor</Text>

      <Pressable onPress={() => setShow(show == 1 ? 0 : 1)} style={{ padding: 16, backgroundColor: '#4ec9b0', borderRadius: 8, marginTop: 16 }}>
        <Text fontSize={14} color="#ffffff">Toggle Fade</Text>
      </Pressable>

      <Box style={{ padding: 32, backgroundColor: '#569cd6', borderRadius: 12, marginTop: 16, opacity: opacity }}>
        <Text fontSize={24} color="#ffffff">I fade in and out</Text>
        <Text fontSize={14} color="#d4d4d4">500ms easeOut transition</Text>
      </Box>
    </Box>
  );
}
