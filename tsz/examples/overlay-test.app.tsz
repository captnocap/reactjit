function App() {
  const [menuVisible, setMenuVisible] = useState(0);
  const [menuX, setMenuX] = useState(0);
  const [menuY, setMenuY] = useState(0);
  const [modalVisible, setModalVisible] = useState(0);

  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1e1e2a', padding: 32 }}>
      <Text fontSize={24} color="#ffffff">Overlay Test</Text>
      <Text fontSize={14} color="#888888">Right-click for context menu. Click button for modal.</Text>

      <Box style={{ width: '100%', flexGrow: 1, backgroundColor: '#2d2d3d', borderRadius: 8, marginTop: 16, padding: 16 }}
        onRightClick={(x, y) => { setMenuX(x); setMenuY(y); setMenuVisible(1); }}>
        <Text fontSize={16} color="#aaaaaa">Right-click anywhere in this box</Text>
      </Box>

      <Pressable onPress={() => setModalVisible(1)}
        style={{ padding: 16, backgroundColor: '#4ec9b0', borderRadius: 8, marginTop: 16 }}>
        <Text fontSize={16} color="#ffffff">Open Modal</Text>
      </Pressable>

      <Overlay type="context-menu" visible={menuVisible} x={menuX} y={menuY}
        onDismiss={() => setMenuVisible(0)}>
        <Box style={{ backgroundColor: '#2d2d3d', borderRadius: 8, padding: 4, width: 180 }}>
          <Pressable onPress={() => { setMenuVisible(0); }}
            style={{ padding: 8, borderRadius: 4 }}>
            <Text fontSize={13} color="#ffffff">Cut</Text>
          </Pressable>
          <Pressable onPress={() => { setMenuVisible(0); }}
            style={{ padding: 8, borderRadius: 4 }}>
            <Text fontSize={13} color="#ffffff">Copy</Text>
          </Pressable>
          <Pressable onPress={() => { setMenuVisible(0); }}
            style={{ padding: 8, borderRadius: 4 }}>
            <Text fontSize={13} color="#ffffff">Paste</Text>
          </Pressable>
        </Box>
      </Overlay>

      <Overlay type="modal" visible={modalVisible}
        onDismiss={() => setModalVisible(0)}>
        <Box style={{ width: 400, backgroundColor: '#1e1e2a', borderRadius: 12, padding: 24 }}>
          <Text fontSize={20} color="#ffffff">Confirm Action</Text>
          <Text fontSize={14} color="#888888">Are you sure you want to proceed?</Text>
          <Box style={{ flexDirection: 'row', gap: 8, marginTop: 16 }}>
            <Pressable onPress={() => setModalVisible(0)}
              style={{ padding: 12, backgroundColor: '#333333', borderRadius: 6 }}>
              <Text fontSize={14} color="#ffffff">Cancel</Text>
            </Pressable>
            <Pressable onPress={() => setModalVisible(0)}
              style={{ padding: 12, backgroundColor: '#4ec9b0', borderRadius: 6 }}>
              <Text fontSize={14} color="#ffffff">Confirm</Text>
            </Pressable>
          </Box>
        </Box>
      </Overlay>
    </Box>
  );
}
