// Control flow test — while loops, if/else in handlers
function App() {
  const [count, setCount] = useState(0);
  const [label, setLabel] = useState("Ready");

  return (
    <Box style={{ width: '100%', height: '100%', padding: 32, flexDirection: 'column', gap: 16, backgroundColor: '#1e1e2a' }}>
      <Text fontSize={28} color="#ffffff">Control Flow Test</Text>
      <Text fontSize={48} color="#ff79c6">{`${count}`}</Text>
      <Text fontSize={20} color="#4ec9b0">{`${label}`}</Text>

      <Pressable onPress={() => {
        while (count < 10) {
          setCount(count + 1);
        }
      }} style={{ padding: 16, backgroundColor: '#4ec9b0' }}>
        <Text fontSize={16} color="#ffffff">While: count to 10</Text>
      </Pressable>

      <Pressable onPress={() => {
        if (count > 5) {
          setLabel("High");
        } else if (count > 0) {
          setLabel("Low");
        } else {
          setLabel("Zero");
        }
      }} style={{ padding: 16, backgroundColor: '#6c5ce7' }}>
        <Text fontSize={16} color="#ffffff">If/Else: classify count</Text>
      </Pressable>

      <Pressable onPress={() => {
        switch (count) {
          case 0: setLabel("Zero"); break;
          case 1: setLabel("One"); break;
          case 2: setLabel("Two"); break;
          default: setLabel("Many");
        }
      }} style={{ padding: 16, backgroundColor: '#00b894' }}>
        <Text fontSize={16} color="#ffffff">Switch: name the count</Text>
      </Pressable>

      <Pressable onPress={() => {
        for (let i = 0; i < 3; i++) {
          count += 1;
        }
      }} style={{ padding: 16, backgroundColor: '#0984e3' }}>
        <Text fontSize={16} color="#ffffff">For: count += 1 x3</Text>
      </Pressable>

      <Pressable onPress={() => { count += 5; }} style={{ padding: 16, backgroundColor: '#e17055' }}>
        <Text fontSize={16} color="#ffffff">count += 5</Text>
      </Pressable>

      <Pressable onPress={() => { count -= 3; }} style={{ padding: 16, backgroundColor: '#fdcb6e' }}>
        <Text fontSize={16} color="#1e1e2a">count -= 3</Text>
      </Pressable>

      <Pressable onPress={() => setCount(0)} style={{ padding: 12, backgroundColor: '#282838' }}>
        <Text fontSize={14} color="#78788c">Reset</Text>
      </Pressable>
    </Box>
  );
}
