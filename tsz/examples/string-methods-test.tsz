// String methods test — .length, .includes, .indexOf, .trim, .startsWith, .endsWith
function App() {
  const [text, setText] = useState("Hello World");
  const [result, setResult] = useState("Ready");

  return (
    <Box style={{ width: '100%', height: '100%', padding: 32, flexDirection: 'column', gap: 16, backgroundColor: '#1e1e2a' }}>
      <Text fontSize={28} color="#ffffff">String Methods</Text>
      <Text fontSize={20} color="#ff79c6">{`${text}`}</Text>
      <Text fontSize={20} color="#4ec9b0">{`${result}`}</Text>

      <Pressable onPress={() => {
        if (text.includes("World")) {
          setResult("Contains World!");
        } else {
          setResult("No World found");
        }
      }} style={{ padding: 16, backgroundColor: '#6c5ce7' }}>
        <Text fontSize={16} color="#ffffff">Check .includes("World")</Text>
      </Pressable>

      <Pressable onPress={() => {
        if (text.startsWith("Hello")) {
          setResult("Starts with Hello");
        } else {
          setResult("Does not start with Hello");
        }
      }} style={{ padding: 16, backgroundColor: '#00b894' }}>
        <Text fontSize={16} color="#ffffff">Check .startsWith("Hello")</Text>
      </Pressable>

      <Pressable onPress={() => setText("  Trimmed  ")} style={{ padding: 16, backgroundColor: '#e17055' }}>
        <Text fontSize={16} color="#ffffff">Set to "  Trimmed  "</Text>
      </Pressable>

      <Pressable onPress={() => setText("Goodbye")} style={{ padding: 12, backgroundColor: '#282838' }}>
        <Text fontSize={14} color="#78788c">Set to "Goodbye"</Text>
      </Pressable>
    </Box>
  );
}
