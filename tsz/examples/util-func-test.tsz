// Utility function test — non-component functions with return values
function clamp(value, min, max) {
  if (value < min) return min;
  if (value > max) return max;
  return value;
}

function double(x) {
  return x * 2;
}

function App() {
  const [count, setCount] = useState(0);
  const clamped = clamp(count, 0, 20);
  const doubled = double(count);

  return (
    <Box style={{ width: '100%', height: '100%', padding: 32, flexDirection: 'column', gap: 16, backgroundColor: '#1e1e2a' }}>
      <Text fontSize={28} color="#ffffff">Utility Functions</Text>
      <Text fontSize={48} color="#ff79c6">{`${count}`}</Text>
      <Text fontSize={20} color="#4ec9b0">{`Clamped(0-20): ${clamped}`}</Text>
      <Text fontSize={20} color="#6c5ce7">{`Doubled: ${doubled}`}</Text>

      <Pressable onPress={() => { count += 5; }} style={{ padding: 16, backgroundColor: '#4ec9b0' }}>
        <Text fontSize={16} color="#ffffff">count += 5</Text>
      </Pressable>

      <Pressable onPress={() => { count -= 3; }} style={{ padding: 16, backgroundColor: '#e17055' }}>
        <Text fontSize={16} color="#ffffff">count -= 3</Text>
      </Pressable>

      <Pressable onPress={() => setCount(0)} style={{ padding: 12, backgroundColor: '#282838' }}>
        <Text fontSize={14} color="#78788c">Reset</Text>
      </Pressable>
    </Box>
  );
}
