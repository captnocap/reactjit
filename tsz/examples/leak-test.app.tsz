// Leak test — intentionally leaks memory to test the watchdog
// The watchdog should catch it and kill the app before it eats your RAM.

// @ffi <stdlib.h>
declare function malloc(size: number): pointer;

function App() {
  const [leaked, setLeaked] = useState(0);

  return (
    <Box style={{ width: 500, padding: 32, flexDirection: 'column', gap: 16, backgroundColor: '#1e1e2a' }}>
      <Text fontSize={28} color="#ffffff">Leak Test</Text>
      <Text fontSize={14} color="#eb5757">
        This app intentionally leaks memory. The watchdog should kill it.
      </Text>

      <Box style={{ padding: 20, backgroundColor: '#282838' }}>
        <Text fontSize={36} color="#ff79c6">{`${leaked}`}</Text>
        <Text fontSize={12} color="#666688">MB leaked</Text>
      </Box>

      <Pressable onPress={() => leakMemory()} style={{ padding: 16, backgroundColor: '#eb5757' }}>
        <Text fontSize={16} color="#ffffff">Leak 64MB (click repeatedly)</Text>
      </Pressable>

      <Box style={{ padding: 12, backgroundColor: '#16161e' }}>
        <Text fontSize={11} color="#555566">
          Watchdog: 512MB hard limit, 50MB/s rate limit. Should auto-kill.
        </Text>
      </Box>
    </Box>
  );
}
