// Terminal test — PTY + libvterm with colored cell rendering
// Cells painted directly by vterm.paintTerminal via compositor overlay.

function App() {
  const [frame, setFrame] = useState(0);

  // Spawn shell on mount
  useEffect(() => spawnPty("/bin/bash", 24, 80), []);

  // Poll PTY every 16ms (~60fps)
  useEffect(() => {
    pollPty();
    setFrame(frame + 1);
  }, 16);

  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1e1e2e', flexDirection: 'column' }}>
      <Box style={{ padding: 8, backgroundColor: '#181825' }}>
        <Text fontSize={12} color="#585b70">{`Terminal 24x80 | Frame: ${frame}`}</Text>
      </Box>
      <Box testId="terminal" style={{ flexGrow: 1, backgroundColor: '#11111b' }} />
    </Box>
  );
}
