// Bisect: phase 2 + for loop only
function clamp(v, min, max) {
  if (v < min) return min;
  if (v > max) return max;
  return v;
}

function tier(score) {
  if (score >= 90) return 4;
  if (score >= 80) return 3;
  if (score >= 70) return 2;
  if (score >= 60) return 1;
  return 0;
}

function App() {
  const [scores, setScores] = useState([85, 92, 67, 45, 78, 95, 33, 88, 71, 56]);
  const [tags, setTags] = useState("math,science,history,art,music");
  const [user, setUser] = useState({ name: "Alice", level: 3 });
  const [threshold, setThreshold] = useState(70);
  const [mode, setMode] = useState(0);
  const [flags, setFlags] = useState(7);

  const passing = scores.filter(s => s >= threshold);
  const subjects = tags.split(",");
  const { name, level } = user;

  const passSum = passing.reduce((sum, s) => sum + s, 0);
  const avgScore = clamp(passSum, 0, 1000);
  const avgTier = tier(avgScore);

  const firstScore = scores[0];
  const topScore = scores.find(s => s > 90);
  const totalAll = scores.reduce((sum, s) => sum + s, 0);

  const tagLen = tags.length;
  const hasMath = tags.includes("math");
  const upper = tags.toUpperCase();
  const sliced = tags.slice(0, 4);

  const userName = user?.name;
  const display = tags ?? "none";
  const threshType = typeof threshold;

  let label = "";
  switch (mode) {
    case 0: label = "Dashboard"; break;
    case 1: label = "Scores"; break;
    case 2: label = "Tags"; break;
    default: label = "Info";
  }

  let showStats = flags & 1;

  let bonus = 0;
  for (let i = 0; i < 5; i++) {
    bonus += 10;
  }

  return (
    <Box style={{ padding: 24, backgroundColor: '#0f0f1a', width: '100%', height: '100%', flexDirection: 'column', gap: 8 }}>
      <Text fontSize={22} color="#e0e0e0">{`${label}: ${name} Lv.${level}`}</Text>
      <Text fontSize={13} color="#888888">{`Pass: ${passing.length}/${scores.length} avg=${avgScore} T${avgTier} | First:${firstScore} Top:${topScore}`}</Text>
      <Text fontSize={13} color="#6a9fb5">{`Tags(${subjects.length}): ${tagLen}ch math=${hasMath} | ${sliced}`}</Text>
      <Text fontSize={13} color="#555555">{`Flags:${flags} s=${showStats} bonus=${bonus} | type=${threshType} | total=${totalAll}`}</Text>

      <Pressable onPress={() => {
        switch (mode) {
          case 0: setMode(1); break;
          case 1: setMode(2); break;
          default: setMode(0);
        }
      }} style={{ padding: 12, backgroundColor: '#2a5a8a' }}>
        <Text fontSize={14} color="#ffffff">Cycle mode</Text>
      </Pressable>
      <Pressable onPress={() => setThreshold(threshold - 10)} style={{ padding: 12, backgroundColor: '#4a7a4a' }}>
        <Text fontSize={14} color="#ffffff">Lower threshold</Text>
      </Pressable>
      <Pressable onPress={() => setFlags(flags ^ 1)} style={{ padding: 12, backgroundColor: '#6a5a3a' }}>
        <Text fontSize={14} color="#ffffff">Toggle stats</Text>
      </Pressable>
      <Pressable onPress={() => setScores.push(99)} style={{ padding: 12, backgroundColor: '#3a5a6a' }}>
        <Text fontSize={14} color="#ffffff">Push 99</Text>
      </Pressable>
      <Pressable onPress={() => setScores.pop()} style={{ padding: 12, backgroundColor: '#5a3a3a' }}>
        <Text fontSize={14} color="#ffffff">Pop score</Text>
      </Pressable>

      {passing.map(s => (
        <Text fontSize={12} color="#4ec9b0">{`  pass: ${s}`}</Text>
      ))}
      {subjects.map(sub => (
        <Text fontSize={12} color="#c9b04e">{`  tag: ${sub}`}</Text>
      ))}
    </Box>
  );
}
