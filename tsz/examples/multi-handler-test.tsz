function App() {
  const [a, setA] = useState(0);
  const [b, setB] = useState(0);
  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%' }}>
      <Text fontSize={20} color="#ffffff">Multi-Statement Handler Test</Text>
      <Text fontSize={16} color="#808080">{`A=${a}  B=${b}`}</Text>

      <Pressable onPress={() => { setA(a + 1); setB(b + 10); }} style={{ padding: 16, backgroundColor: '#4ec9b0', borderRadius: 8, marginTop: 16 }}>
        <Text fontSize={14} color="#ffffff">Increment Both (A+1, B+10)</Text>
      </Pressable>

      <Pressable onPress={() => { setA(0); setB(0); }} style={{ padding: 16, backgroundColor: '#569cd6', borderRadius: 8, marginTop: 8 }}>
        <Text fontSize={14} color="#ffffff">Reset Both</Text>
      </Pressable>
    </Box>
  );
}
