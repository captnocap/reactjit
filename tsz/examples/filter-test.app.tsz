function App() {
    const [items, setItems] = useState([10, 20, 30, 40, 50]);
    const [threshold, setThreshold] = useState(25);

    const filtered = items.filter(item => item > threshold);

    return (
        <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%', flexDirection: 'column', gap: 12 }}>
            <Text fontSize={24} color="#ffffff">{`Filtered: ${filtered.length} of ${items.length} items (> ${threshold})`}</Text>
            {filtered.map(item => (
                <Text fontSize={14} color="#4ec9b0">{`Item: ${item}`}</Text>
            ))}
            <Pressable onPress={() => setThreshold(threshold - 5)} style={{ padding: 16, backgroundColor: '#4ec9b0' }}>
                <Text fontSize={16} color="#ffffff">Lower threshold</Text>
            </Pressable>
            <Pressable onPress={() => setThreshold(threshold + 5)} style={{ padding: 16, backgroundColor: '#e06c75' }}>
                <Text fontSize={16} color="#ffffff">Raise threshold</Text>
            </Pressable>
        </Box>
    );
}
