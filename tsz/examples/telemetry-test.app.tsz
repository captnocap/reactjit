function App() {
  const [fps, setFps] = useState(0.0);
  const [layoutMs, setLayoutMs] = useState(0.0);
  const [paintMs, setPaintMs] = useState(0.0);
  const [nodes, setNodes] = useState(0);
  const [rss, setRss] = useState(0);

  useEffect(() => {
    setFps(getFps());
    setLayoutMs(getLayoutMs());
    setPaintMs(getPaintMs());
    setNodes(getNodeCount());
    setRss(getRssMb());
  }, 500);

  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1a1a2e', padding: 32, gap: 16 }}>
      <Text fontSize={24} color="#ffffff">Telemetry Test</Text>
      <Box style={{ flexDirection: 'row', gap: 24 }}>
        <Text fontSize={16} color="#4ec9b0">{`FPS: ${fps}`}</Text>
        <Text fontSize={16} color="#888888">{`Layout: ${layoutMs}ms`}</Text>
        <Text fontSize={16} color="#888888">{`Paint: ${paintMs}ms`}</Text>
      </Box>
      <Box style={{ flexDirection: 'row', gap: 24 }}>
        <Text fontSize={16} color="#888888">{`Nodes: ${nodes}`}</Text>
        <Text fontSize={16} color="#888888">{`RSS: ${rss}MB`}</Text>
      </Box>
    </Box>
  );
}
