// Full component composition test — all Tier 1 features

function Badge({ text, bg }: { text: string; bg: string }) {
  return (
    <Box style={{ padding: 6, paddingLeft: 12, paddingRight: 12, backgroundColor: bg, borderRadius: 4 }}>
      <Text fontSize={11} color="#ffffff">{text}</Text>
    </Box>
  );
}

function StatusBar() {
  return (
    <Box style={{ flexDirection: 'row', gap: 8, padding: 8, backgroundColor: '#16161e' }}>
      <Badge text="Zig" bg="#f7a41d" />
      <Badge text="SDL2" bg="#1a5fb4" />
      <Badge text="65KB" bg="#4ec9b0" />
    </Box>
  );
}

function Card({ children }: { children: any }) {
  return (
    <Box style={{ padding: 16, backgroundColor: '#2d2d3f', borderRadius: 8 }}>
      {children}
    </Box>
  );
}

function App() {
  const [count, setCount] = useState(0);
  const doubled = count * 2;
  const label = count > 10 ? 'HIGH' : 'LOW';
  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%', gap: 12 }}>
      <Text fontSize={24} color="#ffffff">Full Component Test</Text>
      <StatusBar />
      <Card>
        <Text fontSize={16} color="#aaaaaa">{`Count: ${count} (${label})`}</Text>
        <Text fontSize={14} color="#4ec9b0">{`Doubled: ${doubled}`}</Text>
      </Card>
      <Pressable onPress={() => { setCount(count + 1); }} style={{ padding: 16, backgroundColor: '#4ec9b0', borderRadius: 8 }}>
        <Text fontSize={14} color="#ffffff">Increment</Text>
      </Pressable>
      <Pressable onPress={() => { setCount(0); }} style={{ padding: 16, backgroundColor: '#569cd6', borderRadius: 8 }}>
        <Text fontSize={14} color="#ffffff">Reset</Text>
      </Pressable>
    </Box>
  );
}
