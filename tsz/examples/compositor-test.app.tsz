function App() {
  const [angle, setAngle] = useState(0);
  const rotation = useTransition(angle, { duration: 300, easing: 'easeOut' });

  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%' }}>
      <Text fontSize={20} color="#ffffff">Compositor Test</Text>
      <Text fontSize={14} color="#808080">Click to rotate — animated via useTransition</Text>

      <Box style={{ flexDirection: 'row', gap: 16, marginTop: 16 }}>
        <Pressable onPress={() => setAngle(angle + 45)} style={{ padding: 16, backgroundColor: '#4ec9b0', borderRadius: 8 }}>
          <Text fontSize={14} color="#ffffff">Rotate +45°</Text>
        </Pressable>
        <Pressable onPress={() => setAngle(0)} style={{ padding: 16, backgroundColor: '#569cd6', borderRadius: 8 }}>
          <Text fontSize={14} color="#ffffff">Reset</Text>
        </Pressable>
      </Box>

      <Box style={{ marginTop: 48, padding: 24, backgroundColor: '#2d2d3f', borderRadius: 12, width: 200, height: 120, rotation: rotation }}>
        <Text fontSize={18} color="#ff79c6">Rotated Card</Text>
        <Text fontSize={12} color="#808080">300ms easeOut</Text>
      </Box>
    </Box>
  );
}
