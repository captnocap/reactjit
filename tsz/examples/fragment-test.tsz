function App() {
  const [count, setCount] = useState(0);
  const [items, setItems] = useState([10, 20, 30]);

  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%' }}>
      <Text fontSize={24} color="#ffffff">Fragment Test</Text>
      <>
        <Text fontSize={18} color="#4ec9b0">Inside fragment 1</Text>
        <Text fontSize={18} color="#4ec9b0">Inside fragment 2</Text>
      </>
      <Text fontSize={16} color="#aaaaaa">{`First item: ${items[0]}`}</Text>
      <Text fontSize={16} color="#aaaaaa">{`Count: ${count}`}</Text>
      <Pressable onPress={() => setCount(count + 1)} style={{ padding: 12, backgroundColor: '#333350', borderRadius: 8 }}>
        <Text fontSize={16} color="#ffffff">Increment</Text>
      </Pressable>
    </Box>
  );
}
