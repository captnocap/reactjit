function App() {
    const [csv, setCsv] = useState("apple,banana,cherry,date");

    const parts = csv.split(",");

    return (
        <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%', flexDirection: 'column', gap: 12 }}>
            <Text fontSize={24} color="#ffffff">{`Parts: ${parts.length}`}</Text>
            {parts.map(part => (
                <Text fontSize={14} color="#4ec9b0">{`- ${part}`}</Text>
            ))}
        </Box>
    );
}
