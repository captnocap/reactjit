function Badge({ text, bg }: { text: string; bg: string }) {
  return (
    <Box style={{ padding: 6, paddingLeft: 12, paddingRight: 12, backgroundColor: bg, borderRadius: 4 }}>
      <Text fontSize={11} color="#ffffff">{text}</Text>
    </Box>
  );
}

function App() {
  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%' }}>
      <Text fontSize={20} color="#ffffff">Component Test</Text>
      <Box style={{ flexDirection: 'row', gap: 8, marginTop: 16 }}>
        <Badge text="Zig" bg="#f7a41d" />
        <Badge text="SDL2" bg="#1a5fb4" />
        <Badge text="No Runtime" bg="#4ec9b0" />
      </Box>
    </Box>
  );
}
