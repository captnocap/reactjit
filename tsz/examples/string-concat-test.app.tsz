// String concatenation with + operator
function App() {
  const [name, setName] = useState("World");
  const greeting = "Hello, " + name + "!";

  return (
    <Box style={{ width: '100%', height: '100%', padding: 32, flexDirection: 'column', gap: 16, backgroundColor: '#1e1e2a' }}>
      <Text fontSize={28} color="#ffffff">String Concat</Text>
      <Text fontSize={24} color="#4ec9b0">{`${greeting}`}</Text>

      <Pressable onPress={() => setName("Zig")} style={{ padding: 16, backgroundColor: '#6c5ce7' }}>
        <Text fontSize={16} color="#ffffff">Set name = "Zig"</Text>
      </Pressable>

      <Pressable onPress={() => setName("World")} style={{ padding: 12, backgroundColor: '#282838' }}>
        <Text fontSize={14} color="#78788c">Reset</Text>
      </Pressable>
    </Box>
  );
}
