          <Box style={{ padding: 12, backgroundColor: '#313244', borderRadius: 6 }}>
            <Text fontSize={12} color="#cdd6f4">Item 4</Text>
          </Box>
          <Box style={{ padding: 12, backgroundColor: '#313244', borderRadius: 6 }}>
            <Text fontSize={12} color="#cdd6f4">Item 5</Text>
          </Box>
          <Box style={{ padding: 12, backgroundColor: '#313244', borderRadius: 6 }}>
            <Text fontSize={12} color="#cdd6f4">Item 6</Text>
          </Box>
          <Box style={{ padding: 12, backgroundColor: '#313244', borderRadius: 6 }}>
            <Text fontSize={12} color="#cdd6f4">Item 7</Text>
          </Box>
          <Box style={{ padding: 12, backgroundColor: '#313244', borderRadius: 6 }}>
            <Text fontSize={12} color="#cdd6f4">Item 8 — Scroll down to see me</Text>
          </Box>
          <Box style={{ padding: 12, backgroundColor: '#313244', borderRadius: 6 }}>
            <Text fontSize={12} color="#cdd6f4">Item 9</Text>
          </Box>
          <Box style={{ padding: 12, backgroundColor: '#313244', borderRadius: 6 }}>
            <Text fontSize={12} color="#a6e3a1">Item 10 — Last item</Text>
