        </ScrollView>
      </C.Card>

      {/* Log viewer pattern */}
      <C.Card>
        <C.CardTitle>Log Viewer</C.CardTitle>
        <C.CardCaption>Monospace text in a scroll container — the classic log tail pattern.</C.CardCaption>
        <ScrollView style={{
          height: 160, backgroundColor: '#11111b',
          borderRadius: 8, padding: 8, gap: 2
        }}>
          <Text fontSize={11} color="#6c7086">[00:00:01] App initialized</Text>
