// ScrollViewStory.tsz — ScrollView demos

import { Card, CardTitle, CardCaption, Row, Title, Subtitle, Badge } from '../styles.cls';

function ScrollViewStory() {
  return (
    <Box style={{ gap: 24 }}>
      <Box style={{ gap: 4 }}>
        <C.Title>ScrollView</C.Title>
        <C.Subtitle>Scrollable containers. Needs explicit height to activate.</C.Subtitle>
      </Box>

      {/* Vertical scroll */}
      <C.Card>
        <C.CardTitle>Vertical Scroll</C.CardTitle>
