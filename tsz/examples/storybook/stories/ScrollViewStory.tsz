          <Text fontSize={11} color="#6c7086">[00:00:02] Connecting to database</Text>
          <Text fontSize={11} color="#a6e3a1">[00:00:03] Database connected (12ms)</Text>
          <Text fontSize={11} color="#6c7086">[00:00:03] Starting HTTP server</Text>
          <Text fontSize={11} color="#a6e3a1">[00:00:03] Listening on :8080</Text>
          <Text fontSize={11} color="#89b4fa">[00:00:05] GET /api/health → 200 (2ms)</Text>
          <Text fontSize={11} color="#89b4fa">[00:00:06] GET /api/users → 200 (45ms)</Text>
          <Text fontSize={11} color="#f9e2af">[00:00:08] WARN: slow query (>100ms) on /api/reports</Text>
          <Text fontSize={11} color="#89b4fa">[00:00:09] POST /api/data → 201 (12ms)</Text>
          <Text fontSize={11} color="#f38ba8">[00:00:12] ERROR: connection reset by peer</Text>
          <Text fontSize={11} color="#6c7086">[00:00:12] Reconnecting...</Text>
          <Text fontSize={11} color="#a6e3a1">[00:00:13] Reconnected OK</Text>
          <Text fontSize={11} color="#89b4fa">[00:00:15] GET /api/health → 200 (1ms)</Text>
