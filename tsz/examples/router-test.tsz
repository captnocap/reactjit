function App() {
  return (
    <Box style={{ width: '100%', height: '100%' }}>
      <Routes>
        <Route path="/" element={
          <Box style={{ padding: 32, backgroundColor: '#1e1e2a', flexGrow: 1 }}>
            <Text fontSize={24} color="#ffffff">Home Page</Text>
            <Pressable onPress={() => navigate('/settings')} style={{ padding: 16, backgroundColor: '#4ec9b0', marginTop: 8, borderRadius: 8 }}>
              <Text fontSize={16} color="#ffffff">Go to Settings</Text>
            </Pressable>
            <Pressable onPress={() => navigate('/about')} style={{ padding: 16, backgroundColor: '#569cd6', marginTop: 8, borderRadius: 8 }}>
              <Text fontSize={16} color="#ffffff">Go to About</Text>
            </Pressable>
          </Box>
        } />
        <Route path="/settings" element={
          <Box style={{ padding: 32, backgroundColor: '#2d2d3d', flexGrow: 1 }}>
            <Text fontSize={24} color="#ffffff">Settings Page</Text>
            <Text fontSize={14} color="#888888">Configure your preferences here</Text>
            <Pressable onPress={() => navigate('/')} style={{ padding: 16, backgroundColor: '#569cd6', marginTop: 16, borderRadius: 8 }}>
              <Text fontSize={16} color="#ffffff">Back to Home</Text>
            </Pressable>
          </Box>
        } />
        <Route path="/about" element={
          <Box style={{ padding: 32, backgroundColor: '#1a2a1a', flexGrow: 1 }}>
            <Text fontSize={24} color="#ffffff">About Page</Text>
            <Text fontSize={14} color="#888888">tsz compile-time router demo</Text>
            <Pressable onPress={() => navigate('/')} style={{ padding: 16, backgroundColor: '#569cd6', marginTop: 16, borderRadius: 8 }}>
              <Text fontSize={16} color="#ffffff">Back to Home</Text>
            </Pressable>
          </Box>
        } />
      </Routes>
    </Box>
  );
}
