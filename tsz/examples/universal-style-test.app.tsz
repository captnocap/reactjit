// Universal Style Parser — identical cards rendered 3 ways: CSS, Tailwind, Bootstrap

function App() {
  return (
    <Box style={{ backgroundColor: '#1e1e2a', flexDirection: 'column', padding: 24, gap: 16 }}>
      <Text fontSize={20} color="#ffffff">Same card, three syntaxes:</Text>

      <Box style={{ flexDirection: 'column', gap: 8 }}>
        <Text fontSize={14} color="gray">1. Inline CSS (kebab-case + units)</Text>
        <Box style={{ 'background-color': '#1e293b', 'flex-direction': 'column', padding: '16px', 'border-radius': '8px', gap: '8px' }}>
          <Text fontSize={18} color="white">Card Title</Text>
          <Text fontSize={14} color="silver">Body text in a padded, rounded card</Text>
          <Box style={{ 'flex-direction': 'row', gap: '8px' }}>
            <Box style={{ 'background-color': '#14b8a6', padding: '8px', 'border-radius': '4px' }}>
              <Text fontSize={12} color="white">Tag A</Text>
            </Box>
            <Box style={{ 'background-color': '#a855f7', padding: '8px', 'border-radius': '4px' }}>
              <Text fontSize={12} color="white">Tag B</Text>
            </Box>
          </Box>
        </Box>
      </Box>

      <Box style={{ flexDirection: 'column', gap: 8 }}>
        <Text fontSize={14} color="gray">2. Tailwind classes</Text>
        <Box className="bg-slate-800 flex-col p-4 rounded-lg gap-2">
          <Text fontSize={18} color="#ffffff">Card Title</Text>
          <Text fontSize={14} color="#c0c0c0">Body text in a padded, rounded card</Text>
          <Box className="flex-row gap-2">
            <Box className="bg-teal-500 p-2 rounded">
              <Text fontSize={12} color="#ffffff">Tag A</Text>
            </Box>
            <Box className="bg-purple-500 p-2 rounded">
              <Text fontSize={12} color="#ffffff">Tag B</Text>
            </Box>
          </Box>
        </Box>
      </Box>

      <Box style={{ flexDirection: 'column', gap: 8 }}>
        <Text fontSize={14} color="gray">3. Bootstrap classes</Text>
        <Box className="d-flex flex-column p-3 rounded-2 gap-2" style={{ backgroundColor: '#1e293b' }}>
          <Text fontSize={18} color="#ffffff">Card Title</Text>
          <Text fontSize={14} color="#c0c0c0">Body text in a padded, rounded card</Text>
          <Box className="d-flex flex-row gap-1">
            <Box style={{ backgroundColor: '#14b8a6', padding: 8, borderRadius: 4 }}>
              <Text fontSize={12} color="#ffffff">Tag A</Text>
            </Box>
            <Box style={{ backgroundColor: '#a855f7', padding: 8, borderRadius: 4 }}>
              <Text fontSize={12} color="#ffffff">Tag B</Text>
            </Box>
          </Box>
        </Box>
      </Box>
    </Box>
  );
}
