// Array methods test — .includes, .indexOf, .find, .reduce
function App() {
  const [items, setItems] = useState([10, 20, 30, 40, 50]);
  const [count, setCount] = useState(0);

  const total = items.reduce((sum, item) => sum + item, 0);
  const hasThirty = items.includes(30);
  const firstBig = items.find(item => item > 25);

  return (
    <Box style={{ width: '100%', height: '100%', padding: 32, flexDirection: 'column', gap: 16, backgroundColor: '#1e1e2a' }}>
      <Text fontSize={28} color="#ffffff">Array Methods</Text>
      <Text fontSize={20} color="#4ec9b0">{`Total (reduce): ${total}`}</Text>
      <Text fontSize={20} color="#6c5ce7">{`First > 25 (find): ${firstBig}`}</Text>
      <Text fontSize={14} color="#78788c">{`Items: ${items.length}`}</Text>

      <Pressable onPress={() => {
        setItems.push(count);
        count += 10;
      }} style={{ padding: 16, backgroundColor: '#4ec9b0' }}>
        <Text fontSize={16} color="#ffffff">{`Push ${count}`}</Text>
      </Pressable>

      <Pressable onPress={() => setCount(0)} style={{ padding: 12, backgroundColor: '#282838' }}>
        <Text fontSize={14} color="#78788c">Reset counter</Text>
      </Pressable>
    </Box>
  );
}
