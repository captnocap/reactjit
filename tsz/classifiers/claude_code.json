{
  "name": "claude_code",
  "version": "1.0",
  "description": "Full semantic classifier for the Claude Code CLI — 25+ tokens covering all UI states",
  "command": ["claude"],
  "tokens": {
    "user_prompt":      { "role": "user",      "lane": "prompt", "color": "#60a5fa", "block": false },
    "user_text":        { "role": "user",      "lane": "text",   "color": "#e2e8f0", "block": true },
    "assistant_text":   { "role": "assistant", "lane": "text",   "color": "#e2e8f0", "block": true },
    "thinking":         { "role": "assistant", "lane": "think",  "color": "#a78bfa", "block": true },
    "thought_complete": { "role": "assistant", "lane": "think",  "color": "#94a3b8", "block": false },
    "tool":             { "role": "assistant", "lane": "tool",   "color": "#eab308", "block": false },
    "result":           { "role": "assistant", "lane": "result", "color": "#94a3b8", "block": false },
    "diff":             { "role": "assistant", "lane": "diff",   "color": "#4ade80", "block": true },
    "error":            { "role": "assistant", "lane": "error",  "color": "#f87171", "block": false },
    "banner":           { "role": "system",    "lane": "state",  "color": "#94a3b8", "block": true, "scope": "session" },
    "status_bar":       { "role": "system",    "lane": "state",  "color": "#64748b", "block": true, "scope": "session" },
    "box_drawing":      { "role": "system",    "lane": "state",  "color": "#334155", "block": false },
    "input_border":     { "role": "system",    "lane": "prompt", "color": "#334155", "block": true, "scope": "session" },
    "input_zone":       { "role": "system",    "lane": "prompt", "color": "#e2e8f0", "block": false, "scope": "session" },
    "permission":       { "role": "system",    "lane": "state",  "color": "#f97316", "block": false },
    "menu_title":       { "role": "system",    "lane": "state",  "color": "#e2e8f0", "block": false },
    "menu_option":      { "role": "system",    "lane": "state",  "color": "#e2e8f0", "block": false },
    "menu_desc":        { "role": "system",    "lane": "state",  "color": "#94a3b8", "block": false },
    "hint":             { "role": "system",    "lane": "state",  "color": "#94a3b8", "block": false },
    "task_done":        { "role": "assistant", "lane": "state",  "color": "#4ade80", "block": false },
    "task_active":      { "role": "assistant", "lane": "state",  "color": "#f97316", "block": false },
    "task_open":        { "role": "assistant", "lane": "state",  "color": "#94a3b8", "block": false },
    "task_summary":     { "role": "assistant", "lane": "state",  "color": "#60a5fa", "block": false },
    "text":             { "role": "system",    "lane": "text",   "color": "#e2e8f0", "block": true }
  },
  "rules": [
    { "token": "permission",       "match": "contains",    "value": "Do you want to ",  "also": { "match": "contains", "value": "?" } },
    { "token": "menu_option",      "match": "regex",       "pattern": "^\\s*[>]?\\s*\\d+\\.\\s+" },
    { "token": "banner",           "match": "contains",    "value": "Claude Code v" },
    { "token": "banner",           "match": "contains",    "value": "Claude Code",      "max_row": 5 },
    { "token": "banner",           "match": "regex",       "pattern": "Opus \\d|Sonnet \\d|Haiku \\d", "max_row": 5 },
    { "token": "banner",           "match": "contains",    "value": "~/",               "max_row": 5 },
    { "token": "hint",             "match": "contains",    "value": "to adjust" },
    { "token": "hint",             "match": "contains",    "value": "\u2190 \u2192" },
    { "token": "hint",             "match": "contains",    "value": "Enter to confirm" },
    { "token": "status_bar",       "match": "regex",       "pattern": "\\d+\\s*tokens" },
    { "token": "status_bar",       "match": "contains",    "value": "for shortcuts" },
    { "token": "status_bar",       "match": "contains",    "value": "esc to interrupt" },
    { "token": "input_border",     "match": "contains",    "value": "\u2500\u2500\u2500\u2500", "on": "trimmed", "zone": "bottom_8" },
    { "token": "input_zone",       "match": "equals",      "value": "\u276f",           "on": "trimmed", "zone": "bottom_8" },
    { "token": "input_zone",       "match": "contains",    "value": "\u276f",           "zone": "bottom_8", "not_contains": "Imagining" },
    { "token": "input_zone",       "match": "regex",       "pattern": "^> .",            "zone": "bottom_8" },
    { "token": "user_prompt",      "match": "contains",    "value": "\u276f",           "not_contains": "Imagining" },
    { "token": "user_prompt",      "match": "regex",       "pattern": "^> ." },
    { "token": "thought_complete", "match": "contains",    "value": "\u273b" },
    { "token": "task_done",        "match": "contains",    "value": "\u2714" },
    { "token": "task_open",        "match": "contains",    "value": "\u25fb" },
    { "token": "task_active",      "match": "contains",    "value": "\u2026", "also": { "match": "contains", "value": "tokens" } },
    { "token": "task_summary",     "match": "regex",       "pattern": "\\d+\\s+tasks?\\s*\\(" },
    { "token": "thinking",         "match": "contains",    "value": "Imagining" },
    { "token": "thinking",         "match": "contains",    "value": "Thinking" },
    { "token": "banner",           "match": "contains",    "value": "Entered plan mode" },
    { "token": "banner",           "match": "contains",    "value": "Exited plan mode" },
    { "token": "tool",             "match": "regex",       "pattern": "[\u25cf\u2022\u25c6]\\s+\\w+\\(" },
    { "token": "diff",             "match": "regex",       "pattern": "^[+\\-]" },
    { "token": "result",           "match": "contains",    "value": "\u23bf" },
    { "token": "box_drawing",      "match": "regex",       "pattern": "[\u250c\u256d\u2502\u2514\u2570]", "on": "trimmed" },
    { "token": "error",            "match": "starts_with", "value": "Error:" },
    { "token": "error",            "match": "starts_with", "value": "error:" }
  ],
  "adjacency": [
    { "when_prev": ["user_prompt", "user_text"],     "when_current": "text",  "promote_to": "user_text" },
    { "when_prev": ["user_prompt", "user_text"],     "when_current": "output","promote_to": "user_text" },
    { "when_prev": ["tool", "thinking", "thought_complete", "result", "assistant_text", "task_done", "task_open", "task_summary", "task_active", "diff"],
      "when_current": "text",  "promote_to": "assistant_text" },
    { "when_prev": ["tool", "thinking", "thought_complete", "result", "assistant_text", "task_done", "task_open", "task_summary", "task_active", "diff"],
      "when_current": "output","promote_to": "assistant_text" },
    { "when_prev": ["menu_option"],                  "when_current": "text",  "promote_to": "menu_desc" },
    { "when_current": "text", "text_contains": "Enter to select", "promote_to": "hint" },
    { "when_current": "text", "text_contains": "Arrow keys",      "promote_to": "hint" },
    { "when_current": "text", "text_contains": "Esc to cancel",   "promote_to": "hint" },
    { "when_current": "text", "text_contains": "Type to search",  "promote_to": "hint" }
  ],
  "turn_start": ["user_prompt"],
  "groups": {
    "menu":       ["menu_title", "menu_option", "menu_desc", "hint"],
    "task":       ["task_summary", "task_done", "task_open", "task_active"],
    "permission": ["permission"]
  },
  "state_derivation": {
    "thinking":       { "mode": "thinking",   "streaming": true },
    "tool":           { "mode": "tool_use",   "streaming": true },
    "assistant_text": { "mode": "responding", "streaming": true },
    "permission":     { "mode": "permission", "awaiting_decision": true, "modal_open": true },
    "menu_title":     { "mode": "menu",       "modal_open": true },
    "menu_option":    { "mode": "menu",       "modal_open": true }
  },
  "default_token": "text"
}
