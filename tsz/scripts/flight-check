#!/bin/bash
# flight-check — post-compile integrity check for generated Zig
# Validates that source .tsz content survived compilation intact.
#
# Runs AFTER forge (Smith), BEFORE zig build.
# Catches: phantom colors, dropped colors, handler imbalance,
#          state slot mismatch, dropped static text.
#
# Usage:
#   ./scripts/flight-check <source.tsz> <gen_dir_or_file>
#   Exit 0 = clean, Exit 2 = failures

SOURCE="${1:-}"
GEN="${2:-}"

if [ -z "$SOURCE" ] || [ -z "$GEN" ]; then
    echo "Usage: flight-check <source.tsz> <gen_dir_or_file>"
    exit 1
fi

NAME=$(basename "$SOURCE" .tsz | sed 's/\.app$//')

# Concat all generated .zig into one blob for searching
if [ -d "$GEN" ]; then
    GEN_BLOB=$(cat "$GEN"/*.zig 2>/dev/null)
else
    GEN_BLOB=$(cat "$GEN" 2>/dev/null)
fi

if [ -z "$GEN_BLOB" ]; then
    echo "[flight] ERROR: no generated code found at $GEN"
    exit 2
fi

FAILS=0

fail() { echo "[flight] FAIL: $1"; FAILS=$((FAILS + 1)); }
warn() { echo "[flight] WARN: $1"; }

# Detect lua-tree mode (LUA_LOGIC with __render = lua-tree architecture)
IS_LUA_TREE=0
if grep -q '__render' <<< "$GEN_BLOB" 2>/dev/null && grep -q 'LUA_LOGIC' <<< "$GEN_BLOB" 2>/dev/null; then
    IS_LUA_TREE=1
fi

# Extract LUA_LOGIC block for lua-tree checks
LUA_BLOB=""
if [ "$IS_LUA_TREE" -eq 1 ]; then
    if [ -d "$GEN" ]; then
        LUA_BLOB=$(sed -n '/^pub const LUA_LOGIC/,/^;$/p' "$GEN/logic.zig" 2>/dev/null)
    else
        LUA_BLOB=$(sed -n '/^pub const LUA_LOGIC/,/^;$/p' "$GEN" 2>/dev/null)
    fi
fi

# Safe grep count — always returns a clean number, never fails
gcount() { local n; n=$(grep -cE "$1" <<< "$2" 2>/dev/null) || n=0; echo "$n"; }
gcount_file() { local n; n=$(grep -cE "$1" "$2" 2>/dev/null) || n=0; echo "$n"; }
gocount() { grep -oE "$1" <<< "$2" 2>/dev/null | wc -l | tr -d ' '; }
gocount_file() { grep -oE "$1" "$2" 2>/dev/null | wc -l | tr -d ' '; }

# ── Hex-to-RGB helper ─────────────────────────────────────────
hex_to_rgb() {
    local hex="${1#\#}"
    if [ ${#hex} -eq 3 ]; then
        hex="${hex:0:1}${hex:0:1}${hex:1:1}${hex:1:1}${hex:2:1}${hex:2:1}"
    fi
    # Strip alpha channel from 8-digit RGBA hex
    if [ ${#hex} -eq 8 ]; then
        hex="${hex:0:6}"
    fi
    local r=$((16#${hex:0:2}))
    local g=$((16#${hex:2:2}))
    local b=$((16#${hex:4:2}))
    echo "$r, $g, $b"
}

# ── 1. Color integrity ────────────────────────────────────────
# Skip color checks entirely for classifier-only files — their colors are consumed
# by the classifier data structures, not emitted as direct Color.rgb() calls.
IS_CLASSIFIER=0
case "$SOURCE" in *.cls.tsz|*.tcls.tsz|*.vcls.tsz) IS_CLASSIFIER=1 ;; esac

SOURCE_COLORS=$(grep -oE '#[0-9a-fA-F]{3,8}' "$SOURCE" 2>/dev/null | sort -u || true)

if [ "$IS_CLASSIFIER" -eq 0 ]; then

SOURCE_HAS_WHITE=0
for c in $SOURCE_COLORS; do
    norm=$(echo "$c" | tr '[:upper:]' '[:lower:]')
    case "$norm" in
        "#fff"|"#ffffff"|"#ffffffff") SOURCE_HAS_WHITE=1 ;;
    esac
done

if [ "$SOURCE_HAS_WHITE" -eq 0 ]; then
    PHANTOM_WHITES=$(gocount '(background_color|border_color) = Color\.rgb\(255, 255, 255\)' "$GEN_BLOB")
    if [ "$PHANTOM_WHITES" -gt 0 ]; then
        fail "$PHANTOM_WHITES phantom white Color.rgb(255,255,255) in output — source has no #ffffff on background/border"
    fi
fi

# Find component functions that are defined but never used in JSX
UNUSED_COMP_COLORS=""
DEFINED_COMPS=$(grep -oE '^function ([A-Z][A-Za-z0-9_]+)' "$SOURCE" 2>/dev/null | sed 's/^function //' | grep -v '^App$' || true)
for comp in $DEFINED_COMPS; do
    if ! grep -qE "<$comp[ />]" "$SOURCE"; then
        # This component is never used — collect its colors to exclude
        COMP_BODY=$(sed -n "/^function $comp/,/^function \|^}/p" "$SOURCE" 2>/dev/null)
        COMP_HEX=$(echo "$COMP_BODY" | grep -oE '#[0-9a-fA-F]{3,8}' | sort -u || true)
        UNUSED_COMP_COLORS="$UNUSED_COMP_COLORS $COMP_HEX"
    fi
done

# Also exclude colors from lowercase helper functions (non-components) that
# return colors via runtime dispatch (e.g. cardBg(cType) — called with variable args).
# These colors can't appear in statically generated Zig output.
HELPER_FN_COLORS=""
DEFINED_HELPERS=$(grep -oE '^function ([a-z][A-Za-z0-9_]+)' "$SOURCE" 2>/dev/null | sed 's/^function //' || true)
for hfn in $DEFINED_HELPERS; do
    HFN_BODY=$(sed -n "/^function $hfn/,/^function \|^}/p" "$SOURCE" 2>/dev/null)
    HFN_HEX=$(echo "$HFN_BODY" | grep -oE '#[0-9a-fA-F]{3,8}' | sort -u || true)
    for hc in $HFN_HEX; do
        # Only exclude if this color doesn't also appear in JSX style attributes
        # (i.e. not inside a function body — appears at top level or in component JSX)
        TOTAL_COUNT=$(grep -oE '#[0-9a-fA-F]{3,8}' "$SOURCE" 2>/dev/null | grep -c "^${hc}$" || true)
        FN_COUNT=0
        for _afn in $DEFINED_HELPERS $DEFINED_COMPS; do
            AFN_BODY=$(sed -n "/^function $_afn/,/^function \|^}/p" "$SOURCE" 2>/dev/null)
            FC=$(echo "$AFN_BODY" | grep -oE '#[0-9a-fA-F]{3,8}' | grep -c "^${hc}$" || true)
            FN_COUNT=$((FN_COUNT + FC))
        done
        [ "$TOTAL_COUNT" -le "$FN_COUNT" ] && HELPER_FN_COLORS="$HELPER_FN_COLORS $hc"
    done
done
# HELPER_FN_COLORS bypass the secondary unused-component check below
# because they've already been verified: total occurrences <= function body occurrences.

# Check each source color lands in generated output
DROPPED=0
DROPPED_LIST=""
for hex in $SOURCE_COLORS; do
    # Skip RGBA hex — compiler strips alpha, Color.rgb() only has RGB
    hex_stripped="${hex#\#}"
    [ ${#hex_stripped} -eq 8 ] && continue
    # Skip colors only reachable through helper function calls (runtime dispatch)
    SKIP_HELPER=0
    for _hfc in $HELPER_FN_COLORS; do
        if [ "$hex" = "$_hfc" ]; then SKIP_HELPER=1; break; fi
    done
    [ "$SKIP_HELPER" -eq 1 ] && continue
    # Skip colors that only appear in unused components
    if [ -n "$UNUSED_COMP_COLORS" ]; then
        IS_UNUSED_ONLY=0
        for uc in $UNUSED_COMP_COLORS; do
            if [ "$hex" = "$uc" ]; then IS_UNUSED_ONLY=1; break; fi
        done
        # Only skip if the color doesn't ALSO appear in used code
        if [ "$IS_UNUSED_ONLY" -eq 1 ]; then
            # Check if this color appears outside the unused component(s)
            OUTSIDE_COUNT=$(grep -oE '#[0-9a-fA-F]{3,8}' "$SOURCE" 2>/dev/null | grep -c "^${hex}$" || true)
            INSIDE_COUNT=0
            for comp in $DEFINED_COMPS; do
                if ! grep -qE "<$comp[ />]" "$SOURCE"; then
                    COMP_BODY=$(sed -n "/^function $comp/,/^function \|^}/p" "$SOURCE" 2>/dev/null)
                    IC=$(echo "$COMP_BODY" | grep -oE '#[0-9a-fA-F]{3,8}' | grep -c "^${hex}$" || true)
                    INSIDE_COUNT=$((INSIDE_COUNT + IC))
                fi
            done
            [ "$OUTSIDE_COUNT" -le "$INSIDE_COUNT" ] && continue
        fi
    fi
    rgb=$(hex_to_rgb "$hex")
    if ! grep -q "Color\.rgb($rgb)" <<< "$GEN_BLOB"; then
        hex_lower=$(echo "$hex" | tr '[:upper:]' '[:lower:]')
        hex_bare="${hex_lower#\#}"
        # Check for #hex (Zig), 0xhex (Lua map templates), or raw hex
        if ! grep -qi -- "$hex_lower" <<< "$GEN_BLOB"; then
            if ! grep -qi -- "0x${hex_bare}" <<< "$GEN_BLOB"; then
                DROPPED=$((DROPPED + 1))
                DROPPED_LIST="$DROPPED_LIST $hex"
            fi
        fi
    fi
done

if [ "$DROPPED" -gt 0 ]; then
    fail "$DROPPED source color(s) not found in generated output:$DROPPED_LIST"
fi

fi # IS_CLASSIFIER color integrity skip

# ── 2. Color{} placeholder audit ──────────────────────────────
if [ "$IS_CLASSIFIER" -eq 0 ]; then
EMPTY_COLORS=$(gocount '(background_color|border_color|text_color) = Color\{\}' "$GEN_BLOB")
if [ "$EMPTY_COLORS" -gt 0 ]; then
    DYN_COLOR_EXPRS=$(gcount_file '(color|backgroundColor|borderColor):.*\?' "$SOURCE")
    # Also count classifier-style color references and ternary color patterns
    DYN_COLOR_CLS=$(gcount_file 'C\.[A-Z]' "$SOURCE")
    DYN_COLOR_TERNARY=$(gocount_file '#[0-9a-fA-F]{3,8}.*\?' "$SOURCE")
    DYN_COLOR_TOTAL=$((DYN_COLOR_EXPRS + DYN_COLOR_CLS + DYN_COLOR_TERNARY))
    if [ "$EMPTY_COLORS" -gt "$((DYN_COLOR_TOTAL + 4))" ]; then
        fail "$EMPTY_COLORS Color{} placeholders but only ~$DYN_COLOR_TOTAL dynamic color expressions in source"
    fi
fi
fi # IS_CLASSIFIER Color{} skip

# ── Sections 3-16: Zig-mode checks (skip for lua-tree) ───────
# These check Zig node arrays, _rebuildMap, createSlot, etc.
# Lua-tree has its own checks in the LT section below.
if [ "$IS_LUA_TREE" -eq 0 ]; then

# ── 3. Handler balance ────────────────────────────────────────
# Count unique handler patterns — avoid double-counting onChange
SRC_HANDLERS=$(gocount_file 'on(Press|Scroll|Focus|Blur)\s*=' "$SOURCE")
SRC_SOUP_HANDLERS=$(gocount_file 'on(Click|Submit)\s*=' "$SOURCE")
SRC_CHANGE_ONLY=$(gocount_file 'on(Change|ChangeText)\s*=' "$SOURCE")
SRC_HANDLERS=$((SRC_HANDLERS + SRC_SOUP_HANDLERS + SRC_CHANGE_ONLY))

GEN_HANDLER_FNS=$(gcount 'pub fn _handler_(press|change|scroll|focus|blur)_[0-9]+' "$GEN_BLOB")
GEN_MAP_HANDLER_SETS=$(gocount '_map_lua_bufs_[0-9]+_[0-9]+' "$GEN_BLOB")
# Also count soup-style JS handlers (_sh_N) and js_on_press wiring
GEN_JS_HANDLERS=$(gocount 'js_on_press = "[^"]*"' "$GEN_BLOB")
# Count lua_on_press, js_on_change, and on_press function assignments
GEN_LUA_HANDLERS=$(gocount 'lua_on_press = ' "$GEN_BLOB")
GEN_JS_CHANGE=$(gocount 'js_on_change = ' "$GEN_BLOB")
GEN_ON_PRESS_FN=$(gocount '\.on_press = ' "$GEN_BLOB")
# Count soup-style input change/submit handlers wired via setOnChange/setOnSubmit
GEN_INPUT_CHANGE_FNS=$(gocount 'fn _inputChange[0-9]+' "$GEN_BLOB")
GEN_INPUT_SUBMIT_FNS=$(gocount 'fn _inputSubmit[0-9]+' "$GEN_BLOB")
GEN_HANDLERS=$((GEN_HANDLER_FNS + GEN_MAP_HANDLER_SETS + GEN_JS_HANDLERS + GEN_LUA_HANDLERS + GEN_JS_CHANGE + GEN_ON_PRESS_FN + GEN_INPUT_CHANGE_FNS + GEN_INPUT_SUBMIT_FNS))

if [ "$SRC_HANDLERS" -gt 0 ] && [ "$GEN_HANDLERS" -eq 0 ]; then
    fail "$SRC_HANDLERS handler(s) in source but 0 in generated output"
elif [ "$SRC_HANDLERS" -gt "$((GEN_HANDLERS + 5))" ]; then
    fail "handler imbalance: $SRC_HANDLERS in source, $GEN_HANDLERS generated"
fi

# ── 3b. Orphaned JS handlers ────────────────────────────────
# JS defines handler functions (_sh_N, __mapPress_N_M) that must be wired
# to a node's js_on_press. If defined but not referenced, handlers are lost.
JS_HANDLER_DEFS=$(gocount 'function (_sh_[0-9]+|__mapPress_[0-9]+_[0-9]+)\(' "$GEN_BLOB")
JS_HANDLER_REFS=$(gocount 'js_on_press = "[^"]*"' "$GEN_BLOB")
# Map handlers also count — each _map_lua_bufs set is one handler wired per-item
JS_HANDLER_REFS=$((JS_HANDLER_REFS + GEN_MAP_HANDLER_SETS))
# onChange/onSubmit handlers routed through _inputChange/_inputSubmit Zig wrappers
# count as wired — the _sh_N body was rewritten into the Zig wrapper, so the
# JS-side _sh_N is vestigial but the handler IS connected.
GEN_INPUT_WIRED=$(gocount 'setOnChange|setOnSubmit' "$GEN_BLOB")
JS_HANDLER_REFS=$((JS_HANDLER_REFS + GEN_INPUT_WIRED))

if [ "$JS_HANDLER_DEFS" -gt 0 ] && [ "$JS_HANDLER_REFS" -eq 0 ]; then
    fail "$JS_HANDLER_DEFS JS handler(s) defined but 0 wired to nodes — all handlers orphaned"
elif [ "$JS_HANDLER_DEFS" -gt 0 ] && [ "$JS_HANDLER_REFS" -lt "$JS_HANDLER_DEFS" ]; then
    ORPHANED=$((JS_HANDLER_DEFS - JS_HANDLER_REFS))
    fail "$ORPHANED orphaned JS handler(s): $JS_HANDLER_DEFS defined, $JS_HANDLER_REFS wired to nodes"
fi

# ── 3e. Missing change handlers ──────────────────────────────
# If source has onChangeText/onChange but generated code has zero
# change handler wiring, the change handlers were dropped entirely.
SRC_CHANGE_HANDLERS=$(gocount_file 'on(ChangeText|Change)\s*=' "$SOURCE")
if [ "$SRC_CHANGE_HANDLERS" -gt 0 ]; then
    GEN_CHANGE_FNS=$(gcount '_handler_change_[0-9]' "$GEN_BLOB")
    GEN_CHANGE_NEW=$(gcount '_inputChange[0-9]' "$GEN_BLOB")
    GEN_CHANGE_WIRED=$(gocount 'js_on_change' "$GEN_BLOB")
    GEN_CHANGE_SETONCHANGE=$(gocount 'setOnChange' "$GEN_BLOB")
    GEN_CHANGE_LUA=$(gocount 'lua_on_change' "$GEN_BLOB")
    GEN_CHANGE_EDIT=$(gocount 'on_edit_change' "$GEN_BLOB")
    # TextInput nodes inherently support change — count those too
    GEN_TEXT_INPUTS=$(gocount 'is_text_input = true' "$GEN_BLOB")
    GEN_INPUT_IDS=$(gocount 'input_id = ' "$GEN_BLOB")
    GEN_CHANGE_TOTAL=$((GEN_CHANGE_FNS + GEN_CHANGE_NEW + GEN_CHANGE_WIRED + GEN_CHANGE_SETONCHANGE + GEN_CHANGE_LUA + GEN_CHANGE_EDIT + GEN_TEXT_INPUTS + GEN_INPUT_IDS))
    if [ "$GEN_CHANGE_TOTAL" -eq 0 ]; then
        fail "$SRC_CHANGE_HANDLERS onChangeText/onChange handler(s) in source but 0 change handlers in generated — all dropped"
    fi
fi

# ── 3c. Map handlers without index ────────────────────────────
# Static _sh_N() handlers (no args) that call functions with bare (i) or (j)
# are broken — the loop variable is unbound. Should be __mapPress with idx.
SH_NO_ARGS=$(grep -A1 'function _sh_[0-9]*()' <<< "$GEN_BLOB" 2>/dev/null || true)
SH_BARE_LOOP=$(echo "$SH_NO_ARGS" | grep -cE '\([ij]\)' 2>/dev/null || true)
if [ "$SH_BARE_LOOP" -gt 0 ]; then
    fail "$SH_BARE_LOOP static _sh handler(s) call functions with bare loop variable (i/j) — should be __mapPress with idx arg"
fi

# ── 3d. Map handlers with hardcoded index ─────────────────────
# If source has handlers inside .map() that use the loop variable (e.g. dismiss(i)),
# but generated code has _sh_N() calling the same function with constant 0,
# the map index was baked instead of passed dynamically.
if [ "$(gcount_file '\.map\s*\(' "$SOURCE")" -gt 0 ]; then
    # Find _sh functions that call something with literal (0) — potential hardcoded index
    SH_HARDCODED=$(grep -A1 'function _sh_[0-9]*()' <<< "$GEN_BLOB" 2>/dev/null | grep -oE '\w+\(0\)' | sort | uniq -d | wc -l | tr -d ' ')
    if [ "$SH_HARDCODED" -gt 0 ]; then
        DUPED_CALLS=$(grep -A1 'function _sh_[0-9]*()' <<< "$GEN_BLOB" 2>/dev/null | grep -oE '\w+\(0\)' | sort | uniq -d | tr '\n' ', ' | sed 's/,$//')
        fail "$SH_HARDCODED map handler(s) with hardcoded index 0: $DUPED_CALLS — should pass per-item index"
    fi
fi

# ── 4. State slot balance ─────────────────────────────────────
SRC_USESTATE=$(gcount_file 'useState\(' "$SOURCE")
SRC_VAR_DECLS=$(gocount_file '^  +[a-z].* is ' "$SOURCE")
GEN_SLOTS=$(gcount 'state\.createSlot' "$GEN_BLOB")
# Object arrays replace useState slots — count OA unpack functions as equivalent
GEN_OA_UNPACKS=$(gcount 'pub fn _oa[0-9]+_unpack' "$GEN_BLOB")
GEN_TOTAL_SLOTS=$((GEN_SLOTS + GEN_OA_UNPACKS))
IS_CHAD=0
[ "$SRC_VAR_DECLS" -gt 0 ] && [ "$SRC_USESTATE" -eq 0 ] && IS_CHAD=1

if [ "$IS_CHAD" -eq 1 ]; then
    # Chad syntax: <var> blocks instead of useState()
    if [ "$GEN_SLOTS" -eq 0 ]; then
        fail "$SRC_VAR_DECLS <var> declarations in source but 0 state slots in generated"
    fi
elif [ "$SRC_USESTATE" -gt 0 ] && [ "$GEN_TOTAL_SLOTS" -eq 0 ]; then
    fail "$SRC_USESTATE useState() in source but 0 createSlot() in generated"
elif [ "$SRC_USESTATE" -gt 0 ] && [ "$GEN_TOTAL_SLOTS" -lt "$SRC_USESTATE" ]; then
    fail "state slot mismatch: $SRC_USESTATE useState() in source, $GEN_TOTAL_SLOTS createSlot()+OA in generated (slots missing)"
fi

# ── 5. Static text survival ──────────────────────────────────
STATIC_TEXTS=$(grep -oE '<Text[^>]*>[^{<][^<]*</Text>' "$SOURCE" 2>/dev/null | \
    sed 's/<Text[^>]*>//;s/<\/Text>//' | \
    sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | \
    grep -v '^\s*$' || true)

DROPPED_TEXT=0
DROPPED_TEXT_LIST=""
while IFS= read -r txt; do
    [ -z "$txt" ] && continue
    # Skip template expressions — compiler turns {expr} into bufPrint format strings
    case "$txt" in *"{"*) continue ;; esac
    # Skip ternary fragments that leaked into the text match
    case "$txt" in *" ? "*) continue ;; esac
    if ! grep -qF -- "$txt" <<< "$GEN_BLOB"; then
        DROPPED_TEXT=$((DROPPED_TEXT + 1))
        DROPPED_TEXT_LIST="$DROPPED_TEXT_LIST \"$txt\""
    fi
done <<< "$STATIC_TEXTS"

if [ "$DROPPED_TEXT" -gt 0 ]; then
    warn "$DROPPED_TEXT static text(s) missing from generated output:$DROPPED_TEXT_LIST"
fi

# ── 5b. Dead _updateConditionals ─────────────────────────────
# If _updateConditionals is defined but never called from _appTick or _appInit,
# conditional display toggles are dead code — handlers fire in JS, state slots
# update, but the Zig side never reads them to toggle element visibility.
# Root cause: soup lane populates ctx._soupConditionals but not ctx.conditionals,
# so meta.hasConds is false and entrypoints.js never wires the call.
GEN_HAS_UPDATE_COND=$(gcount 'fn _updateConditionals\(\)' "$GEN_BLOB")
if [ "$GEN_HAS_UPDATE_COND" -gt 0 ]; then
    TICK_BODY=$(sed -n '/fn _appTick/,/^fn \|^export /p' <<< "$GEN_BLOB")
    INIT_BODY=$(sed -n '/fn _appInit/,/^fn \|^export /p' <<< "$GEN_BLOB")
    TICK_CALLS=$(echo "$TICK_BODY" | grep -c '_updateConditionals()' 2>/dev/null || true)
    INIT_CALLS=$(echo "$INIT_BODY" | grep -c '_updateConditionals()' 2>/dev/null || true)
    if [ "$TICK_CALLS" -eq 0 ] && [ "$INIT_CALLS" -eq 0 ]; then
        fail "_updateConditionals() defined but never called from _appTick or _appInit — conditional visibility is dead code"
    fi
fi

# ── 5c. js_on_press arg/param mismatch ──────────────────────
# If js_on_press = "_sh_N()" calls a handler with no arguments, but the JS
# function _sh_N has parameters (_idx, etc.), those params will be undefined
# at runtime — producing garbage values (NaN-boxed undefined read as i64).
# Typically caused by map-item onClick handlers losing the iterator variable.
SH_WITH_PARAMS=$(grep -oE 'function _sh_[0-9]+\([^)]+\)' <<< "$GEN_BLOB" 2>/dev/null || true)
SH_ARG_MISMATCH=0
SH_ARG_MISMATCH_LIST=""
while IFS= read -r fn_sig; do
    [ -z "$fn_sig" ] && continue
    FN_NAME=$(echo "$fn_sig" | grep -oE '_sh_[0-9]+')
    [ -z "$FN_NAME" ] && continue
    # Check if any js_on_press calls this function with no args
    if grep -qE "js_on_press = \"${FN_NAME}\(\)\"" <<< "$GEN_BLOB" 2>/dev/null; then
        SH_ARG_MISMATCH=$((SH_ARG_MISMATCH + 1))
        SH_ARG_MISMATCH_LIST="$SH_ARG_MISMATCH_LIST ${FN_NAME}()"
    fi
done <<< "$SH_WITH_PARAMS"
if [ "$SH_ARG_MISMATCH" -gt 0 ]; then
    fail "$SH_ARG_MISMATCH handler(s) called with no args but function has params — undefined at runtime:$SH_ARG_MISMATCH_LIST"
fi

# ── 6. Map / For loop content check ──────────────────────────
SRC_MAPS=$(gcount_file '\.map\s*\(' "$SOURCE")
SRC_FOR=$(gcount_file '<For ' "$SOURCE")
SRC_LOOPS=$((SRC_MAPS + SRC_FOR))
if [ "$SRC_LOOPS" -gt 0 ]; then
    GEN_REBUILD_FNS=$(gcount 'fn _rebuildMap[0-9]+' "$GEN_BLOB")
    if [ "$GEN_REBUILD_FNS" -eq 0 ]; then
        warn "$SRC_LOOPS loop(s) in source (.map/$SRC_MAPS, <For>/$SRC_FOR) but no _rebuildMap function in generated"
    fi
    GEN_MAP_ALLOCS=$(gcount '_pool_arena\.allocator\(\)\.alloc\(' "$GEN_BLOB")
    if [ "$GEN_REBUILD_FNS" -gt 0 ] && [ "$GEN_MAP_ALLOCS" -eq 0 ]; then
        fail "map rebuild exists but allocates 0 child arrays — loop content was dropped"
    fi
fi

# ── 6a. Callback syntax leaked as text ───────────────────────
# If a .map()/callback header fragment lands in a generated text node,
# the parser left callback tokens unconsumed and rendered them literally.
if [ "$SRC_LOOPS" -gt 0 ]; then
    CALLBACK_TEXT_MATCHES=$(grep -oE '\.text = "[^"]*\)[[:space:]]*=>[[:space:]]*\([^"]*"' <<< "$GEN_BLOB" 2>/dev/null || true)
    CALLBACK_TEXTS=0
    CALLBACK_SAMPLES=""
    while IFS= read -r cm; do
        [ -z "$cm" ] && continue
        TEXT_VAL=$(echo "$cm" | sed 's/^\.text = "//; s/"$//')
        [ -z "$TEXT_VAL" ] && continue
        # Skip intentional code-sample text that exists as a quoted literal in source.
        if grep -qF -- "\"$TEXT_VAL\"" "$SOURCE" 2>/dev/null || grep -qF -- "'$TEXT_VAL'" "$SOURCE" 2>/dev/null; then
            continue
        fi
        CALLBACK_TEXTS=$((CALLBACK_TEXTS + 1))
        CALLBACK_SAMPLES="$CALLBACK_SAMPLES \"$TEXT_VAL\""
    done <<< "$CALLBACK_TEXT_MATCHES"
    if [ "$CALLBACK_TEXTS" -gt 0 ]; then
        fail "$CALLBACK_TEXTS callback fragment text node(s) in generated output — callback syntax leaked into UI:$CALLBACK_SAMPLES"
    fi
fi

# ── 6a2. Raw JSX leaked into Lua map templates ──────────────
# If a Lua map rebuilder (__rebuildLuaMap) contains literal JSX tags
# (< Box, < Text, < /Box, etc.), the nested map content was not
# decomposed — the compiler stringified JSX instead of emitting
# node construction. This produces garbage text at runtime.
if [ "$SRC_LOOPS" -gt 0 ]; then
    # Only check Lua map rebuilders in logic.zig
    if [ -d "$GEN" ] && [ -f "$GEN/logic.zig" ]; then
        LOGIC_BLOB=$(cat "$GEN/logic.zig" 2>/dev/null)
        # Extract Lua rebuilder bodies only (between __rebuildLuaMap and end of function)
        LUA_REBUILDERS=$(sed -n '/__rebuildLuaMap[0-9]/,/^\\\\end/p' <<< "$LOGIC_BLOB" 2>/dev/null || true)
        if [ -z "$LUA_REBUILDERS" ]; then
            # Fallback: grep for the pattern in the whole Lua logic block
            LUA_REBUILDERS=$(sed -n '/LUA_LOGIC/,/^;/p' <<< "$LOGIC_BLOB" 2>/dev/null || true)
        fi
        JSX_IN_LUA=0
        JSX_IN_LUA_SAMPLES=""
        # Look for JSX open/close tags inside Lua string content
        # These patterns cannot legitimately appear in Lua code
        JSX_OPEN=$(echo "$LUA_REBUILDERS" | grep -oE '< (Box|Text|Pressable|ScrollView|Image|Cartridge|Graph) ' 2>/dev/null | wc -l | tr -d ' ')
        JSX_CLOSE=$(echo "$LUA_REBUILDERS" | grep -oE '</ (Box|Text|Pressable|ScrollView|Image|Cartridge|Graph) >' 2>/dev/null | wc -l | tr -d ' ')
        JSX_SELF=$(echo "$LUA_REBUILDERS" | grep -oE '< [A-Z][a-zA-Z]+ [^>]*/>' 2>/dev/null | wc -l | tr -d ' ')
        JSX_IN_LUA=$((JSX_OPEN + JSX_CLOSE + JSX_SELF))
        if [ "$JSX_IN_LUA" -gt 0 ]; then
            fail "$JSX_IN_LUA raw JSX tag(s) in Lua map rebuilder — nested map content not decomposed into node construction"
        fi
    fi
fi

# ── 6b. Map conditional display toggles ──────────────────────
# If source has conditionals inside a .map() (e.g. {expr && <JSX>}),
# the generated code must have display toggle statements. If the source
# has conditionals referencing map-item fields but zero display toggles
# appear in the generated code, the conditionals were dropped/static.
if [ "$SRC_LOOPS" -gt 0 ]; then
    # Count conditionals inside map bodies in source (both React and soup syntax)
    # Look for {expr && pattern and {expr === pattern inside the map block
    SRC_MAP_CONDS=$(gocount_file '\{[^}]*===?\s*(null|true|false|[0-9]+)\s*&&' "$SOURCE")
    # Also count mixed-style: item.field == N &&
    SRC_MAP_CONDS2=$(gocount_file '\{[^}]*\.[a-zA-Z]+\s*==\s*[0-9]+\s*&&' "$SOURCE")
    SRC_MAP_CONDS=$((SRC_MAP_CONDS + SRC_MAP_CONDS2))
    GEN_DISPLAY_TOGGLES=$(gcount 'style\.display = if' "$GEN_BLOB")
    # Also count Lua-style conditionals in map templates: (cond) and element or nil
    # These may span multiple lines so count opening patterns
    GEN_LUA_CONDS=$(gcount ') and \{' "$GEN_BLOB")
    GEN_ALL_CONDS=$((GEN_DISPLAY_TOGGLES + GEN_LUA_CONDS))
    if [ "$SRC_MAP_CONDS" -gt 0 ] && [ "$GEN_ALL_CONDS" -eq 0 ]; then
        fail "$SRC_MAP_CONDS conditional(s) in map body but 0 display toggles in generated — conditionals not compiled"
    fi
fi

# ── 6c. Unresolved bracket text in map ───────────────────────
# If generated code contains .text = "[fieldname]" with literal brackets,
# a template expression like {item.field} was compiled as literal text
# instead of resolving to an OA field reference.
if [ "$SRC_LOOPS" -gt 0 ]; then
    # Find bracket texts in generated, but exclude ones that appear as literal text in source
    BRACKET_MATCHES=$(grep -oE '\.text = "\[[a-zA-Z]+\][^"]*"' <<< "$GEN_BLOB" 2>/dev/null || true)
    BRACKET_TEXTS=0
    BRACKET_SAMPLES=""
    while IFS= read -r bm; do
        [ -z "$bm" ] && continue
        # Extract the [word] part
        BW=$(echo "$bm" | grep -oE '\[[a-zA-Z]+\]' | head -1)
        [ -z "$BW" ] && continue
        # If source has this exact bracket text as literal content, skip it
        if grep -qF -- "$BW" "$SOURCE" 2>/dev/null; then
            continue
        fi
        BRACKET_TEXTS=$((BRACKET_TEXTS + 1))
        BRACKET_SAMPLES="$BRACKET_SAMPLES $bm"
    done <<< "$BRACKET_MATCHES"
    if [ "$BRACKET_TEXTS" -gt 0 ]; then
        fail "$BRACKET_TEXTS unresolved bracket text(s) in map — template expressions not compiled:$BRACKET_SAMPLES"
    fi
fi

# ── 6d. Unfilled empty text nodes ─────────────────────────────
# Every .text = "" was intended to have content. Some are dynText placeholders
# filled at runtime via _dyn_text_N vars, bufPrint, or __setStateString.
# Any text="" without a corresponding fill is a dropped expression.
GEN_EMPTY_TEXTS=$(gocount '\.text = ""' "$GEN_BLOB")
if [ "$GEN_EMPTY_TEXTS" -gt 0 ]; then
    # _dyn_text_N vars: each unique var is one placeholder fill
    GEN_DYN_TEXT_UNIQUE=$(grep -oE '_dyn_text_[0-9]+' <<< "$GEN_BLOB" 2>/dev/null | sort -u | wc -l | tr -d ' ')
    # JS __setStateString fills (each targets a string state slot used as text)
    GEN_JS_TEXT_FILLS=$(gocount '__setStateString' "$GEN_BLOB")
    # Map text arrays: each unique _map_texts_N_M covers one text="" per map item
    GEN_MAP_TEXT_UNIQUE=$(grep -oE '_map_texts_[0-9]+_[0-9]+' <<< "$GEN_BLOB" 2>/dev/null | sort -u | wc -l | tr -d ' ')
    GEN_TOTAL_FILLS=$((GEN_DYN_TEXT_UNIQUE + GEN_JS_TEXT_FILLS + GEN_MAP_TEXT_UNIQUE))
    UNFILLED=$((GEN_EMPTY_TEXTS - GEN_TOTAL_FILLS))
    if [ "$UNFILLED" -gt 0 ]; then
        fail "$UNFILLED text node(s) compiled as empty with no runtime fill — expression dropped"
    fi
fi

# ── 6e. Truncated mixed text ──────────────────────────────────
# If source has text nodes with static text + {expr} interpolations
# (e.g. <p>mode: {mode} · selected: {idx}</p> or `count: ${n}`),
# the static text segments must appear in the generated bufPrint format.
# A bare "{d}" or "{s}" format means surrounding text was dropped.
#
# Detect: extract static text before/between {expr} from source text nodes,
# check if those segments appear in generated bufPrint format strings.
BARE_FMTS=$(gocount 'bufPrint\(&[^,]+, "\{[ds]\}"' "$GEN_BLOB")
if [ "$BARE_FMTS" -gt 0 ]; then
    # Extract mixed text patterns: >static text {expr} more text<
    # These are JSX text nodes with both static text and expressions
    MIXED_TEXTS=$(grep -oE '>[a-zA-Z][^<]*\{[a-zA-Z]' "$SOURCE" 2>/dev/null | sed 's/^>//' | head -5 || true)
    TRUNCATED=0
    while IFS= read -r mt; do
        [ -z "$mt" ] && continue
        # Get the static prefix before the first {
        PREFIX=$(echo "$mt" | cut -d'{' -f1 | sed 's/[[:space:]]*$//')
        [ -z "$PREFIX" ] && continue
        [ ${#PREFIX} -lt 3 ] && continue
        if ! grep -qF -- "$PREFIX" <<< "$GEN_BLOB"; then
            TRUNCATED=$((TRUNCATED + 1))
        fi
    done <<< "$MIXED_TEXTS"
    if [ "$TRUNCATED" -gt 0 ]; then
        fail "$TRUNCATED mixed text node(s) truncated — static text dropped, only bare {d}/{s} remains"
    fi
fi

# ── 6f. Unconditional display toggles ────────────────────────
# if (true) .flex in display toggles means the conditional was not resolved —
# it's always visible, defeating the purpose of the conditional.
UNCONDITIONAL_DISPLAY=$(gocount 'if \(true\) \.flex' "$GEN_BLOB")
if [ "$UNCONDITIONAL_DISPLAY" -gt 0 ]; then
    fail "$UNCONDITIONAL_DISPLAY display toggle(s) compiled as 'if (true)' — conditional not resolved"
fi

# ── 6g2. Ternary in map without complementary display toggles ─
# If source has ternary JSX (cond ? (<A>) : (<B>)) inside a .map() body,
# generated maps.zig must have complementary display toggle pairs:
# ".flex else .none" AND ".none else .flex" per ternary.
# Missing ".none else .flex" = ternary compiled flat (both branches visible).
if [ "$SRC_LOOPS" -gt 0 ]; then
    SRC_TERNARY_BRANCH=$(gcount_file '\)\s*:\s*\(' "$SOURCE")
    if [ "$SRC_TERNARY_BRANCH" -gt 0 ]; then
        GEN_FALSE_TOGGLES=0
        if [ -d "$GEN" ] && [ -f "$GEN/maps.zig" ]; then
            GEN_FALSE_TOGGLES=$(gocount_file '\.none else \.flex' "$GEN/maps.zig")
        fi
        if [ "$GEN_FALSE_TOGGLES" -eq 0 ]; then
            fail "$SRC_TERNARY_BRANCH ternary branch(es) in map but 0 complementary display toggles (.none else .flex) — both ternary branches always visible"
        fi
    fi
fi

# ── 6g3. Cross-scope literal in map template text ────────────
# If generated maps.zig has bufPrint format strings containing
# "identifier.field" as literal text (not interpolated), a template
# expression like ${section.title} was not resolved to an OA reference.
# Symptom: text shows "section.title" instead of the actual value.
if [ "$SRC_LOOPS" -gt 0 ] && [ -d "$GEN" ] && [ -f "$GEN/maps.zig" ]; then
    LITERAL_DOT_REFS=$(grep -oE 'bufPrint\([^)]+, "[^"]*[a-z]+\.[a-z]+[^"]*"' "$GEN/maps.zig" 2>/dev/null | \
        grep -oE '[a-z]+\.[a-z]+' | \
        grep -v 'std\.\|mem\.\|fmt\.\|const\.\|catch\.\|else\.' | \
        sort -u || true)
    CROSS_SCOPE_LITERALS=0
    for ref in $LITERAL_DOT_REFS; do
        # Check if this dot-ref also appears as a template expression in source
        if grep -qE "\\\$\{${ref}\}" "$SOURCE" 2>/dev/null; then
            CROSS_SCOPE_LITERALS=$((CROSS_SCOPE_LITERALS + 1))
        fi
    done
    if [ "$CROSS_SCOPE_LITERALS" -gt 0 ]; then
        fail "$CROSS_SCOPE_LITERALS template expression(s) compiled as literal text in map — cross-scope variable not resolved"
    fi
fi

# ── 6g. Handler parameter dropped ────────────────────────────
# Script functions defined with parameters (e.g. const toggle = (index) => {...})
# must keep those parameters in the generated JS. If the generated function has
# no params but the body references a param name, the parameter was dropped.
PARAMLESS_WITH_BODY_REF=$(grep -A2 'function [a-zA-Z_][a-zA-Z0-9_]*()' <<< "$GEN_BLOB" 2>/dev/null | \
    grep -cE '\b(index|idx)\b' 2>/dev/null || true)
# Only flag if these are script-defined functions (not built-in _sh_N)
# Note: 'id' excluded — too common as object key (e.g. { id: 1, text: ... })
PARAMLESS_SCRIPT_FNS=$(grep -A2 'function [a-zA-Z][a-zA-Z0-9]*()' <<< "$GEN_BLOB" 2>/dev/null | \
    grep -v '_sh_\|__mapPress\|__eval\|__setObj' | \
    grep -cE '\b(index|idx)\b' 2>/dev/null || true)
if [ "$PARAMLESS_SCRIPT_FNS" -gt 0 ]; then
    fail "$PARAMLESS_SCRIPT_FNS script function(s) reference 'index/idx' but have no parameters — param dropped"
fi

# ── 6h. Object array stubbed as scalar ───────────────────────
# If source has useState([{...}]) (array of objects) but generated JS has
# var name = 0 (scalar int), the OA was not created properly.
# Match useState([ { across same or adjacent lines
SRC_OA_STATES=$(grep -c 'useState(\[{' "$SOURCE" 2>/dev/null || true)
SRC_OA_STATES2=$(grep -c 'useState(\[ {' "$SOURCE" 2>/dev/null || true)
# Also check multi-line: useState([\n  {
SRC_OA_STATES3=$(grep -A1 'useState(\[' "$SOURCE" 2>/dev/null | grep -c '^\s*{' || true)
SRC_OA_STATES=$((SRC_OA_STATES + SRC_OA_STATES2 + SRC_OA_STATES3))
if [ "$SRC_OA_STATES" -gt 0 ]; then
    GEN_OA_ZIG=$(gcount 'fn _oa[0-9]+_unpack' "$GEN_BLOB")
    GEN_OA_JS=$(gcount '__setObjArr' "$GEN_BLOB")
    GEN_OA_UNPACKS=$((GEN_OA_ZIG + GEN_OA_JS))
    if [ "$GEN_OA_UNPACKS" -eq 0 ]; then
        fail "$SRC_OA_STATES useState([{...}]) in source but 0 OA unpacks in generated — object array stubbed as scalar"
    fi
fi

# ── 7. Component inlining check ──────────────────────────────
if [ "$IS_CLASSIFIER" -eq 0 ]; then
COMPONENT_DEFS=$(grep -oE '^function ([A-Z][A-Za-z0-9_]+)' "$SOURCE" 2>/dev/null | \
    sed 's/^function //' | grep -v '^App$' || true)

for comp in $COMPONENT_DEFS; do
    if grep -qE "<$comp[ />]" "$SOURCE"; then
        COMP_BODY=$(sed -n "/^function $comp/,/^function \|^}/p" "$SOURCE")
        COMP_COLORS=$(echo "$COMP_BODY" | grep -oE '#[0-9a-fA-F]{6}' | sort -u || true)
        COMP_MISSING=0
        COMP_TOTAL=0
        for cc in $COMP_COLORS; do
            [ -z "$cc" ] && continue
            COMP_TOTAL=$((COMP_TOTAL + 1))
            cc_rgb=$(hex_to_rgb "$cc")
            cc_bare="${cc#\#}"
            if ! grep -q "Color\.rgb($cc_rgb)" <<< "$GEN_BLOB" && ! grep -qi "0x${cc_bare}" <<< "$GEN_BLOB"; then
                COMP_MISSING=$((COMP_MISSING + 1))
            fi
        done
        if [ "$COMP_TOTAL" -gt 0 ] && [ "$COMP_MISSING" -eq "$COMP_TOTAL" ]; then
            fail "component $comp used in JSX but ALL its colors ($COMP_TOTAL) missing from output — likely not inlined"
        fi
    fi
done
fi # IS_CLASSIFIER component inlining skip

# ── 8. Empty node array detection ────────────────────────────
# Node arrays with a single empty node `.{  }` or `.{}` indicate dropped content.
# Exclude map target arrays — they're legitimately empty because map children are
# assigned at runtime in maps.zig (pattern: nodes._arr_N[0].children = _map_pool_).
EMPTY_NODES=0
MAP_TARGETS=""
MAPS_FILE=""
if [ -d "$GEN" ] && [ -f "$GEN/maps.zig" ]; then
    MAPS_FILE="$GEN/maps.zig"
elif [ -f "$GEN" ]; then
    MAPS_FILE="$GEN"
fi
if [ -n "$MAPS_FILE" ]; then
    MAP_TARGETS=$(grep -oE 'nodes\._arr_[0-9]+' "$MAPS_FILE" 2>/dev/null | sed 's/nodes\.//' | sort -u)
fi
while IFS= read -r line; do
    [ -z "$line" ] && continue
    ARR_NAME=$(echo "$line" | grep -oE '_arr_[0-9]+' | head -1)
    IS_MAP_TARGET=0
    for mt in $MAP_TARGETS; do
        [ "$ARR_NAME" = "$mt" ] && IS_MAP_TARGET=1 && break
    done
    [ "$IS_MAP_TARGET" -eq 0 ] && EMPTY_NODES=$((EMPTY_NODES + 1))
done < <(grep -E '_arr_[0-9]+ = \[_\]Node\{ \.\{[[:space:]]*\} \}' <<< "$GEN_BLOB" 2>/dev/null || true)
if [ "$EMPTY_NODES" -gt 0 ]; then
    fail "$EMPTY_NODES empty node array(s) — content was dropped (look for _arr_N = [_]Node{ .{} })"
fi

# ── 9. Multi-file import content check ───────────────────────
# If source imports other files, check their static text survives
SOURCE_DIR=$(dirname "$SOURCE")
IMPORTS=$(grep -oE "from '\./[^']+'" "$SOURCE" 2>/dev/null | sed "s/from '//;s/'$//" || true)
for imp in $IMPORTS; do
    # Skip data-only imports — their content is consumed by registries, not emitted as text
    case "$imp" in
        *.glyphs|*.effects|*.cls|*.tcls|*.vcls) continue ;;
    esac
    # Resolve import path — try with .tsz extensions
    IMP_FILE=""
    for ext in ".tsz" ".c.tsz" "/$(basename "$imp").tsz"; do
        if [ -f "$SOURCE_DIR/${imp}${ext}" ]; then
            IMP_FILE="$SOURCE_DIR/${imp}${ext}"
            break
        fi
    done
    [ -z "$IMP_FILE" ] && continue

    # Check characteristic static text from imported file
    IMP_TEXTS=$(grep -oE ">[A-Z][^<{]+</" "$IMP_FILE" 2>/dev/null | sed 's/^>//;s/<\/$//' | head -5 || true)
    IMP_NAME=$(basename "$imp")
    IMP_MISSING=0
    IMP_TOTAL=0
    while IFS= read -r itxt; do
        [ -z "$itxt" ] && continue
        [ ${#itxt} -lt 3 ] && continue
        IMP_TOTAL=$((IMP_TOTAL + 1))
        if ! grep -qF -- "$itxt" <<< "$GEN_BLOB"; then
            IMP_MISSING=$((IMP_MISSING + 1))
        fi
    done <<< "$IMP_TEXTS"
    if [ "$IMP_TOTAL" -gt 0 ] && [ "$IMP_MISSING" -eq "$IMP_TOTAL" ]; then
        fail "imported $IMP_NAME: ALL static text ($IMP_TOTAL items) missing from output — page/component may not be compiled"
    fi
done

# ── 11. Handler coverage for chad syntax ─────────────────────
# Chad uses onPress=functionName and <For> with onPress
SRC_CHAD_HANDLERS=$(gocount_file 'onPress=' "$SOURCE")
if [ "$SRC_CHAD_HANDLERS" -gt 0 ] && [ "$SRC_HANDLERS" -eq 0 ]; then
    # Recount with chad-style handler pattern
    GEN_ANY_HANDLERS=$(gcount '(on_press|js_on_press|lua_on_press)' "$GEN_BLOB")
    if [ "$GEN_ANY_HANDLERS" -eq 0 ]; then
        fail "$SRC_CHAD_HANDLERS onPress in source but 0 press handlers wired in generated"
    fi
fi

# ── 12. Map handler arg check ─────────────────────────────────
# In map rebuild functions, handlers should pass the item index.
# "functionName()" with no args is wrong when it's inside a map —
# the handler needs the item/index. Only check maps.zig, not nodes.zig.
if [ -d "$GEN" ] && [ -f "$GEN/maps.zig" ]; then
    MAP_BLOB=$(cat "$GEN/maps.zig" 2>/dev/null)
    MAP_HANDLERS_NO_ARGS=$(gocount 'js_on_press = "[a-zA-Z_]+\(\)"' "$MAP_BLOB")
    if [ "$MAP_HANDLERS_NO_ARGS" -gt 0 ]; then
        fail "$MAP_HANDLERS_NO_ARGS map handler(s) call with no arguments — item/index not passed to handler"
    fi
fi

# ── 13. Chad page routing check ──────────────────────────────
# If source has <pages> block declaring page names, the generated code
# should contain content from those page files (found in same directory).
SRC_PAGES=$(sed -n '/<pages>/,/<\/pages>/p' "$SOURCE" 2>/dev/null | grep -v '<' | tr -s ' ' '\n' | grep -v '^$' | sort -u || true)
if [ -n "$SRC_PAGES" ]; then
    SOURCE_DIR=$(dirname "$SOURCE")
    PAGES_MISSING=0
    PAGES_MISSING_LIST=""
    for pg in $SRC_PAGES; do
        PG_FILE=""
        for candidate in "$SOURCE_DIR/$pg.tsz" "$SOURCE_DIR/${pg}.tsz"; do
            [ -f "$candidate" ] && PG_FILE="$candidate" && break
        done
        [ -z "$PG_FILE" ] && continue
        # Check if ANY characteristic content from this page made it to output
        # Look for static text or unique identifiers from the page file
        PG_TEXTS=$(grep -oE ">[A-Z][^<{]*<" "$PG_FILE" 2>/dev/null | sed 's/^>//;s/<$//' | head -5 || true)
        PG_FOUND=0
        while IFS= read -r ptxt; do
            [ -z "$ptxt" ] && continue
            [ ${#ptxt} -lt 3 ] && continue
            if grep -qF -- "$ptxt" <<< "$GEN_BLOB"; then
                PG_FOUND=1
                break
            fi
        done <<< "$PG_TEXTS"
        if [ "$PG_FOUND" -eq 0 ]; then
            PAGES_MISSING=$((PAGES_MISSING + 1))
            PAGES_MISSING_LIST="$PAGES_MISSING_LIST $pg"
        fi
    done
    if [ "$PAGES_MISSING" -gt 0 ]; then
        fail "$PAGES_MISSING page(s) declared in <pages> but no content in output:$PAGES_MISSING_LIST"
    fi
fi

# ── 14. Unresolved glyph shortcodes ──────────────────────────
# Glyph shortcodes like :sun: :check: :error: should resolve to inline
# SVG paths (inline_glyphs). Only flag if shortcodes appear as LITERAL
# strings in the generated .text fields — that means the resolver failed.
# Don't flag missing inline_glyphs count since shortcodes may appear in
# script blocks, data declarations, or comments where they're just strings.
SRC_GLYPHS=$(grep -oE ':[a-z_]+:' "$SOURCE" 2>/dev/null | sort -u || true)
if [ -n "$SRC_GLYPHS" ]; then
    UNRESOLVED=0
    UNRESOLVED_LIST=""
    for glyph in $SRC_GLYPHS; do
        # Check if this shortcode appears as a literal string in generated text
        if grep -qF -- "\"$glyph\"" <<< "$GEN_BLOB" || grep -qF -- "'$glyph'" <<< "$GEN_BLOB"; then
            UNRESOLVED=$((UNRESOLVED + 1))
            UNRESOLVED_LIST="$UNRESOLVED_LIST $glyph"
        fi
    done
    if [ "$UNRESOLVED" -gt 0 ]; then
        fail "$UNRESOLVED glyph shortcode(s) appear as literal strings in output:$UNRESOLVED_LIST"
    fi
fi

# ── 15. Map variant stomp check ───────────────────────────────
# If multiple classifier entries patch inside a map loop, they must target
# DIFFERENT nodes. If 2+ different "Map variant patch: X" comments all
# target the same _map_pool_N[_mi] (no .children[...] indexing), the
# patches stomp each other and only the last one takes effect.
VARIANT_PATCH_NAMES=$(grep -oE '// Map variant patch: [A-Za-z0-9_]+' <<< "$GEN_BLOB" 2>/dev/null | sort -u || true)
VARIANT_PATCH_COUNT=0
for _vp in $VARIANT_PATCH_NAMES; do VARIANT_PATCH_COUNT=$((VARIANT_PATCH_COUNT + 1)); done
if [ "$VARIANT_PATCH_COUNT" -gt 1 ]; then
    # Extract unique target paths from variant patch lines (maps._map_pool_N[_mi].xxx = ...)
    # Strip the .style.property = ... part, keep just the node target
    VARIANT_TARGETS=$(grep -oE 'maps\._map_pool_[0-9]+\[_mi\][^.]*' <<< "$GEN_BLOB" 2>/dev/null | sort -u || true)
    UNIQUE_TARGETS=0
    for _vt in $VARIANT_TARGETS; do UNIQUE_TARGETS=$((UNIQUE_TARGETS + 1)); done
    if [ "$UNIQUE_TARGETS" -le 1 ]; then
        PATCH_LIST=$(echo "$VARIANT_PATCH_NAMES" | sed 's/\/\/ Map variant patch: //' | tr '\n' ', ' | sed 's/,$//')
        fail "$VARIANT_PATCH_COUNT variant classifiers ($PATCH_LIST) ALL target same map node — patches stomp each other, only last wins"
    fi
fi

# ── 16. Map text buffer stomping ──────────────────────────────
# If the same _map_texts_N_M[_i] is written by two consecutive bufPrint
# calls, the second overwrites the first — one text value is lost.
# Also detect: same text buffer used by two different .text = assignments.
if [ -d "$GEN" ] && [ -f "$GEN/maps.zig" ]; then
    # Find text buffers written more than once (consecutive bufPrint stomps)
    STOMPED_BUFS=$(grep -oE '_map_texts_[0-9]+_[0-9]+\[_i\] = std\.fmt\.bufPrint' "$GEN/maps.zig" 2>/dev/null | sort | uniq -d || true)
    STOMP_COUNT=0
    STOMP_LIST=""
    for sb in $STOMPED_BUFS; do
        buf_name=$(echo "$sb" | grep -oE '_map_texts_[0-9]+_[0-9]+')
        STOMP_COUNT=$((STOMP_COUNT + 1))
        STOMP_LIST="$STOMP_LIST $buf_name"
    done
    if [ "$STOMP_COUNT" -gt 0 ]; then
        fail "$STOMP_COUNT map text buffer(s) written multiple times — second write stomps first:$STOMP_LIST"
    fi

    # Find text buffers referenced by multiple .text = assignments in node arrays
    TEXT_REFS=$(grep -oE '\.text = _map_texts_[0-9]+_[0-9]+\[' "$GEN/maps.zig" 2>/dev/null | sort || true)
    DUPE_REFS=$(echo "$TEXT_REFS" | uniq -d || true)
    DUPE_COUNT=0
    DUPE_LIST=""
    for dr in $DUPE_REFS; do
        [ -z "$dr" ] && continue
        buf_name=$(echo "$dr" | grep -oE '_map_texts_[0-9]+_[0-9]+')
        DUPE_COUNT=$((DUPE_COUNT + 1))
        DUPE_LIST="$DUPE_LIST $buf_name"
    done
if [ "$DUPE_COUNT" -gt 0 ]; then
        warn "$DUPE_COUNT map text buffer(s) shared by multiple nodes — different text nodes get same value:$DUPE_LIST"
fi
fi

fi # IS_LUA_TREE == 0 (end of Zig-mode checks sections 3-16)

# ══════════════════════════════════════════════════════════════
# ── LUA-TREE FLIGHT CHECKS ───────────────────────────────────
# These run on lua-tree mode carts (LUA_LOGIC with __render)
# ══════════════════════════════════════════════════════════════
if [ "$IS_LUA_TREE" -eq 1 ] && [ -n "$LUA_BLOB" ]; then

# ── LT1. Zig syntax leaked into LUA_LOGIC ────────────────────
# These are Zig constructs that should never appear in Lua code
ZIG_LEAK=0
ZIG_LEAK_DETAILS=""

# @as() / @intCast() / @floatFromInt() — Zig builtins
n=$(gocount '@as\(|@intCast\(|@floatFromInt\(|@floatCast\(' "$LUA_BLOB")
if [ "$n" -gt 0 ]; then ZIG_LEAK=$((ZIG_LEAK + n)); ZIG_LEAK_DETAILS="$ZIG_LEAK_DETAILS @as/$n"; fi

# &_eval_buf / &_map_texts — Zig pointer syntax
n=$(gocount '&_eval_buf|&_map_texts|&_map_lua' "$LUA_BLOB")
if [ "$n" -gt 0 ]; then ZIG_LEAK=$((ZIG_LEAK + n)); ZIG_LEAK_DETAILS="$ZIG_LEAK_DETAILS &ptr/$n"; fi

# qjs_runtime. / luajit_runtime. / state.getSlot — Zig runtime calls
n=$(gocount 'qjs_runtime\.|luajit_runtime\.|state\.getSlot' "$LUA_BLOB")
if [ "$n" -gt 0 ]; then ZIG_LEAK=$((ZIG_LEAK + n)); ZIG_LEAK_DETAILS="$ZIG_LEAK_DETAILS zig_runtime/$n"; fi

# Zig if/else ternary: if (cond) val else val — should be (cond) and val or val
n=$(gocount '\bif\s+\(' "$LUA_BLOB")
if [ "$n" -gt 0 ]; then ZIG_LEAK=$((ZIG_LEAK + n)); ZIG_LEAK_DETAILS="$ZIG_LEAK_DETAILS zig_if/$n"; fi

# && / || — JS logical operators (should be and/or in Lua)
n=$(gocount '&&|\|\|' "$LUA_BLOB")
if [ "$n" -gt 0 ]; then ZIG_LEAK=$((ZIG_LEAK + n)); ZIG_LEAK_DETAILS="$ZIG_LEAK_DETAILS js_logical/$n"; fi

# _oa0_ refs — OA array refs not resolved to _item.field
n=$(gocount '_oa[0-9]+_' "$LUA_BLOB")
if [ "$n" -gt 0 ]; then ZIG_LEAK=$((ZIG_LEAK + n)); ZIG_LEAK_DETAILS="$ZIG_LEAK_DETAILS oa_ref/$n"; fi

# __eval("...") — Zig bridge call that should be a Lua ternary
n=$(gocount '__eval\(' "$LUA_BLOB")
if [ "$n" -gt 0 ]; then ZIG_LEAK=$((ZIG_LEAK + n)); ZIG_LEAK_DETAILS="$ZIG_LEAK_DETAILS __eval/$n"; fi

# Color.rgb(...) — Zig Color type leaked into Lua (should be 0xHEXHEX)
n=$(gocount 'Color\.rgb\(' "$LUA_BLOB")
if [ "$n" -gt 0 ]; then ZIG_LEAK=$((ZIG_LEAK + n)); ZIG_LEAK_DETAILS="$ZIG_LEAK_DETAILS Color.rgb/$n"; fi

if [ "$ZIG_LEAK" -gt 0 ]; then
    fail "$ZIG_LEAK Zig syntax leaked into LUA_LOGIC:$ZIG_LEAK_DETAILS"
fi

# ── LT2. Unquoted enum values in Lua tables ──────────────────
# Lua table values like align_items = center crash — must be "center"
UNQUOTED=0
UNQUOTED_LIST=""
for kw in center flex_start flex_end space_between space_around space_evenly stretch baseline row column row_reverse column_reverse wrap nowrap hidden visible scroll absolute relative; do
    n=$(grep -cE "= ${kw}([, }]|$)" <<< "$LUA_BLOB" 2>/dev/null) || n=0
    if [ "$n" -gt 0 ]; then
        UNQUOTED=$((UNQUOTED + n))
        UNQUOTED_LIST="$UNQUOTED_LIST $kw($n)"
    fi
done
if [ "$UNQUOTED" -gt 0 ]; then
    fail "$UNQUOTED unquoted enum value(s) in LUA_LOGIC (must be strings):$UNQUOTED_LIST"
fi

# ── LT3. <script> tags in JS_LOGIC ───────────────────────────
# Script content should be extracted, not passed with tags
JS_BLOB=""
if [ -d "$GEN" ]; then
    JS_BLOB=$(sed -n '/^pub const JS_LOGIC/,/^;$/p' "$GEN/logic.zig" 2>/dev/null)
else
    JS_BLOB=$(sed -n '/^pub const JS_LOGIC/,/^;$/p' "$GEN" 2>/dev/null)
fi
if [ -n "$JS_BLOB" ]; then
    n=$(gocount '<script>|</script>' "$JS_BLOB")
    if [ "$n" -gt 0 ]; then
        fail "$n <script> tag(s) leaked into JS_LOGIC — content should be extracted without tags"
    fi
fi

# ── LT4. Broken string literals in handlers ──────────────────
# Unescaped quotes inside handler strings break Lua parsing
# e.g. lua_on_press = "setAction("inspect")" — inner quotes kill outer
BROKEN_HANDLERS=0
while IFS= read -r hline; do
    [ -z "$hline" ] && continue
    # Skip handlers that use .. concatenation — those are intentionally spliced strings
    echo "$hline" | grep -q '\.\.' && continue
    # Extract the handler value between the first pair of quotes
    # If there's an unescaped " inside, the string has 3+ quote-delimited segments
    hval=$(echo "$hline" | sed 's/.*lua_on_press = "//;s/.*js_on_press = "//')
    # Count unescaped quotes (not preceded by \)
    qcount=$(echo "$hval" | grep -oE '[^\\]"' | wc -l | tr -d ' ')
    if [ "$qcount" -gt 1 ]; then
        BROKEN_HANDLERS=$((BROKEN_HANDLERS + 1))
    fi
done < <(grep -E '(lua_on_press|js_on_press) = "' <<< "$LUA_BLOB" 2>/dev/null || true)
if [ "$BROKEN_HANDLERS" -gt 0 ]; then
    fail "$BROKEN_HANDLERS handler(s) with unescaped quotes — string literal is broken"
fi

# ── LT4c. State key mismatch — setter writes to wrong key ────
# Pattern: function setFoo(v) _state["setFoo"] = v  (WRONG — should be _state["foo"])
# The setter name "setFoo" is used as the key instead of the variable name "foo"
STATE_KEY_BAD=0
while IFS= read -r sline; do
    [ -z "$sline" ] && continue
    # Extract: function setXxx(v) _state["setXxx"]
    setter_name=$(echo "$sline" | grep -oE 'function (set[A-Za-z0-9_]+)' | sed 's/function //')
    stored_key=$(echo "$sline" | grep -oE '_state\["[^"]+"\]' | head -1 | sed 's/_state\["//;s/"\]//')
    if [ -n "$setter_name" ] && [ -n "$stored_key" ] && [ "$setter_name" = "$stored_key" ]; then
        STATE_KEY_BAD=$((STATE_KEY_BAD + 1))
    fi
done < <(grep -E 'function set[A-Z].*_state\[' <<< "$LUA_BLOB" 2>/dev/null || true)
if [ "$STATE_KEY_BAD" -gt 0 ]; then
    fail "$STATE_KEY_BAD setter(s) write to wrong state key (setFoo stores to _state[\"setFoo\"] instead of _state[\"foo\"])"
fi

# ── LT4d. Dropped conditional branches ───────────────────────
# Source has {expr && <JSX>} or {expr ? <A> : <B>} but generated tree has fewer
# conditional patterns — content was silently dropped during compilation.
SRC_SHORT_COND=$(grep -cE '&&\s*<' "$SOURCE" 2>/dev/null) || SRC_SHORT_COND=0
SRC_TERNARY_COND=$(grep -cE '\?\s*<' "$SOURCE" 2>/dev/null) || SRC_TERNARY_COND=0
SRC_TOTAL_COND=$((SRC_SHORT_COND + SRC_TERNARY_COND))
if [ "$SRC_TOTAL_COND" -gt 0 ]; then
    GEN_LUA_COND=$(grep -cE '\) and \{' <<< "$LUA_BLOB" 2>/dev/null) || GEN_LUA_COND=0
    if [ "$GEN_LUA_COND" -eq 0 ]; then
        fail "$SRC_TOTAL_COND conditional branch(es) in source (&&/$SRC_SHORT_COND ?/$SRC_TERNARY_COND) but 0 in generated — content dropped"
    fi
fi

# ── LT4e. Dropped children — source elements compiled to empty nodes ──
# Nodes with style but no text/children in Lua tree when source has content inside
# Pattern in lua: { style = { ... } } with NO children = {} and NO text =
# This catches <Box>..content..</Box> compiling to just { style = { ... } }
if [ -n "$LUA_BLOB" ]; then
    # Count nodes in source that have children (opening + closing tag with stuff between)
    SRC_ELEMENTS=$(grep -cE '<(Box|Pressable|ScrollView)[^/]*>' "$SOURCE" 2>/dev/null) || SRC_ELEMENTS=0
    # Count empty style-only nodes in generated (style but no children, no text)
    GEN_EMPTY_STYLED=$(grep -oE '\{ style = \{[^}]+\} \}[,)]' <<< "$LUA_BLOB" 2>/dev/null | wc -l | tr -d ' ')
    # Only flag if there are many empty nodes relative to source elements
    if [ "$GEN_EMPTY_STYLED" -gt 3 ] && [ "$SRC_ELEMENTS" -gt 0 ]; then
        EMPTY_RATIO=$((GEN_EMPTY_STYLED * 100 / SRC_ELEMENTS))
        if [ "$EMPTY_RATIO" -gt 30 ]; then
            warn "$GEN_EMPTY_STYLED empty styled node(s) in generated ($EMPTY_RATIO% of $SRC_ELEMENTS source elements) — possible dropped children"
        fi
    fi
fi

# ── LT4f. Color integrity — handled by check 1 above (works for both modes)

# ── LT5. Map variable leakage in handlers ────────────────────
# Inside __mapLoop bodies, handler strings should use _item not source vars
# Detect: map source var (from .map((x, ...) in source) appearing raw in handlers
MAP_VARS=$(grep -oE '\.map\(\s*\(\s*([a-zA-Z_]\w*)' "$SOURCE" 2>/dev/null | sed 's/.*(\s*//' || true)
for mv in $MAP_VARS; do
    # Check if the source map var name appears in handler strings inside LUA_LOGIC
    # Pattern: js_on_press = "... mv . field ..." (should be _item.field)
    n=$(grep -oE "js_on_press = \"[^\"]*\b${mv}\s*\.\s*\w+" <<< "$LUA_BLOB" 2>/dev/null | wc -l | tr -d ' ')
    if [ "$n" -gt 0 ]; then
        fail "$n handler(s) reference map var '$mv' instead of '_item' inside __mapLoop"
    fi
done

fi # IS_LUA_TREE

# ── Summary ───────────────────────────────────────────────────
if [ "$FAILS" -gt 0 ]; then
    echo "[flight] $NAME: $FAILS FAILURE(S)"
    exit 2
else
    echo "[flight] $NAME: OK"
    exit 0
fi
