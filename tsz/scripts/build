#!/bin/bash
# Build a .tsz cart into a native binary.
#
# Usage:
#   ./scripts/build carts/storybook/Storybook.tsz
#   ./scripts/build carts/storybook/Storybook.tsz --debug
#
# First run builds the engine .a (~24s one-time). Every build after: ~6s.

set -euo pipefail

# Ensure PATH includes common tool locations (needed when launched from GUI/runtime)
export PATH="$HOME/miniconda3/bin:$HOME/.local/bin:/home/linuxbrew/.linuxbrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"
BUILD_T0=$(date +%s%N)
cd "$(dirname "$0")/.."

# ── Parse flags ──────────────────────────────────────────────────────
POSITIONAL=()
DBG_FLAGS=""
TRACE_FLAGS=""
GDB_MODE=0
PROVE_I_BROKE_IT=0
PROVE_COMPILER_BROKE_IT=0
SKIP_SNAPSHOT=0
for arg in "$@"; do
    case "$arg" in
        --fast) ;; # ignored, fast is always on
        --proveIBrokeIt) PROVE_I_BROKE_IT=1 ;;
        --proveMyCompilerBrokeIt) PROVE_COMPILER_BROKE_IT=1 ;;
        --skip-snapshot) SKIP_SNAPSHOT=1 ;;  # iterate-with-broken-snapshot escape hatch
        -n) DBG_FLAGS="$DBG_FLAGS --dbg-nodes" ;;
        -s) DBG_FLAGS="$DBG_FLAGS --dbg-state" ;;
        -c) DBG_FLAGS="$DBG_FLAGS --dbg-compiler" ;;
        --trace-mutations) TRACE_FLAGS="$TRACE_FLAGS --trace-mutations" ;;
        --trace-line=*) TRACE_FLAGS="$TRACE_FLAGS --trace-mutations $arg" ;;
        -g) GDB_MODE=1 ;;
        -nsc|-nsv|-ns|-nc|-sc|-snc|-ng|-sg|-cg|-nsg|-ncg|-scg|-nscg) # combo flags
            [[ "$arg" == *n* ]] && DBG_FLAGS="$DBG_FLAGS --dbg-nodes"
            [[ "$arg" == *s* ]] && DBG_FLAGS="$DBG_FLAGS --dbg-state"
            [[ "$arg" == *c* ]] && DBG_FLAGS="$DBG_FLAGS --dbg-compiler"
            [[ "$arg" == *g* ]] && GDB_MODE=1
            ;;
        *) POSITIONAL+=("$arg") ;;
    esac
done

if [ "${#POSITIONAL[@]}" -eq 0 ]; then
    echo "Usage: scripts/build <cart.tsz> [--debug] [--proveIBrokeIt]"
    exit 1
fi

# ── Startup latency ─────────────────────────────────────────────────
BUILD_T1=$(date +%s%N)
STARTUP_MS=$(( (BUILD_T1 - BUILD_T0) / 1000000 ))
if [ "$STARTUP_MS" -gt 500 ]; then
    echo "[$NAME] !! STARTUP LATENCY: ${STARTUP_MS}ms before build began"
fi

# Auto-rebuild vello if stripped lib is missing (happens after fresh clone or git filter-repo)
VELLO_LIB="../deps/vello_ffi/target/release/libvello_ffi_stripped.a"
if [ ! -f "$VELLO_LIB" ]; then
    echo "[vello_ffi] stripped lib missing — rebuilding..."
    bash ../deps/vello_ffi/build.sh
fi

CART="${POSITIONAL[0]}"
NAME=$(basename "$CART" .tsz)
OPT="${POSITIONAL[1]:---release}"
GEN_ROOT="/tmp/tsz-gen"
GEN="$GEN_ROOT/generated_${NAME}.zig"
GEN_DIR="$GEN_ROOT/generated_${NAME}"

# ── Conformance tracking ───────────────────────────────────────────
# Auto-record builds for carts/conformance/ into conformance.db
CONF_DB="conformance.db"
IS_CONFORMANCE=0
CONF_LANE="unknown"

if [[ "$CART" == *carts/conformance/* ]] && [[ "$CART" != *.script.tsz ]] && [[ "$CART" != *.cls.tsz ]] && [[ "$CART" != *.mod.tsz ]] && [[ "$CART" != *.c.tsz ]]; then
    IS_CONFORMANCE=1
    # Lane = first subdirectory under carts/conformance/, or "root"
    CONF_REL="${CART#*carts/conformance/}"
    if [[ "$CONF_REL" == */* ]]; then
        CONF_LANE="${CONF_REL%%/*}"
    else
        CONF_LANE="root"
    fi

    # Qualified test name: includes subdirectory to avoid collisions.
    # e.g. "smith-test/counter" instead of just "counter"
    CONF_BASENAME=$(basename "$CART" .tsz | sed 's/\.app$//')
    CONF_LANE_REL="${CONF_REL%/*}"  # strip filename, keep subdirs under lane
    if [[ "$CONF_REL" == */*/* ]]; then
        # Has sub-subdirectory: lane/subdir/file → subdir/name
        CONF_SUBPATH="${CONF_LANE_REL#*/}"
        CONF_NAME="${CONF_SUBPATH}/${CONF_BASENAME}"
    elif [[ "$CONF_REL" == */* ]]; then
        # Direct child of lane: lane/file → name
        CONF_NAME="$CONF_BASENAME"
    else
        # Root level
        CONF_NAME="$CONF_BASENAME"
    fi

    # sqlite3 with busy timeout for parallel build safety
    cdb() { sqlite3 "$CONF_DB" ".timeout 5000" "$1"; }

    # Ensure db + table exist
    cdb "CREATE TABLE IF NOT EXISTS builds (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        test_name   TEXT    NOT NULL,
        lane        TEXT    NOT NULL,
        built_at    TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
        status      TEXT    NOT NULL,
        generated   TEXT,
        binary_sha  TEXT,
        binary_size INTEGER,
        error_log   TEXT,
        verified_at TEXT,
        source_sha  TEXT,
        engine_sha  TEXT
    );
    CREATE INDEX IF NOT EXISTS idx_test_time ON builds(test_name, built_at DESC);
    CREATE INDEX IF NOT EXISTS idx_lane      ON builds(lane);
    CREATE INDEX IF NOT EXISTS idx_status    ON builds(status);
    CREATE TABLE IF NOT EXISTS source_overrides (
        test_name     TEXT PRIMARY KEY,
        source_sha    TEXT NOT NULL,
        overridden_at TEXT NOT NULL
    );
    CREATE TABLE IF NOT EXISTS verified_sources (
        test_name        TEXT PRIMARY KEY,
        source_sha       TEXT NOT NULL,
        verified_at      TEXT NOT NULL,
        source_path      TEXT NOT NULL,
        verified_build_id INTEGER,
        engine_sha       TEXT
    );
    CREATE TABLE IF NOT EXISTS engine_builds (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        engine_sha  TEXT    NOT NULL UNIQUE,
        built_at    TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
        blessed_at  TEXT,
        commit_sha  TEXT,
        source_hash TEXT,
        last_good_at TEXT
    );
    CREATE INDEX IF NOT EXISTS idx_engine_sha ON engine_builds(engine_sha);
    CREATE TABLE IF NOT EXISTS compiler_builds (
        id            INTEGER PRIMARY KEY AUTOINCREMENT,
        compiler_sha  TEXT    NOT NULL UNIQUE,
        built_at      TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
        blessed_at    TEXT,
        commit_sha    TEXT,
        source_hash   TEXT,
        last_good_at  TEXT
    );
    CREATE INDEX IF NOT EXISTS idx_compiler_sha ON compiler_builds(compiler_sha);
    CREATE TABLE IF NOT EXISTS build_perf (
        id             INTEGER PRIMARY KEY AUTOINCREMENT,
        test_name      TEXT    NOT NULL,
        lane           TEXT    NOT NULL,
        built_at       TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S', 'now', 'localtime')),
        source_lines   INTEGER NOT NULL,
        generated_bytes INTEGER NOT NULL,
        forge_ms       INTEGER NOT NULL,
        zig_ms         INTEGER NOT NULL,
        total_ms       INTEGER NOT NULL,
        lines_per_sec  REAL   NOT NULL,
        bytes_per_line REAL   NOT NULL
    );
    CREATE INDEX IF NOT EXISTS idx_perf_test ON build_perf(test_name);
    CREATE INDEX IF NOT EXISTS idx_perf_date ON build_perf(built_at);
    CREATE TABLE IF NOT EXISTS snapshots (
        id              INTEGER PRIMARY KEY AUTOINCREMENT,
        test_name       TEXT    NOT NULL,
        lane            TEXT    NOT NULL,
        snapped_at      TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
        expect_count    INTEGER NOT NULL DEFAULT 0,
        click_count     INTEGER NOT NULL DEFAULT 0,
        node_count      INTEGER NOT NULL DEFAULT 0,
        text_count      INTEGER NOT NULL DEFAULT 0,
        pressable_count INTEGER NOT NULL DEFAULT 0,
        state_slots     INTEGER NOT NULL DEFAULT 0,
        snap_ms         INTEGER NOT NULL DEFAULT 0,
        contract_clean  INTEGER NOT NULL DEFAULT 1,
        engine_sha      TEXT,
        compiler_sha    TEXT,
        source_sha      TEXT
    );
    CREATE INDEX IF NOT EXISTS idx_snap_test ON snapshots(test_name, snapped_at DESC);
    CREATE INDEX IF NOT EXISTS idx_snap_lane ON snapshots(lane);"
    # Migrations: add columns to existing tables (no-op if already present)
    cdb "ALTER TABLE builds ADD COLUMN engine_sha TEXT;" 2>/dev/null || true
    cdb "ALTER TABLE verified_sources ADD COLUMN engine_sha TEXT;" 2>/dev/null || true
    cdb "ALTER TABLE engine_builds ADD COLUMN last_good_at TEXT;" 2>/dev/null || true
    cdb "ALTER TABLE builds ADD COLUMN compiler_sha TEXT;" 2>/dev/null || true
    cdb "ALTER TABLE verified_sources ADD COLUMN compiler_sha TEXT;" 2>/dev/null || true
    # edit_commit: gitea edit-trail branch HEAD (fine-grained per-edit commits)
    # Used by the failure receipt to diff exactly what changed vs last-known-good.
    cdb "ALTER TABLE engine_builds ADD COLUMN edit_commit TEXT;" 2>/dev/null || true
    cdb "ALTER TABLE compiler_builds ADD COLUMN edit_commit TEXT;" 2>/dev/null || true
fi

record_build() {
    [ "$IS_CONFORMANCE" -eq 0 ] && return
    local status="$1"
    local error_log="${2:-}"
    local bin_sha=""
    local bin_size=""
    local bin_path="zig-out/bin/$NAME"

    if [ "$status" = "compiled" ] && [ -f "$bin_path" ]; then
        bin_sha=$(sha256sum "$bin_path" | awk '{print $1}')
        bin_size=$(stat --printf="%s" "$bin_path" 2>/dev/null || stat -f%z "$bin_path" 2>/dev/null || echo "")
    fi

    # Hash the engine .so that was linked against.
    # Prefer REACTJIT_ENGINE_SHA if set (locked by ICantCallPreExistingOnThisOne
    # before the build starts — immune to parallel sessions overwriting the .so).
    local eng_sha="${REACTJIT_ENGINE_SHA:-}"
    if [ -z "$eng_sha" ]; then
        local engine_so="zig-out/lib/libreactjit-core.so"
        [ -f "$engine_so" ] && eng_sha=$(sha256sum "$engine_so" | awk '{print $1}')
    fi

    # Gitea edit-trail branch head — fine-grained per-edit commits.
    # Falls back to main HEAD if edit-trail doesn't exist.
    local edit_head=$(git rev-parse edit-trail 2>/dev/null || git rev-parse HEAD 2>/dev/null || echo "unknown")

    # Register this engine in engine_builds if not already known
    local fw_hash_now=$(find framework/ -name '*.zig' -exec sha256sum {} + 2>/dev/null | sort | sha256sum | cut -c1-64)
    if [ -n "$eng_sha" ]; then
        local safe_eng=$(printf '%s' "$eng_sha" | sed "s/'/''/g")
        local commit=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
        cdb "INSERT OR IGNORE INTO engine_builds (engine_sha, commit_sha, source_hash, edit_commit)
            VALUES ('$safe_eng', '$commit', '$fw_hash_now', '$edit_head');"
        # Update edit_commit on subsequent records of the same engine — the
        # edit-trail advances on every edit, so the last recorded value wins.
        cdb "UPDATE engine_builds SET edit_commit = '$edit_head' WHERE engine_sha = '$safe_eng';"
    fi

    # On success: update this engine as "last known good" (compiled something)
    if [ "$status" = "compiled" ] && [ -n "$eng_sha" ]; then
        local safe_eng2=$(printf '%s' "$eng_sha" | sed "s/'/''/g")
        cdb "UPDATE engine_builds SET last_good_at = strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')
            WHERE engine_sha = '$safe_eng2';"
    fi

    # Hash the compiler (forge binary) that was used.
    # Prefer REACTJIT_COMPILER_SHA if set (locked by --proveMyCompilerBrokeIt).
    local comp_sha="${REACTJIT_COMPILER_SHA:-}"
    if [ -z "$comp_sha" ]; then
        local forge_bin="zig-out/bin/forge"
        [ -f "$forge_bin" ] && comp_sha=$(sha256sum "$forge_bin" | awk '{print $1}')
    fi

    # Register this compiler in compiler_builds if not already known
    local smith_hash_now=$(find compiler/ -name '*.js' -exec sha256sum {} + 2>/dev/null | sort | sha256sum | cut -c1-64)
    if [ -n "$comp_sha" ]; then
        local safe_comp=$(printf '%s' "$comp_sha" | sed "s/'/''/g")
        local commit=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
        cdb "INSERT OR IGNORE INTO compiler_builds (compiler_sha, commit_sha, source_hash, edit_commit)
            VALUES ('$safe_comp', '$commit', '$smith_hash_now', '$edit_head');"
        cdb "UPDATE compiler_builds SET edit_commit = '$edit_head' WHERE compiler_sha = '$safe_comp';"
    fi

    # On success: update this compiler as "last known good"
    if [ "$status" = "compiled" ] && [ -n "$comp_sha" ]; then
        local safe_comp2=$(printf '%s' "$comp_sha" | sed "s/'/''/g")
        cdb "UPDATE compiler_builds SET last_good_at = strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')
            WHERE compiler_sha = '$safe_comp2';"
    fi

    # Truncate error log to 500 chars, escape single quotes for SQL
    error_log=$(printf '%s' "$error_log" | head -c 500 | sed "s/'/''/g")
    # Escape all values for SQL safety
    local safe_name=$(printf '%s' "$CONF_NAME" | sed "s/'/''/g")
    local safe_lane=$(printf '%s' "$CONF_LANE" | sed "s/'/''/g")
    local safe_sha=$(printf '%s' "$bin_sha" | sed "s/'/''/g")
    local safe_src_sha=$(printf '%s' "$SOURCE_HASH" | sed "s/'/''/g")
    local safe_eng_sha=$(printf '%s' "$eng_sha" | sed "s/'/''/g")
    local safe_comp_sha=$(printf '%s' "$comp_sha" | sed "s/'/''/g")

    cdb "INSERT INTO builds (test_name, lane, status, binary_sha, binary_size, error_log, source_sha, engine_sha, compiler_sha)
        VALUES ('$safe_name', '$safe_lane', '$status', '$safe_sha', $( [ -n "$bin_size" ] && echo "$bin_size" || echo "NULL"), '$error_log', '$safe_src_sha', '$safe_eng_sha', '$safe_comp_sha');"

    # On failure, print the full receipt so Claude can't claim pre-existing
    if [ "$status" != "compiled" ]; then
        report_failure "$status"
    fi
}

report_failure() {
    [ "$IS_CONFORMANCE" -eq 0 ] && return
    local fail_status="$1"
    local safe_name=$(printf '%s' "$CONF_NAME" | sed "s/'/''/g")

    # Current engine + framework state
    local cur_eng="${REACTJIT_ENGINE_SHA:-}"
    if [ -z "$cur_eng" ]; then
        local engine_so="zig-out/lib/libreactjit-core.so"
        [ -f "$engine_so" ] && cur_eng=$(sha256sum "$engine_so" | awk '{print $1}')
    fi
    local fw_hash_now=$(find framework/ -name '*.zig' -exec sha256sum {} + 2>/dev/null | sort | sha256sum | cut -c1-16)

    # Current compiler state
    local cur_comp="${REACTJIT_COMPILER_SHA:-}"
    if [ -z "$cur_comp" ]; then
        local forge_bin="zig-out/bin/forge"
        [ -f "$forge_bin" ] && cur_comp=$(sha256sum "$forge_bin" | awk '{print $1}')
    fi
    local smith_hash_now=$(find compiler/ -name '*.js' -exec sha256sum {} + 2>/dev/null | sort | sha256sum | cut -c1-16)

    # Last good build for this test (now includes compiler_sha)
    local last_good=$(cdb "SELECT built_at, engine_sha, source_sha, compiler_sha
        FROM builds WHERE test_name = '$safe_name' AND status = 'compiled'
        ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)

    # Last good engine's framework source hash + edit-trail commit
    local lg_fw_hash=""
    local lg_comp_hash=""
    local lg_eng_edit=""
    local lg_comp_edit=""
    if [ -n "$last_good" ]; then
        local lg_eng_full=$(echo "$last_good" | cut -d'|' -f2)
        local lg_comp_full=$(echo "$last_good" | cut -d'|' -f4)
        if [ -n "$lg_eng_full" ]; then
            local safe_lg_eng=$(printf '%s' "$lg_eng_full" | sed "s/'/''/g")
            lg_fw_hash=$(cdb "SELECT substr(source_hash,1,16) FROM engine_builds
                WHERE engine_sha = '$safe_lg_eng';" 2>/dev/null || true)
            lg_eng_edit=$(cdb "SELECT edit_commit FROM engine_builds
                WHERE engine_sha = '$safe_lg_eng';" 2>/dev/null || true)
        fi
        if [ -n "$lg_comp_full" ]; then
            local safe_lg_comp=$(printf '%s' "$lg_comp_full" | sed "s/'/''/g")
            lg_comp_hash=$(cdb "SELECT substr(source_hash,1,16) FROM compiler_builds
                WHERE compiler_sha = '$safe_lg_comp';" 2>/dev/null || true)
            lg_comp_edit=$(cdb "SELECT edit_commit FROM compiler_builds
                WHERE compiler_sha = '$safe_lg_comp';" 2>/dev/null || true)
        fi
    fi
    # Current edit-trail HEAD for diffing against last-known-good
    local cur_edit=$(git rev-parse edit-trail 2>/dev/null || git rev-parse HEAD 2>/dev/null || echo "")

    # How many distinct engines and compilers this test has passed on
    local engine_count=$(cdb "SELECT COUNT(DISTINCT engine_sha)
        FROM builds WHERE test_name = '$safe_name' AND status = 'compiled'
        AND engine_sha IS NOT NULL AND engine_sha != '';" 2>/dev/null || echo "0")
    local compiler_count=$(cdb "SELECT COUNT(DISTINCT compiler_sha)
        FROM builds WHERE test_name = '$safe_name' AND status = 'compiled'
        AND compiler_sha IS NOT NULL AND compiler_sha != '';" 2>/dev/null || echo "0")

    # Human verification info
    local verified_info=$(cdb "SELECT verified_at, substr(engine_sha,1,16)
        FROM verified_sources WHERE test_name = '$safe_name';" 2>/dev/null || true)

    # Is current engine blessed?
    local is_eng_blessed=""
    if [ -n "$cur_eng" ]; then
        local safe_cur_eng=$(printf '%s' "$cur_eng" | sed "s/'/''/g")
        is_eng_blessed=$(cdb "SELECT blessed_at FROM engine_builds
            WHERE engine_sha = '$safe_cur_eng' AND blessed_at IS NOT NULL;" 2>/dev/null || true)
    fi

    # Is current compiler blessed?
    local is_comp_blessed=""
    if [ -n "$cur_comp" ]; then
        local safe_cur_comp=$(printf '%s' "$cur_comp" | sed "s/'/''/g")
        is_comp_blessed=$(cdb "SELECT blessed_at FROM compiler_builds
            WHERE compiler_sha = '$safe_cur_comp' AND blessed_at IS NOT NULL;" 2>/dev/null || true)
    fi

    # Last engine that compiled ANYTHING successfully
    local last_any_good=$(cdb "SELECT substr(engine_sha,1,16), last_good_at, substr(source_hash,1,16)
        FROM engine_builds WHERE last_good_at IS NOT NULL
        ORDER BY last_good_at DESC LIMIT 1;" 2>/dev/null || true)

    # Last compiler that compiled ANYTHING successfully
    local last_any_good_comp=$(cdb "SELECT substr(compiler_sha,1,16), last_good_at, substr(source_hash,1,16)
        FROM compiler_builds WHERE last_good_at IS NOT NULL
        ORDER BY last_good_at DESC LIMIT 1;" 2>/dev/null || true)

    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  BUILD FAILURE RECEIPT: $CONF_NAME"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║"
    echo "║  Failed stage:    $fail_status"
    echo "║  Test source:     ${SOURCE_HASH:0:16}..."
    echo "║  Your engine:     ${cur_eng:0:16}...$([ -n "$is_eng_blessed" ] && echo " (BLESSED)" || echo " (NOT BLESSED)")"
    echo "║  Your framework:  ${fw_hash_now}..."
    echo "║  Your compiler:   ${cur_comp:0:16}...$([ -n "$is_comp_blessed" ] && echo " (BLESSED)" || echo " (NOT BLESSED)")"
    echo "║  Your smith src:  ${smith_hash_now}..."
    echo "║"

    if [ -n "$last_good" ]; then
        local lg_time=$(echo "$last_good" | cut -d'|' -f1)
        local lg_eng=$(echo "$last_good" | cut -d'|' -f2)
        local lg_src=$(echo "$last_good" | cut -d'|' -f3)
        local lg_comp=$(echo "$last_good" | cut -d'|' -f4)
        echo "║  ── LAST KNOWN GOOD (this test) ──"
        echo "║  Built at:        $lg_time"
        echo "║  Engine:          ${lg_eng:0:16}..."
        echo "║  Framework src:   ${lg_fw_hash:-unknown}..."
        echo "║  Compiler:        ${lg_comp:0:16}..."
        echo "║  Smith src:       ${lg_comp_hash:-unknown}..."
        if [ "$lg_src" = "$SOURCE_HASH" ]; then
            echo "║  Test source:     UNCHANGED (same hash)"
        else
            echo "║  Test source:     CHANGED (test was modified!)"
        fi
        if [ -n "$lg_fw_hash" ] && [ "$lg_fw_hash" = "$fw_hash_now" ]; then
            echo "║  Framework src:   UNCHANGED (same hash)"
        elif [ -n "$lg_fw_hash" ]; then
            echo "║  Framework src:   CHANGED ← YOU changed the engine code"
        fi
        if [ -n "$lg_comp_hash" ] && [ "$lg_comp_hash" = "$smith_hash_now" ]; then
            echo "║  Smith src:       UNCHANGED (same hash)"
        elif [ -n "$lg_comp_hash" ]; then
            echo "║  Smith src:       CHANGED ← YOU changed the compiler code"
        fi
    else
        echo "║  Last good build:  NEVER (no successful build on record)"
    fi

    echo "║"
    if [ -n "$last_any_good" ]; then
        local lag_eng=$(echo "$last_any_good" | cut -d'|' -f1)
        local lag_time=$(echo "$last_any_good" | cut -d'|' -f2)
        local lag_fw=$(echo "$last_any_good" | cut -d'|' -f3)
        echo "║  ── LAST ENGINE THAT COMPILED ANYTHING ──"
        echo "║  Engine:          ${lag_eng}..."
        echo "║  Compiled at:     $lag_time"
        echo "║  Framework src:   ${lag_fw}..."
        if [ "$lag_fw" != "$fw_hash_now" ]; then
            echo "║  vs your code:    DIFFERENT ← your framework/ changes broke it"
        fi
    fi

    if [ -n "$last_any_good_comp" ]; then
        local lac_comp=$(echo "$last_any_good_comp" | cut -d'|' -f1)
        local lac_time=$(echo "$last_any_good_comp" | cut -d'|' -f2)
        local lac_smith=$(echo "$last_any_good_comp" | cut -d'|' -f3)
        echo "║  ── LAST COMPILER THAT COMPILED ANYTHING ──"
        echo "║  Compiler:        ${lac_comp}..."
        echo "║  Compiled at:     $lac_time"
        echo "║  Smith src:       ${lac_smith}..."
        if [ "$lac_smith" != "$smith_hash_now" ]; then
            echo "║  vs your code:    DIFFERENT ← your compiler/ changes broke it"
        fi
    fi

    # ── What actually changed — diff against last-known-good edit-trail ──
    # The gitea edit-trail branch records every edit as a separate commit,
    # tagged with the session ID that made it. If the framework or compiler
    # hash changed, we can show EXACTLY which files changed and which session
    # touched them.
    local fw_changed=0
    local comp_changed=0
    [ -n "$lg_fw_hash" ] && [ "$lg_fw_hash" != "$fw_hash_now" ] && fw_changed=1
    [ -n "$lg_comp_hash" ] && [ "$lg_comp_hash" != "$smith_hash_now" ] && comp_changed=1

    if [ -n "$cur_edit" ] && { [ "$fw_changed" = "1" ] || [ "$comp_changed" = "1" ]; }; then
        echo "║"
        echo "║  ── WHAT CHANGED (edit-trail diff) ──"
        # last-known-good built_at timestamp — used as a fallback when
        # edit_commit is NULL (historical rows from before this column existed).
        local lg_time_iso=""
        if [ -n "$last_good" ]; then
            lg_time_iso=$(echo "$last_good" | cut -d'|' -f1)
        fi

        # Resolve the "base" commit to diff against:
        # 1. Prefer the explicit edit_commit stored at last-good build time
        # 2. Fall back to the edit-trail commit closest to lg_time_iso
        resolve_base() {
            local stored="$1"
            local dir_filter="$2"
            if [ -n "$stored" ] && git cat-file -e "${stored}^{commit}" 2>/dev/null; then
                echo "$stored"
                return
            fi
            # Fallback: find the edit-trail commit at or just before the
            # last-good build time, narrowed to commits that touched this dir
            if [ -n "$lg_time_iso" ]; then
                git log --before="$lg_time_iso" -1 --format=%H edit-trail -- "$dir_filter" 2>/dev/null
            fi
        }

        if [ "$fw_changed" = "1" ]; then
            local fw_base=$(resolve_base "$lg_eng_edit" "framework/")
            if [ -n "$fw_base" ] && [ "$fw_base" != "$cur_edit" ]; then
                local base_label="${fw_base:0:10}"
                [ -z "$lg_eng_edit" ] && base_label="${base_label} (resolved by timestamp)"
                echo "║  Framework files changed since $base_label:"
                local fw_stat=$(git diff --stat "$fw_base" "$cur_edit" -- framework/ 2>/dev/null | head -20)
                if [ -n "$fw_stat" ]; then
                    echo "$fw_stat" | sed 's/^/║    /'
                else
                    echo "║    (no file-level changes detected)"
                fi
                echo "║"
                echo "║  Edit-trail commits that touched framework/:"
                local fw_log=$(git log --oneline "$fw_base..$cur_edit" -- framework/ 2>/dev/null | head -10)
                if [ -n "$fw_log" ]; then
                    echo "$fw_log" | sed 's/^/║    /'
                else
                    echo "║    (no commits between base and HEAD)"
                fi
            else
                echo "║  Framework: couldn't resolve last-known-good commit (stored=${lg_eng_edit:-none})"
            fi
        fi

        if [ "$comp_changed" = "1" ]; then
            local comp_base=$(resolve_base "$lg_comp_edit" "compiler/")
            if [ -n "$comp_base" ] && [ "$comp_base" != "$cur_edit" ]; then
                local base_label="${comp_base:0:10}"
                [ -z "$lg_comp_edit" ] && base_label="${base_label} (resolved by timestamp)"
                echo "║"
                echo "║  Compiler files changed since $base_label:"
                local comp_stat=$(git diff --stat "$comp_base" "$cur_edit" -- compiler/ 2>/dev/null | head -20)
                if [ -n "$comp_stat" ]; then
                    echo "$comp_stat" | sed 's/^/║    /'
                else
                    echo "║    (no file-level changes detected)"
                fi
                echo "║"
                echo "║  Edit-trail commits that touched compiler/:"
                local comp_log=$(git log --oneline "$comp_base..$cur_edit" -- compiler/ 2>/dev/null | head -10)
                if [ -n "$comp_log" ]; then
                    echo "$comp_log" | sed 's/^/║    /'
                else
                    echo "║    (no commits between base and HEAD)"
                fi
            else
                echo "║  Compiler: couldn't resolve last-known-good commit (stored=${lg_comp_edit:-none})"
            fi
        fi
    fi

    echo "║"
    echo "║  ── HISTORY ──"
    echo "║  Engines this test has passed on:   $engine_count"
    echo "║  Compilers this test has passed on: $compiler_count"
    if [ -n "$verified_info" ]; then
        local v_time=$(echo "$verified_info" | cut -d'|' -f1)
        local v_eng=$(echo "$verified_info" | cut -d'|' -f2)
        echo "║  Human verified:  $v_time (engine $v_eng...)"
    else
        echo "║  Human verified:  NEVER"
    fi

    echo "║"
    if [ -n "$verified_info" ]; then
        echo "║  Human has verified this source code works. It has built"
        echo "║  successfully against $engine_count engine(s). The framework"
        echo "║  source you are running is DIFFERENT from the last working"
        echo "║  build. This is an error in YOUR CODE."
    elif [ "$engine_count" -gt 0 ] 2>/dev/null; then
        echo "║  This test has compiled successfully against $engine_count"
        echo "║  engine(s) in the past. The framework source you are running"
        echo "║  is DIFFERENT from the last working build."
        echo "║  This is an error in YOUR CODE."
    else
        echo "║  This is an error in YOUR CODE."
    fi
    echo "║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
}

# Pick optimize flag
if [ "$OPT" = "--debug" ]; then
    ZIG_OPT=""
else
    ZIG_OPT="-Doptimize=ReleaseFast"
fi

# ── Source hash: baseline lock + tamper check ──────────────────────
SOURCE_HASH=""
if [ "$IS_CONFORMANCE" -eq 1 ]; then
    SOURCE_HASH=$(sha256sum "$CART" | awk '{print $1}')

    # Get the hash from the very first build of this test
    SAFE_CONF_NAME=$(printf '%s' "$CONF_NAME" | sed "s/'/''/g")
    BASELINE_HASH=$(cdb "SELECT source_sha FROM builds WHERE test_name = '$SAFE_CONF_NAME' AND source_sha IS NOT NULL AND source_sha != '' ORDER BY id ASC LIMIT 1;" 2>/dev/null || true)

    if [ -n "$BASELINE_HASH" ] && [ "$SOURCE_HASH" != "$BASELINE_HASH" ]; then
        # Check if human has overridden to accept this hash
        OVERRIDE_HASH=$(cdb "SELECT source_sha FROM source_overrides WHERE test_name = '$SAFE_CONF_NAME';" 2>/dev/null || true)
        if [ "$SOURCE_HASH" != "$OVERRIDE_HASH" ]; then
            echo ""
            echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
            echo "  TAMPER DETECTED: $NAME"
            echo ""
            echo "  The source .tsz has changed since it was first built."
            echo "  Baseline: $BASELINE_HASH"
            echo "  Current:  $SOURCE_HASH"
            echo ""
            echo "  If the source change is legitimate, the HUMAN must run:"
            echo "    ./scripts/conformance-report --override $NAME"
            echo ""
            echo "  DO NOT edit conformance test source files."
            echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
            echo ""
            exit 1
        fi
    fi
fi

# ── Step 1/3: Compiler (forge + smith JS) ───────────────────────────
# Hash smith JS to detect compiler changes. Forge embeds these at compile
# time — if they changed, forge needs a real rebuild (~22s).
SMITH_HASH_NOW=$(find compiler/ -name '*.js' -exec sha256sum {} + 2>/dev/null | sort | sha256sum | cut -c1-16)
FORGE_BIN="zig-out/bin/forge"
BLESSED_FORGE="zig-out/bin/forge-blessed"
FORGE_HASH_BEFORE=$(sha256sum "$FORGE_BIN" 2>/dev/null | cut -c1-16 || echo "none")

# Three modes for compiler:
#   1. --proveMyCompilerBrokeIt → use blessed compiler, lock its hash
#   2. Normal → rebuild forge from current compiler/ source
if [ "$PROVE_COMPILER_BROKE_IT" -eq 1 ]; then
    if [ ! -f "$BLESSED_FORGE" ]; then
        echo "[$NAME] ERROR: --proveMyCompilerBrokeIt requires a blessed compiler."
        echo "  Ask the human to run: ./scripts/bless-compiler"
        exit 1
    fi
    # Back up the dirty forge, swap blessed in
    FORGE_BACKUP=""
    if [ -f "$FORGE_BIN" ]; then
        FORGE_BACKUP=$(mktemp /tmp/rjit-dirty-forge.XXXXXX)
        cp "$FORGE_BIN" "$FORGE_BACKUP"
    fi
    cp "$BLESSED_FORGE" "$FORGE_BIN"
    export REACTJIT_COMPILER_SHA=$(sha256sum "$BLESSED_FORGE" | awk '{print $1}')
    FORGE_MS=0

    # Trap: restore dirty forge on ANY exit (success or failure)
    _restore_forge() {
        if [ -n "${FORGE_BACKUP:-}" ] && [ -f "${FORGE_BACKUP:-}" ]; then
            cp "$FORGE_BACKUP" "$FORGE_BIN"
            rm -f "$FORGE_BACKUP"
        fi
    }
    trap _restore_forge EXIT

    BLESSED_COMP_STAMP="zig-out/bin/.compiler-blessed-stamp"
    if [ -f "$BLESSED_COMP_STAMP" ]; then
        BLESSED_COMP_COMMIT=$(grep '^commit:' "$BLESSED_COMP_STAMP" | cut -d' ' -f2)
        BLESSED_COMP_DATE=$(grep '^date:' "$BLESSED_COMP_STAMP" | cut -d' ' -f2-)
        echo "[$NAME] 1/3 compiler: blessed from ${BLESSED_COMP_COMMIT:0:7} ($BLESSED_COMP_DATE)"
    else
        echo "[$NAME] 1/3 compiler: blessed"
    fi
    echo "[$NAME] 1/3 compiler hash locked: ${REACTJIT_COMPILER_SHA:0:16}..."
else
    PHASE_T=$(date +%s%N)
    zig build forge 2>/dev/null || {
        echo "[$NAME] WARNING: zig build forge failed — using existing binary"
    }
    FORGE_MS=$(( ($(date +%s%N) - PHASE_T) / 1000000 ))

    FORGE_HASH_AFTER=$(sha256sum "$FORGE_BIN" 2>/dev/null | cut -c1-16 || echo "none")
    if [ "$FORGE_HASH_BEFORE" != "$FORGE_HASH_AFTER" ]; then
        echo "[$NAME] 1/3 compiler rebuilt (smith JS changed): ${FORGE_MS}ms"
    else
        echo "[$NAME] 1/3 compiler up to date (${FORGE_MS}ms)"
    fi
fi

# ── Step 2/3: Engine (.so from framework/) ──────────────────────────
PHASE_T=$(date +%s%N)
# Three modes:
#   1. REACTJIT_SKIP_ENGINE_BUILD=1 → blessed engine already swapped in, don't touch
#   2. --proveIBrokeIt → swap blessed engine in for this build
#   3. Normal → check if framework/ changed since last engine build.
#      If changed: force dirty rebuild (cache nuke). If not: use existing.
BLESSED_SO="zig-out/lib/libreactjit-core-blessed.so"

if [ "${REACTJIT_SKIP_ENGINE_BUILD:-0}" = "1" ]; then
    echo "[$NAME] 2/3 engine: blessed (skip rebuild)"

elif [ "$PROVE_I_BROKE_IT" -eq 1 ]; then
    # --proveIBrokeIt: use the blessed engine, lock its hash
    if [ ! -f "$BLESSED_SO" ]; then
        echo "[$NAME] ERROR: --proveIBrokeIt requires a blessed engine."
        echo "  Ask the human to run: ./scripts/bless-engine"
        exit 1
    fi
    cp "$BLESSED_SO" "zig-out/lib/libreactjit-core.so"
    export REACTJIT_ENGINE_SHA=$(sha256sum "$BLESSED_SO" | awk '{print $1}')
    echo "[$NAME] 2/3 engine: blessed (--proveIBrokeIt): ${REACTJIT_ENGINE_SHA:0:16}..."

else
    # Auto-detect: has framework/ changed since last engine build?
    ENGINE_SO="zig-out/lib/libreactjit-core.so"
    FW_HASH_NOW=$(find framework/ -name '*.zig' -exec sha256sum {} + 2>/dev/null | sort | sha256sum | cut -c1-64)

    # Get source hash of the last recorded engine build
    LAST_ENGINE_SRC=""
    if [ -f "$ENGINE_SO" ]; then
        CUR_ENG_SHA=$(sha256sum "$ENGINE_SO" | awk '{print $1}')
        SAFE_CUR_ENG=$(printf '%s' "$CUR_ENG_SHA" | sed "s/'/''/g")
        if [ -f "conformance.db" ]; then
            LAST_ENGINE_SRC=$(sqlite3 conformance.db ".timeout 5000" \
                "SELECT source_hash FROM engine_builds WHERE engine_sha = '$SAFE_CUR_ENG';" 2>/dev/null || true)
        fi
    fi

    # Detect untracked engine builds (someone ran zig build core-so directly)
    if [ -f "$ENGINE_SO" ] && [ -f "conformance.db" ] && [ -z "$LAST_ENGINE_SRC" ]; then
        echo ""
        echo "  !! UNTRACKED ENGINE DETECTED"
        echo "  !! The current engine .so (${CUR_ENG_SHA:0:16}...) is not in the DB."
        echo "  !! Someone ran 'zig build core-so' directly, bypassing the build system."
        echo "  !! Forcing clean rebuild to get back on track."
        echo ""
    fi

    if [ -n "$LAST_ENGINE_SRC" ] && [ "$FW_HASH_NOW" = "$LAST_ENGINE_SRC" ]; then
        # Framework unchanged — use existing engine
        echo "[$NAME] 2/3 engine up to date (framework/ unchanged)"
    else
        # Framework changed, unknown engine, or untracked build — force dirty rebuild
        if [ -n "$LAST_ENGINE_SRC" ]; then
            echo "[$NAME] 2/3 engine: framework/ changed — rebuilding"
        else
            echo "[$NAME] 2/3 engine: not registered — rebuilding"
        fi
        SO_HASH_BEFORE=$(sha256sum "$ENGINE_SO" 2>/dev/null | cut -c1-16 || echo "none")
        zig build core-so -Doptimize=ReleaseFast 2>&1 || {
            echo ""
            echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
            echo "  ENGINE BUILD FAILED"
            echo "  Your framework/ changes don't compile."
            echo "  Fix them before building carts."
            echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"

            # Show the receipt if this is a conformance build
            if [ "$IS_CONFORMANCE" -eq 1 ]; then
                record_build "engine_fail" "engine build failed — framework/ changes don't compile"
            fi
            exit 1
        }
        # Record the new engine
        NEW_ENG_SHA=$(sha256sum "$ENGINE_SO" | awk '{print $1}')
        COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
        if [ -f "conformance.db" ]; then
            sqlite3 conformance.db ".timeout 5000" \
                "INSERT OR REPLACE INTO engine_builds (engine_sha, commit_sha, source_hash)
                 VALUES ('$NEW_ENG_SHA', '$COMMIT', '$FW_HASH_NOW');" 2>/dev/null || true
        fi
        # Verify the rebuild actually produced a different binary
        if [ "$SO_HASH_BEFORE" != "none" ] && [ "$SO_HASH_BEFORE" = "${NEW_ENG_SHA:0:16}" ]; then
            echo "[$NAME] !! ENGINE CACHE LIED: framework changed but .so hash unchanged"
            echo "[$NAME] !! Nuking cache and retrying..."
            rm -rf .zig-cache/h
            rm -f "$ENGINE_SO"
            zig build core-so -Doptimize=ReleaseFast 2>&1 || {
                echo "[$NAME] engine rebuild failed on retry"
                exit 1
            }
            NEW_ENG_SHA=$(sha256sum "$ENGINE_SO" | awk '{print $1}')
        fi
        echo "[$NAME] 2/3 engine rebuilt: ${NEW_ENG_SHA:0:16}..."
    fi
fi
ENGINE_ROUTE_MS=$(( ($(date +%s%N) - PHASE_T) / 1000000 ))
[ "$ENGINE_ROUTE_MS" -gt 500 ] && echo "[$NAME] 2/3 engine: ${ENGINE_ROUTE_MS}ms"

# ── Step 3/3: Cart (.tsz → .zig → binary) ──────────────────────────
rm -f "$GEN"
rm -rf "$GEN_DIR"
echo "[$NAME] 3/3 forge..."
FORGE_START=$(date +%s%N)
FORGE_OUT=$(./zig-out/bin/forge build --fast $DBG_FLAGS $TRACE_FLAGS "$CART" 2>&1) || {
    echo "$FORGE_OUT"
    record_build "forge_fail" "$FORGE_OUT"
    exit 1
}
FORGE_END=$(date +%s%N)
FORGE_MS=$(( (FORGE_END - FORGE_START) / 1000000 ))
echo "$FORGE_OUT"

# Parse source metrics from forge output
SOURCE_LINES=$(echo "$FORGE_OUT" | grep -oP 'source_lines=\K[0-9]+' || echo "0")
GENERATED_BYTES=0
# Get generated output size
if [ -d "$GEN_DIR" ]; then
    GENERATED_BYTES=$(cat "$GEN_DIR"/*.zig 2>/dev/null | wc -c)
elif [ -f "$GEN" ]; then
    GENERATED_BYTES=$(wc -c < "$GEN" 2>/dev/null || echo "0")
fi

# Some soup carts currently return split-output markers in a monolith payload
# instead of a generated directory. Fall back to a single-file forge build so
# the standard native build path can still link the cart.
if [ -f "$GEN" ] && grep -q '^__SPLIT_OUTPUT__$' "$GEN" 2>/dev/null; then
    echo "[$NAME] forge returned split markers in monolith output — retrying with --single..."
    ./zig-out/bin/forge build --fast --single $TRACE_FLAGS "$CART" 2>&1
fi

# If split output, concat all files for lint (grep needs a single target)
SPLIT_LINT=0
if [ -d "$GEN_DIR" ] && [ ! -f "$GEN" ]; then
    GEN=$(mktemp /tmp/lint_XXXXXX.zig)
    cat "$GEN_DIR"/*.zig > "$GEN"
    SPLIT_LINT=1
fi

# ── Preflight block check ───────────────────────────────────────────
if grep -q "PREFLIGHT BLOCKED" "$GEN" 2>/dev/null; then
    echo "[$NAME] PREFLIGHT BLOCKED:"
    grep "FATAL:\|WARN:" "$GEN" 2>/dev/null | sed 's/^\/\/! /  /'
    echo "[$NAME] Fix the .tsz source errors above. Generated file: $GEN"
    if [ "$SPLIT_LINT" -eq 1 ]; then rm -f "$GEN"; fi
    record_build "preflight_blocked" "$(grep 'FATAL:\|WARN:' "$GEN" 2>/dev/null | head -5)"
    exit 1
fi

# ── Step 2: output-level lint ───────────────────────────────────────
LINT_FAIL=0
LINT_WARN=0

BAD_QUOTES=$(grep -n "'\w\w" "$GEN" 2>/dev/null | grep -v '^\s*[0-9]*:\s*\\\\' | grep -v 'lua_on_press' | grep -v 'js_on_press' | grep -v 'evalExpr' | grep -v 'evalToString' | grep -v '^\s*[0-9]*:\s*//' | head -5 || true)
if [ -n "$BAD_QUOTES" ]; then
    echo "[$NAME] LINT FAIL: JS string leaked into Zig (single-quoted multi-char):"
    echo "$BAD_QUOTES"
    LINT_FAIL=1
fi

if grep -q '^const JS_LOGIC =' "$GEN" 2>/dev/null; then
    BAD_JS=$(sed -n '/^const JS_LOGIC =/,/^;$/p' "$GEN" | grep -v '^\s*\\\\' | grep -v '^const \|^;$' | grep -v '^\s*$' | grep -v '^\s*//' | head -5 || true)
    if [ -n "$BAD_JS" ]; then
        echo "[$NAME] LINT FAIL: raw JS leaked into JS_LOGIC Zig string:"
        echo "$BAD_JS"
        LINT_FAIL=1
    fi
fi

for MI in $(grep -oE '_map_inner_[0-9]+' "$GEN" 2>/dev/null | sort -u || true); do
    MAP_NUM=${MI#_map_inner_}
    SHARED=$(grep "$MI\[_i\].*&_arr_" "$GEN" 2>/dev/null | head -3 || true)
    if [ -n "$SHARED" ]; then
        echo "[$NAME] LINT WARN: $MI references shared static _arr_ arrays — map items will render identical content"
        LINT_WARN=1
    fi
done

if grep -q '__setObjArr' "$GEN" 2>/dev/null; then
    echo "[$NAME] LINT WARN: __setObjArr in generated code — verify LuaJIT registration"
    LINT_WARN=1
fi

if [ "$LINT_FAIL" -eq 1 ]; then
    echo "[$NAME] BLOCKED — fix smith before building. Generated file: $GEN"
    record_build "forge_fail" "lint: JS string or bad quote leaked into generated Zig"
    exit 1
fi

if [ "$LINT_WARN" -eq 1 ]; then
    echo "[$NAME] warnings above — building anyway but expect visual bugs"
fi

if [ "$SPLIT_LINT" -eq 1 ]; then rm -f "$GEN"; fi

# ── Step 2b: flight check (post-compile, pre-build integrity) ─────────
FLIGHT_GEN="$GEN_DIR"
[ ! -d "$FLIGHT_GEN" ] && FLIGHT_GEN="$GEN_ROOT/generated_${NAME}.zig"
# Flight check runs for ALL modes — lua-tree checks are inside flight-check itself
if [ -e "$FLIGHT_GEN" ]; then
    FLIGHT_EXIT=0
    FLIGHT_OUT=$(./scripts/flight-check "$CART" "$FLIGHT_GEN" 2>&1) || FLIGHT_EXIT=$?
    echo "$FLIGHT_OUT" | tail -1
    if [ "$FLIGHT_EXIT" -ne 0 ]; then
        echo "$FLIGHT_OUT"
        record_build "flight_fail" "$FLIGHT_OUT"
        exit 1
    fi
fi

# Resolve source: prefer split directory over monolith
if [ -d "$GEN_DIR" ] && [ -f "$GEN_DIR/app.zig" ]; then
    APP_SOURCE="$GEN_DIR/app.zig"
else
    APP_SOURCE="$GEN"
fi

# ── Step 2c: optional dep resolution (deps.json manifest) ────────────
# Scan the .tsz source for each dep's detection patterns. If found,
# build or locate the .so, pass to link.lua, mark for bundling.
IS_LINUX=1; IS_MACOS=0
[ "$(uname -s)" = "Darwin" ] && { IS_LINUX=0; IS_MACOS=1; }

RESOLVED_DEPS=""       # space-separated list of dep names that matched
RESOLVED_SOS=""        # space-separated list of .so paths to link
RESOLVED_LINK_LIBS=""  # space-separated extra -l flags

resolve_deps() {
    local deps_file="deps.json"
    [ ! -f "$deps_file" ] && return

    local dep_names
    dep_names=$(jq -r 'keys[]' "$deps_file")

    for dep in $dep_names; do
        # Build grep pattern from detect array: "pat1\|pat2\|pat3"
        local patterns
        patterns=$(jq -r --arg d "$dep" '.[$d].detect | join("\\|")' "$deps_file")
        [ -z "$patterns" ] && continue

        if ! grep -qE "$(echo "$patterns" | sed 's/\\|/|/g')" "$CART" 2>/dev/null; then
            continue
        fi

        local desc
        desc=$(jq -r --arg d "$dep" '.[$d].description // $d' "$deps_file")
        RESOLVED_DEPS="$RESOLVED_DEPS $dep"

        # Case 1: we build the .so ourselves (like llama)
        local build_step
        build_step=$(jq -r --arg d "$dep" '.[$d].build_step // empty' "$deps_file")
        if [ -n "$build_step" ]; then
            local so_name
            so_name=$(jq -r --arg d "$dep" '.[$d].so // empty' "$deps_file")
            local ext=".so"; [ "$IS_MACOS" -eq 1 ] && ext=".dylib"
            local so_path="zig-out/lib/${so_name}${ext}"
            if [ ! -f "$so_path" ]; then
                echo "[$NAME] $desc detected — building ${so_name}${ext}..."
                local t_start; t_start=$(date +%s%N)
                eval "$build_step" 2>&1 || { echo "[$NAME] ERROR: $dep build failed"; exit 1; }
                local t_ms=$(( ($(date +%s%N) - t_start) / 1000000 ))
                echo "[$NAME] ${so_name}${ext} built (${t_ms}ms)"
            else
                echo "[$NAME] $desc detected — ${so_name}${ext} cached"
            fi
            RESOLVED_SOS="$RESOLVED_SOS $so_path"
        fi

        # Case 2: system .so (like libmpv, libbox2d)
        local so_key="system_so"
        local search_key="system_search"
        [ "$IS_MACOS" -eq 1 ] && { so_key="macos_so"; search_key="macos_search"; }

        local sys_candidates
        sys_candidates=$(jq -r --arg d "$dep" --arg k "$so_key" '.[$d][$k] // [] | .[]' "$deps_file" 2>/dev/null)
        if [ -n "$sys_candidates" ]; then
            local found_so=""
            # Build search paths: system defaults + manifest extras
            local search_paths="/usr/lib /usr/lib/x86_64-linux-gnu /usr/local/lib"
            [ "$IS_MACOS" -eq 1 ] && search_paths="/opt/homebrew/lib /usr/local/lib /usr/lib"
            local extra_paths
            extra_paths=$(jq -r --arg d "$dep" --arg k "$search_key" '.[$d][$k] // [] | .[]' "$deps_file" 2>/dev/null)
            [ -n "$extra_paths" ] && search_paths="$extra_paths $search_paths"

            for candidate in $sys_candidates; do
                # Try ldconfig first (Linux)
                if [ "$IS_LINUX" -eq 1 ]; then
                    found_so=$(ldconfig -p 2>/dev/null | grep "$candidate" | head -1 | sed 's/.* => //' || true)
                    [ -n "$found_so" ] && [ -f "$found_so" ] && break
                fi
                # Search known paths
                for dir in $search_paths; do
                    if [ -f "$dir/$candidate" ]; then
                        found_so="$dir/$candidate"
                        break 2
                    fi
                done
            done

            if [ -n "$found_so" ]; then
                echo "[$NAME] $desc detected — found $found_so"
                RESOLVED_SOS="$RESOLVED_SOS $found_so"
            else
                echo "[$NAME] WARNING: $desc detected in source but library not found on system"
            fi
        fi

        # Extra link libs (like -lvulkan for llama)
        local extra_libs
        extra_libs=$(jq -r --arg d "$dep" '.[$d].link_libs // [] | .[]' "$deps_file" 2>/dev/null)
        for lib in $extra_libs; do
            RESOLVED_LINK_LIBS="$RESOLVED_LINK_LIBS $lib"
        done
    done
}
resolve_deps

# Export for link.lua
if [ -n "$RESOLVED_SOS" ]; then
    export TSZ_LINK_EXTRA_SOS="$RESOLVED_SOS"
    export TSZ_LINK_EXTRA_LIBS="$RESOLVED_LINK_LIBS"
fi

# ── Step 3: LuaJIT link (cart .zig → .o + engine .so → binary) ───────
echo "[$NAME] zig build..."
ZIG_START=$(date +%s%N)
[ "$GDB_MODE" -eq 1 ] && export TSZ_GDB=1
LINK_OUT=$(luajit scripts/link.lua "$APP_SOURCE" "$NAME" 2>&1) || {
    echo "$LINK_OUT"
    record_build "zig_fail" "$LINK_OUT"
    exit 1
}
ZIG_END=$(date +%s%N)
ZIG_MS=$(( (ZIG_END - ZIG_START) / 1000000 ))
echo "$LINK_OUT"

# ── Step 3b: GDB mode — skip packaging, run under gdb ──────────────
if [ "$GDB_MODE" -eq 1 ]; then
    RAW_BIN="zig-out/bin/$NAME"
    echo "[$NAME] running under gdb..."
    LD_LIBRARY_PATH=zig-out/lib gdb -batch \
        -ex run \
        -ex 'bt 20' \
        -ex 'info locals' \
        -ex quit \
        "$RAW_BIN" 2>&1
    echo "[$NAME] gdb done (exit $?)"
    exit 0
fi

# ── Step 4: Package as self-extracting binary ────────────────────────
RAW_BIN="zig-out/bin/$NAME"
OS="$(uname -s)"

if [ -f "$RAW_BIN" ] && [ "$OPT" != "--debug" ]; then
    echo "[$NAME] packaging..."
    TMP_DIR="/tmp/tsz-dist-$NAME"
    LIB_DIR="$TMP_DIR/lib"
    rm -rf "$TMP_DIR"
    mkdir -p "$LIB_DIR"
    cp "$RAW_BIN" "$TMP_DIR/app.bin"

    LIB_COUNT=0

    if [ "$OS" = "Darwin" ]; then
        # ── macOS: package as .app bundle ────────────────────────────
        APP_BUNDLE="zig-out/bin/${NAME}.app"
        CONTENTS="$APP_BUNDLE/Contents"
        MACOS_DIR="$CONTENTS/MacOS"
        FW_DIR="$CONTENTS/Frameworks"
        rm -rf "$APP_BUNDLE"
        mkdir -p "$MACOS_DIR" "$FW_DIR"

        cp "$RAW_BIN" "$MACOS_DIR/$NAME"

        # Info.plist
        cat > "$CONTENTS/Info.plist" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>$NAME</string>
    <key>CFBundleIdentifier</key>
    <string>com.reactjit.$NAME</string>
    <key>CFBundleName</key>
    <string>$NAME</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
</dict>
</plist>
PLIST

        # Bundle engine dylib
        ENGINE_DYLIB="zig-out/lib/libreactjit-core.dylib"
        [ -f "$ENGINE_DYLIB" ] && cp "$ENGINE_DYLIB" "$FW_DIR/libreactjit-core.dylib"

        # Bundle resolved dep .so/.dylibs
        for dep_so in $RESOLVED_SOS; do
            [ -f "$dep_so" ] && cp "$dep_so" "$FW_DIR/$(basename "$dep_so")"
        done

        # Recursively collect non-system dylibs
        collect_dylibs() {
            for bin in "$@"; do
                otool -L "$bin" 2>/dev/null | tail -n +2 | awk '{print $1}' | while read -r lib_path; do
                    case "$lib_path" in
                        /usr/lib/*|/System/*|@rpath/*|@executable_path/*) continue ;;
                    esac
                    [ ! -f "$lib_path" ] && continue
                    lib_name=$(basename "$lib_path")
                    [ -f "$FW_DIR/$lib_name" ] && continue
                    cp "$lib_path" "$FW_DIR/$lib_name"
                    echo "$lib_name"
                done
            done
        }
        collect_dylibs "$MACOS_DIR/$NAME"
        [ -f "$ENGINE_DYLIB" ] && collect_dylibs "$FW_DIR/libreactjit-core.dylib"
        # Transitive deps from all bundled dylibs
        collect_dylibs "$FW_DIR"/*.dylib

        # Rewrite dylib references to @executable_path/../Frameworks/
        rewrite_dylib_paths() {
            local bin="$1"
            otool -L "$bin" 2>/dev/null | tail -n +2 | awk '{print $1}' | while read -r lib_path; do
                case "$lib_path" in
                    /usr/lib/*|/System/*|@rpath/*|@executable_path/*) continue ;;
                esac
                lib_name=$(basename "$lib_path")
                install_name_tool -change "$lib_path" "@executable_path/../Frameworks/$lib_name" "$bin" 2>/dev/null || true
            done
        }

        # Fix the main binary
        rewrite_dylib_paths "$MACOS_DIR/$NAME"
        # Also rewrite @rpath references (engine .dylib is linked via @rpath by link.lua)
        install_name_tool -change "@rpath/libreactjit-core.dylib" "@executable_path/../Frameworks/libreactjit-core.dylib" "$MACOS_DIR/$NAME" 2>/dev/null || true
        install_name_tool -add_rpath "@executable_path/../Frameworks" "$MACOS_DIR/$NAME" 2>/dev/null || true

        # Fix each bundled dylib
        for dylib in "$FW_DIR"/*.dylib; do
            [ -f "$dylib" ] || continue
            lib_name=$(basename "$dylib")
            install_name_tool -id "@executable_path/../Frameworks/$lib_name" "$dylib" 2>/dev/null || true
            rewrite_dylib_paths "$dylib"
        done

        # Ad-hoc sign everything (Sequoia requires valid signatures)
        codesign --force --sign - --deep "$APP_BUNDLE" 2>/dev/null || true

        LIB_COUNT=$(find "$FW_DIR" -name '*.dylib' | wc -l | tr -d ' ')
        SIZE_MB=$(du -sm "$APP_BUNDLE" | cut -f1)
        echo "[$NAME] packaged ${SIZE_MB}MB .app bundle ($LIB_COUNT libs)"
        rm -rf "$TMP_DIR"
    else
        # ── Linux: collect shared libs via ldd ───────────────────────
        ENGINE_SO="zig-out/lib/libreactjit-core.so"
        [ -f "$ENGINE_SO" ] && cp "$(readlink -f "$ENGINE_SO")" "$LIB_DIR/libreactjit-core.so"

        # Bundle resolved dep .so files
        for dep_so in $RESOLVED_SOS; do
            [ -f "$dep_so" ] && cp "$(readlink -f "$dep_so")" "$LIB_DIR/$(basename "$dep_so")"
        done

        LDD_TMP=$(mktemp)
        ldd "$RAW_BIN" >> "$LDD_TMP" 2>/dev/null
        [ -f "$ENGINE_SO" ] && ldd "$ENGINE_SO" >> "$LDD_TMP" 2>/dev/null
        while IFS= read -r line; do
            case "$line" in *linux-vdso*) continue ;; esac
            lib_path=$(echo "$line" | sed -n 's/.* => \([^ ]*\) .*/\1/p')
            [ -z "$lib_path" ] && continue
            [ ! -f "$lib_path" ] && continue
            real_path=$(readlink -f "$lib_path")
            soname=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*=>.*//')
            [ -f "$LIB_DIR/$soname" ] && continue
            cp "$real_path" "$LIB_DIR/$soname"
            LIB_COUNT=$((LIB_COUNT + 1))
        done < "$LDD_TMP"
        rm -f "$LDD_TMP"

        LD_LINUX=$(readlink -f /lib64/ld-linux-x86-64.so.2 2>/dev/null)
        if [ -n "$LD_LINUX" ] && [ -f "$LD_LINUX" ]; then
            cp "$LD_LINUX" "$LIB_DIR/ld-linux-x86-64.so.2"

            cat > "$TMP_DIR/run" << 'LAUNCHER'
#!/bin/sh
DIR="$(cd "$(dirname "$0")" && pwd)"
exec "$DIR/lib/ld-linux-x86-64.so.2" --inhibit-cache --library-path "$DIR/lib" "$DIR/app.bin" "$@"
LAUNCHER
            chmod +x "$TMP_DIR/run"

            TARBALL="/tmp/tsz-${NAME}-payload.tar.gz"
            (cd "$TMP_DIR" && tar czf "$TARBALL" .)

            cat > "$RAW_BIN" << HEADER
#!/bin/sh
set -e
APP_DIR=\${XDG_CACHE_HOME:-\$HOME/.cache}/tsz-$NAME
SIG=\$(md5sum "\$0" 2>/dev/null | cut -c1-8 || cksum "\$0" | cut -d" " -f1)
CACHE="\$APP_DIR/\$SIG"
if [ ! -f "\$CACHE/.ready" ]; then
  rm -rf "\$APP_DIR"
  mkdir -p "\$CACHE"
  SKIP=\$(awk '/^__ARCHIVE__\$/{print NR + 1; exit}' "\$0")
  tail -n+"\$SKIP" "\$0" | tar xz -C "\$CACHE"
  touch "\$CACHE/.ready"
fi
exec "\$CACHE/run" "\$@"
__ARCHIVE__
HEADER
            cat "$TARBALL" >> "$RAW_BIN"
            chmod +x "$RAW_BIN"

            SIZE_MB=$(du -m "$RAW_BIN" | cut -f1)
            echo "[$NAME] packaged ${SIZE_MB}MB self-extracting ($LIB_COUNT libs)"
            rm -rf "$TMP_DIR" "$TARBALL"
        else
            echo "[$NAME] WARNING: ld-linux not found, skipping packaging"
            rm -rf "$TMP_DIR"
        fi
    fi
fi

record_build "compiled"

# ── Record build performance ──────────────────────────────────────
if [ "$IS_CONFORMANCE" -eq 1 ] && [ "${SOURCE_LINES:-0}" -gt 0 ]; then
    TOTAL_MS=$(( FORGE_MS + ZIG_MS ))
    if [ "$TOTAL_MS" -gt 0 ]; then
        LINES_PER_SEC=$(echo "scale=1; $SOURCE_LINES * 1000 / $TOTAL_MS" | bc 2>/dev/null || echo "0")
    else
        LINES_PER_SEC=0
    fi
    if [ "$SOURCE_LINES" -gt 0 ]; then
        BYTES_PER_LINE=$(echo "scale=1; $GENERATED_BYTES / $SOURCE_LINES" | bc 2>/dev/null || echo "0")
    else
        BYTES_PER_LINE=0
    fi
    SAFE_PERF_NAME=$(printf '%s' "$CONF_NAME" | sed "s/'/''/g")
    cdb "INSERT INTO build_perf (test_name, lane, source_lines, generated_bytes, forge_ms, zig_ms, total_ms, lines_per_sec, bytes_per_line)
        VALUES ('$SAFE_PERF_NAME', '$CONF_LANE', $SOURCE_LINES, $GENERATED_BYTES, $FORGE_MS, $ZIG_MS, $TOTAL_MS, $LINES_PER_SEC, $BYTES_PER_LINE);"
    echo "[$NAME] perf: ${SOURCE_LINES} lines in → ${GENERATED_BYTES} bytes out | forge ${FORGE_MS}ms + zig ${ZIG_MS}ms = ${TOTAL_MS}ms (${LINES_PER_SEC} lines/sec)"
fi

# ── Auto-generate autotest from runtime snapshot ─────────────────
# After successful conformance build, run the binary headless to capture
# all visible text nodes and write them as expect lines. The autotest
# becomes a build artifact — never hand-written, always in sync.
if [ "$IS_CONFORMANCE" -eq 1 ]; then
    AUTOTEST_FILE="tests/${CONF_BASENAME}.autotest"
    BINARY="zig-out/bin/$NAME"
    if [ -x "$BINARY" ]; then
        # Run snapshot — capture stderr for runtime error detection
        SNAP_T0=$(date +%s%N)
        SNAP_STDERR=$(mktemp)
        ZIGOS_HEADLESS=1 ZIGOS_WITNESS=snapshot ZIGOS_WITNESS_FILE="$AUTOTEST_FILE" \
            timeout -s KILL 5 "$BINARY" >/dev/null 2>"$SNAP_STDERR" || true
        SNAP_T1=$(date +%s%N)
        SNAP_MS=$(( (SNAP_T1 - SNAP_T0) / 1000000 ))

        # Check for fatal runtime errors in stderr
        RUNTIME_ERRORS=$(grep -cE '^error:|^\[luajit-runtime\]|^\[evalExpr error\]|^\[evalToString error\]|^\[evalLuaMapData error\]|^\[js_on_press\].*error|ReferenceError|SyntaxError|TypeError' "$SNAP_STDERR" 2>/dev/null || true)
        RUNTIME_ERRORS=${RUNTIME_ERRORS//[^0-9]/}; RUNTIME_ERRORS=${RUNTIME_ERRORS:-0}
        if [ "$RUNTIME_ERRORS" -gt 0 ]; then
            echo "[$NAME] runtime: ${RUNTIME_ERRORS} error(s) detected"
            grep -E '^error:|^\[luajit-runtime\]|^\[eval.*error\]|^\[evalLuaMapData error\]|ReferenceError|SyntaxError|TypeError' "$SNAP_STDERR" | head -10
        fi
        # Forward snapshot progress lines (from witness.zig)
        grep '^\[snapshot\]' "$SNAP_STDERR" 2>/dev/null || true
        rm -f "$SNAP_STDERR"

        # Extract metrics from generated autotest
        EXPECT_COUNT=0; CLICK_COUNT=0
        NODE_COUNT=0; TEXT_COUNT=0; PRESSABLE_COUNT=0; STATE_SLOTS=0
        if [ -f "$AUTOTEST_FILE" ]; then
            EXPECT_COUNT=$(grep -c '^expect ' "$AUTOTEST_FILE" 2>/dev/null || true)
            CLICK_COUNT=$(grep -c '^click ' "$AUTOTEST_FILE" 2>/dev/null || true)
            FAIL_COUNT=$(grep -c '^# FAIL' "$AUTOTEST_FILE" 2>/dev/null || true)
            EXPECT_COUNT=${EXPECT_COUNT//[^0-9]/}; EXPECT_COUNT=${EXPECT_COUNT:-0}
            CLICK_COUNT=${CLICK_COUNT//[^0-9]/}; CLICK_COUNT=${CLICK_COUNT:-0}
            FAIL_COUNT=${FAIL_COUNT//[^0-9]/}; FAIL_COUNT=${FAIL_COUNT:-0}
            # Parse health line: # health: N nodes, N text, N pressable, N state slots
            HEALTH_LINE=$(grep '^# health:' "$AUTOTEST_FILE" 2>/dev/null || true)
            if [ -n "$HEALTH_LINE" ]; then
                NODE_COUNT=$(echo "$HEALTH_LINE" | grep -oP '\d+(?= nodes)' 2>/dev/null || true)
                TEXT_COUNT=$(echo "$HEALTH_LINE" | grep -oP '\d+(?= text)' 2>/dev/null || true)
                PRESSABLE_COUNT=$(echo "$HEALTH_LINE" | grep -oP '\d+(?= pressable)' 2>/dev/null || true)
                STATE_SLOTS=$(echo "$HEALTH_LINE" | grep -oP '\d+(?= state)' 2>/dev/null || true)
            fi
            # Ensure all counts are valid integers (empty grep → 0)
            NODE_COUNT=${NODE_COUNT:-0}; [ -z "$NODE_COUNT" ] && NODE_COUNT=0
            TEXT_COUNT=${TEXT_COUNT:-0}; [ -z "$TEXT_COUNT" ] && TEXT_COUNT=0
            PRESSABLE_COUNT=${PRESSABLE_COUNT:-0}; [ -z "$PRESSABLE_COUNT" ] && PRESSABLE_COUNT=0
            STATE_SLOTS=${STATE_SLOTS:-0}; [ -z "$STATE_SLOTS" ] && STATE_SLOTS=0
            # Total fails = snapshot detections + runtime errors
            TOTAL_FAILS=$(( ${FAIL_COUNT:-0} + ${RUNTIME_ERRORS:-0} ))
            if [ "$TOTAL_FAILS" -gt 0 ]; then
                echo "[$NAME] snapshot: ${EXPECT_COUNT} expects + ${CLICK_COUNT} clicks + ${TOTAL_FAILS} FAILS in ${SNAP_MS}ms → $AUTOTEST_FILE"
                if [ "$SKIP_SNAPSHOT" -eq 1 ]; then
                    echo "[$NAME] SNAPSHOT FAILED — --skip-snapshot set, KEEPING binary anyway (iterate at your own risk)"
                else
                    echo "[$NAME] SNAPSHOT FAILED — cleaning up broken binary"
                    rm -f "$BINARY" "zig-out/bin/${NAME}" 2>/dev/null
                fi
            else
                echo "[$NAME] snapshot: ${EXPECT_COUNT} expects + ${CLICK_COUNT} clicks in ${SNAP_MS}ms → $AUTOTEST_FILE"
            fi
        else
            echo "[$NAME] snapshot: failed to generate autotest (${SNAP_MS}ms)"
        fi

        # Run contract check (fast — no build, just parse)
        CONTRACT_CLEAN=1
        CONTRACT_JSON="/tmp/tsz-gen/source_contract_${CONF_BASENAME}.json"
        if ./zig-out/bin/forge contract "$CART" > /dev/null 2>&1 && [ -f "$CONTRACT_JSON" ]; then
            if grep -qE '"</(Text|Box|Pressable|ScrollView|Image)' "$CONTRACT_JSON" 2>/dev/null; then
                CONTRACT_CLEAN=0
                echo "[$NAME] contract: JSX CONTAMINATION detected"
            fi
        fi

        # Record to DB
        SNAP_SRC_SHA=""
        [ -f "$CART" ] && SNAP_SRC_SHA=$(sha256sum "$CART" | cut -c1-16)
        SNAP_ENG_SHA="${REACTJIT_ENGINE_SHA:-}"
        if [ -z "$SNAP_ENG_SHA" ]; then
            [ -f "zig-out/lib/libreactjit-core.so" ] && SNAP_ENG_SHA=$(sha256sum "zig-out/lib/libreactjit-core.so" | cut -c1-16)
        fi
        SNAP_COMP_SHA=""
        [ -f "zig-out/bin/forge" ] && SNAP_COMP_SHA=$(sha256sum "zig-out/bin/forge" | cut -c1-16)
        SAFE_SNAP_NAME=$(printf '%s' "$CONF_NAME" | sed "s/'/''/g")
        cdb "INSERT INTO snapshots (test_name, lane, expect_count, click_count, node_count, text_count, pressable_count, state_slots, snap_ms, contract_clean, engine_sha, compiler_sha, source_sha)
            VALUES ('$SAFE_SNAP_NAME', '$CONF_LANE', ${EXPECT_COUNT:-0}, ${CLICK_COUNT:-0}, ${NODE_COUNT:-0}, ${TEXT_COUNT:-0}, ${PRESSABLE_COUNT:-0}, ${STATE_SLOTS:-0}, ${SNAP_MS:-0}, ${CONTRACT_CLEAN:-1}, '${SNAP_ENG_SHA:-}', '${SNAP_COMP_SHA:-}', '${SNAP_SRC_SHA:-}');" 2>/dev/null || true
    fi
fi

echo "[$NAME] done → zig-out/bin/$NAME"
