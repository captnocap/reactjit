#!/bin/bash
# Promote the current forge binary (compiler) to blessed status.
#
# HUMAN ONLY. Claude does not call this. Ever.
#
# Usage:
#   ./scripts/bless-compiler              # promote current build
#   ./scripts/bless-compiler --status     # show what's blessed
#   ./scripts/bless-compiler --diff       # show compiler/ changes since last bless

set -euo pipefail
cd "$(dirname "$0")/.."

FORGE_BIN="zig-out/bin/forge"
BLESSED_FORGE="zig-out/bin/forge-blessed"
BLESS_STAMP="zig-out/bin/.compiler-blessed-stamp"

if [ "${1:-}" = "--status" ]; then
    if [ -f "$BLESS_STAMP" ]; then
        echo "Blessed compiler:"
        cat "$BLESS_STAMP"
        echo ""
        if [ -f "$BLESSED_FORGE" ]; then
            echo "  forge: $(sha256sum "$BLESSED_FORGE" | cut -c1-16)... ($(stat --printf='%s' "$BLESSED_FORGE" 2>/dev/null || stat -f%z "$BLESSED_FORGE") bytes)"
        fi
    else
        echo "No blessed compiler. Run ./scripts/bless-compiler to promote current build."
    fi
    exit 0
fi

if [ "${1:-}" = "--diff" ]; then
    if [ -f "$BLESS_STAMP" ]; then
        BLESSED_AT=$(grep '^commit:' "$BLESS_STAMP" | cut -d' ' -f2)
        echo "Compiler changes since bless (${BLESSED_AT:0:7}):"
        git diff "${BLESSED_AT}" -- compiler/ 2>/dev/null || echo "(commit not found — blessed from a different history)"
    else
        echo "No blessed compiler to diff against."
    fi
    exit 0
fi

# ── Promote ─────────────────────────────────────────────────────────

# Build fresh from current source
echo "[bless] building forge from current compiler/ source..."
zig build forge || {
    echo "[bless] FAILED — forge doesn't compile. Fix compiler/ first."
    exit 1
}

if [ ! -f "$FORGE_BIN" ]; then
    echo "[bless] No forge binary at $FORGE_BIN — build failed silently?"
    exit 1
fi

# Copy to blessed
cp "$FORGE_BIN" "$BLESSED_FORGE"

# Hash the compiler JS source (same method as scripts/build)
SMITH_SRC_HASH=$(find compiler/ -name '*.js' -exec sha256sum {} + 2>/dev/null | sort | sha256sum | cut -c1-64)
FORGE_SHA=$(sha256sum "$BLESSED_FORGE" | awk '{print $1}')

# Stamp
COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
cat > "$BLESS_STAMP" << EOF
commit: $COMMIT
date: $(date '+%Y-%m-%d %H:%M:%S')
sha256_forge: $FORGE_SHA
smith_source_hash: $SMITH_SRC_HASH
EOF

# Record in conformance DB
CONF_DB="conformance.db"
if [ -f "$CONF_DB" ]; then
    NOW=$(date '+%Y-%m-%d %I:%M:%S %p')
    sqlite3 "$CONF_DB" ".timeout 5000" \
        "CREATE TABLE IF NOT EXISTS compiler_builds (
            id            INTEGER PRIMARY KEY AUTOINCREMENT,
            compiler_sha  TEXT    NOT NULL UNIQUE,
            built_at      TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
            blessed_at    TEXT,
            commit_sha    TEXT,
            source_hash   TEXT,
            last_good_at  TEXT
        );
        CREATE INDEX IF NOT EXISTS idx_compiler_sha ON compiler_builds(compiler_sha);
        INSERT OR REPLACE INTO compiler_builds (compiler_sha, built_at, blessed_at, commit_sha, source_hash)
        VALUES ('$FORGE_SHA', '$NOW', '$NOW', '$COMMIT', '$SMITH_SRC_HASH');"
    echo "[bless] recorded in conformance.db"
fi

echo ""
echo "══════════════════════════════════════════════════════════"
echo "  COMPILER BLESSED at ${COMMIT:0:7}"
echo "  forge:  $(sha256sum "$BLESSED_FORGE" | cut -c1-16)..."
echo "  smith:  ${SMITH_SRC_HASH:0:16}..."
echo ""
echo "  Claude must now use:"
echo "    ./scripts/build <cart.tsz> --proveMyCompilerBrokeIt"
echo "  to build against the blessed engine + blessed compiler."
echo "══════════════════════════════════════════════════════════"
echo ""
