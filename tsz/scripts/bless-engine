#!/bin/bash
# Promote the current engine .so to blessed status.
#
# HUMAN ONLY. Claude does not call this. Ever.
#
# Usage:
#   ./scripts/bless-engine              # promote current build
#   ./scripts/bless-engine --status     # show what's blessed
#   ./scripts/bless-engine --diff       # show framework changes since last bless

set -euo pipefail
cd "$(dirname "$0")/.."

BLESSED_SO="zig-out/lib/libreactjit-core-blessed.so"
BLESSED_A="zig-out/lib/libreactjit-core-blessed.a"
DIRTY_SO="zig-out/lib/libreactjit-core.so"
DIRTY_A="zig-out/lib/libreactjit-core.a"
BLESS_STAMP="zig-out/lib/.blessed-stamp"

if [ "${1:-}" = "--status" ]; then
    if [ -f "$BLESS_STAMP" ]; then
        echo "Blessed engine:"
        cat "$BLESS_STAMP"
        echo ""
        if [ -f "$BLESSED_SO" ]; then
            echo "  .so: $(sha256sum "$BLESSED_SO" | cut -c1-16)... ($(stat --printf='%s' "$BLESSED_SO" 2>/dev/null || stat -f%z "$BLESSED_SO") bytes)"
        fi
        if [ -f "$BLESSED_A" ]; then
            echo "  .a:  $(sha256sum "$BLESSED_A" | cut -c1-16)... ($(stat --printf='%s' "$BLESSED_A" 2>/dev/null || stat -f%z "$BLESSED_A") bytes)"
        fi
    else
        echo "No blessed engine. Run ./scripts/bless-engine to promote current build."
    fi
    exit 0
fi

if [ "${1:-}" = "--diff" ]; then
    if [ -f "$BLESS_STAMP" ]; then
        BLESSED_AT=$(grep '^commit:' "$BLESS_STAMP" | cut -d' ' -f2)
        echo "Framework changes since bless (${BLESSED_AT:0:7}):"
        git diff "${BLESSED_AT}" -- framework/ 2>/dev/null || echo "(commit not found — blessed from a different history)"
    else
        echo "No blessed engine to diff against."
    fi
    exit 0
fi

# ── Promote ─────────────────────────────────────────────────────────

# Build fresh from current source
echo "[bless] building engine from current framework/ source..."
zig build core-so -Doptimize=ReleaseFast || {
    echo "[bless] FAILED — engine doesn't compile. Fix framework/ first."
    exit 1
}
zig build core -Doptimize=ReleaseFast || {
    echo "[bless] FAILED — static lib doesn't compile. Fix framework/ first."
    exit 1
}

if [ ! -f "$DIRTY_SO" ]; then
    echo "[bless] No engine .so at $DIRTY_SO — build failed silently?"
    exit 1
fi

# Copy to blessed
cp "$DIRTY_SO" "$BLESSED_SO"
[ -f "$DIRTY_A" ] && cp "$DIRTY_A" "$BLESSED_A"

# Stamp
COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
ENGINE_SHA=$(sha256sum "$BLESSED_SO" | awk '{print $1}')
cat > "$BLESS_STAMP" << EOF
commit: $COMMIT
date: $(date '+%Y-%m-%d %H:%M:%S')
sha256_so: $ENGINE_SHA
sha256_a: $([ -f "$BLESSED_A" ] && sha256sum "$BLESSED_A" | cut -c1-64 || echo "none")
EOF

# Record in conformance DB
CONF_DB="conformance.db"
if [ -f "$CONF_DB" ]; then
    NOW=$(date '+%Y-%m-%d %I:%M:%S %p')
    SRC_HASH=$(find framework/ -name '*.zig' -exec sha256sum {} + 2>/dev/null | sort | sha256sum | cut -c1-64)
    sqlite3 "$CONF_DB" ".timeout 5000" \
        "INSERT OR REPLACE INTO engine_builds (engine_sha, built_at, blessed_at, commit_sha, source_hash)
         VALUES ('$ENGINE_SHA', '$NOW', '$NOW', '$COMMIT', '$SRC_HASH');"
    echo "[bless] recorded in conformance.db"
fi

echo ""
echo "══════════════════════════════════════════════════════════"
echo "  ENGINE BLESSED at ${COMMIT:0:7}"
echo "  $(sha256sum "$BLESSED_SO" | cut -c1-16)..."
echo ""
echo "  Claude must now use:"
echo "    ./scripts/ICantCallPreExistingOnThisOne <cart.tsz>"
echo "  to build against this engine."
echo "══════════════════════════════════════════════════════════"
echo ""
