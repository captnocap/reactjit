#!/bin/bash
# Run an autotest: build cart, run headless with test script, generate proof grid.
#
# Usage:
#   scripts/autotest d03_conditional_wrapping_map
#   scripts/autotest d15_unmount_remount
#
# Looks for: tests/<name>.autotest
# Finds cart: carts/**/<name>.tsz
# Outputs:   tests/screenshots/<name>/proof.png
set -euo pipefail
cd "$(dirname "$0")/.."

if [ $# -lt 1 ]; then
    echo "Usage: scripts/autotest <test_name>"
    echo "  e.g.: scripts/autotest d03_conditional_wrapping_map"
    exit 1
fi

NAME="$1"
TEST_FILE="tests/${NAME}.autotest"
CART=$(find carts/ -name "${NAME}.tsz" -not -name "*.script.tsz" -not -name "*.cls.tsz" 2>/dev/null | head -1)

if [ ! -f "$TEST_FILE" ]; then
    echo "[autotest] ERROR: no test file at $TEST_FILE"
    exit 1
fi

if [ -z "$CART" ]; then
    echo "[autotest] ERROR: no cart found for $NAME"
    exit 1
fi

# 1. Build
BINARY="zig-out/bin/$NAME"

# Skip build if binary is newer than source
if [ -x "$BINARY" ] && [ "$BINARY" -nt "$CART" ]; then
    echo "[autotest] $NAME binary is current, skipping build"
else
    echo "[autotest] building $NAME..."
    ./scripts/buildFromMyShittyNewCode "$CART" >/dev/null 2>&1 || ./scripts/build "$CART" >/dev/null 2>&1 || { echo "[autotest] BUILD FAILED"; exit 1; }
fi

if [ ! -x "$BINARY" ]; then
    echo "[autotest] ERROR: binary not found at $BINARY"
    exit 1
fi

# 2. Timestamped output dir
TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
FLAT_DIR="tests/screenshots/${NAME}"
OUT_DIR="${FLAT_DIR}/${TIMESTAMP}"

# Clear only flat files (Zig writes here), preserve timestamped subdirs
mkdir -p "$FLAT_DIR"
rm -f "$FLAT_DIR"/step_*.png "$FLAT_DIR"/manifest.txt "$FLAT_DIR"/proof.png

# 3. Run headless autotest
echo "[autotest] running..."
set +e
# Pass script imports as source for audit (data strings should always render)
# Main .tsz has conditional UI text — only audit .script.tsz data
SCRIPT_FILE=$(echo "$CART" | sed 's/\.tsz$/.script.tsz/')
SOURCE_FILES=""
[ -f "$SCRIPT_FILE" ] && SOURCE_FILES="$SCRIPT_FILE"

TMPLOG=$(mktemp)
ZIGOS_HEADLESS=1 ZIGOS_WITNESS=autotest ZIGOS_WITNESS_FILE="$TEST_FILE" ZIGOS_SOURCE="$SOURCE_FILES" timeout -s KILL 5 "$BINARY" >"$TMPLOG" 2>&1 || true
grep -v "AUTOTEST RESULT" "$TMPLOG" | grep -E "expect|click|reject|color|bg|border|styles|PASS|FAIL|OK|VERIFY|audit|MISSING|changed" || true
rm -f "$TMPLOG"
set -e

# 4. Generate proof grid
if [ -f "${FLAT_DIR}/manifest.txt" ]; then
    python3 scripts/autotest-grid "$NAME"

    # 5. Grid script writes final verdict to verdict.txt (it does pixel verification)
    TAG=$(cat "${FLAT_DIR}/verdict.txt" 2>/dev/null || echo "FAIL")
    [ "$TAG" = "PASS" ] && EXIT=0 || EXIT=1
    TAGGED_DIR="${FLAT_DIR}/${TIMESTAMP}_${TAG}"
    mkdir -p "$TAGGED_DIR"
    mv "${FLAT_DIR}"/step_*.png "${FLAT_DIR}/manifest.txt" "${FLAT_DIR}/proof.png" "${FLAT_DIR}/verdict.txt" "$TAGGED_DIR/" 2>/dev/null

    # Symlink "latest" for easy access
    ln -sfn "$(basename "$TAGGED_DIR")" "${FLAT_DIR}/latest"

    # Print the authoritative result (after pixel verification)
    if [ "$TAG" = "PASS" ]; then
        echo "[autotest] PASS — proof: ${TAGGED_DIR}/proof.png"
    else
        echo "[autotest] FAIL — proof: ${TAGGED_DIR}/proof.png"
    fi
else
    echo "[autotest] WARNING: no manifest — screenshots may not have been captured"
fi

exit $EXIT
