#!/bin/bash
# Ledger watcher — debounced filesystem watcher for zig-out/bin/.
# Writes a JSON staging file on changes, waits for 15s of quiet,
# then flushes to the SQLite ledger.
#
# Usage: scripts/ledger-watch
# Ctrl+C to stop cleanly.

cd "$(dirname "$0")/.."

BIN_DIR="zig-out/bin"
STAGING="/tmp/ledger-staging-$$.json"
DB="conformance.db"
DEBOUNCE=15  # seconds of quiet before flushing

# Clean exit
cleanup() {
    rm -f "$STAGING"
    echo ""
    echo "Watch stopped."
    exit 0
}
trap cleanup INT TERM

echo "=== Ledger Watch (debounced ${DEBOUNCE}s) ==="
echo "Watching $BIN_DIR/ for new binaries. Ctrl+C to stop."
echo ""

# Take initial snapshot: name → sha
declare -A KNOWN
for f in "$BIN_DIR"/*; do
    [ -f "$f" ] || continue
    name=$(basename "$f")
    case "$name" in
        forge|forge-*|tsz|tsz-*|dev-shell|dev_shell|cursor-ide*|*.pdb|*.dll|*.o) continue ;;
    esac
    sz=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null || echo "0")
    # Only track real binaries (>1MB)
    [ "$sz" -lt 1048576 ] && continue
    sha=$(sha256sum "$f" 2>/dev/null | cut -d' ' -f1 || shasum -a 256 "$f" | cut -d' ' -f1)
    KNOWN["$name"]="$sha"
done
echo "Baseline: ${#KNOWN[@]} binaries tracked."

# Staging: associative array of cart → latest sha
declare -A STAGED
last_change=0

while true; do
    sleep 2

    changed=0
    for f in "$BIN_DIR"/*; do
        [ -f "$f" ] || continue
        name=$(basename "$f")
        case "$name" in
            forge|forge-*|tsz|tsz-*|dev-shell|dev_shell|cursor-ide*|*.pdb|*.dll|*.o) continue ;;
        esac

        sz=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null || echo "0")
        # Skip intermediates
        [ "$sz" -lt 1048576 ] && continue

        sha=$(sha256sum "$f" 2>/dev/null | cut -d' ' -f1 || shasum -a 256 "$f" | cut -d' ' -f1)

        # Check if new or changed
        if [ "${KNOWN[$name]:-}" != "$sha" ]; then
            STAGED["$name"]="$sha|$sz"
            KNOWN["$name"]="$sha"
            changed=1
            echo "  [staged] $name (${sha:0:12}..., $(awk "BEGIN{printf \"%.1f\", $sz/1048576}")M)"
        fi
    done

    if [ "$changed" -eq 1 ]; then
        last_change=$(date +%s)
    fi

    # Flush after DEBOUNCE seconds of quiet
    now=$(date +%s)
    if [ ${#STAGED[@]} -gt 0 ] && [ $((now - last_change)) -ge "$DEBOUNCE" ]; then
        echo ""
        echo "  Flushing ${#STAGED[@]} carts to ledger..."

        for name in "${!STAGED[@]}"; do
            IFS='|' read -r sha sz <<< "${STAGED[$name]}"

            # Detect lane
            lane="unknown"
            for dir in carts/conformance/soup carts/conformance/mixed carts/conformance/chad carts/conformance/lscript carts/conformance; do
                if [ -f "$dir/${name}.tsz" ]; then
                    case "$dir" in
                        *soup*) lane="soup" ;; *mixed*) lane="mixed" ;; *chad*) lane="chad" ;; *lscript*) lane="lscript" ;; *) lane="shared" ;;
                    esac
                    break
                fi
            done

            gen_file="/tmp/tsz-gen/generated_${name}.zig"
            gen=""
            if [ -f "$gen_file" ]; then
                gen=$(cat "$gen_file" | sed "s/'/''/g")
            fi

            sqlite3 "$DB" "INSERT INTO builds (test_name, lane, status, generated, binary_sha, binary_size)
                           VALUES ('${name//\'/\'\'}', '$lane', 'compiled', '$gen', '$sha', $sz);"

            ts=$(date '+%H:%M:%S')
            echo "  [$ts] STAMPED: $name ($lane) sha:${sha:0:12}... $(awk "BEGIN{printf \"%.1f\", $sz/1048576}")M"
        done

        # Clear staging
        declare -A STAGED
        echo ""
    fi
done
