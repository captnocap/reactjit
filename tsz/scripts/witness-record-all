#!/bin/bash
# Record witnesses for all conformance carts, one at a time.
# Skips carts that already have a witness file (use --force to re-record all).
# Close each window when done interacting to move to the next.
set -euo pipefail
cd "$(dirname "$0")/.."

FORCE=false
[ "${1:-}" = "--force" ] && FORCE=true

total=0
skipped=0
recorded=0
failed=0

for cart in carts/conformance/mixed/d*.tsz; do
    [ -f "$cart" ] || continue
    # Skip .script.tsz and .cls.tsz
    [[ "$cart" == *.script.tsz ]] && continue
    [[ "$cart" == *.cls.tsz ]] && continue

    name=$(basename "$cart" .tsz)
    total=$((total + 1))

    if [ "$FORCE" = false ] && [ -f "witnesses/${name}.witness" ]; then
        echo "[$name] skip — witness exists (use --force to re-record)"
        skipped=$((skipped + 1))
        continue
    fi

    echo ""
    echo "══════════════════════════════════════════"
    echo "  [$((recorded + failed + 1))/$total] $name"
    echo "  Interact with the app, then close the window."
    echo "══════════════════════════════════════════"
    echo ""

    if ./scripts/witness record "$cart"; then
        recorded=$((recorded + 1))
    else
        echo "[$name] FAILED to record"
        failed=$((failed + 1))
    fi
done

echo ""
echo "═══ Done ═══"
echo "Total: $total | Recorded: $recorded | Skipped: $skipped | Failed: $failed"
