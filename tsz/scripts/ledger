#!/bin/bash
# Conformance ledger — SQLite-backed build tracker with generated code archive.
#
# Usage:
#   ledger watch          — poll zig-out/bin/, auto-stamp new binaries
#   ledger run [lane]     — build all tests (or one lane), stamp results into DB
#   ledger status         — show what's passing, broken, regressed, fixed
#   ledger diff <test>    — diff current generated .zig vs last good build
#   ledger show <test>    — print last good generated .zig to stdout
#   ledger history <test> — show build history for a test
#   ledger clean [N]      — prune to last N builds per test (default 50)
#   ledger init           — (re)create the database
#
# The DB lives at tsz/conformance.db (gitignored).

set -uo pipefail
# NOTE: no set -e — the watch loop must survive non-zero returns from
# grep, sqlite3, stat, etc. Individual commands handle their own errors.
cd "$(dirname "$0")/.."

DB="conformance.db"
BIN_DIR="zig-out/bin"
SCRIPTS_DIR="scripts"

# ── Platform shims ────────────────────────────────────────────

file_size() {
    if [[ "$OSTYPE" == darwin* ]]; then
        stat -f%z "$1" 2>/dev/null || echo "0"
    else
        stat -c%s "$1" 2>/dev/null || echo "0"
    fi
}

compute_sha() {
    if command -v sha256sum &>/dev/null; then
        sha256sum "$1" | cut -d' ' -f1
    else
        shasum -a 256 "$1" | cut -d' ' -f1
    fi
}

find_executables() {
    local dir="$1"
    if [[ "$OSTYPE" == darwin* ]]; then
        find "$dir" -maxdepth 1 -type f -perm +111 -exec stat -f '%N %m' {} \; 2>/dev/null |
            sed "s|${dir}/||"
    else
        find "$dir" -maxdepth 1 -type f -executable -printf '%f %T@\n' 2>/dev/null
    fi
}

# ── DB bootstrap ──────────────────────────────────────────────

init_db() {
    sqlite3 "$DB" <<'SQL'
CREATE TABLE IF NOT EXISTS builds (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    test_name   TEXT    NOT NULL,
    lane        TEXT    NOT NULL,
    built_at    TEXT    NOT NULL DEFAULT (datetime('now')),
    status      TEXT    NOT NULL,  -- compiled | forge_fail | zig_fail | preflight_blocked | bloated
    generated   TEXT,              -- full generated .zig source
    binary_sha  TEXT,              -- sha256 of the output binary
    binary_size INTEGER,           -- binary size in bytes
    error_log   TEXT               -- first 500 chars of error output if failed
);

CREATE INDEX IF NOT EXISTS idx_test_time ON builds(test_name, built_at DESC);
CREATE INDEX IF NOT EXISTS idx_lane      ON builds(lane);
CREATE INDEX IF NOT EXISTS idx_status    ON builds(status);
SQL
}

# Ensure DB exists
[ -f "$DB" ] || init_db

# ── Helpers ───────────────────────────────────────────────────

# Detect which lane a .tsz file belongs to
detect_lane() {
    local path="$1"
    case "$path" in
        *conformance/soup/*)    echo "soup" ;;
        *conformance/mixed/*)   echo "mixed" ;;
        *conformance/chad/*)    echo "chad" ;;
        *conformance/lscript/*) echo "lscript" ;;
        *conformance/apps/*)    echo "apps" ;;
        *conformance/libs/*)    echo "libs" ;;
        *conformance/*)         echo "shared" ;;
        *)                      echo "unknown" ;;
    esac
}

# Get test name from .tsz path (strip extension and path)
test_name_from_path() {
    basename "$1" .tsz
}

# Record a build result into the DB
stamp() {
    local name="$1" lane="$2" status="$3" gen_file="$4" binary="$5" err_log="${6:-}"

    local generated=""
    if [ -f "$gen_file" ]; then
        generated=$(cat "$gen_file")
    fi

    local sha=""
    local size=0
    if [ -f "$binary" ]; then
        sha=$(compute_sha "$binary")
        size=$(file_size "$binary")
    fi

    # Skip intermediate binaries — the build pipeline writes a small linked
    # binary first, then repacks as a self-extracting archive (~23MB).
    # Anything under 1MB is the intermediate, not the final binary.
    if [ "$size" -gt 0 ] && [ "$size" -lt 1048576 ]; then
        return 0
    fi

    # Check for bloat: if we have a previous good build, compare sizes
    # >30% growth is suspicious — flag it
    local bloat_warn=""
    if [ "$status" = "compiled" ] && [ "$size" -gt 0 ]; then
        local prev_size
        prev_size=$(sqlite3 "$DB" "SELECT binary_size FROM builds
                    WHERE test_name = '${name//\'/\'\'}' AND status = 'compiled' AND binary_size > 0
                    ORDER BY built_at DESC LIMIT 1;" 2>/dev/null || echo "0")
        prev_size="${prev_size:-0}"

        if [ "$prev_size" -gt 0 ]; then
            local growth
            growth=$(( (size - prev_size) * 100 / prev_size ))
            if [ "$growth" -gt 30 ]; then
                local prev_mb curr_mb
                prev_mb=$(awk "BEGIN {printf \"%.1f\", $prev_size/1048576}")
                curr_mb=$(awk "BEGIN {printf \"%.1f\", $size/1048576}")
                bloat_warn="BLOAT: ${prev_mb}M -> ${curr_mb}M (+${growth}%)"
                status="bloated"
            fi
        fi
    fi

    # Truncate error log
    err_log=$(echo "$err_log" | head -c 500)

    # Escape single quotes for SQL
    generated="${generated//\'/\'\'}"
    err_log="${err_log//\'/\'\'}"
    name="${name//\'/\'\'}"

    sqlite3 "$DB" "INSERT INTO builds (test_name, lane, status, generated, binary_sha, binary_size, error_log)
                   VALUES ('$name', '$lane', '$status', '$generated', '$sha', $size, '$err_log');"

    # Return bloat warning if any (caller can print it)
    if [ -n "$bloat_warn" ]; then echo "$bloat_warn"; fi
}

# Get the last good generated code for a test
last_good_generated() {
    local name="$1"
    sqlite3 "$DB" "SELECT generated FROM builds
                   WHERE test_name = '$name' AND status = 'compiled'
                   ORDER BY built_at DESC LIMIT 1;"
}

# Skip non-buildable file extensions
is_buildable() {
    local bn
    bn=$(basename "$1")
    case "$bn" in
        *.script.tsz|*.cls.tsz|*.effects.tsz|*.glyphs.tsz|*.tcls.tsz|*.vcls.tsz|*.c.tsz|*.cmod.tsz|*.mod.tsz|*.lscript.tsz) return 1 ;;
        *) return 0 ;;
    esac
}

# ── Watch mode ────────────────────────────────────────────────

cmd_watch() {
    echo "=== Ledger Watch ==="
    echo "Watching $BIN_DIR/ for new binaries. Ctrl+C to stop."
    echo ""

    WATCH_SNAPSHOT="/tmp/ledger_snapshot_$$"
    WATCH_CURRENT="/tmp/ledger_current_$$"
    trap 'rm -f "$WATCH_SNAPSHOT" "$WATCH_CURRENT"; exit 0' INT TERM

    find_executables "$BIN_DIR" | sort > "$WATCH_SNAPSHOT"

    while true; do
        sleep 2

        find_executables "$BIN_DIR" | sort > "$WATCH_CURRENT"

        # Find new or modified binaries
        while IFS= read -r line; do
            local name mtime
            name=$(echo "$line" | cut -d' ' -f1)
            mtime=$(echo "$line" | cut -d' ' -f2)

            # Skip non-conformance binaries
            case "$name" in
                forge|forge-*|tsz|tsz-*|dev-shell|dev_shell|cursor-ide*) continue ;;
            esac

            # Check if this is new or modified
            local old_mtime
            old_mtime=$(grep "^${name} " "$WATCH_SNAPSHOT" 2>/dev/null | cut -d' ' -f2)

            if [ -z "$old_mtime" ] || [ "$old_mtime" != "$mtime" ]; then
                # Try to find the source .tsz and its lane
                local lane="unknown"
                local tsz_path=""
                for dir in carts/conformance/soup carts/conformance/mixed carts/conformance/chad carts/conformance/lscript carts/conformance; do
                    if [ -f "$dir/${name}.tsz" ]; then
                        tsz_path="$dir/${name}.tsz"
                        lane=$(detect_lane "$tsz_path")
                        break
                    fi
                done

                local gen_file="/tmp/tsz-gen/generated_${name}.zig"
                local binary="$BIN_DIR/$name"
                local sha=""
                if [ -f "$binary" ]; then
                    sha=$(compute_sha "$binary")
                fi

                stamp "$name" "$lane" "compiled" "$gen_file" "$binary"

                local ts
                ts=$(date '+%H:%M:%S')
                echo "[$ts] STAMPED: $name ($lane) sha:${sha:0:12}..."
            fi
        done < "$WATCH_CURRENT"

        # Update snapshot
        mv "$WATCH_CURRENT" "$WATCH_SNAPSHOT"
    done
}

# ── Run mode ──────────────────────────────────────────────────

cmd_run() {
    local target_lane="${1:-all}"

    echo "=== Ledger Run: $target_lane ==="
    echo ""

    local pass=0 fail=0 total=0

    # Collect .tsz files to build
    local files=()
    if [ "$target_lane" = "all" ]; then
        for dir in carts/conformance/soup carts/conformance/mixed carts/conformance/chad carts/conformance/lscript carts/conformance; do
            [ -d "$dir" ] || continue
            for f in "$dir"/*.tsz; do
                [ -f "$f" ] || continue
                is_buildable "$f" || continue
                files+=("$f")
            done
        done
    else
        local dir="carts/conformance/$target_lane"
        if [ ! -d "$dir" ]; then
            echo "ERROR: lane '$target_lane' not found at $dir"
            exit 1
        fi
        for f in "$dir"/*.tsz; do
            [ -f "$f" ] || continue
            is_buildable "$f" || continue
            files+=("$f")
        done
    fi

    echo "Building ${#files[@]} tests..."
    echo ""

    for f in "${files[@]}"; do
        local name lane gen_file binary
        name=$(test_name_from_path "$f")
        lane=$(detect_lane "$f")
        gen_file="/tmp/tsz-gen/generated_${name}.zig"
        binary="$BIN_DIR/$name"

        total=$((total + 1))
        printf "  [%3d/%3d] %-45s " "$total" "${#files[@]}" "$name"

        # Clean stale artifacts
        rm -f "$gen_file" "$binary"

        # Build via the one true command
        local build_out build_rc=0
        build_out=$("$SCRIPTS_DIR/build" "$f" 2>&1) || build_rc=$?

        if [ -f "$binary" ]; then
            local bloat
            bloat=$(stamp "$name" "$lane" "compiled" "$gen_file" "$binary")
            pass=$((pass + 1))
            if [ -n "$bloat" ]; then
                echo "$bloat"
            else
                echo "PASS"
            fi
        elif [ -f "$gen_file" ] && grep -q "PREFLIGHT BLOCKED" "$gen_file" 2>/dev/null; then
            stamp "$name" "$lane" "preflight_blocked" "$gen_file" "" "$build_out"
            fail=$((fail + 1))
            echo "PREFLIGHT"
        elif [ -f "$gen_file" ]; then
            stamp "$name" "$lane" "zig_fail" "$gen_file" "" "$build_out"
            fail=$((fail + 1))
            echo "ZIG_FAIL"
        else
            stamp "$name" "$lane" "forge_fail" "" "" "$build_out"
            fail=$((fail + 1))
            echo "FORGE_FAIL"
        fi
    done

    echo ""
    echo "=== Results: $pass/$total passed, $fail failed ==="
}

# ── Status mode ───────────────────────────────────────────────

cmd_status() {
    echo "=== Conformance Ledger Status ==="
    echo ""

    # Latest build per test
    echo "--- By Lane ---"
    sqlite3 -header -column "$DB" "
        SELECT
            lane,
            COUNT(DISTINCT test_name) as tests,
            SUM(CASE WHEN status = 'compiled' THEN 1 ELSE 0 END) as passing,
            SUM(CASE WHEN status != 'compiled' THEN 1 ELSE 0 END) as failing
        FROM (
            SELECT test_name, lane, status,
                   ROW_NUMBER() OVER (PARTITION BY test_name ORDER BY built_at DESC) as rn
            FROM builds
        ) WHERE rn = 1
        GROUP BY lane
        ORDER BY lane;
    "

    echo ""
    echo "--- Regressions (was compiled, now failing) ---"
    sqlite3 -header -column "$DB" "
        WITH latest AS (
            SELECT test_name, lane, status, built_at,
                   ROW_NUMBER() OVER (PARTITION BY test_name ORDER BY built_at DESC) as rn
            FROM builds
        ),
        prev_good AS (
            SELECT test_name, MAX(built_at) as last_good
            FROM builds
            WHERE status = 'compiled'
            GROUP BY test_name
        )
        SELECT l.test_name, l.lane, l.status, l.built_at as broke_at, p.last_good
        FROM latest l
        JOIN prev_good p ON l.test_name = p.test_name
        WHERE l.rn = 1 AND l.status != 'compiled'
        ORDER BY l.built_at DESC
        LIMIT 20;
    "

    echo ""
    echo "--- Newly Fixed (was failing, now compiled) ---"
    sqlite3 -header -column "$DB" "
        WITH ranked AS (
            SELECT test_name, lane, status, built_at,
                   ROW_NUMBER() OVER (PARTITION BY test_name ORDER BY built_at DESC) as rn
            FROM builds
        )
        SELECT r1.test_name, r1.lane, r1.built_at as fixed_at
        FROM ranked r1
        JOIN ranked r2 ON r1.test_name = r2.test_name AND r2.rn = 2
        WHERE r1.rn = 1 AND r1.status = 'compiled' AND r2.status != 'compiled'
        ORDER BY r1.built_at DESC
        LIMIT 20;
    "

    echo ""
    echo "--- Never Compiled ---"
    sqlite3 -header -column "$DB" "
        SELECT test_name, lane, status, built_at as last_attempt
        FROM (
            SELECT test_name, lane, status, built_at,
                   ROW_NUMBER() OVER (PARTITION BY test_name ORDER BY built_at DESC) as rn
            FROM builds
        ) WHERE rn = 1
        AND test_name NOT IN (SELECT DISTINCT test_name FROM builds WHERE status = 'compiled')
        ORDER BY lane, test_name;
    "

    echo ""
    echo "--- Bloated Binaries (>30% size jump) ---"
    sqlite3 -header -column "$DB" "
        SELECT test_name, lane, built_at,
               printf('%.1fM', binary_size / 1048576.0) as size
        FROM (
            SELECT test_name, lane, status, built_at, binary_size,
                   ROW_NUMBER() OVER (PARTITION BY test_name ORDER BY built_at DESC) as rn
            FROM builds
        ) WHERE rn = 1 AND status = 'bloated'
        ORDER BY binary_size DESC;
    "

    echo ""
    echo "--- Size Distribution (latest good builds) ---"
    sqlite3 "$DB" "
        WITH latest_good AS (
            SELECT test_name, binary_size,
                   ROW_NUMBER() OVER (PARTITION BY test_name ORDER BY built_at DESC) as rn
            FROM builds
            WHERE status = 'compiled' AND binary_size > 0
        )
        SELECT
            printf('%.1fM', MIN(binary_size) / 1048576.0) as smallest,
            printf('%.1fM', AVG(binary_size) / 1048576.0) as average,
            printf('%.1fM', MAX(binary_size) / 1048576.0) as largest
        FROM latest_good WHERE rn = 1;
    "
}

# ── Diff mode ─────────────────────────────────────────────────

cmd_diff() {
    local name="$1"
    local gen_file="/tmp/tsz-gen/generated_${name}.zig"

    if [ ! -f "$gen_file" ]; then
        echo "No current generated file: $gen_file"
        echo "Build it first: scripts/build carts/conformance/*/${name}.tsz"
        exit 1
    fi

    local last_good
    last_good=$(last_good_generated "$name")

    if [ -z "$last_good" ]; then
        echo "No previous good build for '$name' in ledger."
        echo "Current generated file exists at: $gen_file"
        exit 0
    fi

    local tmp="/tmp/ledger_lastgood_${name}.zig"
    echo "$last_good" > "$tmp"

    echo "=== Diff: $name (last good -> current) ==="
    diff --color=auto -u "$tmp" "$gen_file" || true
    rm -f "$tmp"
}

# ── Show mode ─────────────────────────────────────────────────

cmd_show() {
    local name="$1"
    local last_good
    last_good=$(last_good_generated "$name")

    if [ -z "$last_good" ]; then
        echo "No good build for '$name' in ledger."
        exit 1
    fi

    echo "$last_good"
}

# ── History mode ──────────────────────────────────────────────

cmd_history() {
    local name="$1"
    sqlite3 -header -column "$DB" "
        SELECT id, built_at, status, binary_sha,
               LENGTH(generated) as gen_size,
               SUBSTR(error_log, 1, 80) as error_preview
        FROM builds
        WHERE test_name = '$name'
        ORDER BY built_at DESC
        LIMIT 20;
    "
}

# ── Clean mode ────────────────────────────────────────────────

# Count buildable entry points in a directory
count_entry_points() {
    local dir="$1"
    find "$dir" -name '*.tsz' \
        ! -name '*.script.tsz' ! -name '*.cls.tsz' ! -name '*.effects.tsz' \
        ! -name '*.glyphs.tsz' ! -name '*.tcls.tsz' ! -name '*.vcls.tsz' \
        ! -name '*.c.tsz' ! -name '*.cmod.tsz' ! -name '*.mod.tsz' \
        ! -name '*.lscript.tsz' 2>/dev/null | wc -l
}

# ── Baseline mode ─────────────────────────────────────────────

cmd_baseline() {
    echo "=== Conformance Baseline ==="
    echo ""
    printf "  %-20s %6s %6s %6s\n" "Lane" "Pass" "Total" "Rate"
    printf "  %-20s %6s %6s %6s\n" "----" "----" "-----" "----"

    local grand_pass=0 grand_total=0

    for lane in soup mixed chad lscript wpt-flex; do
        local dir="carts/conformance/$lane"
        [ -d "$dir" ] || continue

        local total
        total=$(count_entry_points "$dir")

        local pass
        pass=$(sqlite3 "$DB" "
            SELECT COUNT(DISTINCT test_name) FROM (
                SELECT test_name, status,
                       ROW_NUMBER() OVER (PARTITION BY test_name ORDER BY built_at DESC) as rn
                FROM builds WHERE lane = '$lane'
            ) WHERE rn = 1 AND status = 'compiled';
        " 2>/dev/null || echo "0")
        pass="${pass:-0}"

        local rate="0%"
        if [ "$total" -gt 0 ]; then
            rate="$(awk "BEGIN{printf \"%.0f%%\", ($pass/$total)*100}")"
        fi

        printf "  %-20s %6d %6d %6s\n" "$lane" "$pass" "$total" "$rate"
        grand_pass=$((grand_pass + pass))
        grand_total=$((grand_total + total))
    done

    printf "  %-20s %6s %6s %6s\n" "----" "----" "-----" "----"
    local grand_rate="0%"
    if [ "$grand_total" -gt 0 ]; then
        grand_rate="$(awk "BEGIN{printf \"%.0f%%\", ($grand_pass/$grand_total)*100}")"
    fi
    printf "  %-20s %6d %6d %6s\n" "TOTAL" "$grand_pass" "$grand_total" "$grand_rate"
    echo ""
}

# ── Clean mode ────────────────────────────────────────────────

cmd_clean() {
    local keep="${1:-10}"
    local before
    before=$(sqlite3 "$DB" "SELECT COUNT(*) FROM builds;")
    # Keep last N builds per test + always preserve the most recent 'compiled'
    # build (the diff anchor). This bounds growth while ensuring ledger diff
    # works even if a test has been broken for more than N consecutive builds.
    sqlite3 "$DB" "
        DELETE FROM builds WHERE id NOT IN (
            -- Last N builds per test
            SELECT id FROM (
                SELECT id, ROW_NUMBER() OVER (
                    PARTITION BY test_name
                    ORDER BY built_at DESC
                ) as rn
                FROM builds
            ) WHERE rn <= $keep
            UNION
            -- Most recent 'compiled' build per test (diff anchor)
            SELECT id FROM (
                SELECT id, ROW_NUMBER() OVER (
                    PARTITION BY test_name
                    ORDER BY built_at DESC
                ) as rn
                FROM builds
                WHERE status = 'compiled'
            ) WHERE rn = 1
        );
        VACUUM;
    "
    local after
    after=$(sqlite3 "$DB" "SELECT COUNT(*) FROM builds;")
    echo "Pruned $((before - after)) rows (kept last $keep + compiled anchor per test). $after rows remain."
}

# ── Dispatch ──────────────────────────────────────────────────

case "${1:-help}" in
    init)
        init_db
        echo "Database initialized at $DB"
        ;;
    watch)
        cmd_watch
        ;;
    run)
        cmd_run "${2:-all}"
        ;;
    status)
        cmd_status
        ;;
    diff)
        [ -z "${2:-}" ] && echo "Usage: ledger diff <test_name>" && exit 1
        cmd_diff "$2"
        ;;
    show)
        [ -z "${2:-}" ] && echo "Usage: ledger show <test_name>" && exit 1
        cmd_show "$2"
        ;;
    history)
        [ -z "${2:-}" ] && echo "Usage: ledger history <test_name>" && exit 1
        cmd_history "$2"
        ;;
    baseline)
        cmd_baseline
        ;;
    clean)
        cmd_clean "${2:-10}"
        ;;
    help|--help|-h)
        echo "Conformance Ledger — SQLite-backed build tracker"
        echo ""
        echo "Usage: scripts/ledger <command> [args]"
        echo ""
        echo "Commands:"
        echo "  run [lane]     Build all tests (or one lane), stamp results (pass + fail)"
        echo "  baseline       Show pass rate per lane against filesystem entry point count"
        echo "  status         Show passing/broken/regressed/fixed summary"
        echo "  diff <test>    Diff current generated .zig vs last good"
        echo "  show <test>    Print last good generated .zig"
        echo "  history <test> Show build history for a test"
        echo "  clean [N]      Prune to last N builds per test (default 10)"
        echo "  init           (Re)create the database"
        echo ""
        echo "Passive watcher (catches new passes during dev):"
        echo "  scripts/ledger-watch"
        echo ""
        echo "Lanes: soup, mixed, chad, lscript, wpt-flex"
        ;;
    *)
        echo "Unknown command: $1 (try 'ledger help')"
        exit 1
        ;;
esac
