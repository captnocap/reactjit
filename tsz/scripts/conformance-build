#!/bin/bash
# Run build + witness replay against all conformance tests that have witness files.
# Tests without witness files are build-only (same as before).
#
# Usage:
#   ./scripts/conformance-build                # build all, replay witnesses
#   ./scripts/conformance-build --witness-only # only run witness replays (skip build)
#   ./scripts/conformance-build --no-witness   # only build, no replays
set -uo pipefail
cd "$(dirname "$0")/.."

WITNESS_ONLY=0
NO_WITNESS=0
for arg in "$@"; do
    case "$arg" in
        --witness-only) WITNESS_ONLY=1 ;;
        --no-witness)   NO_WITNESS=1 ;;
    esac
done

WITNESS_DIR="witnesses"
DB="conformance.db"

# Ensure witness_replays table exists
if [ -f "$DB" ]; then
    sqlite3 "$DB" ".timeout 5000" \
        "CREATE TABLE IF NOT EXISTS witness_replays (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            test_name   TEXT    NOT NULL,
            replayed_at TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
            status      TEXT    NOT NULL,
            passed      INTEGER NOT NULL,
            total       INTEGER NOT NULL,
            source_sha  TEXT
        );" 2>/dev/null
fi

# ── Phase 1: Build ──────────────────────────────────────────────────────

BUILD_PASS=0; BUILD_FAIL=0; BUILD_TIMEOUT=0
BUILD_FAILS=""; BUILD_TIMEOUTS=""
TOTAL=$(ls carts/conformance/mixed/d*.tsz 2>/dev/null | grep -v '\.script\.tsz' | grep -v '\.cls\.tsz' | wc -l)
BUILD_COUNT=0

if [ "$WITNESS_ONLY" -eq 0 ]; then
    echo "═══ Phase 1: Build ($TOTAL carts) ═══"
    echo ""

    for f in $(ls carts/conformance/mixed/d*.tsz | grep -v '\.script\.tsz' | grep -v '\.cls\.tsz' | sort -V); do
        name=$(basename "$f" .tsz)
        BUILD_COUNT=$((BUILD_COUNT+1))
        if timeout 30 ./scripts/build "$f" > /tmp/conformance_build.log 2>&1; then
            BUILD_PASS=$((BUILD_PASS+1))
            printf "\033[32m.\033[0m"
        elif [ $? -eq 124 ]; then
            BUILD_TIMEOUT=$((BUILD_TIMEOUT+1))
            BUILD_TIMEOUTS="$BUILD_TIMEOUTS\n  $name"
            printf "\033[33mT\033[0m"
        else
            BUILD_FAIL=$((BUILD_FAIL+1))
            BUILD_FAILS="$BUILD_FAILS\n  $name"
            printf "\033[31mX\033[0m"
        fi
    done

    echo ""
    echo ""
    echo "Build: ${BUILD_PASS}/${TOTAL} pass, ${BUILD_FAIL} fail, ${BUILD_TIMEOUT} timeout"
    if [ -n "$BUILD_FAILS" ]; then echo -e "  Failed:$BUILD_FAILS"; fi
    if [ -n "$BUILD_TIMEOUTS" ]; then echo -e "  Timed out:$BUILD_TIMEOUTS"; fi
    echo ""
fi

# ── Phase 2: Witness Replay ─────────────────────────────────────────────

if [ "$NO_WITNESS" -eq 1 ]; then
    exit 0
fi

WITNESS_COUNT=0
WITNESS_PASS=0
WITNESS_FAIL=0
WITNESS_FAILS=""
WITNESS_DIFFS=""

# Collect witness files
shopt -s nullglob
WITNESS_FILES=("$WITNESS_DIR"/*.witness)
shopt -u nullglob

if [ ${#WITNESS_FILES[@]} -eq 0 ]; then
    echo "No witness files to replay."
    exit 0
fi

echo "═══ Phase 2: Witness Replay (${#WITNESS_FILES[@]} witnesses) ═══"
echo ""

for wfile in "${WITNESS_FILES[@]}"; do
    wname=$(basename "$wfile" .witness)
    WITNESS_COUNT=$((WITNESS_COUNT+1))

    # Find the cart .tsz
    cart=$(find carts/ -name "${wname}.tsz" -not -name "*.script.tsz" -not -name "*.cls.tsz" 2>/dev/null | head -1)
    if [ -z "$cart" ]; then
        printf "\033[33mS\033[0m"  # skip
        continue
    fi

    # Binary should exist from phase 1 build
    binary="zig-out/bin/$wname"
    if [ ! -x "$binary" ]; then
        printf "\033[33mS\033[0m"  # skip — build failed in phase 1
        continue
    fi

    # Replay
    tmpout="/tmp/witness_replay_${wname}_$$"
    ZIGOS_HEADLESS=1 \
    ZIGOS_WITNESS=replay \
    ZIGOS_WITNESS_FILE="$wfile" \
    timeout -s KILL 5 "$binary" >"$tmpout" 2>&1 || true

    if grep -q "WITNESS RESULT" "$tmpout"; then
        passed=$(grep "WITNESS RESULT" "$tmpout" | grep -oP '\d+(?=/)')
        total=$(grep "WITNESS RESULT" "$tmpout" | grep -oP '(?<=/)\d+')

        if [ "$passed" = "$total" ]; then
            WITNESS_PASS=$((WITNESS_PASS+1))
            rm -f "$tmpout"
        else
            WITNESS_FAIL=$((WITNESS_FAIL+1))
            echo "  FAIL: $wname ($passed/$total)"
            WITNESS_FAILS="$WITNESS_FAILS\n  $wname ($passed/$total)"
            mv "$tmpout" "/tmp/witness_fail_${wname}.log"
        fi

        # Record in DB
        if [ -f "$DB" ]; then
            safe_name=$(printf '%s' "$wname" | sed "s/'/''/g")
            NOW=$(date '+%Y-%m-%d %I:%M:%S %p')
            source_sha=$(sha256sum "$cart" 2>/dev/null | cut -c1-64 || echo "unknown")
            status="pass"; [ "$passed" != "$total" ] && status="fail"
            sqlite3 "$DB" ".timeout 5000" \
                "INSERT INTO witness_replays (test_name, replayed_at, status, passed, total, source_sha)
                 VALUES ('$safe_name', '$NOW', '$status', $passed, $total, '$source_sha');" 2>/dev/null
        fi
    else
        WITNESS_FAIL=$((WITNESS_FAIL+1))
        echo "  CRASH: $wname"
        WITNESS_FAILS="$WITNESS_FAILS\n  $wname (crash/timeout)"
        mv "$tmpout" "/tmp/witness_fail_${wname}.log" 2>/dev/null || true
    fi
done

echo ""
echo ""

# ── Summary ─────────────────────────────────────────────────────────────

echo "═══════════════════════════════════════"
if [ "$WITNESS_ONLY" -eq 0 ]; then
    echo "  Build:   ${BUILD_PASS}/${TOTAL} pass"
fi
echo "  Witness: ${WITNESS_PASS}/${WITNESS_COUNT} pass"
echo "═══════════════════════════════════════"

if [ -n "$WITNESS_FAILS" ]; then
    echo -e "\nWitness failures:$WITNESS_FAILS"
fi

# Show diffs for failures
if [ -n "$WITNESS_DIFFS" ]; then
    echo ""
    echo "═══ Failure Details ═══"
    echo -e "$WITNESS_DIFFS"
    echo ""
    echo "Full logs saved to /tmp/witness_fail_*.log"
fi

# Exit code: fail if any witness failed
if [ "$WITNESS_FAIL" -gt 0 ] || [ "$BUILD_FAIL" -gt 0 ]; then
    exit 1
fi
exit 0
