#!/bin/bash
# conformance-report — query the latest conformance results from conformance.db
# Cross-references disk (all entry-point .tsz files) with db (build results).
#
# Usage:
#   ./scripts/conformance-report                  # summary with coverage
#   ./scripts/conformance-report --all             # every test, one per line
#   ./scripts/conformance-report --fails           # only failures + untested
#   ./scripts/conformance-report --lane X          # filter by lane
#   ./scripts/conformance-report --untested        # list tests with no db entry
#   ./scripts/conformance-report --verify <name>   # mark test as human-verified, snapshot generated code
#   ./scripts/conformance-report --verified        # list all human-verified tests
#   ./scripts/conformance-report --pending         # list tests that need verification (compiled but not verified)
#   ./scripts/conformance-report --note <name> "reason"  # attach a failure note to a test
#   ./scripts/conformance-report --notes           # list all failure notes (for Claude to read)
set -euo pipefail
cd "$(dirname "$0")/.."

DB="conformance.db"
CONF_DIR="carts/conformance"
VERIFIED_DIR="$CONF_DIR/.verified"

if [ ! -f "$DB" ]; then
    echo "No conformance.db found. Run a conformance build first."
    exit 1
fi

# Ensure failure_notes table exists
sqlite3 "$DB" ".timeout 5000" \
    "CREATE TABLE IF NOT EXISTS failure_notes (
        test_name  TEXT PRIMARY KEY,
        note       TEXT NOT NULL,
        noted_at   TEXT NOT NULL
    );" 2>/dev/null

# ── Helpers ─────────────────────────────────────────────────────────
disk_tests() {
    find "$CONF_DIR" -name "*.tsz" \
        ! -name "*.script.tsz" \
        ! -name "*.cls.tsz" \
        ! -name "*.mod.tsz" \
        ! -name "*.c.tsz" \
        ! -name "*.effects.tsz" \
        ! -name "*.glyphs.tsz" \
        ! -name "*.tcls.tsz" \
        ! -name "*.vcls.tsz" \
        -type f
}

lane_from_path() {
    local rel="${1#$CONF_DIR/}"
    if [[ "$rel" == */* ]]; then
        echo "${rel%%/*}"
    else
        echo "root"
    fi
}

name_from_path() {
    # Qualified name: includes subdirectory under lane to avoid collisions.
    # Must match scripts/build CONF_NAME derivation exactly.
    # e.g. "carts/conformance/mixed/smith-test/counter.tsz" → "smith-test/counter"
    # e.g. "carts/conformance/mixed/parity/twitter-clone/twitter-clone.tsz" → "parity/twitter-clone/twitter-clone"
    # e.g. "carts/conformance/mixed/d01_nested_maps.tsz" → "d01_nested_maps"
    local rel="${1#*carts/conformance/}"
    local rest="${rel#*/}"          # strip lane prefix
    local base=$(basename "$rest" .tsz | sed 's/\.app$//')
    local subdir=$(dirname "$rest")
    if [ "$subdir" != "." ]; then
        echo "${subdir}/${base}"
    else
        echo "$base"
    fi
}

# Escape a value for safe SQL interpolation (double single quotes)
sql_escape() {
    printf '%s' "$1" | sed "s/'/''/g"
}

# Resolve a user-provided name to a test_name in the DB.
# Tries: exact match, then basename match (case-insensitive), then substring.
# Sets RESOLVED_NAME or prints error and exits.
resolve_test_name() {
    local input="$1"
    local safe=$(sql_escape "$input")

    # 1. Exact match
    local exact=$(sqlite3 "$DB" \
        "SELECT test_name FROM builds WHERE test_name = '$safe' GROUP BY test_name;" 2>/dev/null || true)
    if [ -n "$exact" ]; then
        RESOLVED_NAME="$exact"
        return 0
    fi

    # 2. Disk scan — match basename case-insensitively
    local disk_match=""
    local disk_count=0
    local lower_input=$(echo "$input" | tr '[:upper:]' '[:lower:]')
    while read -r path; do
        local tname=$(name_from_path "$path")
        local tbase=$(basename "$tname" | tr '[:upper:]' '[:lower:]')
        if [ "$tbase" = "$lower_input" ]; then
            disk_match="$tname"
            disk_count=$((disk_count + 1))
        fi
    done < <(disk_tests)

    if [ "$disk_count" -eq 1 ]; then
        RESOLVED_NAME="$disk_match"
        return 0
    elif [ "$disk_count" -gt 1 ]; then
        echo "Ambiguous name '$input'. Multiple basename matches on disk."
        exit 1
    fi

    # 3. DB substring match (case-insensitive) — catches partial names
    local fuzzy=$(sqlite3 "$DB" \
        "SELECT test_name FROM builds WHERE LOWER(test_name) LIKE '%' || LOWER('$safe') || '%' GROUP BY test_name;" 2>/dev/null || true)
    local fcount=0
    [ -n "$fuzzy" ] && fcount=$(echo "$fuzzy" | wc -l)

    if [ "$fcount" -eq 1 ]; then
        RESOLVED_NAME="$fuzzy"
        return 0
    elif [ "$fcount" -gt 1 ]; then
        echo "Ambiguous name '$input'. Matches:"
        echo "$fuzzy" | sed 's/^/  /'
        exit 1
    fi

    echo "No test found for '$input'. Not on disk and not in DB."
    exit 1
}

MODE="${1:---summary}"
LANE_FILTER="${2:-}"

case "$MODE" in
    --note)
        TNAME="${2:-}"
        NOTE_TEXT="${3:-}"
        if [ -z "$TNAME" ] || [ -z "$NOTE_TEXT" ]; then
            echo "Usage: conformance-report --note <test_name> \"why it failed\""
            exit 1
        fi

        resolve_test_name "$TNAME"
        TNAME="$RESOLVED_NAME"
        SAFE_TNAME=$(sql_escape "$TNAME")

        NOW=$(date +"%Y-%m-%d %I:%M:%S %p")
        SAFE_NOTE=$(sql_escape "$NOTE_TEXT")
        sqlite3 "$DB" ".timeout 5000" \
            "INSERT OR REPLACE INTO failure_notes (test_name, note, noted_at)
             VALUES ('$SAFE_TNAME', '$SAFE_NOTE', '$NOW');"
        echo "NOTE: $TNAME"
        echo "  $NOTE_TEXT"
        echo "  (will be cleared on --verify)"
        ;;

    --notes)
        echo ""
        COUNT=$(sqlite3 "$DB" "SELECT COUNT(*) FROM failure_notes;" 2>/dev/null || echo "0")
        if [ "$COUNT" = "0" ]; then
            echo "No failure notes."
        else
            printf "%-35s %-22s %s\n" "TEST" "NOTED" "NOTE"
            printf "%-35s %-22s %s\n" "---" "-----" "----"
            sqlite3 "$DB" \
                "SELECT f.test_name, f.noted_at, f.note
                 FROM failure_notes f
                 ORDER BY f.noted_at DESC;" | while IFS='|' read -r name noted note; do
                printf "%-35s %-22s %s\n" "$name" "$noted" "$note"
            done
        fi
        ;;

    --verify)
        TNAME="${2:-}"
        if [ -z "$TNAME" ]; then
            echo "Usage: conformance-report --verify <test_name>"
            exit 1
        fi

        resolve_test_name "$TNAME"
        TNAME="$RESOLVED_NAME"
        SAFE_TNAME=$(sql_escape "$TNAME")
        LATEST_ID=$(sqlite3 "$DB" \
            "SELECT id FROM builds WHERE test_name = '$SAFE_TNAME' ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)
        if [ -z "$LATEST_ID" ]; then
            echo "No build found for '$TNAME'. Run a build first."
            exit 1
        fi

        LATEST_STATUS=$(sqlite3 "$DB" "SELECT status FROM builds WHERE id = $LATEST_ID;")
        if [ "$LATEST_STATUS" != "compiled" ]; then
            echo "Latest build for '$TNAME' has status '$LATEST_STATUS' — only compiled tests can be verified."
            exit 1
        fi

        # Find source .tsz on disk
        SOURCE_PATH=$(disk_tests | while read -r p; do
            n=$(name_from_path "$p")
            if [ "$n" = "$TNAME" ]; then echo "$p"; break; fi
        done)
        if [ -z "$SOURCE_PATH" ]; then
            echo "Cannot find source .tsz for '$TNAME' on disk."
            exit 1
        fi
        # Refresh in case fuzzy match resolved TNAME
        SAFE_TNAME=$(sql_escape "$TNAME")

        # Mark as verified + lock source hash + engine hash + record which build was verified
        NOW=$(date +"%Y-%m-%d %I:%M:%S %p")
        SOURCE_HASH=$(sha256sum "$SOURCE_PATH" | awk '{print $1}')
        SAFE_SOURCE_PATH=$(sql_escape "$SOURCE_PATH")

        # Get the engine hash from the build record, or hash current .so
        ENGINE_SHA=$(sqlite3 "$DB" ".timeout 5000" \
            "SELECT engine_sha FROM builds WHERE id = $LATEST_ID;" 2>/dev/null || true)
        if [ -z "$ENGINE_SHA" ]; then
            ENGINE_SO="zig-out/lib/libreactjit-core.so"
            [ -f "$ENGINE_SO" ] && ENGINE_SHA=$(sha256sum "$ENGINE_SO" | awk '{print $1}')
        fi
        SAFE_ENGINE_SHA=$(sql_escape "${ENGINE_SHA:-unknown}")

        sqlite3 "$DB" ".timeout 5000" "UPDATE builds SET verified_at = '$NOW' WHERE id = $LATEST_ID;"
        sqlite3 "$DB" ".timeout 5000" "INSERT OR REPLACE INTO verified_sources (test_name, source_sha, verified_at, source_path, verified_build_id, engine_sha)
            VALUES ('$SAFE_TNAME', '$SOURCE_HASH', '$NOW', '$SAFE_SOURCE_PATH', $LATEST_ID, '$SAFE_ENGINE_SHA');"

        # Check if this engine is blessed
        IS_BLESSED=""
        if [ -n "$ENGINE_SHA" ]; then
            IS_BLESSED=$(sqlite3 "$DB" ".timeout 5000" \
                "SELECT blessed_at FROM engine_builds WHERE engine_sha = '$SAFE_ENGINE_SHA' AND blessed_at IS NOT NULL;" 2>/dev/null || true)
        fi

        echo "LOCKED: $SOURCE_PATH"
        echo "  source: $SOURCE_HASH"
        echo "  engine: ${ENGINE_SHA:0:16}...$([ -n "$IS_BLESSED" ] && echo " (BLESSED)" || echo " (unblessed)")"

        # Snapshot generated code
        # Forge uses just the basename (no subdirectory), so "effects/plasma" → "plasma"
        GEN_ROOT="/tmp/tsz-gen"
        GEN_BASENAME=$(basename "$TNAME")
        GEN_FILE="$GEN_ROOT/generated_${GEN_BASENAME}.zig"
        GEN_SPLIT="$GEN_ROOT/generated_${GEN_BASENAME}"
        SNAP_DIR="$VERIFIED_DIR/$TNAME"
        mkdir -p "$SNAP_DIR"

        if [ -d "$GEN_SPLIT" ]; then
            cp "$GEN_SPLIT"/*.zig "$SNAP_DIR/" 2>/dev/null || true
            FILE_COUNT=$(ls "$SNAP_DIR"/*.zig 2>/dev/null | wc -l)
            echo "VERIFIED: $TNAME ($NOW)"
            echo "  Snapshot: $SNAP_DIR/ ($FILE_COUNT files)"
        elif [ -f "$GEN_FILE" ]; then
            cp "$GEN_FILE" "$SNAP_DIR/generated.zig"
            echo "VERIFIED: $TNAME ($NOW)"
            echo "  Snapshot: $SNAP_DIR/generated.zig"
        else
            echo "VERIFIED: $TNAME ($NOW)"
            echo "  WARNING: No generated code found in $GEN_ROOT to snapshot."
            echo "  Run a build first, then verify immediately after."
        fi

        # Wipe any failure note — test is verified now
        HAD_NOTE=$(sqlite3 "$DB" "SELECT COUNT(*) FROM failure_notes WHERE test_name = '$SAFE_TNAME';" 2>/dev/null || echo "0")
        sqlite3 "$DB" ".timeout 5000" "DELETE FROM failure_notes WHERE test_name = '$SAFE_TNAME';"
        [ "$HAD_NOTE" -gt 0 ] && echo "  (failure note cleared)"
        ;;

    --override)
        TNAME="${2:-}"
        if [ -z "$TNAME" ]; then
            echo "Usage: conformance-report --override <test_name>"
            echo "Accepts the current source hash as the new baseline."
            exit 1
        fi

        resolve_test_name "$TNAME"
        TNAME="$RESOLVED_NAME"
        SAFE_TNAME=$(sql_escape "$TNAME")

        # Find source .tsz on disk
        SOURCE_PATH=$(disk_tests | while read -r p; do
            n=$(name_from_path "$p")
            if [ "$n" = "$TNAME" ]; then echo "$p"; break; fi
        done)
        if [ -z "$SOURCE_PATH" ]; then
            echo "Cannot find source .tsz for '$TNAME' on disk."
            exit 1
        fi
        BASELINE=$(sqlite3 "$DB" ".timeout 5000" \
            "SELECT source_sha FROM builds WHERE test_name = '$SAFE_TNAME' AND source_sha IS NOT NULL AND source_sha != '' ORDER BY id ASC LIMIT 1;" 2>/dev/null || true)
        NEW_HASH=$(sha256sum "$SOURCE_PATH" | awk '{print $1}')

        if [ -z "$BASELINE" ]; then
            echo "'$TNAME' has no builds yet. Run a build first."
            exit 1
        fi

        if [ "$BASELINE" = "$NEW_HASH" ]; then
            echo "Source matches baseline — no override needed."
            exit 0
        fi

        NOW=$(date +"%Y-%m-%d %I:%M:%S %p")
        sqlite3 "$DB" ".timeout 5000" \
            "INSERT OR REPLACE INTO source_overrides (test_name, source_sha, overridden_at)
             VALUES ('$SAFE_TNAME', '$NEW_HASH', '$NOW');"
        echo "OVERRIDE: $TNAME"
        echo "  Baseline: $BASELINE"
        echo "  Accepted: $NEW_HASH"
        echo "  Source change accepted at $NOW"
        ;;

    --verified)
        echo ""
        printf "%-30s %-10s %-20s %-18s %-18s %s\n" "TEST" "LANE" "VERIFIED" "ENGINE" "BLESSED?" "ENGINES PASSED"
        printf "%-30s %-10s %-20s %-18s %-18s %s\n" "---" "----" "--------" "------" "--------" "--------------"
        sqlite3 "$DB" ".timeout 5000" \
            "SELECT v.test_name, v.source_path,
                    v.verified_at,
                    COALESCE(v.engine_sha, ''),
                    COALESCE(e.blessed_at, ''),
                    (SELECT COUNT(DISTINCT b.engine_sha)
                     FROM builds b
                     WHERE b.test_name = v.test_name
                       AND b.status = 'compiled'
                       AND b.engine_sha IS NOT NULL)
             FROM verified_sources v
             LEFT JOIN engine_builds e ON e.engine_sha = v.engine_sha
             ORDER BY v.verified_at DESC;" | while IFS='|' read -r name spath verified_at eng_sha blessed_at engine_count; do
            rel="${spath#*carts/conformance/}"
            if [[ "$rel" == */* ]]; then
                lane="${rel%%/*}"
            else
                lane="root"
            fi
            eng_short="${eng_sha:0:12}"
            [ -z "$eng_short" ] && eng_short="-"
            blessed_flag="-"
            [ -n "$blessed_at" ] && blessed_flag="YES"
            printf "%-30s %-10s %-20s %-18s %-18s %s\n" "$name" "$lane" "${verified_at:--}" "$eng_short" "$blessed_flag" "${engine_count:-0}"
        done
        ;;

    --witness)
        # Ensure table exists
        sqlite3 "$DB" ".timeout 5000" \
            "CREATE TABLE IF NOT EXISTS witness_replays (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                test_name   TEXT    NOT NULL,
                replayed_at TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
                status      TEXT    NOT NULL,
                passed      INTEGER NOT NULL,
                total       INTEGER NOT NULL,
                source_sha  TEXT
            );" 2>/dev/null
        echo ""
        printf "%-35s %-8s %-10s %-22s %s\n" "TEST" "RESULT" "CHECKS" "REPLAYED" "FILE"
        printf "%-35s %-8s %-10s %-22s %s\n" "---" "------" "------" "--------" "----"
        sqlite3 "$DB" ".timeout 5000" \
            "SELECT test_name, status, passed, total, replayed_at
             FROM witness_replays
             WHERE id IN (SELECT MAX(id) FROM witness_replays GROUP BY test_name)
             ORDER BY test_name;" | while IFS='|' read -r name status passed total replayed; do
            wfile="witnesses/${name}.witness"
            has_file="-"
            [ -f "$wfile" ] && has_file="$wfile"
            printf "%-35s %-8s %-10s %-22s %s\n" "$name" "$status" "${passed}/${total}" "$replayed" "$has_file"
        done

        # Also show witness files with no replay yet
        for wfile in witnesses/*.witness; do
            [ -f "$wfile" ] || continue
            wname=$(basename "$wfile" .witness)
            in_db=$(sqlite3 "$DB" ".timeout 5000" \
                "SELECT COUNT(*) FROM witness_replays WHERE test_name = '$(sql_escape "$wname")';" 2>/dev/null || echo "0")
            if [ "$in_db" = "0" ]; then
                actions=$(grep -c '^CLICK' "$wfile" 2>/dev/null || echo "0")
                printf "%-35s %-8s %-10s %-22s %s\n" "$wname" "pending" "-" "-" "$wfile (${actions} actions)"
            fi
        done
        echo ""
        ;;

    --all)
        # Ensure witness table exists for the join
        sqlite3 "$DB" ".timeout 5000" \
            "CREATE TABLE IF NOT EXISTS witness_replays (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                test_name   TEXT    NOT NULL,
                replayed_at TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
                status      TEXT    NOT NULL,
                passed      INTEGER NOT NULL,
                total       INTEGER NOT NULL,
                source_sha  TEXT
            );" 2>/dev/null
        echo ""
        printf "%-35s %-12s %-12s %-10s %-12s %s\n" "TEST" "LANE" "STATUS" "WITNESS" "VERIFIED" "BUILT"
        printf "%-35s %-12s %-12s %-10s %-12s %s\n" "---" "----" "------" "-------" "--------" "-----"
        disk_tests | while read -r path; do
            tname=$(name_from_path "$path")
            lane=$(lane_from_path "$path")
            safe_tname=$(sql_escape "$tname")
            row=$(sqlite3 "$DB" \
                "SELECT status, built_at, verified_at FROM builds
                 WHERE test_name = '$safe_tname'
                 ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)
            if [ -n "$row" ]; then
                status=$(echo "$row" | cut -d'|' -f1)
                built=$(echo "$row" | cut -d'|' -f2)
                verified=$(echo "$row" | cut -d'|' -f3)
                [ -z "$verified" ] && verified="-"
            else
                status="untested"
                built="-"
                verified="-"
            fi
            # Witness status
            witness="-"
            wrow=$(sqlite3 "$DB" \
                "SELECT status, passed, total FROM witness_replays
                 WHERE test_name = '$safe_tname'
                 ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)
            if [ -n "$wrow" ]; then
                wstatus=$(echo "$wrow" | cut -d'|' -f1)
                wpassed=$(echo "$wrow" | cut -d'|' -f2)
                wtotal=$(echo "$wrow" | cut -d'|' -f3)
                witness="${wstatus} ${wpassed}/${wtotal}"
            fi
            if [ -z "$LANE_FILTER" ] || [ "$lane" = "$LANE_FILTER" ]; then
                printf "%-35s %-12s %-12s %-10s %-12s %s\n" "$tname" "$lane" "$status" "$witness" "$verified" "$built"
            fi
        done | sort
        ;;

    --fails)
        echo ""
        printf "%-35s %-12s %-12s %s\n" "TEST" "LANE" "STATUS" "ERROR"
        printf "%-35s %-12s %-12s %s\n" "---" "----" "------" "-----"
        disk_tests | while read -r path; do
            tname=$(name_from_path "$path")
            lane=$(lane_from_path "$path")
            safe_tname=$(sql_escape "$tname")
            row=$(sqlite3 "$DB" \
                "SELECT status, substr(error_log, 1, 80) FROM builds
                 WHERE test_name = '$safe_tname'
                 ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)
            if [ -n "$row" ]; then
                status=$(echo "$row" | cut -d'|' -f1)
                err=$(echo "$row" | cut -d'|' -f2-)
            else
                status="untested"
                err=""
            fi
            if [ "$status" != "compiled" ]; then
                printf "%-35s %-12s %-12s %s\n" "$tname" "$lane" "$status" "$err"
                note=$(sqlite3 "$DB" "SELECT note FROM failure_notes WHERE test_name = '$safe_tname';" 2>/dev/null || true)
                [ -n "$note" ] && printf "%-35s %-12s %-12s NOTE: %s\n" "" "" "" "$note"
            fi
        done | sort
        ;;

    --pending)
        echo ""
        echo "Tests needing verification (compiled but not yet verified):"
        echo ""
        printf "  %-35s %-12s %s\n" "TEST" "LANE" "LAST BUILT"
        printf "  %-35s %-12s %s\n" "---" "----" "----------"
        COUNT=0
        disk_tests | while read -r path; do
            tname=$(name_from_path "$path")
            lane=$(lane_from_path "$path")
            safe_tname=$(sql_escape "$tname")
            row=$(sqlite3 "$DB" \
                "SELECT status, built_at FROM builds
                 WHERE test_name = '$safe_tname'
                 ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)
            [ -z "$row" ] && continue
            status=$(echo "$row" | cut -d'|' -f1)
            built=$(echo "$row" | cut -d'|' -f2)
            [ "$status" != "compiled" ] && continue
            verified=$(sqlite3 "$DB" \
                "SELECT COUNT(*) FROM verified_sources WHERE test_name = '$safe_tname';" 2>/dev/null || echo "0")
            if [ "$verified" = "0" ]; then
                printf "  %-35s %-12s %s\n" "$tname" "$lane" "$built"
            fi
        done | sort
        ;;

    --untested)
        echo ""
        echo "Tests with no entry in conformance.db:"
        echo ""
        disk_tests | while read -r path; do
            tname=$(name_from_path "$path")
            lane=$(lane_from_path "$path")
            safe_tname=$(sql_escape "$tname")
            exists=$(sqlite3 "$DB" "SELECT COUNT(*) FROM builds WHERE test_name = '$safe_tname';" 2>/dev/null || echo "0")
            if [ "$exists" = "0" ]; then
                printf "  %-35s %s\n" "$tname" "$lane"
            fi
        done | sort
        ;;

    --lane)
        if [ -z "$LANE_FILTER" ]; then
            echo "Usage: conformance-report --lane <lane_name>"
            echo ""
            echo "Lanes (from disk):"
            disk_tests | while read -r path; do
                lane_from_path "$path"
            done | sort -u | sed 's/^/  /'
            exit 1
        fi
        echo ""
        printf "%-35s %-12s %-12s %s\n" "TEST" "STATUS" "VERIFIED" "BUILT"
        printf "%-35s %-12s %-12s %s\n" "---" "------" "--------" "-----"
        disk_tests | while read -r path; do
            tname=$(name_from_path "$path")
            lane=$(lane_from_path "$path")
            [ "$lane" != "$LANE_FILTER" ] && continue
            safe_tname=$(sql_escape "$tname")
            row=$(sqlite3 "$DB" \
                "SELECT status, built_at, verified_at FROM builds
                 WHERE test_name = '$safe_tname'
                 ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)
            if [ -n "$row" ]; then
                status=$(echo "$row" | cut -d'|' -f1)
                built=$(echo "$row" | cut -d'|' -f2)
                verified=$(echo "$row" | cut -d'|' -f3)
                [ -z "$verified" ] && verified="-"
            else
                status="untested"
                built="-"
                verified="-"
            fi
            printf "%-35s %-12s %-12s %s\n" "$tname" "$status" "$verified" "$built"
        done | sort
        ;;

    --summary|*)
        DISK_TOTAL=0
        DISK_BY_LANE=""
        while read -r path; do
            DISK_TOTAL=$((DISK_TOTAL + 1))
            lane=$(lane_from_path "$path")
            DISK_BY_LANE="${DISK_BY_LANE}${lane}\n"
        done < <(disk_tests)

        DB_COMPILED=$(sqlite3 "$DB" \
            "SELECT COUNT(*) FROM builds
             WHERE id IN (SELECT MAX(id) FROM builds GROUP BY test_name)
               AND status = 'compiled';")
        DB_FAILED=$(sqlite3 "$DB" \
            "SELECT COUNT(*) FROM builds
             WHERE id IN (SELECT MAX(id) FROM builds GROUP BY test_name)
               AND status != 'compiled';")
        DB_VERIFIED=$(sqlite3 "$DB" \
            "SELECT COUNT(DISTINCT test_name) FROM verified_sources;")
        DB_TOTAL=$((DB_COMPILED + DB_FAILED))
        UNTESTED=$((DISK_TOTAL - DB_TOTAL))
        [ "$UNTESTED" -lt 0 ] && UNTESTED=0

        LATEST=$(sqlite3 "$DB" "SELECT built_at FROM builds ORDER BY id DESC LIMIT 1;")

        # Witness stats
        sqlite3 "$DB" ".timeout 5000" \
            "CREATE TABLE IF NOT EXISTS witness_replays (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                test_name   TEXT    NOT NULL,
                replayed_at TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
                status      TEXT    NOT NULL,
                passed      INTEGER NOT NULL,
                total       INTEGER NOT NULL,
                source_sha  TEXT
            );" 2>/dev/null
        WITNESS_TOTAL=$(sqlite3 "$DB" \
            "SELECT COUNT(DISTINCT test_name) FROM witness_replays;" 2>/dev/null || echo "0")
        WITNESS_PASS=$(sqlite3 "$DB" \
            "SELECT COUNT(*) FROM witness_replays
             WHERE id IN (SELECT MAX(id) FROM witness_replays GROUP BY test_name)
               AND status = 'pass';" 2>/dev/null || echo "0")
        WITNESS_FAIL=$(sqlite3 "$DB" \
            "SELECT COUNT(*) FROM witness_replays
             WHERE id IN (SELECT MAX(id) FROM witness_replays GROUP BY test_name)
               AND status != 'pass';" 2>/dev/null || echo "0")
        WITNESS_FILES=$(ls witnesses/*.witness 2>/dev/null | wc -l || echo "0")

        echo "=== CONFORMANCE REPORT ==="
        echo ""
        echo "Latest build: $LATEST"
        echo ""
        printf "  %-20s %s\n" "On disk:" "$DISK_TOTAL"
        printf "  %-20s %s\n" "Compiled:" "$DB_COMPILED"
        printf "  %-20s %s\n" "Human verified:" "$DB_VERIFIED"
        printf "  %-20s %s\n" "Witness recorded:" "$WITNESS_FILES"
        printf "  %-20s %s\n" "Witness pass:" "$WITNESS_PASS"
        [ "$WITNESS_FAIL" -gt 0 ] && printf "  %-20s %s\n" "Witness fail:" "$WITNESS_FAIL"
        printf "  %-20s %s\n" "Build failures:" "$DB_FAILED"
        printf "  %-20s %s\n" "Untested:" "$UNTESTED"
        DB_NOTES=$(sqlite3 "$DB" "SELECT COUNT(*) FROM failure_notes;" 2>/dev/null || echo "0")
        [ "$DB_NOTES" -gt 0 ] && printf "  %-20s %s\n" "Failure notes:" "$DB_NOTES (run --notes)"
        echo ""
        echo "Pass rate: ${DB_COMPILED}/${DISK_TOTAL} ($(( DB_COMPILED * 100 / (DISK_TOTAL > 0 ? DISK_TOTAL : 1) ))%)"
        echo ""

        # By lane (from disk, cross-ref db)
        echo "By lane:"
        printf "  %-12s %6s %8s %8s %6s %8s\n" "LANE" "DISK" "COMPILED" "VERIFIED" "FAIL" "UNTESTED"
        printf "  %-12s %6s %8s %8s %6s %8s\n" "----" "----" "--------" "--------" "----" "--------"
        echo -e "$DISK_BY_LANE" | sort | uniq -c | sort -rn | while read -r count lane; do
            [ -z "$lane" ] && continue
            compiled=0
            failed=0
            untested=0
            verified=0
            while read -r path; do
                tname=$(name_from_path "$path")
                plane=$(lane_from_path "$path")
                [ "$plane" != "$lane" ] && continue
                safe_tname=$(sql_escape "$tname")
                row=$(sqlite3 "$DB" \
                    "SELECT status, verified_at FROM builds
                     WHERE test_name = '$safe_tname'
                     ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)
                if [ -z "$row" ]; then
                    untested=$((untested + 1))
                else
                    s=$(echo "$row" | cut -d'|' -f1)
                    if [ "$s" = "compiled" ]; then
                        compiled=$((compiled + 1))
                        v=$(sqlite3 "$DB" \
                            "SELECT COUNT(*) FROM verified_sources WHERE test_name = '$safe_tname';" 2>/dev/null || echo "0")
                        [ "$v" -gt 0 ] && verified=$((verified + 1))
                    else
                        failed=$((failed + 1))
                    fi
                fi
            done < <(disk_tests)
            printf "  %-12s %6s %8s %8s %6s %8s\n" "$lane" "$count" "$compiled" "$verified" "$failed" "$untested"
        done
        echo ""

        # Build failures detail
        if [ "$DB_FAILED" -gt 0 ]; then
            echo "Build failures:"
            sqlite3 "$DB" \
                "SELECT test_name, status, substr(error_log, 1, 80)
                 FROM builds
                 WHERE id IN (SELECT MAX(id) FROM builds GROUP BY test_name)
                   AND status != 'compiled'
                 ORDER BY test_name;" | while IFS='|' read -r name status err; do
                printf "  %-30s %-18s %s\n" "$name" "$status" "$err"
            done
        fi
        ;;
esac
