#!/bin/bash
# Run every binary in zig-out/bin with a 1s SIGKILL timeout
# Outputs to tsz/run-all.log — grep for errors after
DIR="$(dirname "$0")/../zig-out/bin"
LOG="$(dirname "$0")/../run-all.log"
> "$LOG"
for bin in "$DIR"/*; do
  [ ! -x "$bin" ] && continue
  name=$(basename "$bin")
  echo "=== $name ===" >> "$LOG"
  ZIGOS_HEADLESS=1 timeout -s KILL 1 "$bin" >> "$LOG" 2>&1
  echo "" >> "$LOG"
done
echo "done → $LOG"
