#!/bin/bash
# Build a cart using the DIRTY engine — rebuilt from current framework/ source.
#
# This is what Claude uses when it touched framework/ code.
# The engine .so is rebuilt from whatever is in framework/ right now.
# If the cart crashes, it's because Claude just broke it.
#
# Usage:
#   ./scripts/buildFromMyShittyNewCode carts/app.tsz
#   ./scripts/buildFromMyShittyNewCode carts/app.tsz -n    # with debug flags

set -euo pipefail
cd "$(dirname "$0")/.."

if [ "${#@}" -eq 0 ]; then
    echo "Usage: ./scripts/buildFromMyShittyNewCode <cart.tsz> [flags...]"
    echo ""
    echo "Rebuilds the engine from current framework/ source (DIRTY),"
    echo "then builds the cart against it."
    echo ""
    echo "If it breaks: YOU broke it. Not pre-existing. You just built it."
    exit 1
fi

DIRTY_SO="zig-out/lib/libreactjit-core.so"
DIRTY_STAMP="zig-out/lib/.dirty-stamp"

echo ""
echo "┌─────────────────────────────────────────────────────────┐"
echo "│  DIRTY ENGINE BUILD                                     │"
echo "│  Rebuilding engine from current framework/ source.      │"
echo "│  Any bugs from here are YOURS. Not pre-existing.        │"
echo "└─────────────────────────────────────────────────────────┘"
echo ""

# ── Hash framework source BEFORE build ──────────────────────────
SRC_HASH_BEFORE=$(find framework/ -name '*.zig' -exec sha256sum {} + 2>/dev/null | sort | sha256sum | cut -c1-16)
SO_HASH_BEFORE=$(sha256sum "$DIRTY_SO" 2>/dev/null | cut -c1-16 || echo "none")
echo "[dirty] framework source hash: $SRC_HASH_BEFORE"
echo "[dirty] engine .so hash before: $SO_HASH_BEFORE"

# ── Rebuild engine from current (dirty) source ──────────────────
echo "[dirty] rebuilding engine .so from framework/..."
zig build core-so -Doptimize=ReleaseFast 2>&1 || {
    echo ""
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    echo "  ENGINE BUILD FAILED"
    echo "  Your framework/ changes don't compile."
    echo "  Fix them before building carts."
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    exit 1
}

# ── Verify the build actually changed ───────────────────────────
SO_HASH_AFTER=$(sha256sum "$DIRTY_SO" 2>/dev/null | cut -c1-16 || echo "MISSING")
echo "[dirty] engine .so hash after:  $SO_HASH_AFTER"

if [ "$SO_HASH_BEFORE" != "none" ] && [ "$SO_HASH_BEFORE" = "$SO_HASH_AFTER" ]; then
    echo "[dirty] !! CACHE LIED: framework changed but .so hash unchanged"
    echo "[dirty] !! Nuking engine cache and retrying..."
    rm -rf .zig-cache/h
    rm -f "$DIRTY_SO"
    zig build core-so -Doptimize=ReleaseFast 2>&1 || {
        echo "[dirty] engine rebuild failed on retry"
        exit 1
    }
    SO_HASH_AFTER=$(sha256sum "$DIRTY_SO" 2>/dev/null | cut -c1-16 || echo "MISSING")
    echo "[dirty] engine .so hash after retry: $SO_HASH_AFTER"
fi

# Stamp the dirty build
COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
DIRTY_FILES=$(git diff --name-only -- framework/ 2>/dev/null | head -20)
cat > "$DIRTY_STAMP" << EOF
commit: $COMMIT
date: $(date '+%Y-%m-%d %H:%M:%S')
source_hash: $SRC_HASH_BEFORE
so_hash: $SO_HASH_AFTER
dirty_files:
$DIRTY_FILES
EOF

if [ -n "$DIRTY_FILES" ]; then
    echo "[dirty] changed framework files:"
    echo "$DIRTY_FILES" | sed 's/^/  /'
fi
echo ""

# ── Now build the cart ──────────────────────────────────────────
# Tell scripts/build not to rebuild the engine — we just did it clean.
export REACTJIT_SKIP_ENGINE_BUILD=1
exec ./scripts/build "$@"
