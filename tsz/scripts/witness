#!/bin/bash
# Witness — record and replay human-verified interactions for regression testing.
#
# Usage:
#   ./scripts/witness record carts/my-cart.tsz     # build + run, record interactions
#   ./scripts/witness replay carts/my-cart.tsz     # build + run, replay and verify
#   ./scripts/witness replay-all                   # replay entire witness catalog
#   ./scripts/witness list                         # list all witness files
#   ./scripts/witness status                       # show pass/fail for each witness
#
# Record mode: builds the cart normally, runs with ZIGOS_WITNESS=record.
# You interact with the app — every click is recorded with its semantic target
# and state snapshot. Close the window to save.
#
# Replay mode: builds the cart, runs with ZIGOS_WITNESS=replay.
# The witness file drives the app — clicks are replayed by finding the same
# nodes semantically, state is compared at each step. Exits 0/1.

set -euo pipefail
cd "$(dirname "$0")/.."

WITNESS_DIR="witnesses"
DB="conformance.db"

# Ensure witness tables exist
ensure_db() {
    [ -f "$DB" ] || return
    sqlite3 "$DB" ".timeout 5000" \
        "CREATE TABLE IF NOT EXISTS witness_replays (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            test_name   TEXT    NOT NULL,
            replayed_at TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
            status      TEXT    NOT NULL,
            passed      INTEGER NOT NULL,
            total       INTEGER NOT NULL,
            source_sha  TEXT
        );
        CREATE TABLE IF NOT EXISTS witness_files (
            test_name   TEXT    PRIMARY KEY,
            content     BLOB    NOT NULL,
            file_sha    TEXT    NOT NULL,
            recorded_at TEXT    NOT NULL,
            source_sha  TEXT,
            actions     INTEGER NOT NULL DEFAULT 0,
            nodes       INTEGER NOT NULL DEFAULT 0
        );" 2>/dev/null
}

usage() {
    echo "Usage: scripts/witness <command> [cart.tsz]"
    echo ""
    echo "Commands:"
    echo "  record <cart.tsz>   Build and run, recording interactions"
    echo "  replay <cart.tsz>   Build and replay witness, verify state"
    echo "  replay-all          Replay all witnesses in the catalog"
    echo "  list                List all witness files"
    echo "  status              Show pass/fail status for each witness"
    exit 1
}

if [ $# -lt 1 ]; then usage; fi

CMD="$1"
shift

cart_name() {
    basename "$1" .tsz
}

witness_file() {
    local name
    name=$(cart_name "$1")
    echo "$WITNESS_DIR/${name}.witness"
}

# ── Record ──────────────────────────────────────────────────────────────

do_record() {
    if [ $# -lt 1 ]; then
        echo "Usage: scripts/witness record <cart.tsz>"
        exit 1
    fi
    local cart="$1"
    local name
    name=$(cart_name "$cart")
    local wfile
    wfile=$(witness_file "$cart")

    echo "[witness] building $name..."
    ./scripts/build "$cart" 2>&1 | tail -3

    local binary="zig-out/bin/$name"
    if [ ! -x "$binary" ]; then
        echo "[witness] ERROR: binary not found at $binary"
        exit 1
    fi

    echo "[witness] recording — interact with the app, close window to save"
    echo ""

    ZIGOS_WITNESS=record \
    ZIGOS_WITNESS_FILE="$wfile" \
    "$binary" 2>&1

    if [ -f "$wfile" ]; then
        local actions
        actions=$(grep -c '^CLICK' "$wfile" 2>/dev/null || echo "0")
        local nodes
        nodes=$(grep '^TREE' "$wfile" 2>/dev/null | head -1 | awk '{print $2}')
        nodes="${nodes:-0}"
        echo ""
        echo "[witness] saved: $wfile ($actions actions, $nodes tree nodes)"

        # Store in DB as SSoT
        ensure_db
        if [ -f "$DB" ]; then
            local file_sha
            file_sha=$(sha256sum "$wfile" | cut -c1-64)
            local source_sha
            source_sha=$(sha256sum "$cart" 2>/dev/null | cut -c1-64 || echo "unknown")
            local NOW
            NOW=$(date '+%Y-%m-%d %I:%M:%S %p')
            local safe_name
            safe_name=$(printf '%s' "$name" | sed "s/'/''/g")

            # Store file content as hex blob
            sqlite3 "$DB" ".timeout 5000" \
                "INSERT OR REPLACE INTO witness_files (test_name, content, file_sha, recorded_at, source_sha, actions, nodes)
                 VALUES ('$safe_name', X'$(xxd -p "$wfile" | tr -d '\n')', '$file_sha', '$NOW', '$source_sha', $actions, ${nodes:-0});"
            echo "[witness] stored in conformance.db (sha: ${file_sha:0:16}...)"
        fi
    else
        echo "[witness] WARNING: no witness file created (no interactions recorded?)"
    fi
}

# ── Restore from DB ─────────────────────────────────────────────────────

restore_from_db() {
    local rname="$1"
    local rfile="$2"
    local safe_name
    safe_name=$(printf '%s' "$rname" | sed "s/'/''/g")
    sqlite3 "$DB" ".timeout 5000" \
        "SELECT writefile('$rfile', content) FROM witness_files WHERE test_name='$safe_name';" 2>/dev/null
    if [ -f "$rfile" ]; then
        echo "[witness] restored $rfile from DB"
    else
        echo "[witness] ERROR: restore failed"
    fi
}

# ── Replay ──────────────────────────────────────────────────────────────

do_replay() {
    if [ $# -lt 1 ]; then
        echo "Usage: scripts/witness replay <cart.tsz>"
        exit 1
    fi
    local cart="$1"
    local name
    name=$(cart_name "$cart")
    local wfile
    wfile=$(witness_file "$cart")

    ensure_db

    if [ ! -f "$wfile" ]; then
        # Try to restore from DB
        if [ -f "$DB" ]; then
            local safe_name
            safe_name=$(printf '%s' "$name" | sed "s/'/''/g")
            local has_db
            has_db=$(sqlite3 "$DB" "SELECT COUNT(*) FROM witness_files WHERE test_name='$safe_name';" 2>/dev/null || echo "0")
            if [ "$has_db" -gt 0 ]; then
                echo "[witness] disk file missing — restoring from DB..."
                restore_from_db "$name" "$wfile"
            else
                echo "[witness] no witness file for $name (not on disk or in DB)"
                return 1
            fi
        else
            echo "[witness] no witness file for $name ($wfile)"
            return 1
        fi
    fi

    # Tamper check: compare disk file hash against DB SSoT
    if [ -f "$DB" ]; then
        local safe_name
        safe_name=$(printf '%s' "$name" | sed "s/'/''/g")
        local db_sha
        db_sha=$(sqlite3 "$DB" "SELECT file_sha FROM witness_files WHERE test_name='$safe_name';" 2>/dev/null || true)
        if [ -n "$db_sha" ]; then
            local disk_sha
            disk_sha=$(sha256sum "$wfile" | cut -c1-64)
            if [ "$disk_sha" != "$db_sha" ]; then
                echo "[witness] TAMPER DETECTED: $wfile differs from DB SSoT"
                echo "  disk: ${disk_sha:0:16}..."
                echo "  db:   ${db_sha:0:16}..."
                echo "  Restoring from DB..."
                restore_from_db "$name" "$wfile"
            fi
        fi
    fi

    echo -n "[$name] building... "
    if ! ./scripts/build "$cart" >/dev/null 2>&1; then
        echo "BUILD_FAIL"
        return 1
    fi

    local binary="zig-out/bin/$name"
    if [ ! -x "$binary" ]; then
        echo "NO_BINARY"
        return 1
    fi

    echo "replaying..."
    echo ""

    # Run and capture output + exit code
    local tmpout="/tmp/witness_replay_$$"
    ZIGOS_HEADLESS=1 \
    ZIGOS_WITNESS=replay \
    ZIGOS_WITNESS_FILE="$wfile" \
    timeout -s KILL 5 "$binary" >"$tmpout" 2>&1 || true

    # Show the witness replay section (everything between REPLAY and end)
    sed -n '/WITNESS REPLAY/,/WITNESS RESULT/p' "$tmpout"

    # Get pass/fail from result
    local exit_code=0
    local passed=0
    local total=0
    local status="crash"
    if grep -q "WITNESS RESULT" "$tmpout"; then
        passed=$(grep "WITNESS RESULT" "$tmpout" | grep -oP '\d+(?=/)')
        total=$(grep "WITNESS RESULT" "$tmpout" | grep -oP '(?<=/)\d+')
        if [ "$passed" = "$total" ]; then
            status="pass"
        else
            status="fail"
            exit_code=1
        fi
    else
        echo "[witness] no result — app may have crashed"
        tail -5 "$tmpout"
        exit_code=1
    fi

    # Record in conformance.db
    local CONF_DB="conformance.db"
    if [ -f "$CONF_DB" ]; then
        local safe_name
        safe_name=$(printf '%s' "$name" | sed "s/'/''/g")
        local NOW
        NOW=$(date '+%Y-%m-%d %I:%M:%S %p')
        local source_sha
        source_sha=$(sha256sum "$cart" 2>/dev/null | cut -c1-64 || echo "unknown")
        sqlite3 "$CONF_DB" ".timeout 5000" \
            "CREATE TABLE IF NOT EXISTS witness_replays (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                test_name   TEXT    NOT NULL,
                replayed_at TEXT    NOT NULL DEFAULT (strftime('%Y-%m-%d %I:%M:%S %p', 'now', 'localtime')),
                status      TEXT    NOT NULL,
                passed      INTEGER NOT NULL,
                total       INTEGER NOT NULL,
                source_sha  TEXT
            );
            INSERT INTO witness_replays (test_name, replayed_at, status, passed, total, source_sha)
            VALUES ('$safe_name', '$NOW', '$status', $passed, $total, '$source_sha');"
    fi

    rm -f "$tmpout"
    echo ""
    return $exit_code
}

# ── Replay all ──────────────────────────────────────────────────────────

do_replay_all() {
    echo "=== Witness Replay All ==="
    echo ""

    local pass=0 fail=0 total=0 build_fail=0

    for wfile in "$WITNESS_DIR"/*.witness; do
        [ -f "$wfile" ] || continue
        total=$((total + 1))

        local name
        name=$(basename "$wfile" .witness)

        # Find the cart .tsz
        local cart
        cart=$(find carts/ -name "${name}.tsz" -not -name "*.script.tsz" -not -name "*.cls.tsz" 2>/dev/null | head -1)
        if [ -z "$cart" ]; then
            echo "[$name] SKIP — no matching .tsz"
            continue
        fi

        if do_replay "$cart"; then
            pass=$((pass + 1))
        else
            fail=$((fail + 1))
        fi
    done

    echo ""
    echo "=== Summary ==="
    echo "Total: $total | Pass: $pass | Fail: $fail"
    echo ""

    if [ "$fail" -gt 0 ]; then
        exit 1
    fi
}

# ── List ────────────────────────────────────────────────────────────────

do_list() {
    echo "=== Witness Catalog ==="
    echo ""
    local count=0
    for wfile in "$WITNESS_DIR"/*.witness; do
        [ -f "$wfile" ] || continue
        count=$((count + 1))
        local name
        name=$(basename "$wfile" .witness)
        local actions
        actions=$(grep -c '^CLICK' "$wfile" 2>/dev/null || echo "0")
        local slots
        slots=$(grep '^SLOTS' "$wfile" 2>/dev/null | awk '{print $2}' || echo "?")
        printf "  %-40s %3s actions  %3s slots\n" "$name" "$actions" "$slots"
    done

    if [ "$count" -eq 0 ]; then
        echo "  (no witnesses recorded yet)"
        echo ""
        echo "  Record one:  ./scripts/witness record carts/conformance/d01.tsz"
    fi
    echo ""
    echo "Total: $count witnesses"
}

# ── Status ──────────────────────────────────────────────────────────────

do_status() {
    echo "=== Witness Status ==="
    echo ""
    printf "%-40s %-10s %s\n" "Cart" "Status" "Details"
    printf "%-40s %-10s %s\n" "----" "------" "-------"

    for wfile in "$WITNESS_DIR"/*.witness; do
        [ -f "$wfile" ] || continue
        local name
        name=$(basename "$wfile" .witness)
        local actions
        actions=$(grep -c '^CLICK' "$wfile" 2>/dev/null || echo "0")

        # Check if cart exists
        local cart
        cart=$(find carts/ -name "${name}.tsz" -not -name "*.script.tsz" -not -name "*.cls.tsz" 2>/dev/null | head -1)
        if [ -z "$cart" ]; then
            printf "%-40s %-10s %s\n" "$name" "ORPHAN" "no .tsz found"
            continue
        fi

        printf "%-40s %-10s %s\n" "$name" "RECORDED" "${actions} actions"
    done
    echo ""
}

# ── Dispatch ────────────────────────────────────────────────────────────

do_purge() {
    if [ $# -lt 1 ]; then
        echo "Usage: scripts/witness purge <name>    # remove one test's witness data"
        echo "       scripts/witness purge --all     # remove ALL witness data"
        exit 1
    fi
    ensure_db
    if [ "$1" = "--all" ]; then
        echo "[witness] purging ALL witness data..."
        sqlite3 "$DB" ".timeout 5000" \
            "DELETE FROM witness_replays;
             DELETE FROM witness_files;" 2>/dev/null
        rm -f "$WITNESS_DIR"/*.witness
        echo "[witness] done — all witness files and DB entries removed"
    else
        local name="$1"
        local safe_name
        safe_name=$(printf '%s' "$name" | sed "s/'/''/g")
        sqlite3 "$DB" ".timeout 5000" \
            "DELETE FROM witness_replays WHERE test_name='$safe_name';
             DELETE FROM witness_files WHERE test_name='$safe_name';" 2>/dev/null
        rm -f "$WITNESS_DIR/${name}.witness"
        echo "[witness] purged: $name (DB entries + disk file removed)"
    fi
}

do_restore() {
    if [ $# -lt 1 ]; then
        echo "Usage: scripts/witness restore <name>"
        echo "  Restores witness file from DB to disk."
        echo "  Use 'restore --all' to restore all witness files."
        exit 1
    fi
    ensure_db
    if [ "$1" = "--all" ]; then
        echo "[witness] restoring all witness files from DB..."
        sqlite3 "$DB" ".timeout 5000" \
            "SELECT test_name FROM witness_files ORDER BY test_name;" 2>/dev/null | while read -r rname; do
            rfile="$WITNESS_DIR/${rname}.witness"
            restore_from_db "$rname" "$rfile"
        done
        echo "[witness] done"
    else
        local name="$1"
        local wfile="$WITNESS_DIR/${name}.witness"
        restore_from_db "$name" "$wfile"
    fi
}

case "$CMD" in
    record)     do_record "$@" ;;
    replay)     do_replay "$@" ;;
    replay-all) do_replay_all ;;
    restore)    do_restore "$@" ;;
    purge)      do_purge "$@" ;;
    list)       do_list ;;
    status)     do_status ;;
    *)          usage ;;
esac
