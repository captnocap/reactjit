#!/bin/bash
# Build every .tsz entry point in carts/conformance/ to baseline the conformance report.
# Runs each through scripts/build so results are recorded in conformance.db.
#
# Usage:
#   ./scripts/build-all-conformance           # all lanes
#   ./scripts/build-all-conformance mixed     # one lane
#   ./scripts/build-all-conformance soup chad # specific lanes
#
# Skips non-entry files (.c.tsz, .cls.tsz, .script.tsz, .mod.tsz, etc.)
# Logs results to /tmp/conformance-build.log

set -uo pipefail
cd "$(dirname "$0")/.."

LOG="/tmp/conformance-build.log"
echo "=== Conformance build started: $(date) ===" > "$LOG"

LANES=("$@")
if [ ${#LANES[@]} -eq 0 ]; then
  LANES=(mixed chad soup http ipc lscript socks5 ws wpt-flex zscript)
fi

PASS=0
FAIL=0
SKIP=0
TOTAL=0

for lane in "${LANES[@]}"; do
  LANE_DIR="carts/conformance/$lane"
  if [ ! -d "$LANE_DIR" ]; then
    echo "Lane not found: $lane" | tee -a "$LOG"
    continue
  fi

  echo "" | tee -a "$LOG"
  echo "━━━ Lane: $lane ━━━" | tee -a "$LOG"

  # Find all .tsz files, skip non-entry extensions
  while IFS= read -r tsz; do
    # Skip non-entry files
    case "$tsz" in
      *.c.tsz|*.cls.tsz|*.tcls.tsz|*.script.tsz|*.mod.tsz|*.effects.tsz|*.glyphs.tsz|*.zscript.tsz|*.lscript.tsz|*_cmod.tsz|*_clsmod.tsz)
        SKIP=$((SKIP + 1))
        continue
        ;;
    esac

    TOTAL=$((TOTAL + 1))
    name=$(basename "$tsz" .tsz)

    echo -n "  [$TOTAL] $tsz ... " | tee -a "$LOG"

    if ./scripts/build "$tsz" >> "$LOG" 2>&1; then
      echo "PASS" | tee -a "$LOG"
      PASS=$((PASS + 1))
    else
      echo "FAIL" | tee -a "$LOG"
      FAIL=$((FAIL + 1))
    fi
  done < <(find "$LANE_DIR" -name "*.tsz" | sort)
done

echo "" | tee -a "$LOG"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" | tee -a "$LOG"
echo "TOTAL: $TOTAL  PASS: $PASS  FAIL: $FAIL  SKIPPED: $SKIP" | tee -a "$LOG"
echo "Finished: $(date)" | tee -a "$LOG"
echo "Full log: $LOG"
