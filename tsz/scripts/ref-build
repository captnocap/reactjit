#!/bin/bash
# Run the FROZEN reference compiler and rename its output so it doesn't stomp other builds.
# Usage: ./scripts/ref-build carts/conformance/d01_nested_maps.tsz
# Output: ref_d01_nested_maps.zig (NOT generated_app.zig)

set -euo pipefail
cd "$(dirname "$0")/.."

if [ -z "${1:-}" ]; then
    echo "Usage: scripts/ref-build <cart.tsz>"
    exit 1
fi

CART="$1"
NAME=$(basename "$CART" .tsz)

# Lock so parallel workers don't stomp each other
LOCKFILE="/tmp/tsz-ref-build.lock"
exec 200>"$LOCKFILE"
flock 200

../bin/tsz build "$CART" 2>/dev/null
mv generated_app.zig "ref_${NAME}.zig"

exec 200>&-

echo "[ref] ref_${NAME}.zig"
