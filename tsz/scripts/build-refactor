#!/bin/bash
# Build a .tsz cart with the isolated Smith refactor compiler.
#
# Usage:
#   ./scripts/build-refactor carts/conformance/s01a_counter.tsz
#   ./scripts/build-refactor carts/conformance/s01a_counter.tsz --debug

set -euo pipefail
cd "$(dirname "$0")/.."

POSITIONAL=()
for arg in "$@"; do
    case "$arg" in
        --fast) ;;
        *) POSITIONAL+=("$arg") ;;
    esac
done

if [ "${#POSITIONAL[@]}" -eq 0 ]; then
    echo "Usage: scripts/build-refactor <cart.tsz> [--debug]"
    exit 1
fi

VELLO_LIB="../deps/vello_ffi/target/release/libvello_ffi_stripped.a"
if [ ! -f "$VELLO_LIB" ]; then
    echo "[vello_ffi] stripped lib missing — rebuilding..."
    bash ../deps/vello_ffi/build.sh
fi

CART="${POSITIONAL[0]}"
NAME=$(basename "$CART" .tsz)
OUT_NAME="${NAME}_refactor"
OPT="${POSITIONAL[1]:---release}"
GEN_MONOLITH="refactor_generated_${NAME}.zig"
GEN="$GEN_MONOLITH"
GEN_DIR="refactor_generated_${NAME}"

if [ "$OPT" = "--debug" ]; then
    ZIG_OPT=""
else
    ZIG_OPT="-Doptimize=ReleaseFast"
fi

echo "[$OUT_NAME] forge-refactor..."
./zig-out/bin/forge-refactor build --fast "$CART" 2>&1

if [ -f "$GEN" ] && grep -q '^__SPLIT_OUTPUT__$' "$GEN" 2>/dev/null; then
    echo "[$OUT_NAME] forge-refactor returned split markers in monolith output — retrying with --single..."
    ./zig-out/bin/forge-refactor build --fast --single "$CART" 2>&1
fi

HAS_SPLIT_DIR=0
if [ -d "$GEN_DIR" ] && [ -f "$GEN_DIR/app.zig" ]; then
    HAS_SPLIT_DIR=1
fi

SPLIT_LINT=0
if [ "$HAS_SPLIT_DIR" -eq 1 ]; then
    GEN=$(mktemp /tmp/lint_refactor_XXXXXX.zig)
    cat "$GEN_DIR"/*.zig > "$GEN"
    SPLIT_LINT=1
fi

if grep -q "PREFLIGHT BLOCKED" "$GEN" 2>/dev/null; then
    echo "[$OUT_NAME] PREFLIGHT BLOCKED:"
    grep "FATAL:\|WARN:" "$GEN" 2>/dev/null | sed 's/^\/\/! /  /'
    echo "[$OUT_NAME] Fix the .tsz source errors above. Generated file: $GEN"
    if [ "$SPLIT_LINT" -eq 1 ]; then rm -f "$GEN"; fi
    exit 1
fi

LINT_FAIL=0
LINT_WARN=0

BAD_QUOTES=$(grep -n "'\w\w" "$GEN" 2>/dev/null | grep -v '^\s*[0-9]*:\s*\\\\' | grep -v 'lua_on_press' | grep -v 'js_on_press' | grep -v '^\s*[0-9]*:\s*//' | head -5 || true)
if [ -n "$BAD_QUOTES" ]; then
    echo "[$OUT_NAME] LINT FAIL: JS string leaked into Zig (single-quoted multi-char):"
    echo "$BAD_QUOTES"
    LINT_FAIL=1
fi

if grep -q '^const JS_LOGIC =' "$GEN" 2>/dev/null; then
    BAD_JS=$(sed -n '/^const JS_LOGIC =/,/^;$/p' "$GEN" | grep -v '^\s*\\\\' | grep -v '^const \|^;$' | head -5 || true)
    if [ -n "$BAD_JS" ]; then
        echo "[$OUT_NAME] LINT FAIL: raw JS leaked into JS_LOGIC Zig string:"
        echo "$BAD_JS"
        LINT_FAIL=1
    fi
fi

for MI in $(grep -oE '_map_inner_[0-9]+' "$GEN" 2>/dev/null | sort -u || true); do
    MAP_NUM=${MI#_map_inner_}
    SHARED=$(grep "$MI\[_i\].*&_arr_" "$GEN" 2>/dev/null | head -3 || true)
    if [ -n "$SHARED" ]; then
        echo "[$OUT_NAME] LINT WARN: $MI references shared static _arr_ arrays — map items will render identical content"
        LINT_WARN=1
    fi
done

if grep -q '__setObjArr' "$GEN" 2>/dev/null; then
    echo "[$OUT_NAME] LINT WARN: __setObjArr in generated code — verify LuaJIT registration"
    LINT_WARN=1
fi

if [ "$LINT_FAIL" -eq 1 ]; then
    echo "[$OUT_NAME] BLOCKED — fix smith-refactor before building. Generated file: $GEN"
    exit 1
fi

if [ "$LINT_WARN" -eq 1 ]; then
    echo "[$OUT_NAME] warnings above — building anyway but expect visual bugs"
fi

if [ "$SPLIT_LINT" -eq 1 ]; then rm -f "$GEN"; fi

if [ "$HAS_SPLIT_DIR" -eq 1 ]; then
    echo "[$OUT_NAME] forge-refactor --single for stable link output..."
    ./zig-out/bin/forge-refactor build --fast --single "$CART" 2>&1
fi

APP_SOURCE="$GEN_MONOLITH"

# Build through Zig's native cart-fast path instead of the LuaJIT link shim.
CORE_ARCHIVE="zig-out/lib/libreactjit-core.a"
if [ "$OPT" != "--debug" ]; then
    echo "[$OUT_NAME] ensuring ReleaseFast core archive..."
    zig build core -Doptimize=ReleaseFast 2>&1
elif [ ! -f "$CORE_ARCHIVE" ]; then
    echo "[$OUT_NAME] core archive missing — building cached engine..."
    zig build core -Doptimize=ReleaseFast 2>&1
fi

echo "[$OUT_NAME] zig build..."
BUILD_CMD=(zig build cart-fast "-Dapp-source=$APP_SOURCE" "-Dapp-name=$OUT_NAME")
if [ "$OPT" != "--debug" ]; then
    BUILD_CMD+=("-Doptimize=ReleaseFast")
fi
"${BUILD_CMD[@]}" 2>&1

RAW_BIN="zig-out/bin/$OUT_NAME"
OS="$(uname -s)"

if [ -f "$RAW_BIN" ] && [ "$OPT" != "--debug" ]; then
    echo "[$OUT_NAME] packaging..."
    TMP_DIR="/tmp/tsz-dist-$OUT_NAME"
    LIB_DIR="$TMP_DIR/lib"
    rm -rf "$TMP_DIR"
    mkdir -p "$LIB_DIR"
    cp "$RAW_BIN" "$TMP_DIR/app.bin"

    LIB_COUNT=0

    if [ "$OS" = "Darwin" ]; then
        APP_BUNDLE="zig-out/bin/${OUT_NAME}.app"
        CONTENTS="$APP_BUNDLE/Contents"
        MACOS_DIR="$CONTENTS/MacOS"
        FW_DIR="$CONTENTS/Frameworks"
        rm -rf "$APP_BUNDLE"
        mkdir -p "$MACOS_DIR" "$FW_DIR"

        cp "$RAW_BIN" "$MACOS_DIR/$OUT_NAME"

        cat > "$CONTENTS/Info.plist" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>$OUT_NAME</string>
    <key>CFBundleIdentifier</key>
    <string>com.reactjit.$OUT_NAME</string>
    <key>CFBundleName</key>
    <string>$OUT_NAME</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
</dict>
</plist>
PLIST

        ENGINE_DYLIB="zig-out/lib/libreactjit-core.dylib"
        [ -f "$ENGINE_DYLIB" ] && cp "$ENGINE_DYLIB" "$FW_DIR/libreactjit-core.dylib"

        collect_dylibs() {
            for bin in "$@"; do
                otool -L "$bin" 2>/dev/null | tail -n +2 | awk '{print $1}' | while read -r lib_path; do
                    case "$lib_path" in
                        /usr/lib/*|/System/*|@rpath/*|@executable_path/*) continue ;;
                    esac
                    [ ! -f "$lib_path" ] && continue
                    lib_name=$(basename "$lib_path")
                    [ -f "$FW_DIR/$lib_name" ] && continue
                    cp "$lib_path" "$FW_DIR/$lib_name"
                    echo "$lib_name"
                done
            done
        }
        collect_dylibs "$MACOS_DIR/$OUT_NAME"
        [ -f "$ENGINE_DYLIB" ] && collect_dylibs "$FW_DIR/libreactjit-core.dylib"
        collect_dylibs "$FW_DIR"/*.dylib

        rewrite_dylib_paths() {
            local bin="$1"
            otool -L "$bin" 2>/dev/null | tail -n +2 | awk '{print $1}' | while read -r lib_path; do
                case "$lib_path" in
                    /usr/lib/*|/System/*|@rpath/*|@executable_path/*) continue ;;
                esac
                lib_name=$(basename "$lib_path")
                install_name_tool -change "$lib_path" "@executable_path/../Frameworks/$lib_name" "$bin" 2>/dev/null || true
            done
        }

        rewrite_dylib_paths "$MACOS_DIR/$OUT_NAME"
        install_name_tool -change "@rpath/libreactjit-core.dylib" "@executable_path/../Frameworks/libreactjit-core.dylib" "$MACOS_DIR/$OUT_NAME" 2>/dev/null || true
        install_name_tool -add_rpath "@executable_path/../Frameworks" "$MACOS_DIR/$OUT_NAME" 2>/dev/null || true

        for dylib in "$FW_DIR"/*.dylib; do
            [ -f "$dylib" ] || continue
            lib_name=$(basename "$dylib")
            install_name_tool -id "@executable_path/../Frameworks/$lib_name" "$dylib" 2>/dev/null || true
            rewrite_dylib_paths "$dylib"
        done

        codesign --force --sign - --deep "$APP_BUNDLE" 2>/dev/null || true

        LIB_COUNT=$(find "$FW_DIR" -name '*.dylib' | wc -l | tr -d ' ')
        SIZE_MB=$(du -sm "$APP_BUNDLE" | cut -f1)
        echo "[$OUT_NAME] packaged ${SIZE_MB}MB .app bundle ($LIB_COUNT libs)"
        rm -rf "$TMP_DIR"
    else
        ENGINE_SO="zig-out/lib/libreactjit-core.so"
        [ -f "$ENGINE_SO" ] && cp "$(readlink -f "$ENGINE_SO")" "$LIB_DIR/libreactjit-core.so"

        LDD_TMP=$(mktemp)
        ldd "$RAW_BIN" >> "$LDD_TMP" 2>/dev/null
        [ -f "$ENGINE_SO" ] && ldd "$ENGINE_SO" >> "$LDD_TMP" 2>/dev/null
        while IFS= read -r line; do
            case "$line" in *linux-vdso*) continue ;; esac
            lib_path=$(echo "$line" | sed -n 's/.* => \([^ ]*\) .*/\1/p')
            [ -z "$lib_path" ] && continue
            [ ! -f "$lib_path" ] && continue
            real_path=$(readlink -f "$lib_path")
            soname=$(echo "$line" | sed 's/^ *//;s/ *=>.*//')
            [ -f "$LIB_DIR/$soname" ] && continue
            cp "$real_path" "$LIB_DIR/$soname"
            LIB_COUNT=$((LIB_COUNT + 1))
        done < "$LDD_TMP"
        rm -f "$LDD_TMP"

        LD_LINUX=$(readlink -f /lib64/ld-linux-x86-64.so.2 2>/dev/null)
        if [ -n "$LD_LINUX" ] && [ -f "$LD_LINUX" ]; then
            cp "$LD_LINUX" "$LIB_DIR/ld-linux-x86-64.so.2"

            cat > "$TMP_DIR/run" << 'LAUNCHER'
#!/bin/sh
DIR="$(cd "$(dirname "$0")" && pwd)"
exec "$DIR/lib/ld-linux-x86-64.so.2" --inhibit-cache --library-path "$DIR/lib" "$DIR/app.bin" "$@"
LAUNCHER
            chmod +x "$TMP_DIR/run"

            TARBALL="/tmp/tsz-${OUT_NAME}-payload.tar.gz"
            (cd "$TMP_DIR" && tar czf "$TARBALL" .)

            cat > "$RAW_BIN" << HEADER
#!/bin/sh
set -e
APP_DIR=\${XDG_CACHE_HOME:-\$HOME/.cache}/tsz-$OUT_NAME
SIG=\$(md5sum "\$0" 2>/dev/null | cut -c1-8 || cksum "\$0" | cut -d" " -f1)
CACHE="\$APP_DIR/\$SIG"
if [ ! -f "\$CACHE/.ready" ]; then
  rm -rf "\$APP_DIR"
  mkdir -p "\$CACHE"
  SKIP=\$(awk '/^__ARCHIVE__\$/{print NR + 1; exit}' "\$0")
  tail -n+"\$SKIP" "\$0" | tar xz -C "\$CACHE"
  touch "\$CACHE/.ready"
fi
exec "\$CACHE/run" "\$@"
__ARCHIVE__
HEADER
            cat "$TARBALL" >> "$RAW_BIN"
            chmod +x "$RAW_BIN"

            SIZE_MB=$(du -m "$RAW_BIN" | cut -f1)
            echo "[$OUT_NAME] packaged ${SIZE_MB}MB self-extracting ($LIB_COUNT libs)"
            rm -rf "$TMP_DIR" "$TARBALL"
        else
            echo "[$OUT_NAME] WARNING: ld-linux not found, skipping packaging"
            rm -rf "$TMP_DIR"
        fi
    fi
fi

echo "[$OUT_NAME] done → zig-out/bin/$OUT_NAME"
