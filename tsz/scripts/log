#!/bin/bash
# Run any app with full logging to /tmp/zigos.log
#
# Usage:
#   scripts/log Storybook
#   scripts/log d01_nested_maps
#   scripts/log zig-out/bin/Storybook
#
# Ctrl+C to stop. Log is at /tmp/zigos.log — grep it freely.

set -euo pipefail
cd "$(dirname "$0")/.."

if [ $# -eq 0 ]; then
    echo "Usage: scripts/log <app-name-or-path>"
    exit 1
fi

ARG="$1"

# Resolve binary path
if [ -f "$ARG" ]; then
    BIN="$ARG"
elif [ -f "zig-out/bin/$ARG" ]; then
    BIN="zig-out/bin/$ARG"
else
    echo "Not found: $ARG (tried $ARG and zig-out/bin/$ARG)"
    exit 1
fi

LOG=/tmp/zigos.log
rm -f "$LOG"

echo "Logging to $LOG"
echo "Ctrl+C to stop, then: grep <pattern> $LOG"
echo ""

ZIGOS_LOG=all ZIGOS_LOG_FILE="$LOG" LD_LIBRARY_PATH=zig-out/lib "$BIN" || true

echo ""
echo "Log: $LOG ($(wc -l < "$LOG") lines)"
