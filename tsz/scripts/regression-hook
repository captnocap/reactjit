#!/bin/bash
# Post-commit regression hook.
# Fires ONLY when compiler or engine files changed in the commit.
# Delegates to `ledger run all` for builds, then diffs against the prior baseline.
#
# Install:  ln -sf ../../tsz/scripts/regression-hook .git/hooks/post-commit
# Manual:   scripts/regression-hook [commit-sha]
#
# Output is a compact diff: newly regressed, still broken, newly fixed, stable.

set -euo pipefail
cd "$(dirname "$0")/.."

DB="conformance.db"
LEDGER="scripts/ledger"

# ── Which commit are we checking? ─────────────────────────────

COMMIT="${1:-HEAD}"
COMMIT_SHA=$(git rev-parse --short "$COMMIT" 2>/dev/null || echo "manual")
COMMIT_MSG=$(git log -1 --format='%s' "$COMMIT" 2>/dev/null || echo "manual run")

# ── Should we run? Only if compiler/engine paths changed ──────

TRIGGER_PATHS=(
    "compiler/"
    "framework/"
    "runtime/"
    "scripts/build"
    "scripts/link.lua"
    "*.zig"
)

changed_files=$(git diff-tree --no-commit-id --name-only -r "$COMMIT" 2>/dev/null || echo "")

should_run=0
for pattern in "${TRIGGER_PATHS[@]}"; do
    if echo "$changed_files" | grep -q "^$pattern"; then
        should_run=1
        break
    fi
done

# Allow forced run
if [ "${FORCE:-0}" = "1" ]; then
    should_run=1
fi

if [ "$should_run" -eq 0 ]; then
    exit 0
fi

printf "\n"
printf "╔══════════════════════════════════════════════════════════╗\n"
printf "║  Regression scan: %-37s  ║\n" "$COMMIT_SHA"
printf "║  %-55s ║\n" "${COMMIT_MSG:0:55}"
printf "╚══════════════════════════════════════════════════════════╝\n"
printf "\n"

# ── Snapshot the current baseline (by id, not timestamp) ──────

BASELINE_PASS=$(sqlite3 "$DB" ".timeout 5000" "
    SELECT test_name FROM builds
    WHERE id IN (SELECT MAX(id) FROM builds GROUP BY test_name)
      AND status = 'compiled'
    ORDER BY test_name;
" 2>/dev/null || echo "")

BASELINE_FAIL=$(sqlite3 "$DB" ".timeout 5000" "
    SELECT test_name FROM builds
    WHERE id IN (SELECT MAX(id) FROM builds GROUP BY test_name)
      AND status != 'compiled'
    ORDER BY test_name;
" 2>/dev/null || echo "")

# ── Run the full conformance sweep via ledger ─────────────────
# Single source of truth: ledger handles building + db recording.

echo "Running conformance sweep via ledger..."
echo ""

if [ -x "$LEDGER" ]; then
    "$LEDGER" run all >/dev/null 2>&1 || true
else
    # Fallback: build each cart individually via scripts/build
    fail_count=0
    for f in $(find carts/conformance -name "*.tsz" \
        ! -name "*.script.tsz" ! -name "*.cls.tsz" \
        ! -name "*.mod.tsz" ! -name "*.c.tsz" -type f | sort); do
        scripts/build "$f" >/dev/null 2>&1 || true
        # Early abort on catastrophic failure
        fail_count=$((fail_count + 1))
        current_fails=$(sqlite3 "$DB" ".timeout 5000" "
            SELECT COUNT(*) FROM builds
            WHERE id IN (SELECT MAX(id) FROM builds GROUP BY test_name)
              AND status != 'compiled';" 2>/dev/null || echo "0")
        if [ "$current_fails" -gt 50 ] && [ "$fail_count" -gt 60 ]; then
            echo "Catastrophic failure ($current_fails tests failing), aborting early."
            break
        fi
    done
fi

# ── Query new state from db ───────────────────────────────────

NEW_STATE=$(sqlite3 "$DB" ".timeout 5000" "
    SELECT test_name, status, binary_size, substr(error_log, 1, 120)
    FROM builds
    WHERE id IN (SELECT MAX(id) FROM builds GROUP BY test_name)
    ORDER BY test_name;
" 2>/dev/null || echo "")

# ── Compute diff ──────────────────────────────────────────────

newly_regressed=()
still_broken=()
newly_fixed=()
bloated=()
stable=0
total=0

while IFS='|' read -r name status bsize err; do
    [ -z "$name" ] && continue
    total=$((total + 1))

    was_passing=$(echo "$BASELINE_PASS" | grep -c "^${name}$" || true)
    was_failing=$(echo "$BASELINE_FAIL" | grep -c "^${name}$" || true)

    if [ "$status" = "bloated" ]; then
        bloated+=("$name")
    elif [ "$status" = "compiled" ]; then
        # Check for bloat (>30% growth)
        prev_size=$(sqlite3 "$DB" ".timeout 5000" "
            SELECT binary_size FROM builds
            WHERE test_name = '${name//\'/\'\'}' AND status = 'compiled' AND binary_size > 0
              AND id < (SELECT MAX(id) FROM builds WHERE test_name = '${name//\'/\'\'}')
            ORDER BY id DESC LIMIT 1;" 2>/dev/null || echo "0")
        prev_size="${prev_size:-0}"
        if [ "$prev_size" -gt 0 ] && [ "${bsize:-0}" -gt 0 ]; then
            growth=$(awk "BEGIN {printf \"%d\", (($bsize - $prev_size) * 100) / $prev_size}")
            if [ "$growth" -gt 30 ]; then
                bloated+=("$name (+${growth}%)")
            fi
        fi

        if [ "$was_failing" -gt 0 ]; then
            newly_fixed+=("$name")
        else
            stable=$((stable + 1))
        fi
    else
        if [ "$was_passing" -gt 0 ]; then
            # Include error context for regressions
            err_line=$(echo "$err" | grep -oP 'error:.*' | head -1)
            newly_regressed+=("$name ($status)${err_line:+: $err_line}")
        else
            still_broken+=("$name")
        fi
    fi
done <<< "$NEW_STATE"

# ── Report ────────────────────────────────────────────────────

echo ""
echo "┌──────────────────────────────────────────────────────────┐"
printf "│  Regression Report for %-33s  │\n" "$COMMIT_SHA"
printf "│  %d tests scanned%*s│\n" "$total" $((39 - ${#total})) ""
echo "├──────────────────────────────────────────────────────────┤"
printf "│  %3d newly regressed                                    │\n" "${#newly_regressed[@]}"
printf "│  %3d bloated (>30%% size jump)                           │\n" "${#bloated[@]}"
printf "│  %3d still broken from before                           │\n" "${#still_broken[@]}"
printf "│  %3d newly compiling                                    │\n" "${#newly_fixed[@]}"
printf "│  %3d unchanged/stable                                   │\n" "$stable"
echo "└──────────────────────────────────────────────────────────┘"

if [ ${#newly_regressed[@]} -gt 0 ]; then
    echo ""
    echo "REGRESSIONS:"
    for t in "${newly_regressed[@]}"; do
        echo "  - $t"
    done
fi

if [ ${#bloated[@]} -gt 0 ]; then
    echo ""
    echo "BLOATED (compiled but suspiciously large):"
    for t in "${bloated[@]}"; do
        echo "  ! $t"
    done
fi

if [ ${#newly_fixed[@]} -gt 0 ]; then
    echo ""
    echo "NEWLY PASSING:"
    for t in "${newly_fixed[@]}"; do
        echo "  + $t"
    done
fi

# Exit non-zero if there are regressions or bloat
if [ ${#newly_regressed[@]} -gt 0 ] || [ ${#bloated[@]} -gt 0 ]; then
    echo ""
    echo "${#newly_regressed[@]} regression(s), ${#bloated[@]} bloat(s). Use 'scripts/ledger diff <test>' to investigate."
    exit 1
fi

exit 0
