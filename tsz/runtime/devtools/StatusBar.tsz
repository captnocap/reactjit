import { Toolbar, ToolbarLabel, ToolbarDim } from './style.cls';

function StatusBar({ fps, layoutMs, paintMs, nodeCount }) {
  return (
    <C.Toolbar>
      <C.ToolbarLabel>{`FPS: ${fps}`}</C.ToolbarLabel>
      <C.ToolbarDim>{`Layout: ${layoutMs}ms`}</C.ToolbarDim>
      <C.ToolbarDim>{`Paint: ${paintMs}ms`}</C.ToolbarDim>
      <C.ToolbarDim>{`Nodes: ${nodeCount}`}</C.ToolbarDim>
      <C.ToolbarDim>F12 close</C.ToolbarDim>
    </C.Toolbar>
  );
}
