// net/manager.tsz — Network Manager — connection registry with auto-reconnect and .onion routing
//
// Port of love2d/lua/network.lua. Central registry for WebSocket connections
// with automatic reconnection backoff and Tor proxy detection for .onion hosts.

const websocket = @import("websocket.zig");
const socks5 = @import("socks5.zig");

// ── Configuration ────────────────────────────────────────────────────────

const MAX_CONNECTIONS = 32;
const MAX_URL = 512;
const MAX_MSG = 65536;
const MAX_EVENTS = 64;
const INITIAL_BACKOFF_MS: u32 = 1000;
const MAX_BACKOFF_MS: u32 = 30000;
const DEFAULT_TOR_PROXY_PORT: u16 = 9050;

// ── Public types ─────────────────────────────────────────────────────────

export interface ConnectOpts {
  reconnect: boolean;
  torProxyPort: u16;
}

export enum NetEventType { connected, message, closed, err, reconnecting }

export interface NetEvent {
  id: u32;
  eventType: NetEventType;
  data: [MAX_MSG]u8;
  dataLen: usize;
}

export function netEventDataSlice(self: *const NetEvent): string {
  return self.data[0..self.dataLen];
}

enum ConnStatus { connecting, tunneling, open, reconnecting, closed }

enum ConnectResult { none, success, failed }

interface Connection {
  active: boolean;
  id: u32;
  ws: ?websocket.WebSocket;
  pendingWs: ?websocket.WebSocket;
  connectDone: boolean;
  connectOk: boolean;
  generation: u32;
  mutex: std.Thread.Mutex;
  url: [MAX_URL]u8;
  urlLen: usize;
  host: [256]u8;
  hostLen: usize;
  port: u16;
  path: [256]u8;
  pathLen: usize;
  status: ConnStatus;
  reconnect: boolean;
  backoffMs: u32;
  nextRetryTick: u32;
  isOnion: boolean;
  torProxyPort: u16;
}

interface ConnectParams {
  conn: *Connection;
  gen: u32;
  host: [256]u8;
  hostLen: usize;
  port: u16;
  path: [256]u8;
  pathLen: usize;
  isOnion: boolean;
  torProxyPort: u16;
}

// ── Module state ─────────────────────────────────────────────────────────

let connections: [MAX_CONNECTIONS]Connection;
let event_count: usize = 0;
let active_workers: u32 = 0;
let initialized: boolean = false;

// ── Public API ───────────────────────────────────────────────────────────

export function init() {
  if (initialized) return;
  for (let i: usize = 0; i < MAX_CONNECTIONS; i++) {
    connections[i].active = false;
    connections[i].mutex = .{};
    connections[i].generation = 0;
  }
  event_count = 0;
  initialized = true;
}

/// Open a WebSocket connection.
export function connect(id: u32, url: string, opts: ConnectOpts) {
  const slot = findSlot() orelse return;
  let conn = &connections[slot];
  conn.pendingWs = null;
  conn.connectDone = false;
  conn.connectOk = false;
  conn.ws = null;
  conn.active = true;
  conn.id = id;
  conn.status = .connecting;
  conn.reconnect = opts.reconnect;
  conn.backoffMs = INITIAL_BACKOFF_MS;
  conn.torProxyPort = opts.torProxyPort;

  const ulen = @min(url.len, MAX_URL);
  @memcpy(conn.url[0..ulen], url[0..ulen]);
  conn.urlLen = ulen;

  parseUrl(conn, url[0..ulen]);
  conn.isOnion = isOnion(conn.host[0..conn.hostLen]);
  startConnection(conn);
}

/// Send data on a connection.
export function sendMsg(id: u32, data: string) {
  if (findById(id)) |conn| {
    if (conn.status === .open) {
      if (conn.ws) |*ws| {
        ws.send(data) catch {};
      }
    }
  }
}

/// Close a connection.
export function closeConn(id: u32) {
  if (findById(id)) |conn| {
    conn.mutex.lock();
    conn.reconnect = false;
    conn.generation +%= 1;
    if (conn.pendingWs) |*pws| pws.shutdown();
    conn.pendingWs = null;
    conn.connectDone = false;
    conn.connectOk = false;
    if (conn.ws) |*ws| ws.shutdown();
    conn.ws = null;
    conn.status = .closed;
    conn.active = false;
    conn.mutex.unlock();
  }
}

/// Poll for events. Call once per frame. Returns count of events.
export function poll(out: NetEvent[]): usize {
  event_count = 0;

  for (let ci: usize = 0; ci < MAX_CONNECTIONS; ci++) {
    if (!connections[ci].active) continue;
    let conn = &connections[ci];

    // Check for connect worker completion
    let connectResult: ConnectResult = .none;
    conn.mutex.lock();
    if (conn.connectDone) {
      conn.connectDone = false;
      if (conn.connectOk) {
        conn.ws = conn.pendingWs;
        conn.pendingWs = null;
        conn.status = .connecting;
        connectResult = .success;
      } else {
        connectResult = .failed;
      }
    }
    conn.mutex.unlock();

    if (connectResult === .failed) {
      handleDisconnect(conn);
      continue;
    }

    switch (conn.status) {
      case .open, .connecting:
        if (conn.ws) |*ws| {
          let safety: u32 = 0;
          while (safety < 100) {
            if (ws.update()) |event| {
              switch (event) {
                case .open:
                  conn.status = .open;
                  conn.backoffMs = INITIAL_BACKOFF_MS;
                  pushEvent(out, conn.id, .connected, "");
                  break;
                case .message: |msg|
                  pushEvent(out, conn.id, .message, msg);
                  break;
                case .close: |cl|
                  pushEvent(out, conn.id, .closed, cl.reason);
                  handleDisconnect(conn);
                  break;
                case .err: |e|
                  pushEvent(out, conn.id, .err, e);
                  handleDisconnect(conn);
                  break;
              }
            } else {
              break;
            }
            safety += 1;
          }
        }
        break;
      case .reconnecting:
        const now = getTicks();
        if (now >= conn.nextRetryTick) {
          pushEvent(out, conn.id, .reconnecting, "");
          startConnection(conn);
        }
        break;
      case .closed, .tunneling: break;
    }
  }

  return @min(event_count, out.len);
}

/// Shutdown all connections.
export function destroy() {
  for (let i: usize = 0; i < MAX_CONNECTIONS; i++) {
    connections[i].mutex.lock();
    connections[i].generation +%= 1;
    if (connections[i].pendingWs) |*pws| pws.shutdown();
    connections[i].pendingWs = null;
    connections[i].connectDone = false;
    connections[i].connectOk = false;
    if (connections[i].active) {
      if (connections[i].ws) |*ws| ws.shutdown();
      connections[i].ws = null;
      connections[i].active = false;
    }
    connections[i].mutex.unlock();
  }
  // Best-effort wait for in-flight threads (max 5s)
  let waitCount: u32 = 0;
  while (@atomicLoad(u32, &active_workers, .seq_cst) > 0 && waitCount < 5000) {
    std.Thread.sleep(1_000_000);
    waitCount += 1;
  }
  initialized = false;
}

// ── Internal ─────────────────────────────────────────────────────────────

function findSlot(): ?usize {
  for (let i: usize = 0; i < MAX_CONNECTIONS; i++) {
    if (!connections[i].active) return i;
  }
  return null;
}

function findById(id: u32): ?*Connection {
  for (let i: usize = 0; i < MAX_CONNECTIONS; i++) {
    if (connections[i].active && connections[i].id == id) return &connections[i];
  }
  return null;
}

function startConnection(conn: *Connection) {
  let params: ConnectParams = undefined;
  params.conn = conn;
  params.gen = conn.generation;
  params.hostLen = conn.hostLen;
  params.port = conn.port;
  params.pathLen = conn.pathLen;
  params.isOnion = conn.isOnion;
  params.torProxyPort = conn.torProxyPort;
  @memcpy(params.host[0..conn.hostLen], conn.host[0..conn.hostLen]);
  @memcpy(params.path[0..conn.pathLen], conn.path[0..conn.pathLen]);

  conn.status = .connecting;
  _ = @atomicRmw(u32, &active_workers, .Add, 1, .seq_cst);
  _ = std.Thread.spawn(.{ stackSize: 1024 * 1024 }, connectWorker, .{params}) catch {
    _ = @atomicRmw(u32, &active_workers, .Sub, 1, .seq_cst);
    handleDisconnect(conn);
  };
}

function connectWorker(params: ConnectParams) {
  defer _ = @atomicRmw(u32, &active_workers, .Sub, 1, .seq_cst);

  const host = params.host[0..params.hostLen];
  const path = params.path[0..params.pathLen];
  const conn = params.conn;

  let newWs: ?websocket.WebSocket = null;

  if (params.isOnion) {
    const stream = socks5.connect("127.0.0.1", params.torProxyPort, host, params.port, null, null) catch {
      publishResult(conn, params.gen, null, false);
      return;
    };
    newWs = websocket.WebSocket.connectViaStream(stream, host, params.port, path) catch {
      stream.close();
      publishResult(conn, params.gen, null, false);
      return;
    };
  } else {
    newWs = websocket.WebSocket.connectTcp(host, params.port, path) catch {
      publishResult(conn, params.gen, null, false);
      return;
    };
  }

  publishResult(conn, params.gen, newWs, true);
}

function publishResult(conn: *Connection, expectedGen: u32, newWs: ?websocket.WebSocket, ok: boolean) {
  conn.mutex.lock();
  defer conn.mutex.unlock();
  if (conn.generation == expectedGen) {
    conn.pendingWs = newWs;
    conn.connectDone = true;
    conn.connectOk = ok;
  } else {
    if (newWs) |ws| {
      let wsCopy = ws;
      wsCopy.shutdown();
    }
  }
}

function handleDisconnect(conn: *Connection) {
  if (conn.ws) |*ws| ws.shutdown();
  conn.ws = null;
  if (conn.reconnect) {
    conn.status = .reconnecting;
    conn.nextRetryTick = getTicks() + conn.backoffMs;
    conn.backoffMs = @min(conn.backoffMs * 2, MAX_BACKOFF_MS);
  } else {
    conn.status = .closed;
    conn.active = false;
  }
}

function pushEvent(out: NetEvent[], id: u32, eventType: NetEventType, data: string) {
  if (event_count >= out.len) return;
  out[event_count].id = id;
  out[event_count].eventType = eventType;
  const dlen = @min(data.len, MAX_MSG);
  if (dlen > 0) @memcpy(out[event_count].data[0..dlen], data[0..dlen]);
  out[event_count].dataLen = dlen;
  event_count += 1;
}

function parseUrl(conn: *Connection, url: string) {
  let start: usize = 0;
  if (url.len > 5 && std.mem.eql(u8, url[0..5], "ws://")) {
    start = 5;
    conn.port = 80;
  } else if (url.len > 6 && std.mem.eql(u8, url[0..6], "wss://")) {
    start = 6;
    conn.port = 443;
  }

  let hostEnd = start;
  while (hostEnd < url.len && url[hostEnd] !== ':' && url[hostEnd] !== '/') {
    hostEnd += 1;
  }
  const hlen = hostEnd - start;
  @memcpy(conn.host[0..hlen], url[start..hostEnd]);
  conn.hostLen = hlen;

  if (hostEnd < url.len && url[hostEnd] == ':') {
    hostEnd += 1;
    let portEnd = hostEnd;
    while (portEnd < url.len && url[portEnd] !== '/') {
      portEnd += 1;
    }
    conn.port = std.fmt.parseInt(u16, url[hostEnd..portEnd], 10) catch conn.port;
    hostEnd = portEnd;
  }

  if (hostEnd < url.len && url[hostEnd] == '/') {
    const plen = url.len - hostEnd;
    @memcpy(conn.path[0..plen], url[hostEnd..url.len]);
    conn.pathLen = plen;
  } else {
    conn.path[0] = '/';
    conn.pathLen = 1;
  }
}

function isOnion(host: string): boolean {
  return host.len > 6 && std.mem.eql(u8, host[host.len - 6..], ".onion");
}

function getTicks(): u32 {
  let ts: std.posix.timespec = undefined;
  std.posix.clock_gettime(.MONOTONIC, &ts);
  return @intCast(@as(u64, @intCast(ts.sec)) * 1000 + @as(u64, @intCast(ts.nsec)) / 1_000_000);
}
