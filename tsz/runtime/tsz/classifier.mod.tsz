// classifier.tsz — Row classification for semantic terminal rendering
//
// Ports of love2d/lua/classifiers/basic.lua and
// love2d/lua/classifiers/claude_code.lua.
// Pattern-matches terminal row text to assign semantic token kinds.

// ── Token kinds ─────────────────────────────────────────────────

export enum TokenKind {
  // Basic shell tokens (basic.lua)
  command,
  output,
  err,
  success,
  heading,
  separator,
  progress,

  // Claude Code tokens (claude_code.lua)
  user_prompt,
  user_text,
  user_input,
  thinking,
  thought_complete,
  assistant_text,
  tool,
  result,
  diff,
  error_text,
  banner,
  status_bar,
  idle_prompt,
  input_border,
  input_zone,
  box_drawing,
  menu_title,
  menu_option,
  menu_desc,
  list_selectable,
  list_selected,
  list_info,
  search_box,
  selector,
  confirmation,
  hint,
  picker_title,
  picker_item,
  picker_selected,
  picker_meta,
  permission,
  plan_border,
  plan_mode,
  wizard_step,
  task_summary,
  task_done,
  task_open,
  task_active,
  slash_menu,
  image_attachment,

  // Fallback
  plain,
}

// ── UTF-8 byte sequences for Unicode chars ──────────────────────

const UTF8_CHEVRON = "\xe2\x9d\xaf"; // ❯ U+276F
const UTF8_BULLET = "\xe2\x97\x8f"; // ● U+25CF
const UTF8_BULLET_SM = "\xe2\x80\xa2"; // • U+2022
const UTF8_DIAMOND = "\xe2\x97\x86"; // ◆ U+25C6
const UTF8_CHECK = "\xe2\x9c\x94"; // ✔ U+2714
const UTF8_OPEN_BOX = "\xe2\x97\xbb"; // ◻ U+25FB
const UTF8_ELLIPSIS = "\xe2\x80\xa6"; // … U+2026
const UTF8_SPARKLE = "\xe2\x9c\xbb"; // ✻ U+273B
const UTF8_RESULT = "\xe2\x8e\xbf"; // ⎿ U+23BF
const UTF8_BOX_H = "\xe2\x94\x80"; // ─ U+2500
const UTF8_BOX_V = "\xe2\x94\x82"; // │ U+2502
const UTF8_BOX_TL = "\xe2\x94\x8c"; // ┌ U+250C
const UTF8_BOX_BL = "\xe2\x94\x94"; // └ U+2514
const UTF8_ROUND_TL = "\xe2\x95\xad"; // ╭ U+256D
const UTF8_ROUND_BL = "\xe2\x95\xb0"; // ╰ U+2570
const UTF8_DASHED_H = "\xe2\x95\x8c"; // ╌ U+254C
const UTF8_MIDDOT = "\xc2\xb7"; // · U+00B7
const UTF8_ARROW_DOWN = "\xe2\x86\x93"; // ↓ U+2193
const UTF8_ARROW_LEFT = "\xe2\x86\x90"; // ← U+2190
const UTF8_ARROW_RIGHT = "\xe2\x86\x92"; // → U+2192
const UTF8_CROSS = "\xe2\x9c\x97"; // ✗ U+2717
const UTF8_HEAVY_CROSS = "\xe2\x9c\x98"; // ✘ U+2718
const UTF8_CHECK_MARK = "\xe2\x9c\x93"; // ✓ U+2713
const UTF8_SQUARE = "\xe2\x96\xa1"; // □ U+25A1
const UTF8_NBSP = "\xc2\xa0"; // NBSP U+00A0

// ── Helpers ─────────────────────────────────────────────────────

function contains(haystack: string, needle: string): boolean {
  return std.mem.indexOf(u8, haystack, needle) !== null;
}

function startsWith(haystack: string, needle: string): boolean {
  return std.mem.startsWith(u8, haystack, needle);
}

function trim(text: string): string {
  return std.mem.trim(u8, text, " \t");
}

/// Check if text matches a digit pattern like "N. " (numbered menu item)
function hasNumberedPrefix(text: string): boolean {
  const t = trim(text);
  let i: usize = 0;
  // Skip optional > prefix
  if (i < t.length && t[i] === '>') i += 1;
  // Skip spaces
  while (i < t.length && t[i] === ' ') i += 1;
  // Need at least one digit
  if (i >= t.length || t[i] < '0' || t[i] > '9') return false;
  while (i < t.length && t[i] >= '0' && t[i] <= '9') i += 1;
  // Then a dot and space
  if (i + 1 < t.length && t[i] === '.' && t[i + 1] === ' ') return true;
  return false;
}

/// Check if text contains a digit followed by "%" (progress indicator)
function hasPercentage(text: string): boolean {
  let i: usize = 0;
  while (i < text.length) {
    if (text[i] >= '0' && text[i] <= '9') {
      // Skip rest of digits
      while (i + 1 < text.length && text[i + 1] >= '0' && text[i + 1] <= '9') i += 1;
      if (i + 1 < text.length && text[i + 1] === '%') return true;
    }
    i += 1;
  }
  return false;
}

/// Check if text has "N tokens" pattern
function hasTokenCount(text: string): boolean {
  if (std.mem.indexOf(u8, text, "tokens")) |pos| {
    // Check for digits before "tokens"
    if (pos > 0) {
      let i = pos - 1;
      while (i > 0 && text[i] === ' ') i -= 1;
      if (text[i] >= '0' && text[i] <= '9') return true;
    }
  }
  return false;
}

/// Check if text starts with $ + space + content (shell prompt)
function isDollarPrompt(text: string): boolean {
  const t = trim(text);
  if (t.length >= 3 && t[0] === '$' && t[1] === ' ' && t[2] !== ' ') return true;
  return false;
}

/// Check if text starts with > + space + content
function isAnglePrompt(text: string): boolean {
  const t = trim(text);
  if (t.length >= 3 && t[0] === '>' && t[1] === ' ' && t[2] !== ' ') return true;
  return false;
}

/// Check if line is entirely box-drawing or separator chars
function isSeparatorLine(text: string): boolean {
  const t = trim(text);
  if (t.length === 0) return false;
  let i: usize = 0;
  while (i < t.length) {
    const b = t[i];
    // ASCII separators: - = ~ * _
    if (b === '-' || b === '=' || b === '~' || b === '*' || b === '_') {
      i += 1;
      continue;
    }
    // UTF-8 box/separator chars (3-byte sequences starting with 0xE2)
    if (b === 0xE2 && i + 2 < t.length) {
      const b1 = t[i + 1];
      // ─ ═ ╌ ╍ ┄ ┅ ┈ ┉ and box corners/intersections
      if (b1 === 0x94 || b1 === 0x95) {
        i += 3;
        continue;
      }
      return false;
    }
    return false;
  }
  return true;
}

/// Check for user@host:path$ prompt pattern
function isUserHostPrompt(text: string): boolean {
  // Look for @ followed later by $ or #
  const at_pos = std.mem.indexOf(u8, text, "@") ?? return false;
  // Must have text before @
  if (at_pos === 0) return false;
  // Look for : or ~ after @
  const after_at = text[at_pos + 1..];
  if (std.mem.indexOf(u8, after_at, ":") !== null ||
      std.mem.indexOf(u8, after_at, "~") !== null) {
    // Look for $ or # followed by space
    if (std.mem.indexOf(u8, after_at, "$ ") !== null ||
        std.mem.indexOf(u8, after_at, "# ") !== null) {
      return true;
    }
  }
  return false;
}

/// Check if trimmed text is all uppercase (for heading detection)
function isAllCaps(text: string): boolean {
  if (text.length === 0 || text.length >= 60) return false;
  let has_letter = false;
  for (const ch of text) {
    if (ch >= 'a' && ch <= 'z') return false;
    if (ch >= 'A' && ch <= 'Z') has_letter = true;
  }
  return has_letter;
}

/// Check if text has bullet followed by function call pattern: word(
function hasBulletFuncCall(text: string): boolean {
  // Look for ● , • , or ◆ followed by space and word(
  const bullets = [_]string{ UTF8_BULLET, UTF8_BULLET_SM, UTF8_DIAMOND };
  for (const bullet of bullets) {
    if (std.mem.indexOf(u8, text, bullet)) |pos| {
      const after = text[pos + bullet.length..];
      // Skip spaces
      let i: usize = 0;
      while (i < after.length && after[i] === ' ') i += 1;
      // Look for word(
      while (i < after.length && ((after[i] >= 'a' && after[i] <= 'z') ||
          (after[i] >= 'A' && after[i] <= 'Z') || after[i] === '_')) {
        i += 1;
      }
      if (i > 0 && i < after.length && after[i] === '(') return true;
    }
  }
  return false;
}

/// Get text after chevron (❯), skipping NBSP
function textAfterChevron(text: string): ?string {
  const pos = std.mem.indexOf(u8, text, UTF8_CHEVRON) ?? return null;
  let rest = text[pos + UTF8_CHEVRON.length..];
  // Skip NBSP
  if (startsWith(rest, UTF8_NBSP)) rest = rest[UTF8_NBSP.length..];
  // Skip spaces
  rest = std.mem.trimLeft(u8, rest, " ");
  if (rest.length > 0) return rest;
  return null;
}

// ── Basic classifier ────────────────────────────────────────────
// Port of love2d/lua/classifiers/basic.lua

export function classifyBasic(text: string, row: u16, _: u16): TokenKind {
  const stripped = trim(text);
  if (stripped.length === 0) return .output;

  // Separator lines
  if (isSeparatorLine(stripped)) return .separator;

  // Error patterns
  if (startsWith(stripped, "Error:") || startsWith(stripped, "Error[") ||
      startsWith(stripped, "error:") || startsWith(stripped, "error[")) return .err;
  if (startsWith(stripped, "Failed") || startsWith(stripped, "failed")) return .err;
  if (startsWith(stripped, "FAIL")) return .err;
  if (startsWith(stripped, "panic:")) return .err;
  if (startsWith(stripped, "fatal:")) return .err;
  if (startsWith(stripped, "Exception:") || startsWith(stripped, "exception:")) return .err;
  if (startsWith(stripped, UTF8_CROSS) || startsWith(stripped, UTF8_HEAVY_CROSS)) return .err;

  // Success patterns
  if (startsWith(stripped, "Done") || startsWith(stripped, "done")) return .success;
  if (startsWith(stripped, "OK")) return .success;
  if (startsWith(stripped, "PASS")) return .success;
  if (startsWith(stripped, "Success") || startsWith(stripped, "success")) return .success;
  if (startsWith(stripped, UTF8_CHECK_MARK) || startsWith(stripped, UTF8_CHECK)) return .success;

  // Progress
  if (hasPercentage(text)) return .progress;
  if (contains(text, "ETA") || contains(text, "eta")) return .progress;
  if (std.mem.endsWith(u8, stripped, "...")) return .progress;

  // Command: shell prompt patterns
  if (isDollarPrompt(text)) return .command;
  if (isAnglePrompt(text)) return .command;
  if (row <= 3 && stripped.length >= 3 && stripped[0] === '#' && stripped[1] === ' ') return .heading;
  if (isUserHostPrompt(text)) return .command;

  // Heading: short all-caps, or === / --- underlines
  if (isAllCaps(stripped)) return .heading;
  if (stripped.length >= 3) {
    let all_eq = true;
    let all_dash = true;
    for (const ch of stripped) {
      if (ch !== '=') all_eq = false;
      if (ch !== '-') all_dash = false;
    }
    if (all_eq || all_dash) return .heading;
  }

  return .output;
}

// ── Claude Code classifier ──────────────────────────────────────
// Port of love2d/lua/classifiers/claude_code.lua

export function classifyClaude(text: string, row: u16, total_rows: u16): TokenKind {
  if (text.length === 0) return .plain;

  // Permission prompt: "Do you want to ..."
  if (contains(text, "Do you want to ") && contains(text, "?")) return .permission;

  // Numbered menu options
  if (hasNumberedPrefix(text)) return .menu_option;
  // ❯ followed by numbered option
  if (textAfterChevron(text)) |rest| {
    if (rest.length > 2 && rest[0] >= '0' && rest[0] <= '9') {
      let i: usize = 1;
      while (i < rest.length && rest[i] >= '0' && rest[i] <= '9') i += 1;
      if (i < rest.length && rest[i] === '.' && i + 1 < rest.length && rest[i + 1] === ' ')
        return .menu_option;
    }
  }

  // Banner / version
  if (contains(text, "Claude Code v")) return .banner;
  if (row <= 5 && contains(text, "Claude Code")) return .banner;
  if (row <= 5 && (contains(text, "Opus ") || contains(text, "Sonnet ") || contains(text, "Haiku "))) return .banner;
  if (row <= 5 && contains(text, "~/")) return .banner;

  // Interactive menu elements
  if (contains(text, UTF8_ARROW_LEFT ++ " " ++ UTF8_ARROW_RIGHT) || contains(text, "to adjust")) return .selector;
  if (contains(text, "Enter to confirm")) return .confirmation;
  if (startsWith(trim(text), "Select ")) return .menu_title;

  // Picker
  if (startsWith(trim(text), "Resume Session")) return .picker_title;
  if (contains(text, "ago") && contains(text, UTF8_MIDDOT)) return .picker_meta;

  // Status bar
  if (hasTokenCount(text) || (text.length > 1 && text[0] === '$' && text[1] >= '0' && text[1] <= '9')) return .status_bar;
  if (contains(text, "for shortcuts") || contains(text, "for short") ||
      contains(text, "esc to interrupt")) return .status_bar;

  // Input area (bottom 8 rows)
  if (row >= total_rows -| 8) {
    const stripped = trim(text);
    if (contains(stripped, UTF8_BOX_H ++ UTF8_BOX_H ++ UTF8_BOX_H ++ UTF8_BOX_H)) return .input_border;
    if (std.mem.eql(u8, stripped, UTF8_CHEVRON) || std.mem.eql(u8, stripped, ">")) return .input_zone;
    if (textAfterChevron(text) !== null && !contains(text, "Imagining")) return .input_zone;
    if (isAnglePrompt(text)) return .input_zone;
  }

  // User prompt: ❯ or > NOT near bottom
  if (!contains(text, "Imagining")) {
    if (textAfterChevron(text) !== null) return .user_prompt;
  }
  if (isAnglePrompt(text)) return .user_prompt;

  // Thought complete
  if (contains(text, UTF8_SPARKLE)) return .thought_complete;

  // Task active (live progress with … and token count or ↓)
  if (contains(text, UTF8_ELLIPSIS) &&
      (contains(text, UTF8_MIDDOT ++ " " ++ UTF8_ARROW_DOWN) || contains(text, "tokens")))
    return .task_active;

  // Task summary: "N tasks("
  if (contains(text, "tasks(") || contains(text, "task(")) return .task_summary;

  // Task done / open
  if (contains(text, UTF8_CHECK)) return .task_done;
  if (contains(text, UTF8_OPEN_BOX)) return .task_open;

  // Thinking
  if (contains(text, "Imagining") || contains(text, "Thinking")) return .thinking;

  // Plan mode
  if (contains(text, "Entered plan mode") || contains(text, "Exited plan mode")) return .plan_mode;
  if (contains(text, "exploring and designing") || contains(text, "now exploring")) return .plan_mode;

  // Tool use: bullet + function call pattern
  if (hasBulletFuncCall(text)) return .tool;

  // Diff lines
  if (text.length > 0 && (text[0] === '+' || text[0] === '-')) return .diff;

  // Image attachment
  if (contains(text, UTF8_RESULT) && contains(text, "[Image")) return .image_attachment;

  // Result bracket
  if (contains(text, UTF8_RESULT)) return .result;

  // Box drawing
  if (contains(text, UTF8_BOX_TL) || contains(text, UTF8_ROUND_TL) ||
      contains(text, UTF8_BOX_V) ||
      contains(text, UTF8_BOX_BL) || contains(text, UTF8_ROUND_BL)) return .box_drawing;

  const stripped = trim(text);
  if (contains(stripped, UTF8_DASHED_H ++ UTF8_DASHED_H ++ UTF8_DASHED_H)) return .plan_border;
  if (contains(stripped, UTF8_BOX_H ++ UTF8_BOX_H ++ UTF8_BOX_H ++ UTF8_BOX_H)) return .box_drawing;

  // Wizard step
  if (contains(text, UTF8_SQUARE) &&
      (contains(text, UTF8_ARROW_LEFT) || contains(text, UTF8_ARROW_RIGHT))) return .wizard_step;

  // Image attachment standalone
  if (contains(text, "[Image")) return .image_attachment;

  // Error
  if (startsWith(trim(text), "Error:") || startsWith(trim(text), "error:")) return .error_text;

  return .plain;
}

// ── Adjacency refinement ────────────────────────────────────────
// Context-aware reclassification based on previous row's token kind.

export function refineAdjacency(kind: TokenKind, prev_kind: TokenKind, text: string): TokenKind {
  // Plain text after user_prompt/user_text → user_text
  if (kind === .plain && (prev_kind === .user_prompt || prev_kind === .user_text))
    return .user_text;

  // Plain text after assistant-attributed tokens → assistant_text
  if (kind === .plain || kind === .menu_option) {
    if (prev_kind === .tool || prev_kind === .thinking || prev_kind === .thought_complete ||
        prev_kind === .result || prev_kind === .assistant_text ||
        prev_kind === .task_done || prev_kind === .task_open ||
        prev_kind === .task_summary || prev_kind === .task_active ||
        prev_kind === .diff || prev_kind === .plan_border) {
      return .assistant_text;
    }
  }

  // Plain text after menu_option → menu_desc
  if (kind === .plain && prev_kind === .menu_option) return .menu_desc;

  // Footer hints
  if (kind === .plain) {
    if (contains(text, "Enter to select") || contains(text, "Arrow keys") ||
        contains(text, "Esc to cancel") || contains(text, "Esc to go back") ||
        contains(text, "Type to search") ||
        (contains(text, "Ctrl+") && contains(text, " to "))) {
      return .hint;
    }
  }

  return kind;
}

// ── Turn and group detection ────────────────────────────────────

export function isTurnStartBasic(kind: TokenKind): boolean {
  return kind === .command;
}

export function isTurnStartClaude(kind: TokenKind): boolean {
  return kind === .user_prompt;
}

// ── Classifier type ─────────────────────────────────────────────

export enum ClassifierType {
  basic,
  claude_code,
}

// ── Global module API ───────────────────────────────────────────

let g_classifier: ClassifierType = .basic;
let g_prev_kind: TokenKind = .plain;

/// Set the active classifier.
export function setClassifier(ct: ClassifierType) {
  g_classifier = ct;
  g_prev_kind = .plain;
}

/// Classify a row of text. Applies adjacency refinement automatically.
export function classifyRow(text: string, row: u16, total_rows: u16): u8 {
  const raw_kind = switch (g_classifier) {
    case .basic: classifyBasic(text, row, total_rows);
    case .claude_code: classifyClaude(text, row, total_rows);
  };

  // Apply adjacency refinement (only for claude_code)
  const kind = if (g_classifier === .claude_code)
    refineAdjacency(raw_kind, g_prev_kind, text)
  else
    raw_kind;

  g_prev_kind = kind;
  return @intFromEnum(kind);
}

/// Reset adjacency state (call when scrolling or switching views).
export function resetClassifier() {
  g_prev_kind = .plain;
}

// ── Token color palette ─────────────────────────────────────────
// Catppuccin-inspired colors for semantic token rendering.

export interface TokenColor {
  r: u8;
  g: u8;
  b: u8;
}

export const TOKEN_COLORS = [_]TokenColor{
  // Basic tokens
  TokenColor{ .r = 137, .g = 180, .b = 250 }, // command — blue
  TokenColor{ .r = 205, .g = 214, .b = 244 }, // output — light text
  TokenColor{ .r = 243, .g = 139, .b = 168 }, // err — red
  TokenColor{ .r = 166, .g = 227, .b = 161 }, // success — green
  TokenColor{ .r = 245, .g = 224, .b = 220 }, // heading — rosewater
  TokenColor{ .r = 88, .g = 91, .b = 112 },  // separator — overlay0
  TokenColor{ .r = 249, .g = 226, .b = 175 }, // progress — yellow

  // Claude Code tokens
  TokenColor{ .r = 96, .g = 165, .b = 250 },  // user_prompt — blue
  TokenColor{ .r = 148, .g = 163, .b = 184 }, // user_text — muted
  TokenColor{ .r = 148, .g = 163, .b = 184 }, // user_input — muted
  TokenColor{ .r = 167, .g = 139, .b = 250 }, // thinking — purple
  TokenColor{ .r = 167, .g = 139, .b = 250 }, // thought_complete — purple
  TokenColor{ .r = 226, .g = 232, .b = 240 }, // assistant_text — light gray
  TokenColor{ .r = 234, .g = 179, .b = 8 },   // tool — yellow
  TokenColor{ .r = 74, .g = 222, .b = 128 },  // result — green
  TokenColor{ .r = 56, .g = 189, .b = 248 },  // diff — sky
  TokenColor{ .r = 248, .g = 113, .b = 113 }, // error_text — red
  TokenColor{ .r = 96, .g = 165, .b = 250 },  // banner — blue
  TokenColor{ .r = 100, .g = 116, .b = 139 }, // status_bar — muted
  TokenColor{ .r = 96, .g = 165, .b = 250 },  // idle_prompt — blue
  TokenColor{ .r = 71, .g = 85, .b = 105 },   // input_border — dim
  TokenColor{ .r = 226, .g = 232, .b = 240 }, // input_zone — light
  TokenColor{ .r = 71, .g = 85, .b = 105 },   // box_drawing — dim
  TokenColor{ .r = 249, .g = 226, .b = 175 }, // menu_title — yellow
  TokenColor{ .r = 226, .g = 232, .b = 240 }, // menu_option — light
  TokenColor{ .r = 148, .g = 163, .b = 184 }, // menu_desc — muted
  TokenColor{ .r = 226, .g = 232, .b = 240 }, // list_selectable — light
  TokenColor{ .r = 96, .g = 165, .b = 250 },  // list_selected — blue
  TokenColor{ .r = 148, .g = 163, .b = 184 }, // list_info — muted
  TokenColor{ .r = 226, .g = 232, .b = 240 }, // search_box — light
  TokenColor{ .r = 96, .g = 165, .b = 250 },  // selector — blue
  TokenColor{ .r = 74, .g = 222, .b = 128 },  // confirmation — green
  TokenColor{ .r = 100, .g = 116, .b = 139 }, // hint — muted
  TokenColor{ .r = 249, .g = 226, .b = 175 }, // picker_title — yellow
  TokenColor{ .r = 226, .g = 232, .b = 240 }, // picker_item — light
  TokenColor{ .r = 96, .g = 165, .b = 250 },  // picker_selected — blue
  TokenColor{ .r = 100, .g = 116, .b = 139 }, // picker_meta — muted
  TokenColor{ .r = 248, .g = 113, .b = 113 }, // permission — red
  TokenColor{ .r = 167, .g = 139, .b = 250 }, // plan_border — purple
  TokenColor{ .r = 167, .g = 139, .b = 250 }, // plan_mode — purple
  TokenColor{ .r = 167, .g = 139, .b = 250 }, // wizard_step — purple
  TokenColor{ .r = 100, .g = 116, .b = 139 }, // task_summary — muted
  TokenColor{ .r = 74, .g = 222, .b = 128 },  // task_done — green
  TokenColor{ .r = 148, .g = 163, .b = 184 }, // task_open — muted
  TokenColor{ .r = 96, .g = 165, .b = 250 },  // task_active — blue
  TokenColor{ .r = 148, .g = 163, .b = 184 }, // slash_menu — muted
  TokenColor{ .r = 148, .g = 163, .b = 184 }, // image_attachment — muted

  // plain fallback
  TokenColor{ .r = 205, .g = 214, .b = 244 }, // plain — default text
};

/// Get the color for a token kind.
export function getTokenColor(kind_idx: u8): TokenColor {
  if (kind_idx < TOKEN_COLORS.length) return TOKEN_COLORS[kind_idx];
  return TOKEN_COLORS[TOKEN_COLORS.length - 1]; // plain fallback
}
