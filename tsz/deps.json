{
  "llama": {
    "detect": ["llama_backend_init", "ffi\\.C\\.llama_", "ffi\\.cdef.*llama_model"],
    "build_step": "zig build llama-so -Doptimize=ReleaseFast",
    "so": "libllama_ffi",
    "link_libs": ["vulkan"],
    "default": false,
    "description": "LLM inference via llama.cpp (LuaJIT FFI)"
  },
  "video": {
    "detect": ["<Video"],
    "system_so": ["libmpv.so.2", "libmpv.so"],
    "macos_so": ["libmpv.2.dylib", "libmpv.dylib"],
    "macos_search": ["/opt/homebrew/lib"],
    "default": false,
    "description": "Video playback via libmpv"
  },
  "physics": {
    "detect": ["<Physics"],
    "system_so": ["libbox2d.so.2", "libbox2d.so"],
    "macos_so": ["libbox2d.dylib"],
    "macos_search": ["/opt/homebrew/lib"],
    "default": false,
    "description": "2D physics via Box2D"
  },
  "terminal": {
    "detect": ["<Terminal"],
    "system_so": ["libvterm.so.0", "libvterm.so"],
    "macos_so": ["libvterm.dylib"],
    "macos_search": ["/opt/homebrew/lib"],
    "default": false,
    "description": "Terminal emulator via libvterm"
  },
  "database": {
    "detect": ["sqlite_open", "sqlite_exec", "<Database"],
    "system_so": ["libsqlite3.so.0", "libsqlite3.so"],
    "macos_so": ["libsqlite3.dylib"],
    "macos_search": ["/opt/homebrew/opt/sqlite/lib"],
    "default": false,
    "description": "SQLite database"
  },
  "networking": {
    "detect": ["<fetch", "http_get", "http_post", "curl_"],
    "system_so": ["libcurl.so.4", "libcurl.so"],
    "macos_so": ["libcurl.dylib"],
    "macos_search": ["/opt/homebrew/lib"],
    "link_libs": ["archive"],
    "default": false,
    "description": "HTTP networking via libcurl + libarchive"
  }
}
