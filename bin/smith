#!/bin/bash
# smith — the only way to build carts
#
# Usage: smith build <cart.tsz>
#        smith build <cart.tsz> --debug
#
# Accepts any path format:
#   smith build carts/storybook/Storybook.tsz
#   smith build tsz/carts/storybook/Storybook.tsz
#   smith build /home/siah/creative/reactjit/tsz/carts/storybook/Storybook.tsz

set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"/../ && pwd)"
TSZ_DIR="$REPO_ROOT/tsz"

cmd="${1:-}"
shift || true

case "$cmd" in
    build)
        # Resolve cart path — accept anything, normalize to tsz-relative
        CART="${1:-}"
        if [ -z "$CART" ]; then
            echo "Usage: smith build <cart.tsz>"
            exit 1
        fi
        shift

        # Try to find the file: check cwd, then tsz/, then repo root
        if [[ "$CART" == /* ]]; then
            RESOLVED="$CART"
        elif [ -f "$(pwd)/$CART" ]; then
            RESOLVED="$(readlink -f "$(pwd)/$CART")"
        elif [ -f "$TSZ_DIR/$CART" ]; then
            RESOLVED="$(readlink -f "$TSZ_DIR/$CART")"
        elif [ -f "$REPO_ROOT/$CART" ]; then
            RESOLVED="$(readlink -f "$REPO_ROOT/$CART")"
        else
            echo "Error: cannot find $CART"
            exit 1
        fi

        # Prefer tsz-relative path if under tsz/, otherwise pass absolute
        CART_REL="${RESOLVED#$TSZ_DIR/}"
        if [[ "$CART_REL" == /* ]]; then
            # Outside tsz/ — pass absolute path
            CART_REL="$RESOLVED"
        fi

        exec "$TSZ_DIR/scripts/build" "$CART_REL" "$@"
        ;;
    engine)
        echo "[smith] Building engine .so..."
        cd "$TSZ_DIR"
        zig build core-so -Doptimize=ReleaseFast 2>&1
        echo "[smith] Engine ready → zig-out/lib/libreactjit-core.so"
        ;;
    *)
        echo "Usage:"
        echo "  smith build <cart.tsz>   Build a cart"
        echo "  smith engine             Rebuild the engine .so"
        exit 1
        ;;
esac
