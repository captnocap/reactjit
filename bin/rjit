#!/bin/bash
# rjit — ReactJIT CLI
#
# Usage:
#   rjit build <cart.tsz>          # fast build (~500ms, LuaJIT linker)
#   rjit build --full <cart.tsz>   # full build (~20s, zig build system)
#   rjit build --debug <cart.tsz>  # debug build (unoptimized)
#   rjit core                      # build/rebuild the cached engine .a
#   rjit run <cart.tsz>            # build + run
#   rjit dev <cart.tsz>            # hot-reload dev mode

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPTS="$REPO_ROOT/tsz/scripts"
TSZ_DIR="$REPO_ROOT/tsz"

# Resolve a .tsz path to absolute
resolve_tsz() {
    local p="$1"
    if [[ -f "$p" ]]; then
        realpath "$p"
    elif [[ -f "$REPO_ROOT/$p" ]]; then
        realpath "$REPO_ROOT/$p"
    else
        echo "$p"
    fi
}

cmd="${1:-}"
shift || true

case "$cmd" in
    build)
        FULL=0
        CART=""
        DEBUG=0
        for arg in "$@"; do
            case "$arg" in
                --full) FULL=1 ;;
                --debug) DEBUG=1 ;;
                *.tsz) CART="$(resolve_tsz "$arg")" ;;
            esac
        done

        if [[ -z "$CART" ]]; then
            echo "Usage: rjit build <cart.tsz> [--full] [--debug]"
            exit 1
        fi

        NAME=$(basename "$CART" .tsz)
        GEN="generated_${NAME}.zig"

        if [[ "$FULL" -eq 1 ]]; then
            # Full build — goes through zig build system
            exec "$SCRIPTS/build" "$CART" $([ "$DEBUG" -eq 1 ] && echo "--debug")
        fi

        # ── Fast path: forge + LuaJIT linker ──────────────────────────
        cd "$TSZ_DIR"

        # Ensure engine .a exists
        if [[ ! -f "zig-out/lib/libreactjit-core.current.a" ]]; then
            echo "[rjit] Engine .a not found — building (one-time, ~24s)..."
            zig build core -Doptimize=ReleaseFast 2>&1
            mkdir -p zig-out/lib
            mv zig-out/lib/libreactjit-core.a zig-out/lib/libreactjit-core.current.a
            echo "[rjit] Engine .a ready"
        fi

        # Ensure forge is built
        if [[ ! -f "zig-out/bin/forge" ]]; then
            echo "[rjit] Building forge..."
            zig build forge 2>&1
        fi

        # Step 1: forge (smith compiler: .tsz → .zig)
        echo "[$NAME] forge..."
        ./zig-out/bin/forge build --fast "$CART" 2>&1

        # Step 2: LuaJIT linker (compile .zig → .o, link → binary)
        luajit scripts/link.lua "$GEN" "$NAME"

        echo "[$NAME] done → zig-out/bin/$NAME"
        ;;
    core)
        echo "[rjit] Building engine core .a..."
        cd "$TSZ_DIR"
        zig build core -Doptimize=ReleaseFast 2>&1
        CORE_DIR="zig-out/lib"
        mkdir -p "$CORE_DIR"
        mv "$CORE_DIR/libreactjit-core.a" "$CORE_DIR/libreactjit-core.candidate.a"
        if [ -f "$CORE_DIR/libreactjit-core.current.a" ]; then
            mv "$CORE_DIR/libreactjit-core.current.a" "$CORE_DIR/libreactjit-core.lastgood.a"
        fi
        mv "$CORE_DIR/libreactjit-core.candidate.a" "$CORE_DIR/libreactjit-core.current.a"
        echo "[rjit] Engine core ready → $CORE_DIR/libreactjit-core.current.a"
        ;;
    run)
        CART=""
        for arg in "$@"; do
            case "$arg" in
                --*) ;;
                *.tsz) CART="$(resolve_tsz "$arg")" ;;
            esac
        done
        if [ -z "$CART" ]; then
            echo "Usage: rjit run <cart.tsz>"
            exit 1
        fi
        NAME=$(basename "$CART" .tsz)
        # Build via rjit build (fast path)
        "$0" build "$CART"
        exec "$TSZ_DIR/zig-out/bin/$NAME"
        ;;
    dev)
        CART="${1:-}"
        if [ -z "$CART" ]; then
            echo "Usage: rjit dev <cart.tsz>"
            exit 1
        fi
        cd "$TSZ_DIR"
        exec "$TSZ_DIR/zig-out/bin/tsz" dev "$CART"
        ;;
    ""|help|--help|-h)
        cat <<'HELP'
rjit — ReactJIT CLI

  rjit build <cart.tsz>          build cart (~500ms, LuaJIT linker)
  rjit build --full <cart.tsz>   full rebuild (~20s, zig build system fallback)
  rjit build --debug <cart.tsz>  debug build (unoptimized)
  rjit core                      build/rebuild engine .a (once, or after framework changes)
  rjit run <cart.tsz>            build + run
  rjit dev <cart.tsz>            hot-reload dev mode (186ms reloads)

First time:
  rjit core            # one-time ~24s engine build
  rjit build cart.tsz  # ~500ms from here on (forge + luajit link)
HELP
        ;;
    *)
        echo "rjit: unknown command '$cmd'. Run 'rjit help' for usage."
        exit 1
        ;;
esac
