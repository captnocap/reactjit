#!/bin/bash
# rjit — ReactJIT CLI
#
# Usage:
#   rjit build <cart.tsz>          # fast build (~500ms, LuaJIT linker)
#   rjit build --full <cart.tsz>   # full build (~20s, zig build system)
#   rjit build --debug <cart.tsz>  # debug build (unoptimized)
#   rjit core                      # build/rebuild the cached engine .a
#   rjit run <cart.tsz>            # build + run
#   rjit dev <cart.tsz>            # hot-reload dev mode

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPTS="$REPO_ROOT/tsz/scripts"
TSZ_DIR="$REPO_ROOT/tsz"

# Resolve a .tsz path to absolute
resolve_tsz() {
    local p="$1"
    if [[ -f "$p" ]]; then
        realpath "$p"
    elif [[ -f "$REPO_ROOT/$p" ]]; then
        realpath "$REPO_ROOT/$p"
    else
        echo "$p"
    fi
}

cmd="${1:-}"
shift || true

case "$cmd" in
    build)
        FULL=0
        CART=""
        DEBUG=0
        for arg in "$@"; do
            case "$arg" in
                --full) FULL=1 ;;
                --debug) DEBUG=1 ;;
                *.tsz) CART="$(resolve_tsz "$arg")" ;;
            esac
        done

        if [[ -z "$CART" ]]; then
            echo "Usage: rjit build <cart.tsz> [--full] [--debug]"
            exit 1
        fi

        NAME=$(basename "$CART" .tsz)
        GEN="generated_${NAME}.zig"

        if [[ "$FULL" -eq 1 ]]; then
            # Full build — goes through zig build system
            exec "$SCRIPTS/build" "$CART" $([ "$DEBUG" -eq 1 ] && echo "--debug")
        fi

        # ── Fast path: forge + LuaJIT linker ──────────────────────────
        cd "$TSZ_DIR"

        # Ensure engine .a exists
        if [[ ! -f "zig-out/lib/libreactjit-core.current.a" ]]; then
            echo "[rjit] Engine .a not found — building (one-time, ~24s)..."
            zig build core -Doptimize=ReleaseFast 2>&1
            mkdir -p zig-out/lib
            mv zig-out/lib/libreactjit-core.a zig-out/lib/libreactjit-core.current.a
            echo "[rjit] Engine .a ready"
        fi

        # Ensure forge is built
        if [[ ! -f "zig-out/bin/forge" ]]; then
            echo "[rjit] Building forge..."
            zig build forge 2>&1
        fi

        # Step 1: forge (smith compiler: .tsz → .zig)
        echo "[$NAME] forge..."
        ./zig-out/bin/forge build --fast --single "$CART" 2>&1

        # Step 2: LuaJIT linker (compile .zig → .o, link → binary)
        luajit scripts/link.lua "$GEN" "$NAME"

        echo "[$NAME] done → zig-out/bin/$NAME"
        ;;
    core)
        echo "[rjit] Building engine..."
        cd "$TSZ_DIR"
        CORE_DIR="zig-out/lib"
        mkdir -p "$CORE_DIR"

        # Build .a (static, for full builds)
        zig build core -Doptimize=ReleaseFast 2>&1
        mv "$CORE_DIR/libreactjit-core.a" "$CORE_DIR/libreactjit-core.current.a"

        # Build .so (dynamic, for fast builds + channel system)
        zig build core-so -Doptimize=ReleaseFast 2>&1
        cp "$CORE_DIR/libreactjit-core.so" "$CORE_DIR/libreactjit-core.bleeding.so"

        # If no stable exists yet, promote bleeding all the way
        if [ ! -f "$CORE_DIR/libreactjit-core.stable.so" ]; then
            cp "$CORE_DIR/libreactjit-core.bleeding.so" "$CORE_DIR/libreactjit-core.stable.so"
            cp "$CORE_DIR/libreactjit-core.bleeding.so" "$CORE_DIR/libreactjit-core.nightly.so"
            echo "[rjit] First build — all channels set to this version"
        fi

        echo "[rjit] Engine ready → bleeding.so (promote with: rjit promote nightly)"
        ;;
    promote)
        cd "$TSZ_DIR"
        CORE_DIR="zig-out/lib"
        TARGET="${1:-}"
        case "$TARGET" in
            nightly)
                if [ ! -f "$CORE_DIR/libreactjit-core.bleeding.so" ]; then
                    echo "[rjit] No bleeding.so — run 'rjit core' first"
                    exit 1
                fi
                cp "$CORE_DIR/libreactjit-core.bleeding.so" "$CORE_DIR/libreactjit-core.nightly.so"
                echo "[rjit] bleeding → nightly"
                ;;
            stable)
                if [ ! -f "$CORE_DIR/libreactjit-core.nightly.so" ]; then
                    echo "[rjit] No nightly.so — promote to nightly first"
                    exit 1
                fi
                if [ -f "$CORE_DIR/libreactjit-core.stable.so" ]; then
                    cp "$CORE_DIR/libreactjit-core.stable.so" "$CORE_DIR/libreactjit-core.stable.prev.so"
                fi
                cp "$CORE_DIR/libreactjit-core.nightly.so" "$CORE_DIR/libreactjit-core.stable.so"
                echo "[rjit] nightly → stable (prev saved as stable.prev.so)"
                ;;
            *)
                echo "Usage: rjit promote <nightly|stable>"
                exit 1
                ;;
        esac
        ;;
    run)
        CART=""
        for arg in "$@"; do
            case "$arg" in
                --*) ;;
                *.tsz) CART="$(resolve_tsz "$arg")" ;;
            esac
        done
        if [ -z "$CART" ]; then
            echo "Usage: rjit run <cart.tsz>"
            exit 1
        fi
        NAME=$(basename "$CART" .tsz)
        # Build via rjit build (fast path)
        "$0" build "$CART"
        exec "$TSZ_DIR/zig-out/bin/$NAME"
        ;;
    dev)
        CART="${1:-}"
        if [ -z "$CART" ]; then
            echo "Usage: rjit dev <cart.tsz>"
            exit 1
        fi
        cd "$TSZ_DIR"
        exec "$TSZ_DIR/zig-out/bin/tsz" dev "$CART"
        ;;
    ""|help|--help|-h)
        cat <<'HELP'
rjit — ReactJIT CLI

  rjit build <cart.tsz>          build cart (~500ms, LuaJIT linker)
  rjit build --full <cart.tsz>   full rebuild (~20s, zig build system fallback)
  rjit core                      build engine (bleeding.so + .a)
  rjit promote nightly           bleeding → nightly (after conformance passes)
  rjit promote stable            nightly → stable (after soak period)
  rjit run <cart.tsz>            build + run
  rjit dev <cart.tsz>            hot-reload dev mode (186ms reloads)

Engine channels (carts pick at launch):
  ./my_app                       loads stable (default)
  ./my_app --engine=nightly      loads nightly
  ./my_app --engine=bleeding     loads bleeding
  RJIT_ENGINE=bleeding ./my_app  env var also works

First time:
  rjit core            # builds engine (~24s), sets all channels
  rjit build cart.tsz  # ~500ms from here on
HELP
        ;;
    *)
        echo "rjit: unknown command '$cmd'. Run 'rjit help' for usage."
        exit 1
        ;;
esac
