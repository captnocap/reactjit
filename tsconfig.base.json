{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@reactjit/core": ["./packages/core/src"],
      "@reactjit/renderer": ["./packages/renderer/src"],
      "@reactjit/router": ["./packages/router/src"],
      "@reactjit/storage": ["./packages/storage/src"],
      "@reactjit/audio": ["./packages/audio/src"],
      "@reactjit/server": ["./packages/server/src"],
      "@reactjit/ai": ["./packages/ai/src"],
      "@reactjit/apis": ["./packages/apis/src"],
      "@reactjit/rss": ["./packages/rss/src"],
      "@reactjit/webhooks": ["./packages/webhooks/src"],
      "@reactjit/crypto": ["./packages/crypto/src"],
      "@reactjit/media": ["./packages/media/src"],
      "@reactjit/3d": ["./packages/3d/src"],
      "@reactjit/theme": ["./packages/theme/src"],
      "@reactjit/controls": ["./packages/controls/src"],
      "@reactjit/geo": ["./packages/geo/src"],
      "@reactjit/geo3d": ["./packages/geo3d/src"],
      "@reactjit/layouts": ["./packages/layouts/src"],
      "@reactjit/terminal": ["./packages/terminal/src"],
      "@reactjit/icons": ["./packages/icons/src"],
      "@reactjit/math": ["./packages/math/src"],
      "@reactjit/time": ["./packages/time/src"],
      "@reactjit/convert": ["./packages/convert/src"],
      "@reactjit/privacy": ["./packages/privacy/src"],
      "@reactjit/physics": ["./packages/physics/src"],
      "@reactjit/wireguard": ["./packages/wireguard/src"]
    }
  }
}
