      "@ilovereact/native": ["./packages/native/src"],
      "@ilovereact/grid": ["./packages/grid/src"],
      "@ilovereact/cc": ["./packages/cc/src"],
      "@ilovereact/nvim": ["./packages/nvim/src"],
      "@ilovereact/hs": ["./packages/hs/src"],
      "@ilovereact/awesome": ["./packages/awesome/src"],
      "@ilovereact/terminal": ["./packages/terminal/src"],
      "@ilovereact/components": ["./packages/components/src"],
      "@ilovereact/router": ["./packages/router/src"],
      "@ilovereact/storage": ["./packages/storage/src"],
      "@ilovereact/audio": ["./packages/audio/src"],
      "@ilovereact/server": ["./packages/server/src"],
      "@ilovereact/ai": ["./packages/ai/src"],
      "@ilovereact/apis": ["./packages/apis/src"],
      "@ilovereact/rss": ["./packages/rss/src"],
      "@ilovereact/webhooks": ["./packages/webhooks/src"]
    }
  }
