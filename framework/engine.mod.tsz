// ═══════════════════════════════════════════════════════════════════════
// ENGINE — the entire runtime lifecycle in intent syntax
//
// Translation of engine.zig (2216 lines). Uses <during> for lifecycle
// phases, state-driven behavior, and recursive tree walks.
// ═══════════════════════════════════════════════════════════════════════

<engine module>

  <uses>
    layout
    gpu
    text
    canvas
    effects
    physics
    audio
    input
    selection
    tooltip
    context_menu
    telemetry
    filedrop
    geometry
    breakpoint
    windows
    svg_path
    videos
    render_surfaces
    capture
    transition
    terminal
    classifier
    semantic
    cartridge
    crashlog
    qjs
    luajit
    pty_remote
    debug_server
    testharness
  </uses>

  // ═════════════════════════════════════════════════════════════════════
  // TYPES
  // ═════════════════════════════════════════════════════════════════════

  <types>
    <Feature>
      quickjs
      physics
      terminal
      video
      render_surfaces
      effects
      canvas
      scene3d
      transitions
      crypto
      blend2d
      debug_server
    </Feature>

    <CursorKind>
      arrow
      hand
    </CursorKind>

    <AppConfig has>
      .title is 'tsz app'
      .width is 1280
      .height is 800
      .min_width is 320
      .min_height is 240
      .root
      .js_logic is ''
      .lua_logic is ''
      .init
      .tick
      .check_reload
      .post_reload
    </AppConfig>
  </types>

  // ═════════════════════════════════════════════════════════════════════
  // STATE
  // ═════════════════════════════════════════════════════════════════════

  <var>
    window
    win_w is 0.0
    win_h is 0.0
    text_engine
    config is AppConfig

    // cursor
    cursor_kind is 'arrow'
    hovered_node

    // subsystem flags
    physics_initialized is false
    carts_scanned is false
    semantic_overlay is false

    // terminal
    terminals_initialized is bool array
    focused_terminal is 0
    terminal_count is 0

    // terminal selection
    <term_sel has>
      .active is false
      .dragging is false
      .start_row is 0
      .start_col is 0
      .end_row is 0
      .end_col is 0
    </term_sel>

    // canvas drag
    <canvas_drag has>
      .node
      .last_x is 0.0
      .last_y is 0.0
    </canvas_drag>

    // text input drag
    <input_drag has>
      .active is false
      .id is 0
      .node_x is 0.0
      .node_pl is 0.0
      .font_size is 0
    </input_drag>

    // paint state
    paint_count is 0
    hidden_count is 0
    zero_count is 0
    dt_sec is 0.0
    paint_opacity is 1.0
    flow_enabled is true
    hover_changed is false

    // main loop
    running is true
    fps_frames is 0
    fps_last is 0
    prev_tick is 0
    cursor_visible is true
  </var>

  <state>
    set_window
    set_win_w
    set_win_h
    set_text_engine
    set_cursor_kind exact CursorKind
    set_hovered_node
    set_physics_initialized
    set_focused_terminal
    set_terminal_count
    set_running
    set_carts_scanned
    set_fps_frames
    set_fps_last
    set_config
    set_prev_tick
    set_cursor_visible
    set_paint_count
    set_hidden_count
    set_zero_count
    set_dt_sec
    set_paint_opacity
    set_flow_enabled
    set_hover_changed
    set_semantic_overlay
  </state>

  // ═════════════════════════════════════════════════════════════════════
  // LIFECYCLE — <during> phases
  // ═════════════════════════════════════════════════════════════════════

  <functions>

    // ── BOOT ──────────────────────────────────────────────────────────
    // The entire engine startup is one composed chain.
    // Each step has a cleanup pair. If any step fails, cleanups
    // unwind in reverse.

    boot:
      crashlog.init + initSignals + initDebugServer + initSDL +
      initCanvas + initGeometry + initWindow + initVideo +
      initRenderSurfaces + initCapture + initEffects + initGPU +
      initText + initLayout + initQJS + initLuaJIT + registerBridges +
      runAppInit + runTestHarness + runScripts + runFirstTick +
      initPtyRemote

    shutdown:
      pty_remote.deinit + debug_server.deinit + windows.deinitAll +
      effects.deinit + capture.deinit + render_surfaces.deinit +
      videos.deinit + gpu.deinit + text_engine.deinit +
      qjs.deinit + luajit.deinit + sdl.quit

    initSignals:
      crashlog.ignoreSignal(13)
      crashlog.ignoreSignal(1)
      crashlog.ignoreSignal(15)
      crashlog.ignoreSignal(20)

    initDebugServer:
      debug_server.init(config.title)

    initDebugServer cleanup:
      debug_server.deinit

    initSDL:
      sdl.init('video')

    initSDL cleanup:
      sdl.quit

    initCanvas:
      canvas.init

    initGeometry:
      geometry.init(config.title)
      saved is geometry.load
      <if saved>
        set_win_w is saved.width
        set_win_h is saved.height
      </if>

    initWindow:
      set_window is sdl.createWindow(config.title, win_w, win_h)
      sdl.setWindowMinSize(window, config.min_width, config.min_height)
      sdl.startTextInput(window)

    initWindow cleanup:
      sdl.destroyWindow(window)
      windows.deinitAll

    initVideo:
      videos.init

    initVideo cleanup:
      videos.deinit

    initRenderSurfaces:
      render_surfaces.init

    initRenderSurfaces cleanup:
      render_surfaces.deinit

    initCapture:
      capture.init

    initCapture cleanup:
      capture.deinit

    initEffects:
      effects.init

    initEffects cleanup:
      effects.deinit

    initGPU:
      gpu.init(window)

    initGPU cleanup:
      gpu.deinit

    initText:
      set_text_engine is text.initHeadless('/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf')
      gpu.initText(text_engine)
      layout.setMeasureFn(measureText)
      layout.setMeasureImageFn(measureImage)
      input.setMeasureWidthFn(measureWidthOnly)

    initText cleanup:
      text_engine.deinit

    initLayout:
      breakpoint.update(win_w)

    initQJS:
      qjs.initVM

    initQJS cleanup:
      qjs.deinit

    initLuaJIT:
      luajit.initVM

    initLuaJIT cleanup:
      luajit.deinit

    registerBridges:
      audio.registerQjsHostFunctions
      pty_client.registerQjsHostFunctions
      applescript.registerQjsHostFunctions
      qjs.setOpenWindowFn(openNewWindow)

    runAppInit:
      <if config.init>
        config.init()
      </if>

    runTestHarness:
      <if testharness.envEnabled>
        testharness.enable
      </if>

    runScripts:
      <if config.js_logic>
        qjs.evalScript(config.js_logic)
      </if>
      <if config.lua_logic>
        luajit.evalScript(config.lua_logic)
      </if>

    runFirstTick:
      <if config.tick>
        config.tick(sdl.getTicks)
      </if>

    initPtyRemote:
      pty_remote.init

    initPtyRemote cleanup:
      pty_remote.deinit

  </functions>

  // ═════════════════════════════════════════════════════════════════════
  // DURING RUNNING — the main loop
  //
  // This entire block is active while `running` is true.
  // Setting running to false exits the engine.
  // ═════════════════════════════════════════════════════════════════════

  <during running>
    checkHotReload + pollEvents + tickSystems + doLayout +
    tickPhysics + layoutWindows + resolveSelection +
    updateMedia + updateTimers + paintFrame + paintOverlays +
    presentFrame + checkCapture + checkTests + collectTelemetry +
    updateFPS
  </during>

  // ═════════════════════════════════════════════════════════════════════
  // DURING STATES — reactive behaviors tied to variables
  // ═════════════════════════════════════════════════════════════════════

  <during physics_initialized>
    tickPhysicsStep every 16
  </during>

  <during term_sel.dragging>
    // terminal selection is active — drag updates happen in handleMouseMove
  </during>

  <during input_drag.active>
    // text input drag is active — updates happen in handleMouseMove
  </during>

  <during canvas_drag.node>
    // canvas pan is active — drag updates happen in handleMouseMove
  </during>

  <during semantic_overlay>
    // semantic coloring is active on focused terminal
  </during>

  // ═════════════════════════════════════════════════════════════════════
  // FRAME FUNCTIONS
  // ═════════════════════════════════════════════════════════════════════

  <functions>

    // ── HOT RELOAD ────────────────────────────────────────────────────

    checkHotReload:
      <if config.check_reload>
        reloaded is config.check_reload(config)
        <if reloaded>
          canvas_drag.node is null
          input_drag.active is false
          term_sel.dragging is false
          set_hovered_node is null
          set_hover_changed is true
          runAppInit + restoreState + runScripts + runFirstTick
        </if>
      </if>

    restoreState:
      <if config.post_reload>
        config.post_reload()
      </if>

    // ── EVENT POLLING ─────────────────────────────────────────────────

    pollEvents:
      <while sdl.pollEvent as event>
        <if windows.routeEvent(event)>
          skip
        </if>
        <switch event.type>
          <case quit>
            set_running is false
          </case>
          <case window_close>
            set_running is false
          </case>
          <case window_resize>
            handleResize
          </case>
          <case window_move>
            geometry.save(window)
          </case>
          <case mouse_down>
            handleMouseDown
          </case>
          <case mouse_move>
            handleMouseMove
          </case>
          <case mouse_up>
            handleMouseUp
          </case>
          <case text_input>
            handleTextInput
          </case>
          <case key_down>
            handleKeyDown
          </case>
          <case mouse_wheel>
            handleScroll
          </case>
          <case file_drop>
            handleFileDrop
          </case>
        </switch>
      </while>

    // ── WINDOW ────────────────────────────────────────────────────────

    handleResize:
      size is sdl.getWindowSize(window)
      set_win_w is size.w
      set_win_h is size.h
      gpu.resize(size.w, size.h)
      breakpoint.update(win_w)
      geometry.save(window)

    // ── MOUSE DOWN ────────────────────────────────────────────────────

    handleMouseDown:
      luajit.updateMouseButton(true, event.button exact 'right')

      <if render_surfaces.handleMouseDown(event.x, event.y, event.button)>
        stop
      </if>

      <if event.button exact 'left' and physics.isInitialized>
        physics.startDrag(event.x, event.y)
      </if>

      <if event.button exact 'left' and context_menu.isVisible>
        <if context_menu.handleClick(event.x, event.y)>
          stop
        </if>
      </if>

      <if event.button exact 'right'>
        handleRightClick
      </if>

      <if event.button exact 'left'>
        handleLeftClick
      </if>

    handleRightClick:
      context_menu.hide
      hit is events.hitTestRightClick(config.root, event.x, event.y)
      <if hit>
        <if hit.handlers.on_right_click>
          hit.handlers.on_right_click(event.x, event.y)
        </if>
        <else if hit.context_menu_items>
          context_menu.show(event.x, event.y, hit.context_menu_items)
        </else>
      </if>

    handleLeftClick:
      hit is layout.hitTest(config.root, event.x, event.y)

      <if hit and hit.interactive>
        handleInteractiveHit
      </if>
      <else if events.findCanvasNode(config.root, event.x, event.y) as cn>
        handleCanvasClick
      </else>
      <else>
        handleBackgroundClick
      </else>

    handleInteractiveHit:
      <if hit.input_id>
        handleInputFocus
      </if>
      <else if hit.handlers.on_press>
        input.unfocus
        hit.handlers.on_press()
        <if hit.handlers.js_on_press>
          qjs.evalExpr(hit.handlers.js_on_press)
        </if>
        <if hit.handlers.lua_on_press>
          luajit.evalExpr(hit.handlers.lua_on_press)
        </if>
      </else>
      <else if hit.handlers.lua_on_press>
        input.unfocus
        luajit.evalExpr(hit.handlers.lua_on_press)
      </else>
      <else if hit.handlers.js_on_press>
        input.unfocus
        qjs.evalExpr(hit.handlers.js_on_press)
      </else>
      <else if hit.href>
        openUrl(hit.href)
      </else>

    handleInputFocus:
      clicks is input.trackClick(sdl.getTicks)
      input.focus(hit.input_id)
      local_x is event.x - hit.computed.x - hit.style.padLeft
      <switch clicks>
        <case 3>
          input.selectAll(hit.input_id)
        </case>
        <case 2>
          input.setCursorFromX(hit.input_id, local_x, hit.font_size)
          input.selectWord(hit.input_id)
        </case>
        <case 1>
          input.setCursorFromX(hit.input_id, local_x, hit.font_size)
          input.startDrag(hit.input_id)
          input_drag.active is true
          input_drag.id is hit.input_id
          input_drag.node_x is hit.computed.x
          input_drag.node_pl is hit.style.padLeft
          input_drag.font_size is hit.font_size
        </case>
      </switch>

    handleCanvasClick:
      gpos is canvas.screenToGraph(event.x, event.y, cn)
      child_hit is findCanvasChildHit(cn, gpos)

      <if child_hit and child_hit.interactive>
        handleInteractiveHit
      </if>
      <else>
        input.unfocus
        <if canvas.getHoveredNode>
          canvas.clickNode
        </if>
        canvas_drag.node is cn
        canvas_drag.last_x is event.x
        canvas_drag.last_y is event.y
      </else>

    handleBackgroundClick:
      clicked_term is findClickedTerminal(event.x, event.y)
      <if clicked_term>
        set_focused_terminal is clicked_term
        startTerminalSelection(event.x, event.y)
      </if>
      <else>
        clearTerminalSelection
        selection.onMouseDown(config.root, event.x, event.y, sdl.getTicks)
      </else>
      input.unfocus

    // ── MOUSE MOVE ────────────────────────────────────────────────────

    handleMouseMove:
      luajit.updateMouse(event.x, event.y)

      <if render_surfaces.handleMouseMotion(event.x, event.y)>
        stop
      </if>

      <during physics.isDragging>
        physics.updateDrag(event.x, event.y)
      </during>

      <during term_sel.dragging>
        updateTerminalDrag(event.x, event.y)
      </during>

      <during input_drag.active>
        local_x is event.x - input_drag.node_x - input_drag.node_pl
        input.updateDrag(input_drag.id, local_x, input_drag.font_size)
      </during>

      updateHover(config.root, event.x, event.y)
      context_menu.updateHover(event.x, event.y)
      updateCanvasHover(event.x, event.y)

      <during canvas_drag.node>
        dx is event.x - canvas_drag.last_x
        dy is event.y - canvas_drag.last_y
        canvas.handleDrag(dx, dy)
        canvas_drag.last_x is event.x
        canvas_drag.last_y is event.y
      </during>

      <if event.dragging_left and not canvas_drag.node>
        selection.onMouseDrag(config.root, event.x, event.y)
      </if>

    // ── MOUSE UP ──────────────────────────────────────────────────────

    handleMouseUp:
      luajit.updateMouseButton(false, event.button exact 'right')

      <if render_surfaces.handleMouseUp(event.x, event.y, event.button)>
        stop
      </if>

      <if event.button exact 'left'>
        physics.endDrag
        canvas_drag.node is null
        input_drag.active is false
        term_sel.dragging is false
        selection.onMouseUp
      </if>

    // ── TEXT INPUT ─────────────────────────────────────────────────────

    handleTextInput:
      <if terminals_initialized[focused_terminal]>
        terminalHandleTextInput(event.text)
        stop
      </if>
      <if qjs.ptyActive>
        qjs.ptyHandleTextInput(event.text)
        stop
      </if>
      <if render_surfaces.handleTextInput(event.text)>
        stop
      </if>
      input.handleTextInput(event.text)

    // ── KEY DOWN ──────────────────────────────────────────────────────

    handleKeyDown:
      <if capture.handleKey(event.sym)>
        stop
      </if>

      <if terminals_initialized[focused_terminal]>
        <if event.ctrl and event.shift>
          <switch event.sym>
            <case 'C'>
              copyTerminalSelection
              stop
            </case>
            <case 'D'>
              toggleSemanticOverlay
              stop
            </case>
            <case 'V'>
              pasteToTerminal
              stop
            </case>
          </switch>
        </if>
        terminalHandleKey(event.sym, event.mod)
        stop
      </if>

      <if qjs.ptyActive>
        qjs.ptyHandleKeyDown(event.sym, event.mod)
        stop
      </if>

      <if render_surfaces.handleKeyDown(event.sym)>
        stop
      </if>

      handleAppKeyDown

    handleAppKeyDown:
      consumed is false
      <if input.getFocusedId>
        <if event.ctrl>
          consumed is input.handleCtrlKey(event.sym)
        </if>
        <else>
          consumed is input.handleKey(event.sym)
        </else>
      </if>
      <if not consumed and not videos.handleKey(event.sym)>
        selection.onKeyDown(config.root, event.sym, event.mod)
        qjs.callGlobalInt('__onKeyDown', event.sym)
      </if>

    // ── SCROLL ────────────────────────────────────────────────────────

    handleScroll:
      <if handleTerminalScroll(event.x, event.y, event.wheel_y)>
        stop
      </if>

      cn is events.findCanvasNode(config.root, event.x, event.y)
      <if cn>
        handleCanvasScroll(cn, event)
      </if>
      <else>
        handleNormalScroll(event)
      </else>

    handleCanvasScroll(cn, event):
      gpos is canvas.screenToGraph(event.x, event.y, cn)
      scroll_hit is findCanvasScrollContainer(cn, gpos)
      <if scroll_hit>
        applyScroll(scroll_hit, event.wheel_y, event.wheel_x)
      </if>
      <else>
        canvas.handleScroll(event.x - cn.computed.x, event.y - cn.computed.y, event.wheel_y, cn.computed.w, cn.computed.h)
      </else>

    handleNormalScroll(event):
      scroll_node is events.findScrollContainer(config.root, event.x, event.y)
      <if scroll_node>
        applyScroll(scroll_node, event.wheel_y, event.wheel_x)
      </if>

    applyScroll(node, wheel_y, wheel_x):
      scale is OS.scrollScale
      <if wheel_y not exact 0>
        node.scroll_y is node.scroll_y - wheel_y * scale
      </if>
      <if wheel_x not exact 0>
        node.scroll_y is node.scroll_y - wheel_x * scale
      </if>
      max_scroll is math.max(0.0, node.content_height - node.computed.h)
      node.scroll_y is math.clamp(node.scroll_y, 0.0, max_scroll)

    handleFileDrop:
      <if event.data>
        filedrop.dispatch(event.data, config.root)
      </if>

    // ── SYSTEM TICKS ──────────────────────────────────────────────────

    tickSystems:
      tickQJS + tickLuaJIT + tickApp + tickCartridges +
      tickTransitions + tickPtyRemote + tickTerminals

    tickQJS:
      qjs.tick

    tickLuaJIT:
      luajit.tick

    tickApp:
      <if config.tick>
        config.tick(sdl.getTicks)
      </if>

    tickCartridges:
      <if cartridge.count above 0>
        cartridge.tickAll(sdl.getTicks)
      </if>
      <if not carts_scanned>
        set_carts_scanned is true
        scanCartridgeNodes(config.root)
      </if>

    tickTransitions:
      now is sdl.getTicks
      dt is now - prev_tick
      transition.tick(dt / 1000.0)

    tickPtyRemote:
      pty_remote.poll

    tickTerminals:
      count is findTerminalNodes(config.root)
      set_terminal_count is count
      <for 0..count as i>
        <if not terminals_initialized[i]>
          terminal.spawnShellIdx(i, 'bash', 24, 80)
          terminals_initialized[i] is true
        </if>
        <if terminal.pollPtyIdx(i)>
          classifier.markDirtyIdx(i)
        </if>
        autoDetectCLI(i)
        reclassifyIfDirty(i)
      </for>

    autoDetectCLI(i):
      <if semantic_detected[i]>
        stop
      </if>
      detect_rows is math.min(terminal.getRowsIdx(i), 6)
      <for 0..detect_rows as row>
        text is terminal.getRowTextIdx(i, row)
        <if text.contains('Claude Code')>
          classifier.setModeIdx(i, 'claude_code')
          classifier.markDirtyIdx(i)
          semantic_detected[i] is true
          stop
        </if>
      </for>

    reclassifyIfDirty(i):
      <if not classifier.isDirtyIdx(i)>
        stop
      </if>
      mode is classifier.getModeIdx(i)
      <if mode exact 'none' or mode exact 'json'>
        stop
      </if>
      rows is terminal.getRowsIdx(i)
      <for 0..rows as row>
        text is terminal.getRowTextIdx(i, row)
        classifier.classifyAndCacheIdx(i, row, text, rows)
      </for>
      classifier.clearDirtyIdx(i)
      <if i exact 0>
        semantic.tick(rows)
      </if>

    // ── LAYOUT ────────────────────────────────────────────────────────

    doLayout:
      layout.layout(config.root, 0, 0, win_w, win_h)

    tickPhysics:
      <if physics.isInitialized>
        now is sdl.getTicks
        dt is math.min((now - prev_tick) / 1000.0, 0.05)
        physics.tick(dt)
      </if>

    layoutWindows:
      windows.layoutAll
      windows.paintAndPresent

    resolveSelection:
      selection.resolvePending

    updateMedia:
      videos.update
      render_surfaces.update

    updateTimers:
      now is sdl.getTicks
      dt_ms is now - prev_tick
      set_prev_tick is now
      set_dt_sec is dt_ms / 1000.0
      set_cursor_visible is input.tickBlink(dt_sec)
      effects.update(dt_sec)
      r3d.update(dt_sec)

    // ── PAINT — recursive tree walk via <during> ──────────────────────

    paintFrame:
      selection.resetWalkState
      set_paint_count is 0
      set_hidden_count is 0
      set_zero_count is 0
      <during paintNode(config.root)>
      </during>

    <during paintNode(node)>
      <if node.style.display exact 'none'>
        set_hidden_count is hidden_count + 1
        stop
      </if>
      set_paint_count is paint_count + 1

      <if node.canvas_path>
        paintCanvasPath(node)
        stop
      </if>

      r is node.computed
      <if r.w exact or below 0 or r.h exact or below 0>
        set_zero_count is zero_count + 1
        stop
      </if>

      saved_opacity is paint_opacity
      <if node.style.opacity below 1.0>
        set_paint_opacity is paint_opacity * node.style.opacity
      </if>
      <if paint_opacity exact or below 0>
        set_paint_opacity is saved_opacity
        stop
      </if>

      paintNodeVisuals(node)
      paintBackgroundEffects(node)

      <if node.canvas_type>
        paintCanvasContainer(node)
        stop
      </if>

      <if node.graph_container>
        paintGraphContainer(node)
        stop
      </if>

      paintChildren(node)
      set_paint_opacity is saved_opacity
    </during>

    paintNodeVisuals(node):
      r is node.computed
      is_hovered is hovered_node exact node and node.hoverable

      <if is_hovered and not node.style.background_color>
        gpu.drawRect(r.x, r.y, r.w, r.h, 0.15, 0.15, 0.22, 0.6, node.style.border_radius)
      </if>

      <if node.style.background_color>
        paintBackground(node, is_hovered)
      </if>

      <if not node.style.background_color and node.style.hasBorder>
        paintBorderOnly(node)
      </if>

      <if node.video_src>
        videos.paintVideo(node.video_src, r.x, r.y, r.w, r.h, paint_opacity)
      </if>

      <if node.render_src>
        render_surfaces.paintSurface(node.render_src, r.x, r.y, r.w, r.h, paint_opacity)
      </if>

      <if node.effect_type>
        effects.paintEffect(node.effect_type, r.x, r.y, r.w, r.h, paint_opacity)
      </if>

      <if node.effect_render and node.effect_name>
        effects.paintNamedEffect(node, node.effect_name, r.x, r.y, r.w, r.h)
      </if>
      <else if node.effect_render>
        effects.paintCustomEffect(node, r.x, r.y, r.w, r.h, paint_opacity)
      </else>

      <if node.scene3d>
        r3d.render(node, r.x, r.y, r.w, r.h, paint_opacity)
      </if>

      selection.paintHighlight(node, r.x, r.y)

      <if node.terminal>
        paintTerminal(node)
      </if>

      <if node.text>
        paintText(node)
      </if>

      <if node.input_id>
        paintTextInput(node, node.input_id)
      </if>

    paintText(node):
      r is node.computed
      tc is node.text_color ?? rgb(255, 255, 255)
      pl is node.style.padLeft
      pt is node.style.padTop
      pr is node.style.padRight

      gpu.resetInlineSlots

      <if node.text_effect>
        fill_info is effects.getEffectFill(node.text_effect)
        <if fill_info>
          gpu.setTextEffect(fill_info)
        </if>
      </if>

      text_h is gpu.drawTextWrapped(node.text, r.x + pl, r.y + pt, node.font_size, math.max(1.0, r.w - pl - pr), tc, paint_opacity, node.number_of_lines)

      <if node.inline_glyphs>
        paintInlineGlyphs(node.inline_glyphs, node.font_size)
      </if>

      <if node.text_effect>
        gpu.clearTextEffect
      </if>

      <if node.href>
        text_w is measureWidthOnly(node.text, node.font_size)
        underline_y is r.y + pt + text_h - 2
        gpu.drawRect(r.x + pl, underline_y, text_w, 1, tc, paint_opacity * 0.6)
      </if>

    paintChildren(node):
      ov is node.style.overflow
      is_scroll is ov exact 'scroll' or (ov exact 'auto' and node.content_height above node.computed.h)
      is_clipped is is_scroll or ov exact 'hidden'

      <if is_clipped>
        gpu.pushScissor(node.computed)
      </if>

      <if is_scroll and node.scroll_y not exact 0>
        offsetDescendants(node, 0 - node.scroll_y)
        <for node.children as child>
          <if not child.effect_background>
            paintNode(child)
          </if>
        </for>
        offsetDescendants(node, node.scroll_y)
      </if>
      <else>
        <for node.children as child>
          <if not child.effect_background>
            paintNode(child)
          </if>
        </for>
      </else>

      <if is_clipped>
        gpu.popScissor
      </if>

    paintGraphContainer(node):
      r is node.computed
      gpu.pushScissor(r)
      vx is node.canvas_view_x
      vy is node.canvas_view_y
      vz is math.max(node.canvas_view_zoom, 1.0)
      cx is r.x + r.w / 2
      cy is r.y + r.h / 2
      saved_tf is gpu.getTransform
      gpu.setTransform(0, 0, cx - vx * vz, cy - vy * vz, vz)

      <for node.children as child>
        paintNode(child)
      </for>

      <if saved_tf.active>
        gpu.setTransform(saved_tf)
      </if>
      <else>
        gpu.resetTransform
      </else>
      gpu.popScissor

    paintOverlays:
      tooltip.paintOverlay(measureText, win_w, win_h)
      context_menu.paintOverlay(measureText, win_w, win_h)
      <if debug_server.getPairingCode as code>
        paintPairingOverlay(code)
      </if>

    presentFrame:
      gpu.frame(0.051, 0.067, 0.090)

    checkCapture:
      <if capture.tick(config.root)>
        sys.exit(0)
      </if>

    checkTests:
      <if testharness.tick>
        exit_code is testharness.runAll(config.root)
        sys.exit(exit_code)
      </if>

    collectTelemetry:
      telemetry.collect(paint_count, hidden_count, zero_count, config.root, window, hovered_node)

    updateFPS:
      set_fps_frames is fps_frames + 1
      now is sdl.getTicks
      <if now - fps_last exact or above 1000>
        qjs.telemetry_fps is fps_frames
        luajit.telemetry_fps is fps_frames
        set_fps_frames is 0
        set_fps_last is now
      </if>

    // ── HELPERS ───────────────────────────────────────────────────────

    openNewWindow(title, w, h):
      windows.open(title, w, h, 'in_process')

    openUrl(url):
      <if qjs.hasGlobal('_browserNavigate')>
        qjs.callGlobalStr('_browserNavigate', url)
      </if>
      <else>
        sys.openExternal(url)
      </else>

    measureText(text, font_size, max_width, letter_spacing, line_height, max_lines, no_wrap):
      <if text_engine>
        text_engine.measureTextWrappedEx(text, font_size, max_width, letter_spacing, line_height, max_lines, no_wrap)
      </if>

    measureWidthOnly(text, font_size):
      <if text_engine>
        text_engine.measureTextWrappedEx(text, font_size, 0, 0, 0, 1, true).width
      </if>

    updateHover(root, mx, my):
      hit is events.hitTestHoverable(root, mx, my)
      <if hit exact hovered_node>
        stop
      </if>

      <if hovered_node and hovered_node.handlers.on_hover_exit>
        hovered_node.handlers.on_hover_exit()
      </if>
      set_hovered_node is hit

      <if hit>
        <if hit.handlers.on_hover_enter>
          hit.handlers.on_hover_enter()
        </if>
        <if hit.tooltip>
          tooltip.show(hit.tooltip, hit.computed)
        </if>
        <else>
          tooltip.hide
        </else>
        <if hit.href>
          set_cursor_kind is 'hand'
        </if>
        <else>
          set_cursor_kind is 'arrow'
        </else>
      </if>
      <else>
        tooltip.hide
        set_cursor_kind is 'arrow'
      </else>

    offsetDescendants(node, dy):
      <for node.children as child>
        child.computed.y is child.computed.y + dy
        offsetDescendants(child, dy)
      </for>

    // ── TERMINAL ──────────────────────────────────────────────────────

    clearTerminalSelection:
      term_sel.active is false
      term_sel.dragging is false

    startTerminalSelection(mx, my):
      tn is findTerminalNodeById(config.root, focused_terminal)
      <if tn>
        cell is termPixelToCell(tn, mx, my)
        term_sel.start_row is cell.row
        term_sel.start_col is cell.col
        term_sel.end_row is cell.row
        term_sel.end_col is cell.col
        term_sel.active is false
        term_sel.dragging is true
      </if>

    updateTerminalDrag(mx, my):
      tn is findTerminalNodeById(config.root, focused_terminal)
      <if tn>
        cell is termPixelToCell(tn, mx, my)
        term_sel.end_row is cell.row
        term_sel.end_col is cell.col
        term_sel.active is term_sel.start_row not exact term_sel.end_row or term_sel.start_col not exact term_sel.end_col
      </if>

    copyTerminalSelection:
      <if term_sel.active>
        text is terminal.copySelectedTextIdx(focused_terminal, term_sel.start_row, term_sel.start_col, term_sel.end_row, term_sel.end_col)
        sdl.setClipboardText(text)
      </if>

    pasteToTerminal:
      clip is sdl.getClipboardText
      <if clip>
        terminal.scrollToBottomIdx(focused_terminal)
        terminal.writePtyIdx(focused_terminal, clip)
      </if>

    toggleSemanticOverlay:
      set_semantic_overlay is not semantic_overlay
      <if semantic_overlay and classifier.getModeIdx(focused_terminal) exact 'none'>
        classifier.setModeIdx(focused_terminal, 'basic')
        classifier.markDirtyIdx(focused_terminal)
      </if>

    terminalHandleKey(sym, mod):
      clearTerminalSelection
      terminal.scrollToBottomIdx(focused_terminal)
      <if mod.ctrl and sym exact or above 'a' and sym exact or below 'z'>
        terminal.writePtyIdx(focused_terminal, controlChar(sym))
        stop
      </if>
      seq is ansiSequence(sym)
      <if seq>
        terminal.writePtyIdx(focused_terminal, seq)
      </if>

    terminalHandleTextInput(text):
      clearTerminalSelection
      terminal.scrollToBottomIdx(focused_terminal)
      terminal.writePtyIdx(focused_terminal, text)

    // ── CARTRIDGE ─────────────────────────────────────────────────────

    <during scanCartridgeNodes(node)>
      <if node.cartridge_src>
        <if node.children.length exact 0>
          idx is cartridge.load(node.cartridge_src)
          <if idx>
            cr is cartridge.get(idx)
            node.children is cr.root.children
          </if>
        </if>
        <else>
          refreshCartridgeChildren(node)
        </else>
      </if>
      <for node.children as child>
        scanCartridgeNodes(child)
      </for>
    </during>

    refreshCartridgeChildren(node):
      <for 0..cartridge.count as i>
        cr is cartridge.get(i)
        <if cr and cr.soPath exact node.cartridge_src>
          node.children is cr.root.children
          stop
        </if>
      </for>

    // ── PHYSICS ───────────────────────────────────────────────────────

    <during initPhysicsFromTree(node)>
      <if node.physics_world>
        physics.init(node.physics_gravity_x, node.physics_gravity_y)
        <for node.children as child>
          initPhysicsFromTree(child)
        </for>
        stop
      </if>
      <if node.physics_body>
        createPhysicsBody(node)
        stop
      </if>
      <for node.children as child>
        initPhysicsFromTree(child)
      </for>
    </during>

    createPhysicsBody(node):
      visual_child is findVisualChild(node)
      collider_child is findColliderChild(node)
      target is visual_child ?? node

      <switch node.physics_body_type>
        <case 0>
          body_type is 'static'
        </case>
        <case 1>
          body_type is 'kinematic'
        </case>
        <case else>
          body_type is 'dynamic'
        </case>
      </switch>

      idx is physics.createBody(body_type, node.physics_x, node.physics_y, node.physics_angle, target)
      <if idx>
        node.physics_body_idx is idx
        <if node.physics_fixed_rotation>
          physics.setFixedRotation(idx, true)
        </if>
        <if node.physics_bullet>
          physics.setBullet(idx, true)
        </if>
        <if node.physics_gravity_scale not exact 1.0>
          physics.setGravityScale(idx, node.physics_gravity_scale)
        </if>
        <if collider_child>
          attachCollider(idx, collider_child, visual_child)
        </if>
      </if>

    attachCollider(body_idx, collider, visual):
      <if collider.physics_shape exact 1>
        physics.addCircleCollider(body_idx, collider.physics_radius, collider.physics_density, collider.physics_friction, collider.physics_restitution)
      </if>
      <else>
        w is visual.style.width ?? 40
        h is visual.style.height ?? 40
        physics.addBoxCollider(body_idx, w, h, collider.physics_density, collider.physics_friction, collider.physics_restitution)
      </else>

    // ── CANVAS ────────────────────────────────────────────────────────

    positionCanvasNodes(parent):
      <for parent.children as child>
        <if child.canvas_node>
          positionOneCanvasNode(child)
        </if>
        <else if not child.canvas_path and not child.canvas_clamp>
          <for child.children as gc>
            <if gc.canvas_node>
              positionOneCanvasNode(gc)
            </if>
          </for>
        </else>
      </for>

    positionOneCanvasNode(child):
      target_x is child.canvas_gx - child.computed.w / 2
      target_y is child.canvas_gy - child.computed.h / 2
      dx is target_x - child.computed.x
      dy is target_y - child.computed.y
      child.computed.x is target_x
      child.computed.y is target_y
      <for child.children as gc>
        offsetNodeXY(gc, dx, dy)
      </for>

    offsetNodeXY(node, dx, dy):
      node.computed.x is node.computed.x + dx
      node.computed.y is node.computed.y + dy
      <for node.children as child>
        offsetNodeXY(child, dx, dy)
      </for>

    OS.scrollScale:
      <if sys.os exact 'macos'>
        10.0
      </if>
      <else>
        30.0
      </else>

  </functions>

</engine>
