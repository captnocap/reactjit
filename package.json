{
  "name": "reactjit",
  "version": "0.1.0",
  "description": "Write it in React, render it with a hand-rolled SDL2 + OpenGL renderer on LuaJIT",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/renderer",
    "packages/router",
    "packages/storage",
    "packages/audio",
    "packages/ai",
    "packages/3d",
    "packages/theme",
    "packages/controls",
    "packages/geo",
    "packages/geo3d",
    "packages/layouts",
    "packages/terminal",
    "packages/icons",
    "packages/math",
    "packages/time",
    "packages/convert",
    "packages/privacy",
    "packages/physics",
    "packages/wireguard",
    "packages/imaging",
    "packages/finance",
    "packages/chemistry",
    "packages/data",
    "packages/networking"
  ],
  "scripts": {
    "build:native": "esbuild --bundle --format=iife --global-name=ReactJIT --target=es2020 --jsx=automatic --outfile=examples/native-hud/game/bundle.js examples/native-hud/src/main.tsx",
    "watch:native": "esbuild --bundle --format=iife --global-name=ReactJIT --target=es2020 --jsx=automatic --outfile=examples/native-hud/game/bundle.js --watch examples/native-hud/src/main.tsx",
    "build:storybook": "npx tsx scripts/docs/build.ts && esbuild --bundle --format=iife --global-name=ReactJITStorybook --target=es2020 --jsx=automatic --outfile=storybook/love/bundle.js storybook/src/main.tsx",
    "watch:storybook": "npx tsx scripts/docs/build.ts && esbuild --bundle --format=iife --global-name=ReactJITStorybook --target=es2020 --jsx=automatic --outfile=storybook/love/bundle.js --watch storybook/src/main.tsx",
    "build:docs": "npx tsx scripts/docs/build.ts",
    "validate:docs": "npx tsx scripts/docs/build.ts validate",
    "validate:story-layout": "node scripts/validate-story-layout.mjs",
    "validate:story-centering": "node scripts/validate-story-centering.mjs",
    "validate:story-titles": "node scripts/validate-story-title-alignment.mjs",
    "test:ai-providers": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/ai/test/providers.test.mjs",
    "test:ai-stream": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/ai/test/stream.test.mjs",
    "test:ai-tools": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/ai/test/tools.test.mjs",
    "test:ai-mcp-protocol": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/ai/test/mcp-protocol.test.mjs",
    "test:ai-mcp-transport": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/ai/test/mcp-transport.test.mjs",
    "test:core": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test packages/core/test/tw-roundtrip.test.mjs",
    "test:math": "sh -c 'if command -v luajit >/dev/null 2>&1; then luajit packages/math/test/precision-harness.lua; else lua packages/math/test/precision-harness.lua; fi'",
    "test:router": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/router/test/router.test.mjs",
    "test:storage-migrations": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/storage/test/migrations.test.mjs",
    "test:storage-query": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/storage/test/query.test.mjs",
    "test:storage": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/storage/test/format.test.mjs",
    "test:time-timezone": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/time/test/timezone.test.mjs",
    "test:time-utils": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON packages/time/test/utils.test.mjs",
    "poly:fetch": "node scripts/poly-pizza-fetch.mjs"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "react": "^18.3.0",
    "react-reconciler": "^0.29.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "esbuild": "^0.24.0",
    "lucide-static": "^0.575.0",
    "typescript": "^5.5.0"
  }
}
