#\!/bin/sh
# CartridgeOS /init — PID 1
# No display server. Just kernel -> KMS/DRM -> SDL2 -> LuaJIT -> ReactJIT.

mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev

echo 1 > /proc/sys/kernel/printk 2>/dev/null || true

echo ""
echo "  CartridgeOS v0.1"
echo "  ReactJIT -- no X11, no Wayland, no display server"
echo "  kernel: $(uname -r)"
echo ""

sleep 0.5

if ls /dev/dri/ >/dev/null 2>&1; then
  echo "  DRM devices: $(ls /dev/dri/)"
else
  echo "  WARNING: no /dev/dri devices -- check QEMU -device flags"
fi
echo ""

export SDL_VIDEODRIVER=kmsdrm
export LIBGL_DRIVERS_PATH=/usr/lib/dri
export LIBGL_DRIVERS_DIR=/usr/lib/dri
export EGL_PLATFORM=drm
export LD_LIBRARY_PATH=/app:/usr/lib:/lib

echo "  Launching ReactJIT..."
echo ""

exec /usr/bin/luajit /app/main.lua

echo ""
echo "  [cartridge] app exited -- dropping to shell"
exec /bin/sh
