// Populate entries for triple capture test

var entries = [];
var labels = ['Mercury', 'Venus', 'Earth', 'Mars', 'Jupiter',
              'Saturn', 'Uranus', 'Neptune', 'Pluto', 'Ceres',
              'Eris', 'Haumea', 'Makemake', 'Sedna', 'Quaoar'];

for (var i = 0; i < 15; i++) {
  entries.push({
    label: labels[i],
    weight: (i + 1) * 3,
    category: i % 3
  });
}
setEntries(entries);
