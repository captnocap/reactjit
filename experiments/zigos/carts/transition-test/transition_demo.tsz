// Transition demo: opacity and width animate smoothly on state change.
// Press the button to toggle expanded/collapsed state.

const [mode, setMode] = useState(0);

function App() {
  return (
    <Box style={{ width: "100%", height: "100%", padding: 20, backgroundColor: "#1e293b", gap: 16, flexDirection: "column" }}>
      <Text fontSize={18} color="#e2e8f0">Transition Demo</Text>

      <Pressable onPress={() => { setMode(mode == 0 ? 1 : 0) }}>
        <Box style={{ padding: 12, backgroundColor: "#3b82f6", borderRadius: 8, width: 180 }}>
          <Text color="#ffffff" fontSize={14}>Toggle Animation</Text>
        </Box>
      </Pressable>

      <Text fontSize={12} color="#94a3b8">Width + opacity transition (easeInOut, 500ms)</Text>
      <Box style={{
        width: mode ? 400 : 100,
        height: 40,
        opacity: mode ? 1.0 : 0.3,
        backgroundColor: "#ef4444",
        borderRadius: 8,
        transition: {
          width: { duration: 500, easing: "easeInOut" },
          opacity: { duration: 300, easing: "easeOut" }
        }
      }} />

      <Text fontSize={12} color="#94a3b8">Border radius transition (bounce, 400ms)</Text>
      <Box style={{
        width: 80,
        height: 80,
        backgroundColor: "#8b5cf6",
        borderRadius: mode ? 40 : 4,
        transition: { borderRadius: { duration: 400, easing: "bounce" } }
      }} />
    </Box>
  );
}
