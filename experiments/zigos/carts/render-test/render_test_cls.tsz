classifier Page(Box) {
  width: '100%';
  height: '100%';
  backgroundColor: '#0d1117';
  padding: 24;
  gap: 20;
}

classifier Header(Box) {
  flexDirection: 'row';
  alignItems: 'center';
  gap: 12;
}

classifier Title(Text) {
  fontSize: 22;
  color: '#e6edf3';
}

classifier Subtitle(Text) {
  fontSize: 14;
  color: '#8b949e';
}

classifier RenderContainer(Box) {
  flexGrow: 1;
  backgroundColor: '#161b22';
  borderRadius: 8;
  borderWidth: 1;
  borderColor: '#30363d';
  overflow: 'hidden';
}

classifier StatusBar(Box) {
  flexDirection: 'row';
  gap: 16;
  alignItems: 'center';
  padding: 12;
  backgroundColor: '#161b22';
  borderRadius: 8;
  borderWidth: 1;
  borderColor: '#30363d';
}

classifier StatusLabel(Text) {
  fontSize: 12;
  color: '#8b949e';
}

classifier StatusValue(Text) {
  fontSize: 12;
  color: '#58a6ff';
}
