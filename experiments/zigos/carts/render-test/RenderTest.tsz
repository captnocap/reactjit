import { Page, Header, Title, Subtitle, RenderContainer, StatusBar, StatusLabel, StatusValue } from './render_test_cls';

function App() {
  return (
    <C.Page>
      <C.Header>
        <C.Title>Render Surface Test</C.Title>
        <C.Subtitle>AppEmbed — native app running inside a virtual display</C.Subtitle>
      </C.Header>

      <Render src="app:kitty -o remember_window_size=no -o initial_window_width=1280 -o initial_window_height=648" style={{ flexGrow: 1, backgroundColor: '#161b22', borderRadius: 8, borderWidth: 1, borderColor: '#30363d' }} />

      <C.StatusBar>
        <C.StatusLabel>Source:</C.StatusLabel>
        <C.StatusValue>app:kitty (embedded terminal)</C.StatusValue>
        <C.StatusLabel>Backend:</C.StatusLabel>
        <C.StatusValue>Xvfb + XShm + XTest</C.StatusValue>
        <C.StatusLabel>Input:</C.StatusLabel>
        <C.StatusValue>XTest synthetic events</C.StatusValue>
      </C.StatusBar>
    </C.Page>
  );
}
