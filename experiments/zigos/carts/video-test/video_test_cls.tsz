classifier Page(Box) {
  width: '100%';
  height: '100%';
  backgroundColor: '#0d1117';
  padding: 24;
  gap: 20;
}

classifier Header(Box) {
  flexDirection: 'row';
  alignItems: 'center';
  gap: 12;
}

classifier Title(Text) {
  fontSize: 22;
  color: '#e6edf3';
}

classifier Subtitle(Text) {
  fontSize: 14;
  color: '#8b949e';
}

classifier VideoContainer(Box) {
  flexGrow: 1;
  backgroundColor: '#161b22';
  borderRadius: 8;
  borderWidth: 1;
  borderColor: '#30363d';
  overflow: 'hidden';
}

classifier Controls(Box) {
  flexDirection: 'row';
  gap: 10;
  alignItems: 'center';
  padding: 12;
  backgroundColor: '#161b22';
  borderRadius: 8;
  borderWidth: 1;
  borderColor: '#30363d';
}

classifier Btn(Box) {
  paddingLeft: 16;
  paddingRight: 16;
  paddingTop: 8;
  paddingBottom: 8;
  backgroundColor: '#238636';
  borderRadius: 6;
}

classifier BtnText(Text) {
  fontSize: 13;
  color: '#ffffff';
}

classifier InfoRow(Box) {
  flexDirection: 'row';
  gap: 16;
  alignItems: 'center';
}

classifier InfoLabel(Text) {
  fontSize: 12;
  color: '#8b949e';
}

classifier InfoValue(Text) {
  fontSize: 12;
  color: '#58a6ff';
}
