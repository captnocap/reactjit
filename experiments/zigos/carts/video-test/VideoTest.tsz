import { Page, Header, Title, Subtitle, VideoContainer, Controls, InfoRow, InfoLabel, InfoValue } from './video_test_cls';

function App() {
  return (
    <C.Page>
      <C.Header>
        <C.Title>Video Test</C.Title>
        <C.Subtitle>libmpv OpenGL render API → wgpu — drop a video file to play</C.Subtitle>
      </C.Header>

      <C.VideoContainer>
        <Video src="test.mp4" style={{ flexGrow: 1 }} />
      </C.VideoContainer>

      <C.Controls>
        <C.InfoRow>
          <C.InfoLabel>Drop any video file onto this window to play it.</C.InfoLabel>
        </C.InfoRow>
      </C.Controls>
    </C.Page>
  );
}
