          <Text color="#FFF" fontSize={9}>g1 s1 b100 min60 max150</Text>
        </div>
        <div style={{ flexGrow: 2, flexShrink: 0, flexBasis: 50, backgroundColor: '#2196F3' }}>
          <Text color="#FFF" fontSize={9}>g2 s0 b50</Text>
