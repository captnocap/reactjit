        <div style={{ width: 60, height: 30, backgroundColor: '#F44336' }} />
      </div>

      <p style={{ fontSize: 11 }}>wrap + align:center — items centered on cross axis per line</p>
      <div style={{ flexDirection: 'row', flexWrap: 'wrap', alignItems: 'center', width: 200, backgroundColor: '#333', gap: 4, padding: 4 }}>
        <div style={{ width: 60, height: 20, backgroundColor: '#4CAF50' }} />
