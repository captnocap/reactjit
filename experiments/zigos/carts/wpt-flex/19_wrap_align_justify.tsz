      <p style={{ fontSize: 11 }}>wrap + justify:center — each line centered</p>
      <div style={{ flexDirection: 'row', flexWrap: 'wrap', justifyContent: 'center', width: 200, backgroundColor: '#333', gap: 4, padding: 4 }}>
