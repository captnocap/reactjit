      <p style={{ fontSize: 11 }}>wrap + justify:end — items packed to end per line</p>
      <div style={{ flexDirection: 'row', flexWrap: 'wrap', justifyContent: 'end', width: 200, backgroundColor: '#333', gap: 4, padding: 4 }}>
