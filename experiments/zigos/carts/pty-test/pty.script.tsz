// PTY script — opens a PTY, runs a VT100 parser, drives row state.
//
// Grid model: 80 cols × 24 rows of characters.
// State is pushed via setRow0..setRow23 (defined in pty.tsz).
// Uses __pty_open / __pty_read / __pty_write / __pty_alive builtins.

var COLS = 80;
var ROWS = 24;

// ── Grid ────────────────────────────────────────────────────────

var _grid = [];
var _cx = 0;
var _cy = 0;

function initGrid() {
  _grid = [];
  for (var r = 0; r < ROWS; r++) {
    var row = [];
    for (var c2 = 0; c2 < COLS; c2++) row.push(' ');
    _grid.push(row);
  }
}

function scrollUp() {
  _grid.shift();
  var row = [];
  for (var c2 = 0; c2 < COLS; c2++) row.push(' ');
  _grid.push(row);
}

function clearScreen() {
  initGrid();
  _cx = 0;
  _cy = 0;
}

function eraseToEOL() {
  for (var c2 = _cx; c2 < COLS; c2++) _grid[_cy][c2] = ' ';
}

function putChar(ch) {
  if (_cx >= COLS) {
    _cx = 0;
    _cy++;
    if (_cy >= ROWS) { scrollUp(); _cy = ROWS - 1; }
  }
  _grid[_cy][_cx] = ch;
  _cx++;
}

function newline() {
  _cy++;
  if (_cy >= ROWS) { scrollUp(); _cy = ROWS - 1; }
}

// ── VT100 state machine ─────────────────────────────────────────
// States: 0=normal, 1=esc, 2=csi, 3=charset_skip

var _vt = 0;
var _params = '';
var _priv = false;

function getParam(idx, def) {
  var parts = _params.split(';');
  if (idx >= parts.length) return def;
  var v = parseInt(parts[idx]);
  return (isNaN(v) || v === 0) ? def : v;
}

function csiDispatch(cmd) {
  if (cmd === 'm') {
    // SGR — color/style — ignore
  } else if (cmd === 'H' || cmd === 'f') {
    // Cursor position [row;col]H — 1-indexed
    var row = getParam(0, 1) - 1;
    var col = getParam(1, 1) - 1;
    _cy = Math.max(0, Math.min(ROWS - 1, row));
    _cx = Math.max(0, Math.min(COLS - 1, col));
  } else if (cmd === 'J') {
    var n = getParam(0, 0);
    if (n === 2 || n === 3) clearScreen();
    // 0=erase below, 1=erase above — skip for now
  } else if (cmd === 'K') {
    eraseToEOL();
  } else if (cmd === 'A') {
    _cy = Math.max(0, _cy - getParam(0, 1));
  } else if (cmd === 'B') {
    _cy = Math.min(ROWS - 1, _cy + getParam(0, 1));
  } else if (cmd === 'C') {
    _cx = Math.min(COLS - 1, _cx + getParam(0, 1));
  } else if (cmd === 'D') {
    _cx = Math.max(0, _cx - getParam(0, 1));
  } else if (cmd === 'P') {
    // Delete n chars at cursor
    var n2 = getParam(0, 1);
    for (var i = _cx; i < COLS - n2; i++) _grid[_cy][i] = _grid[_cy][i + n2];
    for (var i2 = COLS - n2; i2 < COLS; i2++) _grid[_cy][i2] = ' ';
  } else if (cmd === 'G') {
    // Cursor horizontal absolute
    _cx = Math.max(0, Math.min(COLS - 1, getParam(0, 1) - 1));
  } else if (cmd === 'd') {
    // Cursor vertical absolute
    _cy = Math.max(0, Math.min(ROWS - 1, getParam(0, 1) - 1));
  }
  // h, l (mode set/reset), r (scroll region), etc. — ignore
}

function feed(data) {
  for (var i = 0; i < data.length; i++) {
    var ch = data[i];
    var code = data.charCodeAt(i);

    if (_vt === 0) {
      if (code === 27) {
        _vt = 1;
      } else if (code === 13) {
        // CR
        _cx = 0;
      } else if (code === 10) {
        // LF
        newline();
      } else if (code === 8) {
        // Backspace
        if (_cx > 0) _cx--;
      } else if (code === 7) {
        // Bell — ignore
      } else if (code === 9) {
        // Tab — advance to next 8-column stop
        _cx = Math.min(COLS - 1, (_cx + 8) & ~7);
      } else if (code >= 32 && code < 127) {
        putChar(ch);
      }
    } else if (_vt === 1) {
      // After ESC
      if (ch === '[') {
        _vt = 2;
        _params = '';
        _priv = false;
      } else if (ch === '(' || ch === ')' || ch === '*' || ch === '+') {
        _vt = 3; // charset designator, skip next byte
      } else if (ch === 'M') {
        // Reverse index — scroll down if at top
        if (_cy > 0) _cy--; else { _grid.unshift([]); for (var c3 = 0; c3 < COLS; c3++) _grid[0].push(' '); _grid.pop(); }
        _vt = 0;
      } else if (ch === 'c') {
        // Reset terminal
        clearScreen();
        _vt = 0;
      } else {
        _vt = 0;
      }
    } else if (_vt === 2) {
      // CSI parameter accumulation
      if (ch === '?') {
        _priv = true;
      } else if ((code >= 48 && code <= 57) || ch === ';') {
        _params += ch;
      } else {
        csiDispatch(ch);
        _vt = 0;
      }
    } else if (_vt === 3) {
      // Skip one byte for charset designation
      _vt = 0;
    }
  }
}

// ── Row serialization ───────────────────────────────────────────

function rowToString(r) {
  var cells = _grid[r];
  var end = COLS - 1;
  while (end > 0 && cells[end] === ' ') end--;
  var s = '';
  for (var c4 = 0; c4 <= end; c4++) s += cells[c4];
  return s;
}

function flushRows() {
  setRow0(rowToString(0));
  setRow1(rowToString(1));
  setRow2(rowToString(2));
  setRow3(rowToString(3));
  setRow4(rowToString(4));
  setRow5(rowToString(5));
  setRow6(rowToString(6));
  setRow7(rowToString(7));
  setRow8(rowToString(8));
  setRow9(rowToString(9));
  setRow10(rowToString(10));
  setRow11(rowToString(11));
  setRow12(rowToString(12));
  setRow13(rowToString(13));
  setRow14(rowToString(14));
  setRow15(rowToString(15));
  setRow16(rowToString(16));
  setRow17(rowToString(17));
  setRow18(rowToString(18));
  setRow19(rowToString(19));
  setRow20(rowToString(20));
  setRow21(rowToString(21));
  setRow22(rowToString(22));
  setRow23(rowToString(23));
  // Push cursor position so TSZ can show the cursor box
  setPtyCol(_cx);
  setPtyRow(_cy);
}

// ── Poll loop ───────────────────────────────────────────────────

function poll() {
  if (!__pty_alive()) return;
  var data = __pty_read();
  if (data !== undefined && data.length > 0) {
    feed(data);
    flushRows();
  }
}

// ── Init ────────────────────────────────────────────────────────

initGrid();
var result = __pty_open(80, 24);
if (result >= 0) {
  setInterval(poll, 50);
  console.log('[pty] opened PTY, polling every 50ms');
} else {
  console.log('[pty] __pty_open failed');
}
