import { Page, Header, Title, Subtitle, TermContainer, StatusBar, StatusLabel, StatusValue } from './pty_test_cls';

function App() {
  return (
    <C.Page>
      <C.Header>
        <C.Title>PTY Test</C.Title>
        <C.Subtitle>Terminal emulator via Render surface — click to focus, type to interact</C.Subtitle>
      </C.Header>

      <C.TermContainer>
        <Render src="app:xterm -fa Monospace -fs 11 -geometry 160x40" style={{ flexGrow: 1 }} />
      </C.TermContainer>

      <C.StatusBar>
        <C.StatusLabel>Backend:</C.StatusLabel>
        <C.StatusValue>Xvfb + XShm + XTest</C.StatusValue>
        <C.StatusLabel>PTY:</C.StatusLabel>
        <C.StatusValue>xterm forkpty → /bin/bash</C.StatusValue>
      </C.StatusBar>
    </C.Page>
  );
}
