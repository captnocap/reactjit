classifier Term(Box) {
  width: '100%';
  height: '100%';
  backgroundColor: '#0d1117';
  padding: 8;
}

classifier TermInner(Box) {
  flexGrow: 1;
  backgroundColor: '#0d1117';
  overflow: 'hidden';
}

classifier Row(Box) {
  flexDirection: 'row';
  height: 18;
}

classifier Cell(Text) {
  fontSize: 13;
  color: '#c9d1d9';
  fontFamily: 'monospace';
}

classifier Cursor(Box) {
  width: 8;
  height: 14;
  backgroundColor: '#c9d1d9';
}
