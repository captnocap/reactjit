classifier Page(Box) {
  width: '100%';
  height: '100%';
  backgroundColor: '#0d1117';
  padding: 16;
  gap: 12;
}

classifier Header(Box) {
  flexDirection: 'row';
  alignItems: 'center';
  gap: 12;
}

classifier Title(Text) {
  fontSize: 20;
  color: '#e6edf3';
}

classifier Subtitle(Text) {
  fontSize: 13;
  color: '#8b949e';
}

classifier TermContainer(Box) {
  flexGrow: 1;
  backgroundColor: '#000000';
  borderRadius: 6;
  borderWidth: 1;
  borderColor: '#30363d';
  overflow: 'hidden';
}

classifier StatusBar(Box) {
  flexDirection: 'row';
  gap: 16;
  alignItems: 'center';
  padding: 8;
  backgroundColor: '#161b22';
  borderRadius: 6;
  borderWidth: 1;
  borderColor: '#30363d';
}

classifier StatusLabel(Text) {
  fontSize: 11;
  color: '#6e7681';
}

classifier StatusValue(Text) {
  fontSize: 11;
  color: '#58a6ff';
}
