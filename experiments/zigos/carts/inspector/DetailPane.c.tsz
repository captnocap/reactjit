import {
  DetailPaneScroll,
  DetailStack,
  HeroCard,
  HeroRow,
  HeroTitle,
  HeroCopy,
  HeroCode,
  MetricGrid,
  FlexPreview,
  FlexPreviewHeader,
  FlexTrack,
  FlexItemTree,
  FlexItemDetail,
  FlexItemLabel,
  PropertyList,
  BoxModelContainer,
  BoxModelMargin, BoxModelMarginLabel, BoxModelMarginRow,
  BoxModelPadding, BoxModelPaddingLabel, BoxModelPaddingRow,
  BoxModelContent, BoxModelContentLabel, BoxModelLayerLabel,
  BoxModelValue, BoxModelValueDim,
  ProvenanceRow, ProvenanceAxis, ProvenanceChain, ProvenanceResult, ProvenanceSource,
  ChildrenList, ChildRow, ChildName, ChildDims,
  HandlersList, HandlerRow, HandlerName, HandlerSnippet,
  ParentLink, ParentArrow, ParentName, ParentDims,
  AddPropertyBtn, AddPropertyLabel,
} from './style_cls';
import { Badge } from './Badge.c';
import { DetailSection } from './DetailSection.c';
import { MetricCard } from './MetricCard.c';
import { PropertyRow } from './PropertyRow.c';

function DetailPane() {
  return (
    <C.DetailPaneScroll>
      <C.DetailStack>
        <C.HeroCard>
          <C.HeroRow>
            <C.HeroTitle>{'<DetailPane>'}</C.HeroTitle>
            <Badge label="ScrollView" tone={1} />
            <Badge label="selected" tone={2} />
            <Badge label="flexGrow 1" tone={0} />
          </C.HeroRow>
          <C.HeroCopy>Selected node detail surface for box model, sizing, style, and structure.</C.HeroCopy>
          <C.HeroCode>Inspector.tsz / ElementsPage.c.tsz / DetailPane.c.tsz</C.HeroCode>
          <C.ParentLink>
            <C.ParentArrow>{`\u2190`}</C.ParentArrow>
            <C.ParentName>{'<ElementsPage>'}</C.ParentName>
            <C.ParentDims>810x600</C.ParentDims>
          </C.ParentLink>
        </C.HeroCard>

        <DetailSection title="box model" hint="margin / padding / content">
          <C.BoxModelContainer>
            <C.BoxModelMargin>
              <C.BoxModelLayerLabel>margin</C.BoxModelLayerLabel>
              <C.BoxModelMarginRow>
                <C.BoxModelValueDim>0</C.BoxModelValueDim>
                <C.BoxModelMarginLabel>top: 0</C.BoxModelMarginLabel>
                <C.BoxModelValueDim>0</C.BoxModelValueDim>
              </C.BoxModelMarginRow>
              <C.BoxModelPadding>
                <C.BoxModelLayerLabel>padding</C.BoxModelLayerLabel>
                <C.BoxModelPaddingRow>
                  <C.BoxModelValueDim>14</C.BoxModelValueDim>
                  <C.BoxModelPaddingLabel>top: 14</C.BoxModelPaddingLabel>
                  <C.BoxModelValueDim>14</C.BoxModelValueDim>
                </C.BoxModelPaddingRow>
                <C.BoxModelContent>
                  <C.BoxModelContentLabel>480 x 572</C.BoxModelContentLabel>
                </C.BoxModelContent>
                <C.BoxModelPaddingRow>
                  <C.BoxModelValueDim>14</C.BoxModelValueDim>
                  <C.BoxModelPaddingLabel>bottom: 14</C.BoxModelPaddingLabel>
                  <C.BoxModelValueDim>14</C.BoxModelValueDim>
                </C.BoxModelPaddingRow>
              </C.BoxModelPadding>
              <C.BoxModelMarginRow>
                <C.BoxModelValueDim>0</C.BoxModelValueDim>
                <C.BoxModelMarginLabel>bottom: 0</C.BoxModelMarginLabel>
                <C.BoxModelValueDim>0</C.BoxModelValueDim>
              </C.BoxModelMarginRow>
            </C.BoxModelMargin>
          </C.BoxModelContainer>
        </DetailSection>

        <DetailSection title="sizing" hint="width / height / position">
          <C.ProvenanceRow>
            <C.ProvenanceAxis>W</C.ProvenanceAxis>
            <C.ProvenanceChain>{`flex: parent 810 \u2192 basis 0 + grow 1 \u2192 free 480 \u2192`}</C.ProvenanceChain>
            <C.ProvenanceResult>480px</C.ProvenanceResult>
          </C.ProvenanceRow>
          <C.ProvenanceRow>
            <C.ProvenanceSource>{`  flexGrow: 1, flexBasis: 0, parent inner: 810 - tree 330 = 480`}</C.ProvenanceSource>
          </C.ProvenanceRow>
          <C.ProvenanceRow>
            <C.ProvenanceAxis>H</C.ProvenanceAxis>
            <C.ProvenanceChain>{`parent: outer 638 \u2192 padding 38 \u2192 inner 600 \u2192`}</C.ProvenanceChain>
            <C.ProvenanceResult>600px</C.ProvenanceResult>
          </C.ProvenanceRow>
          <C.ProvenanceRow>
            <C.ProvenanceSource>{`  stretch cross-axis: parent column height minus tab bar`}</C.ProvenanceSource>
          </C.ProvenanceRow>
          <C.ProvenanceRow>
            <C.ProvenanceAxis>X</C.ProvenanceAxis>
            <C.ProvenanceChain>{`tree 330 + divider 1 \u2192`}</C.ProvenanceChain>
            <C.ProvenanceResult>331</C.ProvenanceResult>
          </C.ProvenanceRow>
          <C.ProvenanceRow>
            <C.ProvenanceAxis>Y</C.ProvenanceAxis>
            <C.ProvenanceChain>{`tab bar 38 \u2192`}</C.ProvenanceChain>
            <C.ProvenanceResult>38</C.ProvenanceResult>
          </C.ProvenanceRow>
        </DetailSection>

        <DetailSection title="layout" hint="split view">
          <C.MetricGrid>
            <MetricCard label="Direction" value="row" hint="tree and detail panes" />
            <MetricCard label="Tree Width" value="330px" hint="fixed pane" />
            <MetricCard label="Detail Width" value="flexGrow 1" hint="fills remaining space" />
          </C.MetricGrid>
          <C.FlexPreview>
            <C.FlexPreviewHeader>distribution preview</C.FlexPreviewHeader>
            <C.FlexTrack>
              <C.FlexItemTree>
                <C.FlexItemLabel>Tree pane</C.FlexItemLabel>
              </C.FlexItemTree>
              <C.FlexItemDetail>
                <C.FlexItemLabel>Detail flex region</C.FlexItemLabel>
              </C.FlexItemDetail>
            </C.FlexTrack>
          </C.FlexPreview>
        </DetailSection>

        <DetailSection title="style" hint="editable">
          <C.PropertyList>
            <PropertyRow name="overflow" value="scroll" note="detail surface owns vertical scroll" />
            <PropertyRow name="padding" value="10" note="document inset for section rhythm" />
            <PropertyRow name="backgroundColor" value="#0c1018" note="detail pane base tone" accent={1} />
            <PropertyRow name="gap" value="0" note="sections stack directly; spacing lives inside groups" />
            <PropertyRow name="borderColor" value="#1a2030" note="quiet dividers between groups" />
            <PropertyRow name="flexGrow" value="1" note="fills remaining horizontal space" />
            <PropertyRow name="flexBasis" value="0" note="starts from zero, grows into allocation" />
          </C.PropertyList>
          <C.AddPropertyBtn>
            <C.AddPropertyLabel>[+ add property]</C.AddPropertyLabel>
          </C.AddPropertyBtn>
        </DetailSection>

        <DetailSection title="children" hint="direct children">
          <C.ChildrenList>
            <C.ChildRow><C.ChildName>{'<HeroCard>'}</C.ChildName><C.ChildDims>452x86</C.ChildDims></C.ChildRow>
            <C.ChildRow><C.ChildName>{'<DetailSection>'}</C.ChildName><C.ChildDims>452x168</C.ChildDims></C.ChildRow>
            <C.ChildRow><C.ChildName>{'<DetailSection>'}</C.ChildName><C.ChildDims>452x142</C.ChildDims></C.ChildRow>
            <C.ChildRow><C.ChildName>{'<DetailSection>'}</C.ChildName><C.ChildDims>452x118</C.ChildDims></C.ChildRow>
            <C.ChildRow><C.ChildName>{'<DetailSection>'}</C.ChildName><C.ChildDims>452x156</C.ChildDims></C.ChildRow>
            <C.ChildRow><C.ChildName>{'<DetailSection>'}</C.ChildName><C.ChildDims>452x176</C.ChildDims></C.ChildRow>
            <C.ChildRow><C.ChildName>{'<DetailSection>'}</C.ChildName><C.ChildDims>452x84</C.ChildDims></C.ChildRow>
            <C.ChildRow><C.ChildName>{'<DetailSection>'}</C.ChildName><C.ChildDims>452x96</C.ChildDims></C.ChildRow>
          </C.ChildrenList>
        </DetailSection>

        <DetailSection title="handlers" hint="event callbacks">
          <C.HandlersList>
            <C.HandlerRow><C.HandlerName>onScroll</C.HandlerName><C.HandlerSnippet>{`(e) => updateScrollY(e.y)`}</C.HandlerSnippet></C.HandlerRow>
            <C.HandlerRow><C.HandlerName>onLayout</C.HandlerName><C.HandlerSnippet>{`(e) => measureContent(e)`}</C.HandlerSnippet></C.HandlerRow>
          </C.HandlersList>
        </DetailSection>

        <DetailSection title="structure" hint="ownership">
          <C.PropertyList>
            <PropertyRow name="parent" value="<ElementsPage>" note="split shell that owns the left and right panes" />
            <PropertyRow name="children" value="8 nodes" note="hero card plus 7 detail sections" />
            <PropertyRow name="render count" value="8" note="reactive — re-rendered on selection change" accent={1} />
            <PropertyRow name="node id" value="#42" note="stable runtime identifier" />
          </C.PropertyList>
        </DetailSection>

      </C.DetailStack>
    </C.DetailPaneScroll>
  );
}
