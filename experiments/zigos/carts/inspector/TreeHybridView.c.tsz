import { TreeStack, TreeRow, TreeDim } from './style_cls';

// treeNodes object array is declared in Inspector.tsz, accessible here

function TreeHybridView() {
  return (
    <C.TreeStack>
      {treeNodes.map((node) => (
        <C.TreeRow>
          <Text fontSize={11} color={node.tagColor}>{node.tag}</Text>
          <C.TreeDim>{node.dim}</C.TreeDim>
        </C.TreeRow>
      ))}
    </C.TreeStack>
  );
}
