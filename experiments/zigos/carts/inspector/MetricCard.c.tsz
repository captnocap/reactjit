import { MetricCardBox, MetricLabel, MetricValue, MetricHint } from './style_cls';

function MetricCard({ label, value, hint }) {
  return (
    <C.MetricCardBox>
      <C.MetricLabel>{label}</C.MetricLabel>
      <C.MetricValue>{value}</C.MetricValue>
      {hint && <C.MetricHint>{hint}</C.MetricHint>}
    </C.MetricCardBox>
  );
}
