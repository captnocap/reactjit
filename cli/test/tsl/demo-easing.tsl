// Easing functions — the kind of thing you'd drop into lua/easing.lua
// and call from an animation system at 60fps

const PI = Math.PI

export function linear(t: number): number {
  return t
}

export function easeInQuad(t: number): number {
  return t * t
}

export function easeOutQuad(t: number): number {
  return t * (2 - t)
}

export function easeInOutCubic(t: number): number {
  if (t < 0.5) {
    return 4 * t * t * t
  } else {
    return 1 - (-2 * t + 2) ** 3 / 2
  }
}

export function easeOutElastic(t: number): number {
  if (t === 0 || t === 1) {
    return t
  }
  return 2 ** (-10 * t) * Math.sin((t * 10 - 0.75) * (2 * PI / 3)) + 1
}

export function easeOutBounce(t: number): number {
  const n1 = 7.5625
  const d1 = 2.75

  if (t < 1 / d1) {
    return n1 * t * t
  } else if (t < 2 / d1) {
    t = t - 1.5 / d1
    return n1 * t * t + 0.75
  } else if (t < 2.5 / d1) {
    t = t - 2.25 / d1
    return n1 * t * t + 0.9375
  } else {
    t = t - 2.625 / d1
    return n1 * t * t + 0.984375
  }
}

// Interpolate between two values using an easing function
export function lerp(a: number, b: number, t: number, easeFn?: (t: number) => number): number {
  const eased = easeFn ? easeFn(t) : t
  return a + (b - a) * eased
}
