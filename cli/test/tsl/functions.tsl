// Named function
function add(a: number, b: number): number {
  return a + b
}

// Arrow function assigned to const
const multiply = (a: number, b: number): number => {
  return a * b
}

// Expression arrow
const double = (x: number) => x * 2

// Rest params
function sum(...args: number[]) {
  let total = 0
  for (const n of args) {
    total = total + n
  }
  return total
}

// Export
export function greet(name: string) {
  return "hello " + name
}
