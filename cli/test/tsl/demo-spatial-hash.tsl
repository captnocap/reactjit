// Spatial hash grid — fast broad-phase collision detection
// Drop this into lua/ and use it from any game effect

interface Entity {
  id: number
  x: number
  y: number
  w: number
  h: number
}

const cellSize = 64

function keyFor(cx: number, cy: number): string {
  return `${cx},${cy}`
}

export function create() {
  return {
    cells: {} as Record<string, number[]>,
    entityCell: {} as Record<number, string[]>,
  }
}

export function clear(grid: any) {
  grid.cells = {}
  grid.entityCell = {}
}

export function insert(grid: any, entity: Entity) {
  const x1 = Math.floor(entity.x / cellSize)
  const y1 = Math.floor(entity.y / cellSize)
  const x2 = Math.floor((entity.x + entity.w) / cellSize)
  const y2 = Math.floor((entity.y + entity.h) / cellSize)

  const keys: string[] = []

  for (let cx = x1; cx <= x2; cx++) {
    for (let cy = y1; cy <= y2; cy++) {
      const key = keyFor(cx, cy)
      if (!grid.cells[key]) {
        grid.cells[key] = []
      }
      grid.cells[key].push(entity.id)
      keys.push(key)
    }
  }

  grid.entityCell[entity.id] = keys
}

export function query(grid: any, x: number, y: number, w: number, h: number): number[] {
  const x1 = Math.floor(x / cellSize)
  const y1 = Math.floor(y / cellSize)
  const x2 = Math.floor((x + w) / cellSize)
  const y2 = Math.floor((y + h) / cellSize)

  const seen: Record<number, boolean> = {}
  const result: number[] = []

  for (let cx = x1; cx <= x2; cx++) {
    for (let cy = y1; cy <= y2; cy++) {
      const key = keyFor(cx, cy)
      const cell = grid.cells[key]
      if (cell) {
        for (const id of cell) {
          if (!seen[id]) {
            seen[id] = true
            result.push(id)
          }
        }
      }
    }
  }

  return result
}
