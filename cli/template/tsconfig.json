{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@reactjit/core": ["./reactjit/shared/src"],
      "@reactjit/native": ["./reactjit/native/src"],
      "@reactjit/router": ["./reactjit/router/src"],
      "@reactjit/storage": ["./reactjit/storage/src"],
    }
  },
  "include": ["src"]
}
