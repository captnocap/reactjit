{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@reactjit/core": ["./reactjit/core/src"],
      "@reactjit/renderer": ["./reactjit/renderer/src"],
      "@reactjit/theme": ["./reactjit/theme/src"],
      "@reactjit/router": ["./reactjit/router/src"],
      "@reactjit/storage": ["./reactjit/storage/src"],
      "@reactjit/storage/*": ["./reactjit/storage/src/*"],
      "@reactjit/ai": ["./reactjit/ai/src"],
      "@reactjit/layouts": ["./reactjit/layouts/src"],
      "@reactjit/server": ["./reactjit/server/src"],
      "@reactjit/crypto": ["./reactjit/crypto/src"],
      "@reactjit/3d": ["./reactjit/3d/src"],
      "@reactjit/audio": ["./reactjit/audio/src"],
      "@reactjit/controls": ["./reactjit/controls/src"],
      "@reactjit/convert": ["./reactjit/convert/src"],
      "@reactjit/data": ["./reactjit/data/src"],
      "@reactjit/geo": ["./reactjit/geo/src"],
      "@reactjit/icons": ["./reactjit/icons/src"],
      "@reactjit/imaging": ["./reactjit/imaging/src"],
      "@reactjit/math": ["./reactjit/math/src"],
      "@reactjit/media": ["./reactjit/media/src"],
      "@reactjit/privacy": ["./reactjit/privacy/src"],
      "@reactjit/rss": ["./reactjit/rss/src"],
      "@reactjit/terminal": ["./reactjit/terminal/src"],
      "@reactjit/time": ["./reactjit/time/src"],
      "@reactjit/apis": ["./reactjit/apis/src"],
      "@reactjit/presentation": ["./reactjit/presentation/src"],
      "@reactjit/webhooks": ["./reactjit/webhooks/src"]
    }
  },
  "include": [
    "src"
  ]
}
