el(18, 'Ar', 'Argon',         39.948,  'noble-gas',            18, 3, 'gas',   null, [2,8,8], '#80D1E3', 83.80,  87.30,  0.0017837)
// ... elements 19-118 follow the same pattern ...

export function getElement(key: number | string) {
  if (typeof key === 'number') return ELEMENTS[key]
  if (typeof key === 'string') {
    const trimmed = key.trim()
    if (trimmed === '') return null
    const normalizedSymbol = trimmed.substring(0, 1).toUpperCase() + trimmed.substring(1).toLowerCase()
    return BY_SYMBOL[trimmed]
      || BY_SYMBOL[normalizedSymbol]
      || BY_ELEMENT_NAME[trimmed.toLowerCase()]
  }
  return null
}

export function getShells(key: number | string) {
  const e = getElement(key)
  return e ? e.shells : null
}

export function valenceElectrons(z: number) {
  const e = ELEMENTS[z]
  if (!e || !e.shells || e.shells.length === 0) return 0
  return e.shells[e.shells.length - 1]
}

export { ELEMENTS, BY_SYMBOL, BY_ELEMENT_NAME }
