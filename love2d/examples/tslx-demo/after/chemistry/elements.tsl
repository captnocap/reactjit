el(8,  'O',  'Oxygen',        15.999,  'nonmetal',             16, 2, 'gas',   3.44, [2,6],   '#FF0D0D', 54.36,  90.20,  0.001429)
el(9,  'F',  'Fluorine',      18.998,  'halogen',              17, 2, 'gas',   3.98, [2,7],   '#90E050', 53.53,  85.03,  0.001696)
