// If/else
const x = 10
if (x > 5) {
  console.log("big")
} else if (x > 0) {
  console.log("small")
} else {
  console.log("zero or negative")
}

// While loop
let count = 0
while (count < 10) {
  count += 1
}

// For-of
const items = [1, 2, 3]
for (const item of items) {
  console.log(item)
}

// For-in
const obj = { a: 1, b: 2 }
for (const key in obj) {
  console.log(key)
}

// Numeric for
for (let i = 1; i <= 10; i++) {
  console.log(i)
}

// Do-while
let n = 0
do {
  n += 1
} while (n < 5)
