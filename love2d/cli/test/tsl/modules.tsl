// Named imports
import { Effects } from "lua.effects"
import { cos, sin, pi } from "lua.math"

// Namespace import
import * as Utils from "lua.effects.util"

// Types are stripped
interface Point {
  x: number
  y: number
}

type Color = string

// Exported functions
export function create(w: number, h: number) {
  const cx = w / 2
  const cy = h / 2
  return { cx, cy, time: 0 }
}

export function update(state: any, dt: number) {
  state.time = state.time + dt
}

// Non-exported (module-private)
function helper(x: number) {
  return x * 2
}
