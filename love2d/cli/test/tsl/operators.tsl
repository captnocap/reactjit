// Equality
const a = 1 === 1
const b = 1 !== 2

// Logical
const c = true && false
const d = true || false
const e = !true

// Arithmetic
const f = 2 ** 3
const g = 10 % 3

// Ternary
const max = a > b ? a : b

// Nullish coalescing
const val = null ?? "default"

// Optional chaining
const len = obj?.name

// typeof
const t = typeof x

// Template literal
const msg = `hello ${name}, you are ${age} years old`

// Compound assignment
let n = 10
n += 5
n -= 2
n *= 3
n /= 2
