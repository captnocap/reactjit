// Test stdlib helper functions
const nums = [10, 20, 30, 40, 50]

// map
const doubled = nums.map((n: number) => n * 2)
console.log("doubled:", doubled[1], doubled[2], doubled[3])

// filter
const big = nums.filter((n: number) => n > 25)
console.log("big:", big[1], big[2], big[3])

// indexOf
const idx = nums.indexOf(30)
console.log("indexOf 30:", idx)

// reverse
const rev = [1, 2, 3]
rev.reverse()
console.log("reversed:", rev[1], rev[2], rev[3])

// Object methods
const obj = { a: 1, b: 2, c: 3 }
const k = Object.keys(obj)
console.log("keys count:", k.length)

// split
const parts = "hello-world-test".split("-")
console.log("split:", parts[1], parts[2], parts[3])

// spread merge
const base = { x: 1, y: 2 }
const extra = { y: 3, z: 4 }
const merged = { ...base, ...extra }
console.log("merged:", merged.x, merged.y, merged.z)
