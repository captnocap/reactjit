// Object literals → tables
const point = { x: 10, y: 20 }

// Shorthand properties
const name = "alice"
const age = 30
const person = { name, age }

// Arrays → tables
const nums = [1, 2, 3, 4, 5]

// Nested
const config = {
  window: {
    width: 800,
    height: 600,
  },
  debug: false,
}

// Object destructuring
const { x, y } = point

// Array destructuring
const [first, second] = nums

// Computed keys
const key = "dynamic"
const map = { [key]: true }
