// A simple particle effect written in TSL
// This should transpile to idiomatic Lua suitable for LuaJIT

import { Effects } from "lua.effects"
import { prop, boolProp } from "lua.effects.util"

interface Particle {
  x: number
  y: number
  vx: number
  vy: number
  life: number
  color: number
}

interface State {
  particles: Particle[]
  time: number
  cx: number
  cy: number
}

const MAX_PARTICLES = 200
const GRAVITY = 98

function create(w: number, h: number, props: any): State {
  return {
    particles: [],
    time: 0,
    cx: w / 2,
    cy: h / 2,
  }
}

function spawnParticle(cx: number, cy: number, speed: number): Particle {
  const angle = math.random() * math.pi * 2
  const vel = speed * (0.5 + math.random() * 0.5)
  return {
    x: cx,
    y: cy,
    vx: math.cos(angle) * vel,
    vy: math.sin(angle) * vel,
    life: 1,
    color: math.random(),
  }
}

function update(state: State, dt: number, props: any, w: number, h: number) {
  const speed = prop(props, "speed", 100)
  const rate = prop(props, "rate", 5)
  const gravity = boolProp(props, "gravity", true)

  state.time = state.time + dt
  state.cx = w / 2
  state.cy = h / 2

  // Spawn new particles
  for (let i = 1; i <= rate; i++) {
    if (state.particles.length < MAX_PARTICLES) {
      state.particles.push(spawnParticle(state.cx, state.cy, speed))
    }
  }

  // Update existing particles
  let writeIdx = 1
  for (let i = 1; i <= state.particles.length; i++) {
    const p = state.particles[i]
    p.x = p.x + p.vx * dt
    p.y = p.y + p.vy * dt
    if (gravity) {
      p.vy = p.vy + GRAVITY * dt
    }
    p.life = p.life - dt * 0.5

    if (p.life > 0) {
      state.particles[writeIdx] = p
      writeIdx += 1
    }
  }

  // Trim dead particles
  for (let i = writeIdx; i <= state.particles.length; i++) {
    state.particles[i] = null
  }
}

function draw(state: State, w: number, h: number) {
  for (const p of state.particles) {
    if (p !== null && p !== undefined) {
      const alpha = p.life
      const size = 2 + p.life * 3
      // Drawing would happen here via love.graphics
    }
  }
}

export { create, update, draw }
