import { Box, Text } from '@reactjit/core';

capability HelloCard {
  schema: {
    title:    { type: "string", default: "Hello", desc: "Card title" },
    subtitle: { type: "string", default: "",      desc: "Card subtitle" },
  }

  render(props) {
    return (
      <>
        <Text style={{ fontSize: 24, color: "#88c0d0" }}>{props.title}</Text>
        <Text style={{ fontSize: 14, color: "#d8dee9" }}>{props.subtitle}</Text>
      </>
    );
  }
}
