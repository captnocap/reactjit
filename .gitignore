# ── Build artifacts ──────────────────────────────────────
.zig-cache/
zig-out/
zig-out-win/
dist/
node_modules/
*.love
bundle.js

# ── Love2D stack (love2d/) ──────────────────────────────
love2d/cli/runtime/
love2d/.rjit-lint-cache.json

# Love2D example runtime copies (regenerated by `reactjit update`)
love2d/examples/*/reactjit/
love2d/examples/*/lua/
love2d/examples/*/lib/
love2d/examples/*/fonts/
love2d/examples/*/bin/
love2d/examples/*/data/

# Web landing page runtime copies
love2d/web/reactjit/
love2d/web/lua
love2d/web/lib/
love2d/web/fonts/
love2d/web/bin/
love2d/web/love/
love2d/web/node_modules/
love2d/web/logo.png

# Storybook runtime copies (reads from source-of-truth directly)
love2d/storybook/lua/
love2d/storybook/reactjit/
love2d/storybook/lib/
love2d/storybook/bin/
love2d/storybook/data/
love2d/storybook/love/data/

# Font binaries (managed by CLI)
love2d/fonts/
love2d/cli/runtime/fonts/

# QuickJS build artifacts
love2d/libquickjs/
love2d/quickjs/

# llama.cpp build artifacts
love2d/llama.cpp/
*.so
*.so.*
*.dylib
!love2d/lua/emulator/libagnes.so

# Platform binaries
love2d/bin/

# ── TSZ stack (tsz/) ────────────────────────────────────
# Generated app output (compiler writes this)
tsz/runtime/generated_app.zig
tsz/runtime/ffi_libs.txt

# ── General ─────────────────────────────────────────────
# Generated files
src/generated/content.json
screenshot_*.png

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp
*.swo

# Cloned third-party sources
love2d/third_party/luajit/

# Environment variables & secrets
.env
.env.*
!.env.example

# Experiments
love2d/experiments/cuttlefish/*
!love2d/experiments/cuttlefish/setup.sh
love2d/experiments/cartridge-os/dev-key.*
love2d/experiments/cartridge-os/init_pubkey.h
love2d/experiments/cartridge-os/*.cart

# Local development
.claude/settings.local.json
.claude/local/
.claude-overflow/
*.local

# Logs and databases
*.log
npm-debug.log*
*.db
*.sqlite

# Testing
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# Vendor
love2d/vendor/

# Netlify
.netlify

# Game server binaries (too large)
love2d/examples/game-servers/source-server/
love2d/storybook/recording_*
love2d/storybook/screenshot_*

# Large binary assets
love2d/experiments/llm/models/*.gguf
love2d/storybook/love/fonts/cjk/
love2d/storybook/fonts/cjk/
love2d/data/*.db
