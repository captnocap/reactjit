{
  "TSZ Component": {
    "prefix": "tsz-component",
    "body": [
      "function ${1:App}() {",
      "  return (",
      "    <Box style={{ width: '100%', height: '100%', flexDirection: 'column' }}>",
      "      $0",
      "    </Box>",
      "  );",
      "}"
    ],
    "description": "TSZ component function with root Box"
  },
  "TSZ State": {
    "prefix": "tsz-state",
    "body": [
      "const [${1:value}, set${1/(.*)/${1:/capitalize}/}] = useState(${2:0});"
    ],
    "description": "TSZ useState declaration"
  },
  "TSZ Array State": {
    "prefix": "tsz-array-state",
    "body": [
      "const [${1:items}, set${1/(.*)/${1:/capitalize}/}] = useState([{ ${2:text}: '${3}', ${4:color}: 0x${5:ffffff} }]);"
    ],
    "description": "TSZ useState with object array"
  },
  "TSZ Classifier": {
    "prefix": "tsz-classifier",
    "body": [
      "classifier ${1:MyStyle}(${2:Box}) {",
      "  style: {",
      "    ${3:backgroundColor}: '${4:#1a1b26}',",
      "    ${5:padding}: ${6:16},",
      "    ${7:borderRadius}: ${8:8}",
      "  }",
      "}"
    ],
    "description": "TSZ classifier (shared style class)"
  },
  "TSZ Script Import": {
    "prefix": "tsz-script",
    "body": [
      "import { ${1:data} } from \"./${2:filename}.script\";"
    ],
    "description": "Import a .script.tsz file"
  },
  "TSZ Pressable": {
    "prefix": "tsz-pressable",
    "body": [
      "<Pressable onPress={() => { ${1:handler} }} style={{ ${2:backgroundColor: '#7aa2f7', borderRadius: 4, padding: 8} }}>",
      "  <Text fontSize={${3:14}} color=\"${4:#fff}\">${5:Button}</Text>",
      "</Pressable>"
    ],
    "description": "Pressable button with text"
  },
  "TSZ ScrollView": {
    "prefix": "tsz-scroll",
    "body": [
      "<ScrollView style={{ flexGrow: 1${1:, padding: 16} }}>",
      "  $0",
      "</ScrollView>"
    ],
    "description": "ScrollView container"
  },
  "TSZ Map": {
    "prefix": "tsz-map",
    "body": [
      "{${1:items}.map((${2:item}) => (",
      "  <Box style={{ ${3:marginBottom: 4} }}>",
      "    <Text fontSize={${4:14}} color={${2}.${5:color}}>{${2}.${6:text}}</Text>",
      "  </Box>",
      "))}"
    ],
    "description": "Map over array state with JSX"
  },
  "TSZ Text": {
    "prefix": "tsz-text",
    "body": [
      "<Text fontSize={${1:14}} color=\"${2:#c0caf5}\">${3:text}</Text>"
    ],
    "description": "Text element with fontSize and color"
  },
  "TSZ TextInput": {
    "prefix": "tsz-input",
    "body": [
      "<TextInput placeholder=\"${1:Enter text...}\" onChangeText={(text) => { set${2:Value}(text) }} />"
    ],
    "description": "TextInput with change handler"
  }
}
