{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TSZ",
  "scopeName": "source.tsz",
  "patterns": [
    { "include": "#comments" },
    { "include": "#import-statement" },
    { "include": "#classifier-block" },
    { "include": "#function-declaration" },
    { "include": "#use-state" },
    { "include": "#jsx" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.tsz", "match": "//.*$" },
        { "name": "comment.block.tsz", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "import-statement": {
      "match": "\\b(import)\\s+\\{([^}]*)\\}\\s+(from)\\s+\"([^\"]*)\"",
      "captures": {
        "1": { "name": "keyword.control.import.tsz" },
        "2": { "name": "variable.other.readwrite.tsz" },
        "3": { "name": "keyword.control.from.tsz" },
        "4": { "name": "string.quoted.double.tsz" }
      }
    },
    "classifier-block": {
      "begin": "\\b(classifier)\\s+([A-Z]\\w*)\\s*\\(\\s*(\\w+)\\s*\\)\\s*\\{",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.other.classifier.tsz" },
        "2": { "name": "entity.name.type.classifier.tsz" },
        "3": { "name": "support.type.primitive.tsz" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#style-properties" }
      ]
    },
    "function-declaration": {
      "match": "\\b(function)\\s+([A-Za-z_]\\w*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.other.function.tsz" },
        "2": { "name": "entity.name.function.tsz" }
      }
    },
    "use-state": {
      "match": "\\b(const)\\s+\\[\\s*(\\w+)\\s*,\\s*(set\\w+)\\s*\\]\\s*=\\s*(useState)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.other.const.tsz" },
        "2": { "name": "variable.other.readwrite.tsz" },
        "3": { "name": "entity.name.function.setter.tsz" },
        "4": { "name": "support.function.use-state.tsz" }
      }
    },
    "jsx": {
      "patterns": [
        {
          "name": "meta.tag.tsz",
          "begin": "(<)(/?)(Box|Text|Pressable|ScrollView|TextInput|Image|Canvas|Graph|Effect|Video|Render|Route|Routes|3D\\.\\w+|Terminal|C\\.[A-Z]\\w*|[A-Z]\\w*)",
          "end": "/?>",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.tsz" },
            "2": { "name": "punctuation.definition.tag.close.tsz" },
            "3": { "name": "entity.name.tag.tsz" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.tag.end.tsz" }
          },
          "patterns": [
            { "include": "#jsx-attributes" }
          ]
        },
        {
          "name": "meta.tag.html.tsz",
          "begin": "(<)(/?)([a-z][a-z0-9]*)",
          "end": "/?>",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.tsz" },
            "2": { "name": "punctuation.definition.tag.close.tsz" },
            "3": { "name": "entity.name.tag.html.tsz" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.tag.end.tsz" }
          },
          "patterns": [
            { "include": "#jsx-attributes" }
          ]
        }
      ]
    },
    "jsx-attributes": {
      "patterns": [
        {
          "match": "\\b(style|onPress|onChangeText|onHoverEnter|onHoverExit|onRender|onScroll|href|tooltip|src|placeholder|fontSize|color|letterSpacing|lineHeight|numberOfLines|noWrap|hoverable|type|viewX|viewY|zoom)\\b",
          "name": "entity.other.attribute-name.tsz"
        },
        { "include": "#strings" },
        { "include": "#numbers" },
        {
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#style-properties" },
            { "include": "#variables" }
          ]
        }
      ]
    },
    "style-properties": {
      "match": "\\b(width|height|flexDirection|flexGrow|flexShrink|flexBasis|flexWrap|justifyContent|alignItems|alignSelf|alignContent|gap|padding|paddingLeft|paddingRight|paddingTop|paddingBottom|margin|marginLeft|marginRight|marginTop|marginBottom|backgroundColor|borderRadius|borderWidth|borderColor|opacity|overflow|display|position|top|left|right|bottom|transform|zIndex)\\b",
      "name": "support.type.property-name.tsz"
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.single.tsz", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.tsz", "match": "\\\\." }] },
        { "name": "string.quoted.double.tsz", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.tsz", "match": "\\\\." }] },
        { "name": "string.template.tsz", "begin": "`", "end": "`", "patterns": [
          { "name": "constant.character.escape.tsz", "match": "\\\\." },
          { "begin": "\\$\\{", "end": "\\}", "name": "meta.template.expression.tsz", "patterns": [{ "include": "#variables" }] }
        ]}
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.tsz", "match": "\\b0[xX][0-9a-fA-F]+\\b" },
        { "name": "constant.numeric.tsz", "match": "\\b\\d+(\\.\\d+)?\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.tsz", "match": "\\b(if|else|for|while|return|switch|case|break|continue|import|from|export|default)\\b" },
        { "name": "keyword.other.tsz", "match": "\\b(const|let|var|function|class|new|typeof|instanceof|in|of|void|delete|throw|try|catch|finally)\\b" },
        { "name": "keyword.other.tsz", "match": "\\b(classifier|useState)\\b" }
      ]
    },
    "constants": {
      "match": "\\b(true|false|null|undefined|NaN|Infinity)\\b",
      "name": "constant.language.tsz"
    },
    "operators": {
      "match": "=>|===|!==|==|!=|<=|>=|&&|\\|\\||\\?\\?|\\+\\+|--|\\+=|-=|\\*=|/=",
      "name": "keyword.operator.tsz"
    },
    "variables": {
      "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*\\b",
      "name": "variable.other.readwrite.tsz"
    }
  }
}
