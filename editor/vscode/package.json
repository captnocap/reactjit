{
  "name": "tsz",
  "displayName": "TSZ Language Support",
  "description": "Syntax highlighting, snippets, and diagnostics for .tsz files (TypeScript/JSX → native Zig compiler)",
  "version": "0.1.0",
  "publisher": "reactjit",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages", "Snippets", "Linters"],
  "activationEvents": ["onLanguage:tsz"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tsz",
        "aliases": ["TSZ", "tsz"],
        "extensions": [".tsz"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tsz",
        "scopeName": "source.tsz",
        "path": "./syntaxes/tsz.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tsz",
        "path": "./snippets/tsz.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  }
}
