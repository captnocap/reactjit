#!/usr/bin/env python3
"""Compose autotest screenshots + manifest into a single proof grid image."""
import sys, os, subprocess, datetime
from pathlib import Path
from PIL import Image, ImageDraw, ImageFont

def get_hash(path):
    """Get short sha256 of a file."""
    try:
        out = subprocess.check_output(["sha256sum", str(path)], text=True)
        return out[:12]
    except Exception:
        return "?"

def main():
    if len(sys.argv) < 2:
        print("Usage: scripts/autotest-grid <test_name>")
        print("  e.g.: scripts/autotest-grid d03_conditional_wrapping_map")
        sys.exit(1)

    test_name = sys.argv[1]
    ss_dir = Path(f"tests/screenshots/{test_name}")
    manifest = ss_dir / "manifest.txt"
    if not manifest.exists():
        print("No manifest found. Run autotest first.")
        sys.exit(1)

    # Parse manifest: idx|kind|text|result|x,y,w,h
    # Text field can contain |, so split from the right for result and region
    steps = []
    with open(manifest, errors="replace") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            # Split: first field is idx, second is kind, then text|result|region from the right
            # Skip non-step lines
            if line.startswith("COLOR") or line.startswith("SOURCE") or line.startswith("RESULT") or line.startswith("BORDER_PIXEL"):
                continue
            if "|" not in line:
                continue
            first_pipe = line.index("|")
            idx = int(line[:first_pipe])
            rest = line[first_pipe + 1:]
            second_pipe = rest.index("|")
            kind = rest[:second_pipe]
            rest = rest[second_pipe + 1:]
            # Split from right: last field is region (or empty), second-to-last is PASS/FAIL
            rparts = rest.rsplit("|", 2)
            if len(rparts) == 3:
                text, result, region_str = rparts
            elif len(rparts) == 2:
                text, result = rparts
                region_str = ""
            else:
                continue

            s = {"idx": idx, "kind": kind, "text": text, "result": result, "region": None}
            if region_str:
                coords = region_str.split(",")
                if len(coords) == 4:
                    try:
                        s["region"] = tuple(int(float(c)) for c in coords)
                    except ValueError:
                        pass
            steps.append(s)

    if not steps:
        print("Empty manifest.")
        sys.exit(1)

    # Parse audits from manifest (need these before drawing title)
    color_lines = []
    color_audit_summary = ""
    source_audit_summary = ""
    with open(manifest, errors="replace") as f:
        for line in f:
            line = line.strip()
            if line.startswith("SOURCE_AUDIT|"):
                source_audit_summary = line.replace("SOURCE_AUDIT|", "source: ")
            elif line.startswith("COLOR_AUDIT|"):
                color_audit_summary = line.replace("COLOR_AUDIT|", "colors: ")
            elif line.startswith("COLOR|"):
                parts = line.split("|", 2)
                if len(parts) == 3:
                    color_lines.append((parts[1], parts[2]))

    # Each step maps to a screenshot: step_00 is initial, then one per step
    # For clicks, the screenshot is taken AFTER the settle frame
    # Map: step N → screenshot file
    # step_00.png = initial state (before any steps)
    # Then each step produces a screenshot
    # Screenshot index = step_idx + 1 (because step_00 is initial)

    # Collect available screenshots
    screenshots = sorted(ss_dir.glob("step_*.png"), key=lambda p: int(p.stem.split("_")[1]))
    if not screenshots:
        print("No screenshots found.")
        sys.exit(1)

    # Load first screenshot to get dimensions
    sample = Image.open(screenshots[0])
    thumb_w = 320
    thumb_h = int(sample.height * thumb_w / sample.width)
    sample.close()

    # Layout: grid with label bar on top of each thumbnail
    label_h = 28
    pad = 4
    cols = min(4, len(steps))
    rows = (len(steps) + cols - 1) // cols

    cell_w = thumb_w + pad * 2
    cell_h = thumb_h + label_h + pad * 2

    header_h = 105  # room for metadata + source audit + color audit
    grid_w = cols * cell_w + pad
    grid_h = rows * cell_h + pad + header_h

    grid = Image.new("RGB", (grid_w, grid_h), (30, 30, 30))
    draw = ImageDraw.Draw(grid)

    # Try to load a font
    try:
        font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf", 12)
        title_font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSansMono-Bold.ttf", 16)
        meta_font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf", 10)
    except (OSError, IOError):
        font = ImageFont.load_default()
        title_font = font
        meta_font = font

    # Find test script and source files
    test_script = f"tests/{test_name}.autotest"
    cart_tsz = list(Path("carts").rglob(f"{test_name}.tsz"))
    cart_path = str(cart_tsz[0]) if cart_tsz else "?"

    # Hashes
    compiler_hash = get_hash("zig-out/bin/forge") if Path("zig-out/bin/forge").exists() else "?"
    engine_hash = get_hash("zig-out/lib/libreactjit-core.so") if Path("zig-out/lib/libreactjit-core.so").exists() else "?"
    source_hash = get_hash(cart_path) if cart_path != "?" else "?"
    now = datetime.datetime.now().strftime("%Y-%m-%d %I:%M %p")

    # Pixel-verify border checks against actual screenshots using BORDER_PIXEL lines
    # Format: BORDER_PIXEL|step_idx|x,y,w,h|borderWidth|#rrggbb
    border_pixels = {}
    with open(manifest, errors="replace") as f:
        for line in f:
            line = line.strip()
            if line.startswith("BORDER_PIXEL|"):
                parts = line.split("|")
                if len(parts) >= 5:
                    try:
                        bp_idx = int(parts[1])
                        coords = parts[2].split(",")
                        bx, by, bw, bh = int(float(coords[0])), int(float(coords[1])), int(float(coords[2])), int(float(coords[3]))
                        border_w = int(float(parts[3]))
                        exp_hex = parts[4].strip()
                        border_pixels[bp_idx] = (bx, by, bw, bh, border_w, exp_hex)
                    except (ValueError, IndexError):
                        pass

    def hex_to_rgb(h):
        h = h.lstrip("#")
        return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))

    def color_close(c1, c2, tol=40):
        return all(abs(a - b) <= tol for a, b in zip(c1, c2))

    for step_idx, (bx, by, bw, bh, border_w, exp_hex) in border_pixels.items():
        ss_idx = step_idx + 1
        ss_path = ss_dir / f"step_{ss_idx:02d}.png"
        if not ss_path.exists():
            continue
        try:
            img = Image.open(ss_path)
            exp_rgb = hex_to_rgb(exp_hex)
            # Sample pixels at the outer edge of the border rect
            # Top edge: midpoint of top border
            # Left edge: midpoint of left border
            # Bottom edge: midpoint of bottom border
            # Right edge: midpoint of right border
            mid_x = bx + bw // 2
            mid_y = by + bh // 2
            sample_points = [
                (mid_x, by + border_w // 2),           # top border midpoint
                (mid_x, by + bh - border_w // 2 - 1),  # bottom border midpoint
                (bx + border_w // 2, mid_y),            # left border midpoint
                (bx + bw - border_w // 2 - 1, mid_y),  # right border midpoint
            ]
            matches = 0
            for px, py in sample_points:
                px = max(0, min(img.width - 1, px))
                py = max(0, min(img.height - 1, py))
                pixel = img.getpixel((px, py))[:3]
                if color_close(pixel, exp_rgb):
                    matches += 1

            if matches == 0:
                # No border edge pixel matches expected color — border not painted
                for s in steps:
                    if s["idx"] == step_idx and s["kind"] == "border":
                        s["result"] = "PIXEL_FAIL"
            img.close()
        except Exception:
            pass

    # ── Pixel verification for expect steps ──
    # If the tree says text exists (expect PASS) but the node's region in the
    # screenshot has no rendered content, the text wasn't actually painted.
    # Detection: anti-aliased text always creates 10+ unique RGB colors in its
    # region. A blank region (no text rendered) has 1-3 unique colors (just
    # background). Threshold < 4 has zero false positives across 630 test steps.
    TEXT_UNIQ_THRESHOLD = 4

    for step in steps:
        if step["kind"] != "expect" or step["result"] != "PASS":
            continue
        region = step.get("region")
        if not region:
            continue
        rx, ry, rw, rh = region
        if rw <= 0 or rh <= 0:
            step["result"] = "PIXEL_FAIL"
            print(f"[autotest] PIXEL_FAIL: expect \"{step['text']}\" — not visible in pixels")
            continue
        ss_idx = step["idx"] + 1
        ss_path = ss_dir / f"step_{ss_idx:02d}.png"
        if not ss_path.exists():
            continue
        try:
            img = Image.open(ss_path)
            cx1 = max(0, rx)
            cy1 = max(0, ry)
            cx2 = min(img.width, rx + rw)
            cy2 = min(img.height, ry + rh)
            if cx2 <= cx1 or cy2 <= cy1:
                step["result"] = "PIXEL_FAIL"
                print(f"[autotest] PIXEL_FAIL: expect \"{step['text']}\" — not visible in pixels")
                img.close()
                continue
            crop = img.crop((cx1, cy1, cx2, cy2))
            pixels = list(crop.getdata())  # returns list of RGBA tuples
            uniq = len(set(tuple(p[:3]) for p in pixels))
            if uniq < TEXT_UNIQ_THRESHOLD:
                step["result"] = "PIXEL_FAIL"
                print(f"[autotest] PIXEL_FAIL: expect \"{step['text']}\" — not visible in pixels")
            crop.close()
            img.close()
        except Exception as e:
            print(f"[autotest] pixel check warning: {e}")

    # Read the authoritative RESULT line from manifest, fall back to step counts
    result_passed = 0
    result_total = 0
    result_status = "FAIL"
    has_result_line = False
    for line in open(manifest, errors="replace"):
        line = line.strip()
        if line.startswith("RESULT|"):
            parts = line.split("|")
            if len(parts) >= 4:
                result_passed = int(parts[1])
                result_total = int(parts[2])
                result_status = parts[3]
                has_result_line = True
    # Always recompute from steps — pixel verification may have overridden results
    pixel_fails = sum(1 for s in steps if s["result"] == "PIXEL_FAIL")
    if pixel_fails > 0 or not has_result_line:
        result_passed = sum(1 for s in steps if s["result"] == "PASS")
        result_total = len(steps)
        result_status = "PASS" if result_passed == result_total else "FAIL"

    title_color = (100, 255, 100) if result_status == "PASS" else (255, 80, 80)
    title_text = f"AUTOTEST: {result_passed}/{result_total} passed"
    if result_status == "FAIL":
        title_text += f"  ({result_total - result_passed} FAILED)"
    draw.text((pad + 4, pad + 4), title_text, fill=title_color, font=title_font)

    # Metadata lines
    meta_color = (160, 160, 160)
    draw.text((pad + 4, pad + 26), f"source: {cart_path}  |  script: {test_script}", fill=meta_color, font=meta_font)
    draw.text((pad + 4, pad + 40), f"date: {now}  |  compiler: {compiler_hash}  engine: {engine_hash}  source: {source_hash}", fill=meta_color, font=meta_font)
    # Source audit line
    if source_audit_summary:
        src_missing = "missing" in source_audit_summary and not "0 missing" in source_audit_summary
        src_color = (255, 80, 80) if src_missing else (100, 255, 100)
        draw.text((pad + 4, pad + 54), source_audit_summary, fill=src_color, font=meta_font)

    # Color audit line
    color_y = pad + 54 + (14 if source_audit_summary else 0)
    if color_audit_summary:
        missing_count = sum(1 for c, _ in color_lines if c == "NONE")
        audit_color = (100, 255, 100) if missing_count == 0 else (255, 80, 80)
        draw.text((pad + 4, color_y), color_audit_summary, fill=audit_color, font=meta_font)
        # Show any NONE colors as warnings
        if missing_count > 0:
            warn_x = pad + 4 + len(color_audit_summary) * 7
            missing_texts = [t for c, t in color_lines if c == "NONE"]
            warn = "  missing: " + ", ".join(missing_texts[:5])
            if len(missing_texts) > 5:
                warn += f" (+{len(missing_texts)-5} more)"
            draw.text((warn_x, pad + 54), warn, fill=(255, 150, 80), font=meta_font)

    # Separator line
    draw.line([(pad, header_h - 4), (grid_w - pad, header_h - 4)], fill=(60, 60, 60), width=1)

    for i, step in enumerate(steps):
        col = i % cols
        row = i // cols
        x = pad + col * cell_w
        y = header_h + pad + row * cell_h

        passed = step["result"] == "PASS"
        is_pixel_fail = step["result"] == "PIXEL_FAIL"
        if passed:
            bar_color = (30, 120, 30)
            icon = "\u2713"
        elif is_pixel_fail:
            bar_color = (180, 100, 0)  # orange — tree says yes, pixels say no
            icon = "\u2717"
        else:
            bar_color = (160, 30, 30)
            icon = "\u2717"

        # Label bar
        draw.rectangle([x, y, x + cell_w - pad, y + label_h], fill=bar_color)
        ocr_tag = " [NOT IN PIXELS]" if is_pixel_fail else ""
        label = f"{icon} {i+1}. {step['kind']} \"{step['text']}\"{ocr_tag}"
        if len(label) > 48:
            label = label[:45] + "..."
        draw.text((x + 4, y + 6), label, fill=(255, 255, 255), font=font)

        # Screenshot thumbnail
        # Map step index to screenshot file
        # screenshot index = step_idx + 1 (step_00 is pre-test)
        ss_idx = step["idx"] + 1
        ss_path = ss_dir / f"step_{ss_idx:02d}.png"
        if not ss_path.exists():
            # Try the closest available
            ss_path = screenshots[min(ss_idx, len(screenshots) - 1)]

        try:
            img = Image.open(ss_path)
            # Crop around the node region if available
            region = step.get("region")
            if region:
                rx, ry, rw, rh = region
                # Add generous padding around the node (150px or 3x the node size)
                context = max(150, rw * 3, rh * 3)
                cx1 = max(0, rx - context)
                cy1 = max(0, ry - context)
                cx2 = min(img.width, rx + rw + context)
                cy2 = min(img.height, ry + rh + context)
                img = img.crop((cx1, cy1, cx2, cy2))
            img = img.resize((thumb_w, thumb_h), Image.LANCZOS)
            grid.paste(img, (x + pad, y + label_h))
            img.close()
        except Exception:
            draw.rectangle([x + pad, y + label_h, x + pad + thumb_w, y + label_h + thumb_h],
                          fill=(50, 50, 50))
            draw.text((x + pad + 10, y + label_h + thumb_h // 2), "no screenshot",
                      fill=(150, 150, 150), font=font)

    # Save
    out_path = ss_dir / "proof.png"
    grid.save(str(out_path), "PNG")
    print(f"[autotest] proof grid saved: {out_path} ({grid_w}x{grid_h})")

    # Write verdict file for the bash script
    verdict_path = ss_dir / "verdict.txt"
    with open(verdict_path, "w") as vf:
        vf.write(result_status)

    # Overwrite the RESULT line in manifest with the real result (after pixel verification)
    manifest_lines = open(manifest, errors="replace").readlines()
    with open(manifest, "w") as mf:
        for line in manifest_lines:
            if line.startswith("RESULT|"):
                mf.write(f"RESULT|{result_passed}|{result_total}|{result_status}\n")
            else:
                mf.write(line)


if __name__ == "__main__":
    main()
