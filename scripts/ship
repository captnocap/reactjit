#!/bin/bash
# ship — build a .tsx cart into a self-extracting native binary.
#
# Pipeline:
#   1. esbuild cart/<name>.tsx → bundle.js
#   2. zig build app → zig-out/bin/<name> (ELF, dynamic-linked, bundle embedded)
#   3. Package as self-extracting shell wrapper:
#      - ldd the binary, bundle every non-system .so into a lib/ dir
#      - bundle ld-linux loader
#      - tarball { app.bin, lib/, run } together
#      - prepend shell wrapper that extracts to ~/.cache/reactjit-<name>/<sig>/
#        on first run and execs the real binary via the bundled ld-linux
#
# Result: a single-file shippable binary with zero system dependencies.
# LuaJIT stays dynamic at link time (fast builds) but ships bundled (portable).
#
# Usage:
#   scripts/ship <cart-name>          # release, self-extracting
#   scripts/ship <cart-name> -d       # debug build, skips packaging (raw ELF)
#   --raw is DISABLED: the unpackaged ELF segfaults on startup because the
#   Linux bundle's .so staging happens in the self-extracting shell wrapper.
#   scripts/ship <cart-name> --jsrt   # build the JSRT runtime path instead of V8/QJS
#   scripts/ship <cart-name> --qjs    # build the legacy QJS runtime path instead of V8

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

LOCK_FILE="$REPO_ROOT/.zig-cache/.ship.lock"
mkdir -p "$(dirname "$LOCK_FILE")"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "[ship] another build in progress — waiting for lock..."
    flock 9
    echo "[ship] got lock, proceeding"
fi

NAME="${1:-}"
DEBUG=0
RAW=0
JSRT=0
QJS=0
for arg in "${@:2}"; do
    case "$arg" in
        -d|--debug) DEBUG=1 ;;
        --raw)
            echo "[ship] --raw is disabled." >&2
            echo "[ship]" >&2
            echo "[ship] --raw produced an unpackaged ELF that segfaults 100% of the" >&2
            echo "[ship] time on this platform, because the Linux build depends on the" >&2
            echo "[ship] self-extracting shell wrapper around the ELF to stage its .so" >&2
            echo "[ship] deps before exec. Running the raw ELF skips that staging and" >&2
            echo "[ship] crashes at startup. Use the default packaged binary:" >&2
            echo "[ship]" >&2
            echo "[ship]   ./scripts/ship <cart-name>        # self-extracting (working)" >&2
            echo "[ship]" >&2
            echo "[ship] If you need the raw ELF for ldd or gdb, open zig-out/bin/<name>" >&2
            echo "[ship] AFTER a successful ship — the wrapper keeps the ELF alongside." >&2
            exit 1
            ;;
        --jsrt)     JSRT=1 ;;
        --qjs)      QJS=1 ;;
    esac
done

if [[ -z "$NAME" ]]; then
    echo "Usage: scripts/ship <cart-name> [-d|--jsrt|--qjs]" >&2
    echo "  Cart expected at: cart/<cart-name>.tsx" >&2
    exit 1
fi

# Resolve cart entry: prefer cart/<name>/index.tsx (directory layout), fall
# back to cart/<name>.tsx (single-file cart). Directory wins when both exist.
if [[ -f "cart/${NAME}/index.tsx" ]]; then
    CART_FILE="cart/${NAME}/index.tsx"
elif [[ -f "cart/${NAME}.tsx" ]]; then
    CART_FILE="cart/${NAME}.tsx"
else
    echo "[ship] not found: cart/${NAME}/index.tsx or cart/${NAME}.tsx" >&2
    exit 1
fi

# ── 1a. Recompile all primitive .tslx sources ────────────────────────
# framework/primitives/*.tslx → framework/primitives/generated/*.zig
#                            + runtime/primitives_gen/*.tsx
# Idempotent + cheap; always run so a forgotten edit never gets shipped.
if [[ -d "framework/primitives" ]] && compgen -G "framework/primitives/*.tslx" > /dev/null; then
    echo "[ship] compiling primitives from framework/primitives/*.tslx..."
    node scripts/tslx_compile.mjs --all > /dev/null
fi

# ── 1b. Bundle cart entry via esbuild → bundle-<name>.js ─────────────
# Per-cart bundle path means two parallel ships can't overwrite each other's
# output. v8_app.zig / qjs_app.zig embed `bundle-<app-name>.js` at compile time.
BUNDLE_OUT="bundle-${NAME}.js"

AST_OUT=""
if [[ "$JSRT" -eq 1 ]]; then
    AST_OUT="bundle-${NAME}.ast.lua"
    JSRT_SOURCE="${JSRT_AST_SOURCE:-$CART_FILE}"
    if [[ -z "${JSRT_AST_SOURCE:-}" ]]; then
        echo "[ship] bundling $CART_FILE → $BUNDLE_OUT..."
        BUNDLE_FROM_HARNESS=1 node scripts/internal/cart-bundle.mjs "$CART_FILE" --out "$BUNDLE_OUT"
        JSRT_SOURCE="$BUNDLE_OUT"
    else
        echo "[ship] JSRT AST source override: $JSRT_SOURCE"
    fi
    echo "[ship] parsing $JSRT_SOURCE → $AST_OUT..."
    node scripts/build-jsast.mjs "$JSRT_SOURCE" "$AST_OUT"
else
    echo "[ship] bundling $CART_FILE → $BUNDLE_OUT..."
    BUNDLE_FROM_HARNESS=1 node scripts/internal/cart-bundle.mjs "$CART_FILE" --out "$BUNDLE_OUT"
fi

# ── 2. Compile qjs_app.zig (bundle-<name>.js embedded via @embedFile) ─
OPT_FLAG="-Doptimize=ReleaseFast"
if [[ "$DEBUG" -eq 1 ]]; then
    OPT_FLAG="-Doptimize=Debug"
fi

echo "[ship] compiling native binary..."
APP_SOURCE="v8_app.zig"
QJS_FLAG="-Duse-v8=true"
if [[ "$JSRT" -eq 1 ]]; then
    APP_SOURCE="jsrt_app.zig"
    QJS_FLAG=""
elif [[ "$QJS" -eq 1 ]]; then
    APP_SOURCE="qjs_app.zig"
    QJS_FLAG=""
fi

# Cart-declared capabilities (cart/<name>/cart.json). Currently only
# `customChrome: true` is honoured — the runtime reads it as
# build_options.custom_chrome to decide borderless vs windowed chrome.
# Missing cart.json → no flag passed → default false.
CUSTOM_CHROME_FLAG=""
CART_MANIFEST="cart/${NAME}/cart.json"
if [[ -f "$CART_MANIFEST" ]]; then
    CUSTOM_CHROME=$(node -e "try{const m=JSON.parse(require('fs').readFileSync(process.argv[1],'utf8'));process.stdout.write(m.customChrome===true?'true':'false')}catch(e){process.stdout.write('false')}" "$CART_MANIFEST")
    if [[ "$CUSTOM_CHROME" == "true" ]]; then
        CUSTOM_CHROME_FLAG="-Dcustom-chrome=true"
        echo "[ship] cart manifest: customChrome=true"
    fi
fi

zig build app -Dapp-name="$NAME" -Dapp-source="$APP_SOURCE" $QJS_FLAG $CUSTOM_CHROME_FLAG $OPT_FLAG

RAW_BIN="zig-out/bin/$NAME"
if [[ ! -f "$RAW_BIN" ]]; then
    echo "[ship] build produced no binary: $RAW_BIN" >&2
    exit 1
fi

if [[ "$JSRT" -eq 1 ]]; then
    VERIFY_OUT="$(mktemp)"
    trap 'rm -f "$VERIFY_OUT"' EXIT
    "$RAW_BIN" --dump-ast > "$VERIFY_OUT"
    if ! cmp -s "$AST_OUT" "$VERIFY_OUT"; then
        echo "[ship] JSRT AST verification failed: $RAW_BIN --dump-ast does not match $AST_OUT" >&2
        exit 1
    fi
    rm -f "$VERIFY_OUT"
    trap - EXIT
    echo "[ship] JSRT AST verification passed"
fi

# ── 3. Debug / --raw short-circuit ────────────────────────────────────
# In debug or --raw mode, move the ELF to "$NAME-raw" so zig-out/bin/$NAME
# stays reserved for the self-extracting wrapper. Prevents accidentally
# shipping a blue-icon raw binary because someone (read: claude) forgot
# the flag was still in scope.
if [[ "$DEBUG" -eq 1 ]] || [[ "$RAW" -eq 1 ]]; then
    RAW_OUT="zig-out/bin/${NAME}-raw"
    mv -f "$RAW_BIN" "$RAW_OUT"
    SIZE_MB=$(du -m "$RAW_OUT" | cut -f1)
    echo "[ship] done (raw ELF, ${SIZE_MB}MB) → $RAW_OUT"
    echo "[ship] note: zig-out/bin/$NAME left for wrapped build; run './scripts/ship $NAME' for the shippable form."
    exit 0
fi

# ── 4. Package as self-extracting binary ──────────────────────────────
OS="$(uname -s)"

if [[ "$OS" == "Darwin" ]]; then
    # ── macOS: package as .app bundle ──────────────────────────────
    echo "[ship] packaging macOS .app bundle..."
    APP_BUNDLE="zig-out/bin/${NAME}.app"
    CONTENTS="$APP_BUNDLE/Contents"
    MACOS_DIR="$CONTENTS/MacOS"
    FW_DIR="$CONTENTS/Frameworks"
    rm -rf "$APP_BUNDLE"
    mkdir -p "$MACOS_DIR" "$FW_DIR"
    cp "$RAW_BIN" "$MACOS_DIR/$NAME"

    cat > "$CONTENTS/Info.plist" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>$NAME</string>
    <key>CFBundleIdentifier</key>
    <string>com.reactjit.$NAME</string>
    <key>CFBundleName</key>
    <string>$NAME</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
</dict>
</plist>
PLIST

    # Recursively collect non-system dylibs into Frameworks/
    collect_dylibs() {
        for bin in "$@"; do
            otool -L "$bin" 2>/dev/null | tail -n +2 | awk '{print $1}' | while read -r lib_path; do
                case "$lib_path" in
                    /usr/lib/*|/System/*|@rpath/*|@executable_path/*) continue ;;
                esac
                [ ! -f "$lib_path" ] && continue
                lib_name=$(basename "$lib_path")
                [ -f "$FW_DIR/$lib_name" ] && continue
                cp "$lib_path" "$FW_DIR/$lib_name"
                echo "$lib_name"
            done
        done
    }
    collect_dylibs "$MACOS_DIR/$NAME" >/dev/null
    # Transitive deps from bundled dylibs
    collect_dylibs "$FW_DIR"/*.dylib >/dev/null 2>/dev/null || true

    # Rewrite dylib paths → @executable_path/../Frameworks/
    rewrite_dylib_paths() {
        local bin="$1"
        otool -L "$bin" 2>/dev/null | tail -n +2 | awk '{print $1}' | while read -r lib_path; do
            case "$lib_path" in
                /usr/lib/*|/System/*|@rpath/*|@executable_path/*) continue ;;
            esac
            lib_name=$(basename "$lib_path")
            install_name_tool -change "$lib_path" "@executable_path/../Frameworks/$lib_name" "$bin" 2>/dev/null || true
        done
    }
    rewrite_dylib_paths "$MACOS_DIR/$NAME"
    install_name_tool -add_rpath "@executable_path/../Frameworks" "$MACOS_DIR/$NAME" 2>/dev/null || true

    # Fix each bundled dylib's id + transitive refs
    for dylib in "$FW_DIR"/*.dylib; do
        [ -f "$dylib" ] || continue
        lib_name=$(basename "$dylib")
        install_name_tool -id "@executable_path/../Frameworks/$lib_name" "$dylib" 2>/dev/null || true
        rewrite_dylib_paths "$dylib"
    done

    # Ad-hoc sign (Sequoia requires valid signatures even for unsigned builds)
    codesign --force --sign - --deep "$APP_BUNDLE" 2>/dev/null || true

    LIB_COUNT=$(find "$FW_DIR" -name '*.dylib' 2>/dev/null | wc -l | tr -d ' ')
    SIZE_MB=$(du -sm "$APP_BUNDLE" | cut -f1)
    echo "[ship] done (${SIZE_MB}MB .app bundle, $LIB_COUNT dylibs) → $APP_BUNDLE"
    exit 0
fi

if [[ "$OS" != "Linux" ]]; then
    echo "[ship] packaging not implemented for $OS — leaving raw ELF at $RAW_BIN"
    exit 0
fi

echo "[ship] packaging self-extracting binary..."
TMP_DIR="/tmp/reactjit-dist-$NAME"
LIB_DIR="$TMP_DIR/lib"
rm -rf "$TMP_DIR"
mkdir -p "$LIB_DIR"
cp "$RAW_BIN" "$TMP_DIR/app.bin"

# Walk ldd output, bundle every non-system .so
LIB_COUNT=0
LDD_TMP=$(mktemp)
ldd "$RAW_BIN" > "$LDD_TMP" 2>/dev/null || true
while IFS= read -r line; do
    case "$line" in *linux-vdso*) continue ;; esac
    lib_path=$(echo "$line" | sed -n 's/.* => \([^ ]*\) .*/\1/p')
    [[ -z "$lib_path" ]] && continue
    [[ ! -f "$lib_path" ]] && continue
    real_path=$(readlink -f "$lib_path")
    soname=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*=>.*//')
    [[ -f "$LIB_DIR/$soname" ]] && continue
    cp "$real_path" "$LIB_DIR/$soname"
    LIB_COUNT=$((LIB_COUNT + 1))
done < "$LDD_TMP"
rm -f "$LDD_TMP"

# Bundle the dynamic loader itself
LD_LINUX=$(readlink -f /lib64/ld-linux-x86-64.so.2 2>/dev/null || readlink -f /lib/ld-linux-x86-64.so.2 2>/dev/null || echo "")
if [[ -z "$LD_LINUX" ]] || [[ ! -f "$LD_LINUX" ]]; then
    echo "[ship] WARNING: ld-linux-x86-64.so.2 not found — leaving raw ELF at $RAW_BIN"
    rm -rf "$TMP_DIR"
    exit 0
fi
cp "$LD_LINUX" "$LIB_DIR/ld-linux-x86-64.so.2"

# Launcher that execs the real binary via the bundled loader
cat > "$TMP_DIR/run" << 'LAUNCHER'
#!/bin/sh
DIR="$(cd "$(dirname "$0")" && pwd)"
exec "$DIR/lib/ld-linux-x86-64.so.2" --inhibit-cache --library-path "$DIR/lib" "$DIR/app.bin" "$@"
LAUNCHER
chmod +x "$TMP_DIR/run"

# Tarball + self-extracting wrapper
TARBALL="/tmp/reactjit-${NAME}-payload.tar.gz"
(cd "$TMP_DIR" && tar czf "$TARBALL" .)

# Write wrapper to a staging file, then atomic-rename over the raw ELF.
# Atomic rename works even if the previous binary is currently running —
# the running process keeps its fd to the old inode, the dentry is replaced.
STAGED="${RAW_BIN}.staged"
cat > "$STAGED" << HEADER
#!/bin/sh
set -e
APP_DIR=\${XDG_CACHE_HOME:-\$HOME/.cache}/reactjit-$NAME
SIG=\$(md5sum "\$0" 2>/dev/null | cut -c1-8 || cksum "\$0" | cut -d" " -f1)
CACHE="\$APP_DIR/\$SIG"
if [ ! -f "\$CACHE/.ready" ]; then
  rm -rf "\$APP_DIR"
  mkdir -p "\$CACHE"
  SKIP=\$(awk '/^__ARCHIVE__\$/{print NR + 1; exit}' "\$0")
  tail -n+"\$SKIP" "\$0" | tar xz -C "\$CACHE"
  touch "\$CACHE/.ready"
fi
exec "\$CACHE/run" "\$@"
__ARCHIVE__
HEADER
cat "$TARBALL" >> "$STAGED"
chmod +x "$STAGED"
mv -f "$STAGED" "$RAW_BIN"

SIZE_MB=$(du -m "$RAW_BIN" | cut -f1)
echo "[ship] done (${SIZE_MB}MB self-extracting, $LIB_COUNT libs bundled) → $RAW_BIN"
rm -rf "$TMP_DIR" "$TARBALL"

# ── 5. Post-build snapshot gate ───────────────────────────────────────
# Runs the binary headless with ZIGOS_WITNESS=snapshot so framework/witness.zig
# emits tests/<NAME>.autotest capturing all visible text, pressables, and a
# health line. Counts FAIL lines + runtime errors; any failure deletes the
# binary and exits 1. 1:1 port from tsz/scripts/build.
mkdir -p tests
AUTOTEST_FILE="tests/${NAME}.autotest"
SNAP_STDERR=$(mktemp)
SNAP_T0=$(date +%s%N)
ZIGOS_HEADLESS=1 ZIGOS_WITNESS=snapshot ZIGOS_WITNESS_FILE="$AUTOTEST_FILE" \
    timeout -s KILL 300 "$RAW_BIN" >/dev/null 2>"$SNAP_STDERR" || true
SNAP_T1=$(date +%s%N)
SNAP_MS=$(( (SNAP_T1 - SNAP_T0) / 1000000 ))

RUNTIME_ERRORS=$(grep -cE '^error:|^\[luajit-runtime\]|^\[evalExpr error\]|^\[evalToString error\]|^\[evalLuaMapData error\]|^\[js_on_press\].*error|ReferenceError|SyntaxError|TypeError' "$SNAP_STDERR" 2>/dev/null || true)
RUNTIME_ERRORS=${RUNTIME_ERRORS//[^0-9]/}; RUNTIME_ERRORS=${RUNTIME_ERRORS:-0}
if [ "$RUNTIME_ERRORS" -gt 0 ]; then
    echo "[$NAME] runtime: ${RUNTIME_ERRORS} error(s) detected" >&2
    grep -E '^error:|^\[luajit-runtime\]|^\[eval.*error\]|^\[evalLuaMapData error\]|ReferenceError|SyntaxError|TypeError' "$SNAP_STDERR" | head -10 >&2
fi
grep '^\[snapshot\]' "$SNAP_STDERR" 2>/dev/null || true
# Keep the full snapshot log for post-mortem diagnostics. Not a bypass: binary
# still gets cleaned up on TOTAL_FAILS below; this just preserves stack traces.
SNAP_LOG_KEEP="tests/screenshots/${NAME}/.last-snapshot.log"
mkdir -p "$(dirname "$SNAP_LOG_KEEP")"
cp "$SNAP_STDERR" "$SNAP_LOG_KEEP" 2>/dev/null || true
rm -f "$SNAP_STDERR"

EXPECT_COUNT=0; CLICK_COUNT=0; FAIL_COUNT=0
if [ -f "$AUTOTEST_FILE" ]; then
    EXPECT_COUNT=$(grep -c '^expect ' "$AUTOTEST_FILE" 2>/dev/null || true)
    CLICK_COUNT=$(grep -c '^click ' "$AUTOTEST_FILE" 2>/dev/null || true)
    FAIL_COUNT=$(grep -c '^# FAIL' "$AUTOTEST_FILE" 2>/dev/null || true)
    EXPECT_COUNT=${EXPECT_COUNT//[^0-9]/}; EXPECT_COUNT=${EXPECT_COUNT:-0}
    CLICK_COUNT=${CLICK_COUNT//[^0-9]/}; CLICK_COUNT=${CLICK_COUNT:-0}
    FAIL_COUNT=${FAIL_COUNT//[^0-9]/}; FAIL_COUNT=${FAIL_COUNT:-0}
else
    echo "[$NAME] snapshot: failed to generate autotest (${SNAP_MS}ms)" >&2
fi

TOTAL_FAILS=$(( FAIL_COUNT + RUNTIME_ERRORS ))
if [ "$TOTAL_FAILS" -gt 0 ]; then
    echo "[$NAME] snapshot: ${EXPECT_COUNT} expects + ${CLICK_COUNT} clicks + ${TOTAL_FAILS} FAILS in ${SNAP_MS}ms → $AUTOTEST_FILE" >&2
    echo "[$NAME] SNAPSHOT FAILED — cleaning up broken binary" >&2
    rm -f "$RAW_BIN" 2>/dev/null || true
    rm -rf "zig-out/bin/${NAME}.app" 2>/dev/null || true
    exit 1
fi
echo "[$NAME] snapshot: ${EXPECT_COUNT} expects + ${CLICK_COUNT} clicks in ${SNAP_MS}ms → $AUTOTEST_FILE"

# ── 6. Post-build autotest replay ─────────────────────────────────────
# Replay the just-generated autotest against the binary and produce the
# proof grid. Skip with SHIP_SKIP_AUTOTEST=1 for faster iterations.
if [ "${SHIP_SKIP_AUTOTEST:-0}" != "1" ] && [ -f "$AUTOTEST_FILE" ]; then
    "$(dirname "$0")/autotest" "$NAME" || true
fi
