#!/bin/bash
# ship — build a .tsx cart into a self-extracting native binary.
#
# Pipeline:
#   1. esbuild cart/<name>.tsx → bundle-<name>.js (in CART_ROOT)
#   2. zig build app → zig-out/bin/<name> (ELF, dynamic-linked, bundle embedded)
#   3. Package as self-extracting shell wrapper:
#      - ldd the binary, bundle every non-system .so into a lib/ dir
#      - bundle ld-linux loader
#      - tarball { app.bin, lib/, run } together
#      - prepend shell wrapper that extracts to ~/.cache/reactjit-<name>/<sig>/
#        on first run and execs the real binary via the bundled ld-linux
#
# Result: a single-file shippable binary with zero system dependencies.
# LuaJIT stays dynamic at link time (fast builds) but ships bundled (portable).
#
# Two modes (transparent to the user):
#   In-repo: run from a clone. RJIT_HOME and CART_ROOT both = repo root.
#            Behavior is identical to the pre-split script.
#   rjit-driven: the dispatcher sets RJIT_HOME to its SDK install (a
#            ~/.cache/rjit/<sig>/ dir). CART_ROOT is the user's cwd.
#            build.zig + tools + scripts + framework + runtime live under
#            RJIT_HOME; cart inputs and build outputs live under CART_ROOT.
#
# Usage:
#   scripts/ship <cart-name>          # release, self-extracting
#   scripts/ship <cart-name> -d       # debug build, skips packaging

set -euo pipefail

# CART_ROOT is the user's project (where cart/<name>.tsx lives, and where
# bundle-<name>.js, zig-out/, tests/ get written). RJIT_HOME is the SDK
# install (where build.zig, tools/, scripts/, framework/, runtime/ live).
CART_ROOT="$PWD"
RJIT_HOME="${RJIT_HOME:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
cd "$RJIT_HOME"
OS="$(uname -s)"

# Prefer the SDK-bundled zig (tools/zig/zig) over whatever's on PATH —
# Whonix and other minimal distros don't have a system zig and would
# fail with "zig: command not found" otherwise.
ZIG="${REACTJIT_ZIG:-$RJIT_HOME/tools/zig/zig}"
if [[ ! -x "$ZIG" ]]; then
    ZIG="zig"
fi

# Lock guards the SDK's zig-cache against parallel zig-build races on the
# same RJIT_HOME. Multiple ships from different cart dirs against the same
# SDK install must serialize.
LOCK_FILE="$RJIT_HOME/.zig-cache/.ship.lock"
mkdir -p "$(dirname "$LOCK_FILE")"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "[ship] another build in progress — waiting for lock..."
    flock 9
    echo "[ship] got lock, proceeding"
fi

NAME="${1:-}"
DEBUG=0
for arg in "${@:2}"; do
    case "$arg" in
        -d|--debug) DEBUG=1 ;;
        *)
            echo "[ship] unknown flag: $arg" >&2
            echo "Usage: scripts/ship <cart-name> [-d|--debug]" >&2
            exit 1
            ;;
    esac
done

if [[ -z "$NAME" ]]; then
    echo "Usage: scripts/ship <cart-name> [-d|--debug]" >&2
    echo "  Cart expected at: $CART_ROOT/cart/<cart-name>.tsx" >&2
    exit 1
fi

# Resolve cart entry under CART_ROOT: prefer cart/<name>/index.tsx (directory
# layout), fall back to cart/<name>.tsx (single-file cart). Directory wins.
if [[ -f "$CART_ROOT/cart/${NAME}/index.tsx" ]]; then
    CART_FILE="$CART_ROOT/cart/${NAME}/index.tsx"
elif [[ -f "$CART_ROOT/cart/${NAME}.tsx" ]]; then
    CART_FILE="$CART_ROOT/cart/${NAME}.tsx"
else
    echo "[ship] not found: $CART_ROOT/cart/${NAME}/index.tsx or $CART_ROOT/cart/${NAME}.tsx" >&2
    exit 1
fi
CART_DIR="$(dirname "$CART_FILE")"
CART_MANIFEST="$CART_ROOT/cart/${NAME}/cart.json"

resolve_icon_path() {
    local value="$1"
    if [[ -z "$value" ]]; then
        return 1
    fi
    if [[ "$value" = /* ]]; then
        [[ -f "$value" ]] && { printf '%s\n' "$value"; return 0; }
    else
        [[ -f "$CART_DIR/$value" ]] && { printf '%s\n' "$CART_DIR/$value"; return 0; }
        [[ -f "$CART_ROOT/$value" ]] && { printf '%s\n' "$CART_ROOT/$value"; return 0; }
    fi
    return 1
}

ICON_SOURCE=""
ICON_DECLARED=""
if [[ -f "$CART_MANIFEST" ]]; then
    if [[ "$OS" == "Darwin" ]]; then
        ICON_DECLARED="$(tools/v8cli scripts/cart-manifest-field.js "$CART_MANIFEST" icons.macos || true)"
    elif [[ "$OS" == "Linux" ]]; then
        ICON_DECLARED="$(tools/v8cli scripts/cart-manifest-field.js "$CART_MANIFEST" icons.linux || true)"
    fi
    if [[ -z "$ICON_DECLARED" ]]; then
        ICON_DECLARED="$(tools/v8cli scripts/cart-manifest-field.js "$CART_MANIFEST" icons.default || true)"
    fi
    if [[ -z "$ICON_DECLARED" ]]; then
        ICON_DECLARED="$(tools/v8cli scripts/cart-manifest-field.js "$CART_MANIFEST" icon || true)"
    fi
    if [[ -n "$ICON_DECLARED" ]]; then
        if ! ICON_SOURCE="$(resolve_icon_path "$ICON_DECLARED")"; then
            echo "[ship] cart manifest icon not found: $ICON_DECLARED" >&2
            echo "[ship] icon paths are resolved relative to $CART_DIR, then $CART_ROOT" >&2
            exit 1
        fi
    fi
fi
if [[ -z "$ICON_SOURCE" ]]; then
    for candidate in \
        "$CART_ROOT/cart/${NAME}/icon.icns" \
        "$CART_ROOT/cart/${NAME}/icon.png" \
        "$CART_ROOT/cart/${NAME}/icon.svg" \
        "$CART_ROOT/cart/${NAME}/icon.ico" \
        "$CART_ROOT/cart/${NAME}.icns" \
        "$CART_ROOT/cart/${NAME}.png" \
        "$CART_ROOT/cart/${NAME}.svg" \
        "$CART_ROOT/cart/${NAME}.ico"
    do
        if [[ -f "$candidate" ]]; then
            ICON_SOURCE="$candidate"
            break
        fi
    done
fi
ICON_EXT=""
ICON_FILE=""
if [[ -n "$ICON_SOURCE" ]]; then
    ICON_EXT="${ICON_SOURCE##*.}"
    ICON_EXT="${ICON_EXT,,}"
    ICON_FILE="${NAME}.${ICON_EXT}"
    echo "[ship] app icon: $ICON_SOURCE"
fi

# ── 1. Bundle cart entry via esbuild → bundle-<name>.js ──────────────
# Bundle output lives in CART_ROOT so the user's project owns its build
# artefacts. zig build embeds it via -Dbundle-path so v8_app.zig's
# @embedFile resolves the absolute path (instead of the SDK-relative
# default).
BUNDLE_OUT="$CART_ROOT/bundle-${NAME}.js"

# Heal top-level `const { useX } = React;` and stray require('react') lines —
# patterns that fail at module-init before globalThis.React is set.
# fix-react-imports honors RJIT_HOME + CART_ROOT env when set.
RJIT_HOME="$RJIT_HOME" CART_ROOT="$CART_ROOT" scripts/fix-react-imports

echo "[ship] bundling $CART_FILE → $BUNDLE_OUT..."
BUNDLE_FROM_HARNESS=1 CART_ROOT="$CART_ROOT" tools/v8cli scripts/cart-bundle.js "$CART_FILE" --out "$BUNDLE_OUT"

# Zig's @embedFile rejects absolute paths outside the build.zig package
# (RJIT_HOME). When CART_ROOT differs (rjit-driven mode), the bundle just
# written under CART_ROOT cannot be embedded directly; mirror it into a
# package-local dir so the embed path lands inside the package. Avoid
# .zig-cache/ — Zig excludes it from package paths.
EMBED_BUNDLE="$BUNDLE_OUT"
if [[ "$CART_ROOT" != "$RJIT_HOME" ]]; then
    EMBED_BUNDLE="$RJIT_HOME/bundles/bundle-${NAME}.js"
    mkdir -p "$(dirname "$EMBED_BUNDLE")"
    cp -f "$BUNDLE_OUT" "$EMBED_BUNDLE"
fi

# ── 2. Compile v8_app.zig (bundle-<name>.js embedded via @embedFile) ─
OPT_FLAG="-Doptimize=ReleaseFast"
if [[ "$DEBUG" -eq 1 ]]; then
    OPT_FLAG="-Doptimize=Debug"
fi

echo "[ship] compiling native binary..."
APP_SOURCE="v8_app.zig"
V8_FLAG="-Duse-v8=true"

# Cart-declared capabilities (cart/<name>/cart.json). Currently only
# `customChrome: true` is honoured — the runtime reads it as
# build_options.custom_chrome to decide borderless vs windowed chrome.
# Missing cart.json → no flag passed → default false.
CUSTOM_CHROME_FLAG=""
if [[ -f "$CART_MANIFEST" ]]; then
    # Grep-based probe avoids shelling out to a JS runtime for a one-field read.
    # Matches `"customChrome":true` with optional whitespace. A cart author who
    # writes something creative (nested objects, trailing comments) won't match,
    # which is fine — the flag is opt-in and defaulting to "windowed chrome" is
    # the safer fallback.
    if grep -Eq '"customChrome"[[:space:]]*:[[:space:]]*true' "$CART_MANIFEST"; then
        CUSTOM_CHROME_FLAG="-Dcustom-chrome=true"
        echo "[ship] cart manifest: customChrome=true"
    fi
fi

# Detect optional capabilities by scanning the just-built bundle.
# Each capability flag links its corresponding system library and pulls in
# the relevant framework binding. Source-driven: cart says "I use X", we
# ship X. Cart doesn't say, we don't.
# Read the esbuild metafile (sidecar to the bundle, written by cart-bundle.js
# via --metafile). The metafile's `inputs` map lists every source file that
# survived tree-shaking — the structural truth of what's actually in the
# bundle. We check whether specific hook source paths appear there to gate
# V8 binding registration. No grep, no text matching, no false positives
# from comments/strings/identifier collisions.
#
# Hook → ingredients mapping (ingredient = one V8 binding file):
#   runtime/hooks/useHost.ts    → enables process + httpsrv + wssrv together
#   runtime/hooks/usePrivacy.ts → enables privacy
#
# Ingredient-level granularity, not flavor-level: useHost has process/http/ws
# flavors but importing the file at all means register all three. Same way
# usePrivacy has thirty flavors and registering brings them all.
METAFILE="$BUNDLE_OUT.metafile.json"
PRIVACY_FLAG=""
PROCESS_FLAG=""
HTTPSRV_FLAG=""
WSSRV_FLAG=""
NET_FLAG=""
TOR_FLAG=""
FS_FLAG=""
WS_FLAG=""
TEL_FLAG=""
ZIGCALL_FLAG=""
SDK_FLAG=""
WANT_PRIVACY=0
WANT_USEHOST=0
WANT_USECONN=0
WANT_FS=0
WANT_WS=0
WANT_TEL=0
WANT_ZIGCALL=0
WANT_SDK=0
if [[ -f "$METAFILE" ]]; then
    # Pure JSON membership check — v8cli reads the metafile, walks
    # outputs[].inputs (bytes-actually-shipped), and emits a single line of
    # space-separated 0/1 flags in this exact order:
    #   privacy useHost useConnection fs websocket telemetry zigcall sdk
    # See scripts/ship-metafile-gate.js for the hook→binding map.
    GATE_FLAGS=$(tools/v8cli scripts/ship-metafile-gate.js "$METAFILE")
    if [[ -z "$GATE_FLAGS" ]]; then
        echo "[ship] FATAL: ship-metafile-gate.js produced no output." >&2
        echo "[ship] Without the gate, every binding would be force-disabled and" >&2
        echo "[ship] any cart that uses a gated hook would crash at runtime." >&2
        exit 1
    fi
    read -r WANT_PRIVACY WANT_USEHOST WANT_USECONN WANT_FS WANT_WS WANT_TEL WANT_ZIGCALL WANT_SDK <<< "$GATE_FLAGS"
    if [[ "$WANT_PRIVACY" == "1" ]]; then
        PRIVACY_FLAG="-Dhas-privacy=true"
    fi
    if [[ "$WANT_USEHOST" == "1" ]]; then
        PROCESS_FLAG="-Dhas-process=true"
        HTTPSRV_FLAG="-Dhas-httpsrv=true"
        WSSRV_FLAG="-Dhas-wssrv=true"
    fi
    # useHost or useConnection both need the net binding (tcp/udp/socks5).
    if [[ "$WANT_USEHOST" == "1" ]] || [[ "$WANT_USECONN" == "1" ]]; then
        NET_FLAG="-Dhas-net=true"
    fi
    if [[ "$WANT_USECONN" == "1" ]]; then
        TOR_FLAG="-Dhas-tor=true"
    fi
    if [[ "$WANT_FS" == "1" ]]; then
        FS_FLAG="-Dhas-fs=true"
    fi
    if [[ "$WANT_WS" == "1" ]]; then
        WS_FLAG="-Dhas-websocket=true"
    fi
    if [[ "$WANT_TEL" == "1" ]]; then
        TEL_FLAG="-Dhas-telemetry=true"
    fi
    if [[ "$WANT_ZIGCALL" == "1" ]]; then
        ZIGCALL_FLAG="-Dhas-zigcall=true"
    fi
    if [[ "$WANT_SDK" == "1" ]]; then
        SDK_FLAG="-Dhas-sdk=true"
    fi
else
    echo "[ship] WARNING: no metafile at $METAFILE — all opt-in V8 bindings disabled" >&2
fi

BUILD_BINDINGS=()
BUILD_LIBS=()
BUILD_TRIGGERS=()
if [[ "$WANT_PRIVACY" == "1" ]]; then
    BUILD_BINDINGS+=("privacy")
    BUILD_LIBS+=("libsodium")
    BUILD_TRIGGERS+=("privacy: runtime/hooks/usePrivacy.ts")
fi
if [[ "$WANT_USEHOST" == "1" ]]; then
    BUILD_BINDINGS+=("process" "httpsrv" "wssrv")
    BUILD_TRIGGERS+=("useHost: runtime/hooks/useHost.ts")
fi
if [[ "$WANT_USEHOST" == "1" ]] || [[ "$WANT_USECONN" == "1" ]]; then
    BUILD_BINDINGS+=("net")
fi
if [[ "$WANT_USECONN" == "1" ]]; then
    BUILD_BINDINGS+=("tor")
    BUILD_TRIGGERS+=("connection: runtime/hooks/useConnection.ts")
fi
if [[ "$WANT_FS" == "1" ]]; then
    BUILD_BINDINGS+=("fs")
    BUILD_TRIGGERS+=("fs: runtime/hooks/fs.ts")
fi
if [[ "$WANT_WS" == "1" ]]; then
    BUILD_BINDINGS+=("websocket")
    BUILD_TRIGGERS+=("websocket: runtime/hooks/websocket.ts or useConnection")
fi
if [[ "$WANT_TEL" == "1" ]]; then
    BUILD_BINDINGS+=("telemetry")
    BUILD_TRIGGERS+=("telemetry: telemetry cart source")
fi
if [[ "$WANT_ZIGCALL" == "1" ]]; then
    BUILD_BINDINGS+=("zigcall" "zigcall_list")
    BUILD_TRIGGERS+=("zigcall: runtime/hooks/math.ts")
fi
if [[ "$WANT_SDK" == "1" ]]; then
    BUILD_BINDINGS+=("sdk")
    BUILD_TRIGGERS+=("sdk: runtime/hooks/http.ts or runtime/hooks/browser_page.ts")
fi

echo "[ship] build ingredients:"
echo "[ship]   runtime: $APP_SOURCE (V8)"
if [[ "${#BUILD_BINDINGS[@]}" -gt 0 ]]; then
    echo "[ship]   V8 bindings: ${BUILD_BINDINGS[*]}"
else
    echo "[ship]   V8 bindings: none"
fi
if [[ "${#BUILD_LIBS[@]}" -gt 0 ]]; then
    echo "[ship]   native feature libs: ${BUILD_LIBS[*]}"
else
    echo "[ship]   native feature libs: none"
fi
if [[ "${#BUILD_TRIGGERS[@]}" -gt 0 ]]; then
    echo "[ship]   triggers:"
    for trigger in "${BUILD_TRIGGERS[@]}"; do
        echo "[ship]     - $trigger"
    done
else
    echo "[ship]   triggers: none"
fi
# Sysroot — when deps/sysroot/ exists in the SDK install, point the build at
# our vendored headers + .so files instead of /usr/include and the system's
# libfoo.so. This is what lets `rjit ship` work on a fresh distro that
# doesn't have libsdl3-dev / libfreetype-dev / etc. installed.
SYSROOT_FLAG=""
SYSROOT_LIB="$RJIT_HOME/deps/sysroot/usr/lib"
if [[ -d "$RJIT_HOME/deps/sysroot/usr/include" ]]; then
    SYSROOT_FLAG="-Dsysroot=$RJIT_HOME/deps/sysroot"

    # Some libs are system-assumed (we never bundle them) but minimal distros
    # like Whonix ship only the SONAME-versioned .so.N — they lack the
    # unversioned dev symlink the linker needs for `-lX11`. Detect those and
    # synthesize the dev symlink in our sysroot pointing at whatever path
    # ldconfig reports for the system .so.
    for sysname in X11; do
        if [[ ! -e "$SYSROOT_LIB/lib${sysname}.so" ]]; then
            sys_so=$(ldconfig -p 2>/dev/null | awk -v rx="lib${sysname}\\.so" '$1 ~ rx {print $NF; exit}')
            if [[ -n "$sys_so" && -e "$sys_so" ]]; then
                ln -sfn "$sys_so" "$SYSROOT_LIB/lib${sysname}.so"
                echo "[ship] sysroot: linked lib${sysname}.so → $sys_so"
            fi
        fi
    done
fi

echo "[ship]   zig flags: $V8_FLAG${CUSTOM_CHROME_FLAG:+ $CUSTOM_CHROME_FLAG} $OPT_FLAG${SYSROOT_FLAG:+ $SYSROOT_FLAG}${PRIVACY_FLAG:+ $PRIVACY_FLAG}${PROCESS_FLAG:+ $PROCESS_FLAG}${HTTPSRV_FLAG:+ $HTTPSRV_FLAG}${WSSRV_FLAG:+ $WSSRV_FLAG}${NET_FLAG:+ $NET_FLAG}${TOR_FLAG:+ $TOR_FLAG}${FS_FLAG:+ $FS_FLAG}${WS_FLAG:+ $WS_FLAG}${TEL_FLAG:+ $TEL_FLAG}${ZIGCALL_FLAG:+ $ZIGCALL_FLAG}${SDK_FLAG:+ $SDK_FLAG}"

# Zig package cache override — ONLY when running off-tree (rjit-driven).
# In rjit-driven mode the SDK ships a bundled cache at tools/zig/cache/p/
# (overlaid from the dev host's ~/.cache/zig/p at pack-sdk time) so the
# build is hermetic on Whonix etc. In-repo dev uses the default
# ~/.cache/zig which is the authoritative, complete cache.
if [[ "$CART_ROOT" != "$RJIT_HOME" ]]; then
    export ZIG_GLOBAL_CACHE_DIR="$RJIT_HOME/tools/zig/cache"
fi

"$ZIG" build app -p "$CART_ROOT/zig-out" -Dapp-name="$NAME" -Dapp-source="$APP_SOURCE" -Dbundle-path="$EMBED_BUNDLE" $V8_FLAG $CUSTOM_CHROME_FLAG $OPT_FLAG $SYSROOT_FLAG $PRIVACY_FLAG $PROCESS_FLAG $HTTPSRV_FLAG $WSSRV_FLAG $NET_FLAG $TOR_FLAG $FS_FLAG $WS_FLAG $TEL_FLAG $ZIGCALL_FLAG $SDK_FLAG

BUILD_BIN="$CART_ROOT/zig-out/bin/$NAME"
if [[ ! -f "$BUILD_BIN" ]]; then
    echo "[ship] build produced no binary: $BUILD_BIN" >&2
    exit 1
fi

# ── Allergen-label verification ───────────────────────────────────────
# build.zig writes one .flag per opt-in V8 binding domain to
# zig-out/manifest/v8-ingredients/<name>.flag with "1" or "0". Diff that
# against the cart's pre-build declaration. Any disagreement = the
# kitchen contradicted the label, so the binary is destroyed before
# shipping. There is no "trust us, it's fine" path here — by design.
LABEL_DIR="$CART_ROOT/zig-out/manifest/v8-ingredients"
NET_EXPECTED="0"
[[ "$WANT_USEHOST" == "1" || "$WANT_USECONN" == "1" ]] && NET_EXPECTED="1"
declare -A EXPECTED=(
    [privacy]="$WANT_PRIVACY"
    [process]="$WANT_USEHOST"
    [httpsrv]="$WANT_USEHOST"
    [wssrv]="$WANT_USEHOST"
    [net]="$NET_EXPECTED"
    [tor]="$WANT_USECONN"
    [fs]="$WANT_FS"
    [websocket]="$WANT_WS"
    [telemetry]="$WANT_TEL"
    [zigcall]="$WANT_ZIGCALL"
)
LABEL_MISMATCH=0
for ing in privacy process httpsrv wssrv net tor fs websocket telemetry zigcall; do
    flag_file="$LABEL_DIR/${ing}.flag"
    expected="${EXPECTED[$ing]:-0}"
    if [[ ! -f "$flag_file" ]]; then
        echo "[ship] LABEL MISSING: $flag_file (expected $expected)" >&2
        LABEL_MISMATCH=1
        continue
    fi
    actual=$(cat "$flag_file" | tr -d '[:space:]')
    if [[ "$actual" != "$expected" ]]; then
        echo "[ship] LABEL MISMATCH: $ing — cart asked for '$expected' but binary built '$actual'" >&2
        LABEL_MISMATCH=1
    fi
done
if [[ "$LABEL_MISMATCH" -eq 1 ]]; then
    echo "[ship] DESTROYING binary — manifest disagrees with cart declaration" >&2
    rm -f "$BUILD_BIN"
    exit 1
fi

# ── 3. Debug short-circuit ─────────────────────────────────────────────
# In debug mode, move the debug ELF to "$NAME-debug" so zig-out/bin/$NAME
# stays reserved for the self-extracting wrapper.
if [[ "$DEBUG" -eq 1 ]]; then
    DEBUG_OUT="$CART_ROOT/zig-out/bin/${NAME}-debug"
    mv -f "$BUILD_BIN" "$DEBUG_OUT"
    SIZE_MB=$(du -m "$DEBUG_OUT" | cut -f1)
    echo "[ship] done (debug ELF, ${SIZE_MB}MB) → $DEBUG_OUT"
    echo "[ship] note: $BUILD_BIN left for wrapped build; run './scripts/ship $NAME' for the shippable form."
    exit 0
fi

# ── 4. Package as self-extracting binary ──────────────────────────────
if [[ "$OS" == "Darwin" ]]; then
    # ── macOS: package as .app bundle ──────────────────────────────
    echo "[ship] packaging macOS .app bundle..."
    APP_BUNDLE="$CART_ROOT/zig-out/bin/${NAME}.app"
    CONTENTS="$APP_BUNDLE/Contents"
    MACOS_DIR="$CONTENTS/MacOS"
    FW_DIR="$CONTENTS/Frameworks"
    RES_DIR="$CONTENTS/Resources"
    rm -rf "$APP_BUNDLE"
    mkdir -p "$MACOS_DIR" "$FW_DIR" "$RES_DIR"
    cp "$BUILD_BIN" "$MACOS_DIR/$NAME"

    MACOS_ICON_PLIST=""
    if [[ -n "$ICON_SOURCE" ]]; then
        cp "$ICON_SOURCE" "$RES_DIR/$ICON_FILE"
        if [[ "$ICON_EXT" == "icns" ]]; then
            MACOS_ICON_PLIST="    <key>CFBundleIconFile</key>
    <string>$ICON_FILE</string>"
        else
            echo "[ship] macOS icon copied to Resources/$ICON_FILE; Finder icon requires .icns" >&2
        fi
    fi

    cat > "$CONTENTS/Info.plist" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>$NAME</string>
    <key>CFBundleIdentifier</key>
    <string>com.reactjit.$NAME</string>
    <key>CFBundleName</key>
    <string>$NAME</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
${MACOS_ICON_PLIST}
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
</dict>
</plist>
PLIST

    # Recursively collect non-system dylibs into Frameworks/
    collect_dylibs() {
        for bin in "$@"; do
            otool -L "$bin" 2>/dev/null | tail -n +2 | awk '{print $1}' | while read -r lib_path; do
                case "$lib_path" in
                    /usr/lib/*|/System/*|@rpath/*|@executable_path/*) continue ;;
                esac
                [ ! -f "$lib_path" ] && continue
                lib_name=$(basename "$lib_path")
                [ -f "$FW_DIR/$lib_name" ] && continue
                cp "$lib_path" "$FW_DIR/$lib_name"
                echo "$lib_name"
            done
        done
    }
    collect_dylibs "$MACOS_DIR/$NAME" >/dev/null
    # Transitive deps from bundled dylibs
    collect_dylibs "$FW_DIR"/*.dylib >/dev/null 2>/dev/null || true

    # Rewrite dylib paths → @executable_path/../Frameworks/
    rewrite_dylib_paths() {
        local bin="$1"
        otool -L "$bin" 2>/dev/null | tail -n +2 | awk '{print $1}' | while read -r lib_path; do
            case "$lib_path" in
                /usr/lib/*|/System/*|@rpath/*|@executable_path/*) continue ;;
            esac
            lib_name=$(basename "$lib_path")
            install_name_tool -change "$lib_path" "@executable_path/../Frameworks/$lib_name" "$bin" 2>/dev/null || true
        done
    }
    rewrite_dylib_paths "$MACOS_DIR/$NAME"
    install_name_tool -add_rpath "@executable_path/../Frameworks" "$MACOS_DIR/$NAME" 2>/dev/null || true

    # Fix each bundled dylib's id + transitive refs
    for dylib in "$FW_DIR"/*.dylib; do
        [ -f "$dylib" ] || continue
        lib_name=$(basename "$dylib")
        install_name_tool -id "@executable_path/../Frameworks/$lib_name" "$dylib" 2>/dev/null || true
        rewrite_dylib_paths "$dylib"
    done

    # Ad-hoc sign (Sequoia requires valid signatures even for unsigned builds)
    codesign --force --sign - --deep "$APP_BUNDLE" 2>/dev/null || true

    LIB_COUNT=$(find "$FW_DIR" -name '*.dylib' 2>/dev/null | wc -l | tr -d ' ')
    SIZE_MB=$(du -sm "$APP_BUNDLE" | cut -f1)
    echo "[ship] done (${SIZE_MB}MB .app bundle, $LIB_COUNT dylibs) → $APP_BUNDLE"
    exit 0
fi

if [[ "$OS" != "Linux" ]]; then
    echo "[ship] packaging not implemented for $OS — leaving build output at $BUILD_BIN"
    exit 0
fi

echo "[ship] packaging self-extracting binary..."
TMP_DIR="/tmp/reactjit-dist-$NAME"
LIB_DIR="$TMP_DIR/lib"
SHARE_DIR="$TMP_DIR/share"
rm -rf "$TMP_DIR"
mkdir -p "$LIB_DIR"
cp "$BUILD_BIN" "$TMP_DIR/app.bin"

if [[ -n "$ICON_SOURCE" ]]; then
    mkdir -p "$SHARE_DIR/icons" "$SHARE_DIR/applications"
    cp "$ICON_SOURCE" "$SHARE_DIR/icons/$ICON_FILE"
    cat > "$SHARE_DIR/applications/${NAME}.desktop.in" << DESKTOP
[Desktop Entry]
Type=Application
Name=$NAME
Exec=@EXEC@
Icon=@ICON@
Terminal=false
Categories=Development;
DESKTOP
fi

# Walk ldd output, bundle every non-system .so. When the SDK ships a
# matching lib in deps/sysroot/usr/lib (the glibc family + our pins),
# bundle THAT version, not the one ldd resolved from the build host. This
# is what lets a cart built on Whonix (glibc 2.36) still ship our pinned
# SDL3.so.0 — the bundled glibc is from the SDK builder's host (newer),
# so SDL3's GLIBC_2.38 symbol references resolve at runtime.
SR_LIB="$RJIT_HOME/deps/sysroot/usr/lib"
LIB_COUNT=0
LDD_TMP=$(mktemp)
ldd "$BUILD_BIN" > "$LDD_TMP" 2>/dev/null || true
while IFS= read -r line; do
    case "$line" in *linux-vdso*) continue ;; esac
    soname=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*=>.*//')
    if [[ -f "$SR_LIB/$soname" ]]; then
        real_path=$(readlink -f "$SR_LIB/$soname")
    else
        lib_path=$(echo "$line" | sed -n 's/.* => \([^ ]*\) .*/\1/p')
        [[ -z "$lib_path" || ! -f "$lib_path" ]] && continue
        real_path=$(readlink -f "$lib_path")
    fi
    [[ -f "$LIB_DIR/$soname" ]] && continue
    cp "$real_path" "$LIB_DIR/$soname"
    LIB_COUNT=$((LIB_COUNT + 1))
done < "$LDD_TMP"
rm -f "$LDD_TMP"

# Catch-all: copy everything in the SDK sysroot lib dir into the cart's
# bundle. ldd can miss transitively-loaded libs that aren't DT_NEEDED of
# the binary itself (e.g. libpulse.so.0 dlopen's libpulsecommon-17.0.so;
# on Whonix ldd can't even resolve it because Whonix's pulseaudio dir is
# absent or empty). Belt-and-suspenders — better to ship 30 MB of
# unused .so than to crash on launch with a missing dep.
if [[ -d "$SR_LIB" ]]; then
    for so in "$SR_LIB"/*.so*; do
        [[ -e "$so" ]] || continue
        soname=$(basename "$so")
        [[ -e "$LIB_DIR/$soname" ]] && continue
        cp -a "$so" "$LIB_DIR/$soname"
        LIB_COUNT=$((LIB_COUNT + 1))
    done
fi

# Bundle the dynamic loader itself — prefer the SDK-bundled one for the
# same forward-compat reason as above.
LD_LINUX=""
if [[ -f "$SR_LIB/ld-linux-x86-64.so.2" ]]; then
    LD_LINUX=$(readlink -f "$SR_LIB/ld-linux-x86-64.so.2")
fi
if [[ -z "$LD_LINUX" ]]; then
    LD_LINUX=$(readlink -f /lib64/ld-linux-x86-64.so.2 2>/dev/null || readlink -f /lib/ld-linux-x86-64.so.2 2>/dev/null || echo "")
fi
if [[ -z "$LD_LINUX" ]] || [[ ! -f "$LD_LINUX" ]]; then
    echo "[ship] WARNING: ld-linux-x86-64.so.2 not found — leaving build output at $BUILD_BIN"
    rm -rf "$TMP_DIR"
    exit 0
fi
cp "$LD_LINUX" "$LIB_DIR/ld-linux-x86-64.so.2"

# Launcher that execs the real binary via the bundled loader
cat > "$TMP_DIR/run" << 'LAUNCHER'
#!/bin/sh
DIR="$(cd "$(dirname "$0")" && pwd)"
exec "$DIR/lib/ld-linux-x86-64.so.2" --inhibit-cache --library-path "$DIR/lib" "$DIR/app.bin" "$@"
LAUNCHER
chmod +x "$TMP_DIR/run"

# Tarball + self-extracting wrapper
TARBALL="/tmp/reactjit-${NAME}-payload.tar.gz"
(cd "$TMP_DIR" && tar czf "$TARBALL" .)

# Write wrapper to a staging file, then atomic-rename over the build output.
# Atomic rename works even if the previous binary is currently running —
# the running process keeps its fd to the old inode, the dentry is replaced.
STAGED="${BUILD_BIN}.staged"
cat > "$STAGED" << HEADER
#!/bin/sh
set -e
APP_DIR=\${XDG_CACHE_HOME:-\$HOME/.cache}/reactjit-$NAME
SIG=\$(md5sum "\$0" 2>/dev/null | cut -c1-8 || cksum "\$0" | cut -d" " -f1)
CACHE="\$APP_DIR/\$SIG"
ICON_FILE="$ICON_FILE"
if [ ! -f "\$CACHE/.ready" ]; then
  rm -rf "\$APP_DIR"
  mkdir -p "\$CACHE"
  SKIP=\$(awk '/^__ARCHIVE__\$/{print NR + 1; exit}' "\$0")
  tail -n+"\$SKIP" "\$0" | tar xz -C "\$CACHE"
  if [ -n "\$ICON_FILE" ] && [ -f "\$CACHE/share/applications/$NAME.desktop.in" ]; then
    sed "s|@EXEC@|\$CACHE/run|g; s|@ICON@|\$CACHE/share/icons/\$ICON_FILE|g" \
      "\$CACHE/share/applications/$NAME.desktop.in" > "\$CACHE/share/applications/$NAME.desktop"
  fi
  touch "\$CACHE/.ready"
fi
exec "\$CACHE/run" "\$@"
__ARCHIVE__
HEADER
cat "$TARBALL" >> "$STAGED"
chmod +x "$STAGED"
mv -f "$STAGED" "$BUILD_BIN"

SIZE_MB=$(du -m "$BUILD_BIN" | cut -f1)
echo "[ship] done (${SIZE_MB}MB self-extracting, $LIB_COUNT libs bundled) → $BUILD_BIN"
rm -rf "$TMP_DIR" "$TARBALL"

# ── 5. Post-build snapshot gate ───────────────────────────────────────
# Runs the binary headless with ZIGOS_WITNESS=snapshot so framework/witness.zig
# emits tests/<NAME>.autotest capturing all visible text, pressables, and a
# health line. Counts FAIL lines + runtime errors; any failure deletes the
# binary and exits 1. 1:1 port from tsz/scripts/build.
mkdir -p "$CART_ROOT/tests"
AUTOTEST_FILE="$CART_ROOT/tests/${NAME}.autotest"
SNAP_STDERR=$(mktemp)
SNAP_T0=$(date +%s%N)
ZIGOS_HEADLESS=1 ZIGOS_WITNESS=snapshot ZIGOS_WITNESS_FILE="$AUTOTEST_FILE" \
    timeout -s KILL 300 "$BUILD_BIN" >/dev/null 2>"$SNAP_STDERR" || true
SNAP_T1=$(date +%s%N)
SNAP_MS=$(( (SNAP_T1 - SNAP_T0) / 1000000 ))

RUNTIME_ERRORS=$(grep -cE '^error:|^\[luajit-runtime\]|^\[evalExpr error\]|^\[evalToString error\]|^\[evalLuaMapData error\]|^\[js_on_press\].*error|ReferenceError|SyntaxError|TypeError' "$SNAP_STDERR" 2>/dev/null || true)
RUNTIME_ERRORS=${RUNTIME_ERRORS//[^0-9]/}; RUNTIME_ERRORS=${RUNTIME_ERRORS:-0}
if [ "$RUNTIME_ERRORS" -gt 0 ]; then
    echo "[$NAME] runtime: ${RUNTIME_ERRORS} error(s) detected" >&2
    grep -E '^error:|^\[luajit-runtime\]|^\[eval.*error\]|^\[evalLuaMapData error\]|ReferenceError|SyntaxError|TypeError' "$SNAP_STDERR" | head -10 >&2
fi
grep '^\[snapshot\]' "$SNAP_STDERR" 2>/dev/null || true
# Keep the full snapshot log for post-mortem diagnostics. Not a bypass: binary
# still gets cleaned up on TOTAL_FAILS below; this just preserves stack traces.
SNAP_LOG_KEEP="$CART_ROOT/tests/screenshots/${NAME}/.last-snapshot.log"
mkdir -p "$(dirname "$SNAP_LOG_KEEP")"
cp "$SNAP_STDERR" "$SNAP_LOG_KEEP" 2>/dev/null || true
rm -f "$SNAP_STDERR"

EXPECT_COUNT=0; CLICK_COUNT=0; FAIL_COUNT=0
if [ -f "$AUTOTEST_FILE" ]; then
    EXPECT_COUNT=$(grep -c '^expect ' "$AUTOTEST_FILE" 2>/dev/null || true)
    CLICK_COUNT=$(grep -c '^click ' "$AUTOTEST_FILE" 2>/dev/null || true)
    FAIL_COUNT=$(grep -c '^# FAIL' "$AUTOTEST_FILE" 2>/dev/null || true)
    EXPECT_COUNT=${EXPECT_COUNT//[^0-9]/}; EXPECT_COUNT=${EXPECT_COUNT:-0}
    CLICK_COUNT=${CLICK_COUNT//[^0-9]/}; CLICK_COUNT=${CLICK_COUNT:-0}
    FAIL_COUNT=${FAIL_COUNT//[^0-9]/}; FAIL_COUNT=${FAIL_COUNT:-0}
else
    echo "[$NAME] snapshot: failed to generate autotest (${SNAP_MS}ms)" >&2
fi

TOTAL_FAILS=$(( FAIL_COUNT + RUNTIME_ERRORS ))
if [ "$TOTAL_FAILS" -gt 0 ]; then
    echo "[$NAME] snapshot: ${EXPECT_COUNT} expects + ${CLICK_COUNT} clicks + ${TOTAL_FAILS} FAILS in ${SNAP_MS}ms → $AUTOTEST_FILE" >&2
    echo "[$NAME] SNAPSHOT FAILED — cleaning up broken binary" >&2
    rm -f "$BUILD_BIN" 2>/dev/null || true
    rm -rf "$CART_ROOT/zig-out/bin/${NAME}.app" 2>/dev/null || true
    exit 1
fi
echo "[$NAME] snapshot: ${EXPECT_COUNT} expects + ${CLICK_COUNT} clicks in ${SNAP_MS}ms → $AUTOTEST_FILE"

# ── 6. Post-build autotest replay ─────────────────────────────────────
# Replay the just-generated autotest against the binary and produce the
# proof grid. Skip with SHIP_SKIP_AUTOTEST=1 for faster iterations.
if [ "${SHIP_SKIP_AUTOTEST:-0}" != "1" ] && [ -f "$AUTOTEST_FILE" ]; then
    "$(dirname "$0")/autotest" "$NAME" || true
fi
