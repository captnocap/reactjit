{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "@ilovereact/core": ["../../packages/shared/src"],
      "@ilovereact/native": ["../../packages/native/src"],
      "@ilovereact/theme": ["../../packages/theme/src"],
      "@ilovereact/3d": ["../../packages/3d/src"]
    }
  },
  "include": ["src/**/*"]
}
