#!/usr/bin/env node

// dv — CLI for devctl process manager
//
// The daemon auto-starts when you first use a command that needs it.
// The GUI is optional — open it with `dv gui` whenever you want to look.

const { createConnection } = require('net');
const { readFileSync, writeFileSync, mkdirSync, existsSync, unlinkSync } = require('fs');
const { resolve, basename, dirname } = require('path');
const { spawn, execSync } = require('child_process');

const CONTROL_PORT = 19876;
const CONFIG_DIR   = process.env.HOME + '/.config/devctl';
const CONFIG_FILE  = CONFIG_DIR + '/servers.json';
const PID_FILE     = CONFIG_DIR + '/daemon.pid';
const DEVCTL_DIR   = resolve(process.env.HOME, 'creative/reactjit/examples/devctl');
const GUI_PID_FILE = CONFIG_DIR + '/gui.pid';

// ── Daemon lifecycle ─────────────────────────────────────────────────────────────

function isDaemonRunning() {
  try {
    const pid = parseInt(readFileSync(PID_FILE, 'utf-8').trim(), 10);
    if (isNaN(pid)) return false;
    process.kill(pid, 0);
    return true;
  } catch (_) {
    return false;
  }
}

function sleep(ms) {
  return new Promise((res) => setTimeout(res, ms));
}

function canConnectControlSocket(timeoutMs = 250) {
  return new Promise((res) => {
    const conn = createConnection(CONTROL_PORT, '127.0.0.1');
    let done = false;
    const finish = (ok) => {
      if (done) return;
      done = true;
      conn.destroy();
      res(ok);
    };
    conn.setTimeout(timeoutMs);
    conn.on('connect', () => finish(true));
    conn.on('error',   () => finish(false));
    conn.on('timeout', () => finish(false));
  });
}

function killStaleDaemons() {
  try {
    const pid = parseInt(readFileSync(PID_FILE, 'utf-8').trim(), 10);
    if (!isNaN(pid)) {
      try { process.kill(pid, 'SIGTERM'); } catch (_) {}
    }
  } catch (_) {}
  try { unlinkSync(PID_FILE); } catch (_) {}

  try {
    const pids = execSync(
      "ps -eo pid,cmd | grep 'love.*devctl' | grep -v grep | awk '{print $1}'",
      { encoding: 'utf-8', timeout: 3000 }
    ).trim();
    if (pids) {
      for (const p of pids.split('\n')) {
        const pid = parseInt(p.trim(), 10);
        if (!isNaN(pid)) {
          try { process.kill(pid, 'SIGTERM'); } catch (_) {}
        }
      }
    }
  } catch (_) {}
}

async function startDaemon() {
  if (await canConnectControlSocket(120)) return true;

  killStaleDaemons();
  await sleep(300);

  console.log('starting devctl daemon...');
  const child = spawn('love', [DEVCTL_DIR], {
    cwd: DEVCTL_DIR,
    env: Object.assign({}, process.env, { DEVCTL_HEADLESS: '1' }),
    detached: true,
    stdio: 'ignore',
  });
  child.unref();

  for (let i = 0; i < 60; i++) {
    if (await canConnectControlSocket(250)) return true;
    await sleep(100);
  }
  return false;
}

function killDaemon() {
  try {
    const pid = parseInt(readFileSync(PID_FILE, 'utf-8').trim(), 10);
    if (!isNaN(pid)) {
      process.kill(pid, 'SIGTERM');
      console.log('daemon stopped (pid ' + pid + ')');
      try { unlinkSync(PID_FILE); } catch (_) {}
    }
  } catch (_) {
    console.log('no daemon running');
  }
}

async function ensureDaemon() {
  if (await canConnectControlSocket(120)) return true;
  const ok = await startDaemon();
  if (!ok) {
    console.error('failed to start devctl daemon. Is love installed?');
    process.exit(1);
  }
  return true;
}

// ── TCP command ──────────────────────────────────────────────────────────────────

function sendCommand(msg) {
  // All CLI commands carry actor="cli" for audit log attribution
  const payload = Object.assign({ actor: 'cli' }, msg);
  return new Promise((res, rej) => {
    const conn = createConnection(CONTROL_PORT, '127.0.0.1');
    let buf = '';
    conn.setTimeout(5000);

    conn.on('connect', () => {
      conn.write(JSON.stringify(payload) + '\n');
    });

    conn.on('data', (data) => {
      buf += data.toString();
      const nl = buf.indexOf('\n');
      if (nl >= 0) {
        const line = buf.slice(0, nl);
        conn.destroy();
        try { res(JSON.parse(line)); }
        catch (_) { res({ error: 'invalid response' }); }
      }
    });

    conn.on('timeout', () => { conn.destroy(); rej(new Error('timeout')); });
    conn.on('error',   (err) => rej(err));
  });
}

// ── Config helpers ───────────────────────────────────────────────────────────────

function loadConfig() {
  try {
    return JSON.parse(readFileSync(CONFIG_FILE, 'utf-8'));
  } catch (_) {
    return { servers: [], settings: { controlPort: CONTROL_PORT } };
  }
}

function saveConfig(config) {
  mkdirSync(CONFIG_DIR, { recursive: true });
  writeFileSync(CONFIG_FILE, JSON.stringify(config, null, 2) + '\n');
}

function readPackageJson(dir) {
  try { return JSON.parse(readFileSync(resolve(dir, 'package.json'), 'utf-8')); }
  catch (_) { return null; }
}

function resolveServerName() {
  const pkg = readPackageJson(process.cwd());
  if (pkg && pkg.name) return pkg.name;
  return basename(process.cwd());
}

function formatUptime(seconds) {
  if (seconds == null) return '--';
  if (seconds < 60)   return seconds + 's';
  if (seconds < 3600) return Math.floor(seconds / 60) + 'm';
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return h + 'h ' + m + 'm';
}

function pad(s, n) { return (s + ' '.repeat(n)).slice(0, n); }

// ── Commands ─────────────────────────────────────────────────────────────────────

async function cmdAdd() {
  const cwd = process.cwd();
  const pkg = readPackageJson(cwd);
  const name = (pkg && pkg.name) || basename(cwd);
  const scripts = {};

  if (pkg && pkg.scripts) {
    for (const key of Object.keys(pkg.scripts)) {
      scripts[key] = pkg.scripts[key];
    }
  }

  let port = null;
  const devScript = scripts.dev || '';
  const portMatch = devScript.match(/--port\s+(\d+)/) || devScript.match(/PORT=(\d+)/);
  if (portMatch) port = parseInt(portMatch[1], 10);

  const msg = { cmd: 'add', name, cwd, scripts, port };

  if (isDaemonRunning()) {
    const res = await sendCommand(msg);
    if (res.error) { console.error('error: ' + res.error); process.exit(1); }
    console.log('added: ' + (res.name || name) + ' (' + cwd + ')');
  } else {
    const config = loadConfig();
    const idx = config.servers.findIndex(s => s.name === name);
    const entry = { name, cwd, scripts, port, env: {}, autostart: false, pinned: false };
    if (idx >= 0) config.servers[idx] = entry;
    else config.servers.push(entry);
    saveConfig(config);
    console.log('added: ' + name + ' (' + cwd + ')');
  }
  if (Object.keys(scripts).length > 0) console.log('  scripts: ' + Object.keys(scripts).join(', '));
}

async function cmdRun(arg1, arg2) {
  await ensureDaemon();

  let name, script;
  if (arg1) {
    const list = await sendCommand({ cmd: 'list' });
    const names = (list.servers || []).map(s => s.name);
    if (names.includes(arg1)) {
      name   = arg1;
      script = arg2 || null;
    } else {
      name   = resolveServerName();
      script = arg1;
    }
  } else {
    name   = resolveServerName();
    script = null;
  }

  const status = await sendCommand({ cmd: 'list' });
  const srv = (status.servers || []).find(s => s.name === name);
  if (srv && srv.status === 'running') {
    const res = await sendCommand({ cmd: 'restart', name, script });
    if (res.error) { console.error('error: ' + res.error); process.exit(1); }
    console.log('restarted: ' + name + ' (' + (script || 'dev') + ')');
    return;
  }

  const res = await sendCommand({ cmd: 'run', name, script });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  console.log('started: ' + name + ' (' + (script || 'dev') + ')');
}

async function cmdStop(name) {
  await ensureDaemon();
  name = name || resolveServerName();
  const res = await sendCommand({ cmd: 'stop', name });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  console.log('stopped: ' + name);
}

async function cmdRestart(name) {
  await ensureDaemon();
  name = name || resolveServerName();
  const res = await sendCommand({ cmd: 'restart', name });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  console.log('restarted: ' + name);
}

async function cmdRename(oldName, newName) {
  if (!oldName || !newName) {
    console.error('usage: dv rename <old-name> <new-name>');
    process.exit(1);
  }
  await ensureDaemon();
  const res = await sendCommand({ cmd: 'rename', name: oldName, newName });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  console.log('renamed: ' + oldName + ' → ' + (res.newName || newName));
}

async function cmdPin(name) {
  if (!name) { console.error('usage: dv pin <name>'); process.exit(1); }
  await ensureDaemon();
  const res = await sendCommand({ cmd: 'pin', name });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  console.log('pinned: ' + name);
}

async function cmdUnpin(name) {
  if (!name) { console.error('usage: dv unpin <name>'); process.exit(1); }
  await ensureDaemon();
  const res = await sendCommand({ cmd: 'unpin', name });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  console.log('unpinned: ' + name);
}

async function cmdLs() {
  if (!(await canConnectControlSocket(120))) {
    const config = loadConfig();
    if (config.servers.length === 0) {
      console.log('No servers registered. Use `dv add` in a project directory.');
      return;
    }
    console.log('\n  (daemon not running \u2014 showing config only)\n');
    for (const s of config.servers) {
      const pin = s.pinned ? '\u2605 ' : '  ';
      console.log(pin + '\u25CB ' + pad(s.name, 18) + ' ' + pad('--', 10) + ' ' + pad(s.port ? ':' + s.port : '--', 8) + ' ' + s.cwd);
    }
    console.log('');
    return;
  }

  const res = await sendCommand({ cmd: 'list' });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  const servers = res.servers || [];
  if (servers.length === 0) {
    console.log('No servers registered. Use `dv add` in a project directory.');
    return;
  }
  console.log('');
  console.log('  ' + pad('NAME', 22) + ' ' + pad('STATUS', 10) + ' ' + pad('PORT', 8) + ' ' + pad('UPTIME', 10) + ' CWD');
  console.log('  ' + '-'.repeat(22) + ' ' + '-'.repeat(10) + ' ' + '-'.repeat(8) + ' ' + '-'.repeat(10) + ' ---');
  for (const s of servers) {
    const dot = s.status === 'running' ? '\x1b[32m\u25CF\x1b[0m'
              : s.status === 'crashed' || s.status === 'failed' ? '\x1b[31m\u25CF\x1b[0m'
              : '\u25CB';
    const pin = s.pinned ? '\x1b[33m\u2605\x1b[0m ' : '  ';
    console.log(pin + dot + ' ' + pad(s.name, 20) + ' ' + pad(s.status, 10) + ' ' +
                pad(s.port ? ':' + s.port : '--', 8) + ' ' + pad(formatUptime(s.uptime), 10) + ' ' + s.cwd);
  }
  console.log('');
}

async function cmdLogs(name, numLines) {
  await ensureDaemon();
  name = name || resolveServerName();
  const res = await sendCommand({ cmd: 'logs', name, lines: numLines || 50 });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  const lines = res.lines || [];
  if (lines.length === 0) { console.log('No logs for ' + name); return; }
  for (const entry of lines) {
    console.log('  ' + entry.time + '  ' + entry.text);
  }
}

async function cmdAudit(numLines) {
  await ensureDaemon();
  const res = await sendCommand({ cmd: 'auditLog', lines: numLines || 50 });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  const entries = res.entries || [];
  if (entries.length === 0) { console.log('No audit events yet.'); return; }
  console.log('');
  for (const e of [...entries].reverse()) {
    const actor = e.actor === 'gui' ? '\x1b[34mgui\x1b[0m' : '\x1b[32mcli\x1b[0m';
    console.log('  ' + e.time + '  [' + actor + ']  ' + pad(e.event, 30) + ' ' + e.server);
  }
  console.log('');
}

async function cmdRm(name) {
  name = name || resolveServerName();
  if (await canConnectControlSocket(120)) {
    const res = await sendCommand({ cmd: 'rm', name });
    if (res.error) { console.error('error: ' + res.error); process.exit(1); }
    console.log('removed: ' + name);
  } else {
    const config = loadConfig();
    config.servers = config.servers.filter(s => s.name !== name);
    saveConfig(config);
    console.log('removed: ' + name);
  }
}

async function cmdPorts() {
  await ensureDaemon();
  const res = await sendCommand({ cmd: 'ports' });
  if (res.error) { console.error('error: ' + res.error); process.exit(1); }
  const ports = res.ports || [];
  if (ports.length === 0) { console.log('No ports in use.'); return; }
  console.log('');
  for (const p of ports) {
    const dot = p.status === 'running' ? '\x1b[32m\u25CF\x1b[0m' : '\u25CB';
    console.log('  ' + dot + ' :' + pad(String(p.port), 6) + ' ' + p.name);
  }
  console.log('');
}

async function cmdGui() {
  await ensureDaemon();

  try {
    const guiPid = parseInt(readFileSync(GUI_PID_FILE, 'utf-8').trim(), 10);
    if (!isNaN(guiPid)) {
      try {
        process.kill(guiPid, 0);
        console.log('devctl GUI already open (pid ' + guiPid + ')');
        return;
      } catch (_) {}
    }
  } catch (_) {}

  console.log('opening devctl GUI...');
  const child = spawn('love', [DEVCTL_DIR], {
    cwd: DEVCTL_DIR,
    detached: true,
    stdio: 'ignore',
  });
  child.unref();

  mkdirSync(CONFIG_DIR, { recursive: true });
  writeFileSync(GUI_PID_FILE, String(child.pid) + '\n');
}

async function cmdFocus() {
  // Try to raise existing window by title using wmctrl
  try {
    execSync('wmctrl -a devctl 2>/dev/null', { timeout: 1000 });
    return;
  } catch (_) {}

  // No window found — open one
  await cmdGui();
}

function cmdDaemon() {
  canConnectControlSocket(120).then((running) => {
    if (running) { console.log('daemon already running'); return; }
    startDaemon().then(ok => {
      if (ok) console.log('daemon started');
      else { console.error('failed to start daemon'); process.exit(1); }
    });
  }).catch(() => {
    startDaemon().then(ok => {
      if (ok) console.log('daemon started');
      else { console.error('failed to start daemon'); process.exit(1); }
    });
  });
}

async function cmdStatus() {
  if (await canConnectControlSocket(120)) {
    try {
      const pid = readFileSync(PID_FILE, 'utf-8').trim();
      console.log('daemon: running (pid ' + pid + ')');
    } catch (_) {
      console.log('daemon: running');
    }
    return;
  }
  if (isDaemonRunning()) {
    console.log('daemon: process alive but control socket unavailable');
  } else {
    console.log('daemon: not running');
  }
}

// ── Usage ────────────────────────────────────────────────────────────────────────

function usage() {
  console.log([
    '',
    '  dv \u2014 dev server manager',
    '',
    '  SERVERS',
    '    dv add                   Register current project (reads package.json)',
    '    dv run [name] [script]   Start/restart a server',
    '    dv stop [name]           Stop a server (SIGTERM → SIGKILL)',
    '    dv restart [name]        Restart a server',
    '    dv rename <old> <new>    Rename a registered server',
    '    dv pin <name>            Pin server to top of list',
    '    dv unpin <name>          Unpin server',
    '    dv ls                    List all servers',
    '    dv logs [name] [-n N]    Show recent logs',
    '    dv audit [-n N]          Show audit log',
    '    dv rm [name]             Unregister a server',
    '    dv ports                 Show port usage',
    '',
    '  DAEMON',
    '    dv daemon                Start the background daemon',
    '    dv kill                  Stop the daemon',
    '    dv status                Check if daemon is running',
    '',
    '  GUI',
    '    dv gui                   Open the GUI dashboard (singleton)',
    '    dv focus                 Raise the GUI window (or open it)',
    '',
    '  Bind `dv focus` to a global keybind to bring devctl up instantly.',
    '  When [name] is omitted, resolves from package.json in current directory.',
    '',
  ].join('\n'));
}

// ── Main ─────────────────────────────────────────────────────────────────────────

const args = process.argv.slice(2);
const cmd  = args[0];

if (!cmd || cmd === 'help' || cmd === '--help' || cmd === '-h') {
  usage();
} else if (cmd === 'add') {
  cmdAdd();
} else if (cmd === 'run') {
  cmdRun(args[1], args[2]);
} else if (cmd === 'stop') {
  cmdStop(args[1]);
} else if (cmd === 'restart') {
  cmdRestart(args[1]);
} else if (cmd === 'rename') {
  cmdRename(args[1], args[2]);
} else if (cmd === 'pin') {
  cmdPin(args[1]);
} else if (cmd === 'unpin') {
  cmdUnpin(args[1]);
} else if (cmd === 'ls' || cmd === 'list') {
  cmdLs();
} else if (cmd === 'logs' || cmd === 'log') {
  const name = args[1] && !args[1].startsWith('-') ? args[1] : null;
  let numLines = 50;
  const nIdx = args.indexOf('-n');
  if (nIdx >= 0 && args[nIdx + 1]) numLines = parseInt(args[nIdx + 1], 10);
  cmdLogs(name, numLines);
} else if (cmd === 'audit') {
  let numLines = 50;
  const nIdx = args.indexOf('-n');
  if (nIdx >= 0 && args[nIdx + 1]) numLines = parseInt(args[nIdx + 1], 10);
  cmdAudit(numLines);
} else if (cmd === 'rm' || cmd === 'remove') {
  cmdRm(args[1]);
} else if (cmd === 'ports') {
  cmdPorts();
} else if (cmd === 'gui') {
  cmdGui();
} else if (cmd === 'focus') {
  cmdFocus();
} else if (cmd === 'daemon') {
  cmdDaemon();
} else if (cmd === 'kill') {
  killDaemon();
} else if (cmd === 'status') {
  cmdStatus();
} else {
  console.error('Unknown command: ' + cmd);
  usage();
  process.exit(1);
}
