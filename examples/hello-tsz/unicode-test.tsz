// Unicode stress test — verify all codepoint ranges render correctly

function App() {
  return (
    <Box style={{ width: 700, padding: 24, flexDirection: 'column', gap: 12, backgroundColor: '#1a1a2e' }}>
      <Text fontSize={22} color="#e94560">Unicode Coverage Test</Text>

      <Box style={{ padding: 12, backgroundColor: '#16213e' }}>
        <Text fontSize={11} color="#e94560">ASCII</Text>
        <Text fontSize={14} color="#ccccdd">
          The quick brown fox jumps over the lazy dog. 0123456789 !@#$%^&*()
        </Text>
      </Box>

      <Box style={{ padding: 12, backgroundColor: '#16213e' }}>
        <Text fontSize={11} color="#e94560">Latin Extended (accents, diacritics)</Text>
        <Text fontSize={14} color="#ccccdd">
          Héllo Wörld! Ça va? Naïve résumé. Ñoño. Über kühl. Ísland. Łódź.
        </Text>
      </Box>

      <Box style={{ padding: 12, backgroundColor: '#16213e' }}>
        <Text fontSize={11} color="#e94560">Punctuation + Symbols</Text>
        <Text fontSize={14} color="#ccccdd">
          "Smart quotes" — em dash – en dash … ellipsis «guillemets» •bullet ©®™ €£¥¢
        </Text>
      </Box>

      <Box style={{ padding: 12, backgroundColor: '#16213e' }}>
        <Text fontSize={11} color="#e94560">Greek + Cyrillic</Text>
        <Text fontSize={14} color="#ccccdd">
          Ελληνικά: αβγδεζ ΑΒΓΔΕΖ | Русский: абвгдеж АБВГДЕЖ Привет мир!
        </Text>
      </Box>

      <Box style={{ padding: 12, backgroundColor: '#16213e' }}>
        <Text fontSize={11} color="#e94560">Arrows + Math + Box Drawing</Text>
        <Text fontSize={14} color="#ccccdd">
          ← → ↑ ↓ ↔ ⇒ ⇐ ⇔ | ± × ÷ ≠ ≤ ≥ ∞ √ ∑ ∏ | ┌─┐│└─┘ ░▒▓█
        </Text>
      </Box>

      <Box style={{ padding: 12, backgroundColor: '#16213e' }}>
        <Text fontSize={11} color="#e94560">CJK (if font supports)</Text>
        <Text fontSize={14} color="#ccccdd">
          日本語テスト 中文测试 한국어 테스트
        </Text>
      </Box>

      <Box style={{ padding: 12, backgroundColor: '#16213e', textAlign: 'left' }}>
        <Text fontSize={11} color="#e94560">Text Alignment</Text>
        <Text fontSize={14} color="#ccccdd">Left aligned text (default)</Text>
      </Box>
      <Box style={{ padding: 12, backgroundColor: '#0f3460', textAlign: 'center' }}>
        <Text fontSize={14} color="#ccccdd">Center aligned text</Text>
      </Box>
      <Box style={{ padding: 12, backgroundColor: '#16213e', textAlign: 'right' }}>
        <Text fontSize={14} color="#ccccdd">Right aligned text</Text>
      </Box>

      <Box style={{ padding: 12, backgroundColor: '#16213e' }}>
        <Text fontSize={11} color="#e94560">Symbols (dingbats)</Text>
        <Text fontSize={14} color="#ccccdd">
          ★ ☆ ♠ ♥ ♦ ♣ ☀ ☁ ☂ ✓ ✗ ✈ ☎ ♪ ♫ ⚡ ⚠ ☯
        </Text>
      </Box>

      <Box style={{ padding: 12, backgroundColor: '#16213e' }}>
        <Text fontSize={11} color="#e94560">Color Emoji (should be colorful pictures, not monochrome text)</Text>
        <Text fontSize={24} color="#ccccdd">
          😀 🎉 🚀 ❤️ 🌍 🔥 ⭐ 🎨 🧠 💻 🎮 🏠 🌈 ☕ 🍕
        </Text>
        <Text fontSize={11} color="#666688">
          Expected: grin, party, rocket, heart, globe, fire, star, palette, brain, laptop, gamepad, house, rainbow, coffee, pizza
        </Text>
      </Box>
    </Box>
  );
}
