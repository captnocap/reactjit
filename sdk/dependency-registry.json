{
  "schemaVersion": 1,
  "description": "Single source of truth for CLI-carried tools, JS packages, native libraries, and source-triggered build features.",
  "cliPayload": {
    "tools": {
      "zig": {
        "kind": "toolchain",
        "requiredFor": ["scaffold", "build", "ship"],
        "version": "0.15.2",
        "payloadPath": "tools/zig/zig",
        "supportPaths": ["tools/zig/lib", "tools/zig/cache/p"],
        "packPolicy": "required",
        "status": "present"
      },
      "v8cli": {
        "kind": "host-tool",
        "requiredFor": ["scaffold", "build", "ship", "scripts"],
        "payloadPath": "tools/v8cli",
        "packPolicy": "required",
        "status": "present"
      },
      "esbuild": {
        "kind": "bundler",
        "requiredFor": ["build", "ship"],
        "payloadPath": "tools/esbuild",
        "packPolicy": "required",
        "status": "present"
      }
    },
    "jsPackages": {
      "react": {
        "requiredFor": ["scaffold", "build", "ship"],
        "vendorPath": "vendor/react",
        "packPolicy": "required"
      },
      "react-reconciler": {
        "requiredFor": ["build", "ship"],
        "vendorPath": "vendor/react-reconciler",
        "packPolicy": "required"
      },
      "scheduler": {
        "requiredFor": ["build", "ship"],
        "vendorPath": "vendor/scheduler",
        "packPolicy": "required"
      },
      "loose-envify": {
        "requiredFor": ["build", "ship"],
        "vendorPath": "vendor/loose-envify",
        "packPolicy": "required"
      },
      "js-tokens": {
        "requiredFor": ["build", "ship"],
        "vendorPath": "vendor/js-tokens",
        "packPolicy": "required"
      },
      "typescript": {
        "requiredFor": ["scaffold"],
        "vendorPath": "vendor/typescript",
        "packPolicy": "required",
        "note": "Vendored for tsconfig template emission by scripts/init.js. Typecheck (tsc invocation) is not wired."
      }
    }
  },
  "nativeLibraries": {
    "v8": {
      "kind": "static-library",
      "payloadPath": "deps/v8-prebuilt/libc_v8.a",
      "buildImport": "v8",
      "linkPolicy": "engine-v8",
      "bundlePolicy": "always",
      "note": "JS engine. libc_v8.a (~116 MB) is statically linked into every V8-backed cart and into tools/v8cli. The SDK ships the .a so the dispatcher's zig-build invocations can find it."
    },
    "sdl3": {
      "kind": "dynamic-library",
      "systemNames": ["SDL3"],
      "linkPolicy": "foundational",
      "bundlePolicy": "always",
      "note": "Window/input. Every cart binary opens a window. We pin our own version, so SDL3.so ships in the SDK payload."
    },
    "wgpu-native": {
      "kind": "zig-package",
      "payloadPath": "deps/wgpu_native_zig",
      "buildImport": "wgpu",
      "linkPolicy": "foundational",
      "bundlePolicy": "always",
      "note": "Render backbone for every primitive. 241MB static archive linked into every cart. tools/v8cli and the rjit dispatcher don't carry it."
    },
    "freetype": {
      "kind": "dynamic-library",
      "systemNames": ["freetype"],
      "includePaths": ["freetype2"],
      "linkPolicy": "foundational",
      "bundlePolicy": "always",
      "note": "Text rendering. Pinned + bundled."
    },
    "stb-image": {
      "kind": "vendored-c-source",
      "sources": ["stb/stb_image_impl.c"],
      "linkPolicy": "foundational",
      "bundlePolicy": "vendored-source",
      "note": "Powers <Image>. Compiled into every cart from vendored C source — no .so to ship."
    },
    "stb-image-write": {
      "kind": "vendored-c-source",
      "sources": ["stb/stb_image_write_impl.c"],
      "linkPolicy": "foundational",
      "bundlePolicy": "vendored-source",
      "note": "Capture / witness screenshotting. Vendored C source."
    },
    "luajit": {
      "kind": "dynamic-library",
      "systemNames": ["luajit-5.1"],
      "includePaths": ["luajit-2.1"],
      "linkPolicy": "foundational",
      "bundlePolicy": "always",
      "note": "Compute worker runtime. Pinned + bundled."
    },
    "x11": {
      "kind": "platform-library",
      "platforms": ["linux"],
      "systemNames": ["X11"],
      "linkPolicy": "system-assumed",
      "bundlePolicy": "never",
      "note": "Display server protocol. Linked at build time (windows.zig sets _NET_WM_WINDOW_TYPE atoms via 2 extern Xlib calls), but every Linux desktop ships libX11. Don't bundle. Wayland-only systems ship Xwayland which provides libX11 too."
    },
    "posix-threading": {
      "kind": "platform-library",
      "platforms": ["linux"],
      "systemNames": ["m", "pthread", "dl"],
      "linkPolicy": "system-assumed",
      "bundlePolicy": "never",
      "note": "libc, libm, libpthread, libdl — present on every Linux host."
    },
    "libmpv": {
      "kind": "dynamic-library",
      "systemNames": ["mpv"],
      "knownPayloads": ["love2d/storybook/lib/libmpv.so.2", "love2d/web/lib/libmpv.so.2"],
      "linkPolicy": "feature-gated",
      "bundlePolicy": "feature-gated",
      "note": "Runtime dlopen — no link-time cost. Pack libmpv.so.2 into the SDK payload when has-video so carts can dlopen our pinned version instead of relying on the host."
    },
    "libsodium": {
      "kind": "dynamic-library",
      "systemNames": ["sodium"],
      "knownPayloads": ["love2d/storybook/lib/libsodium.so", "love2d/web/lib/libsodium.so"],
      "linkPolicy": "feature-gated",
      "bundlePolicy": "feature-gated",
      "buildFlag": "-Dhas-privacy"
    },
    "sqlite3": {
      "kind": "dynamic-library",
      "systemNames": ["sqlite3"],
      "linkPolicy": "feature-gated",
      "bundlePolicy": "feature-gated",
      "buildFlag": "-Dhas-sqlite"
    },
    "curl": {
      "kind": "dynamic-library",
      "systemNames": ["curl"],
      "linkPolicy": "feature-gated",
      "bundlePolicy": "feature-gated",
      "note": "build.zig still calls linkSystemLibrary unconditionally, but Zig's default --as-needed elides libcurl from carts that reference no curl_* symbols. Net effect matches feature-gating for now; a full -Dhas-http-client gate (with framework/net/http.zig becoming a dispatcher) is the next refactor."
    },
    "libvterm": {
      "kind": "vendored-library",
      "payloadPath": "deps/libvterm",
      "systemNames": ["vterm"],
      "linkPolicy": "feature-gated",
      "bundlePolicy": "feature-gated",
      "buildFlag": "-Dhas-terminal"
    },
    "box2d": {
      "kind": "dynamic-library",
      "systemNames": ["box2d"],
      "linkPolicy": "feature-gated",
      "bundlePolicy": "feature-gated",
      "buildFlag": "-Dhas-physics"
    },
    "tls.zig": {
      "kind": "zig-package",
      "payloadPath": "deps/tls.zig",
      "buildImport": "tls",
      "linkPolicy": "feature-gated",
      "bundlePolicy": "feature-gated",
      "note": "Pulled in by http-client and sdk features."
    },
    "macos-ui-frameworks": {
      "kind": "platform-framework",
      "linkPolicy": "system-assumed",
      "bundlePolicy": "never",
      "note": "Every macOS host has Foundation/QuartzCore/Metal/Cocoa/IOKit/CoreVideo. Linked, not bundled.",
      "platforms": ["macos"],
      "frameworks": ["Foundation", "QuartzCore", "Metal", "Cocoa", "IOKit", "CoreVideo"],
      "linkPolicy": "feature-gated"
    }
  },
  "features": {
    "react-runtime": {
      "requiredFor": ["build", "ship"],
      "jsPackages": ["react", "react-reconciler", "scheduler", "loose-envify", "js-tokens"]
    },
    "cli-toolchain": {
      "requiredFor": ["scaffold", "build", "ship"],
      "tools": ["zig", "v8cli", "esbuild"],
      "jsPackages": ["typescript"]
    },
    "v8-engine": {
      "requiredFor": ["ship"],
      "buildOptions": ["use-v8"],
      "nativeLibraries": ["v8"]
    },
    "window-runtime": {
      "triggers": [
        { "kind": "featureMarker", "input": "runtime/features/window-runtime.ts" }
      ],
      "buildOptions": ["has-window-runtime"],
      "note": "Native libs (sdl3, wgpu-native, freetype, stb-image*, x11, posix-threading, macos-ui-frameworks) are foundational — always linked. The build option only signals intent; nothing extra is link-gated by it."
    },
    "canvas": {
      "triggers": [
        { "kind": "featureMarker", "input": "runtime/features/canvas.ts" }
      ],
      "buildOptions": ["has-canvas"],
      "note": "wgpu-native is foundational; this flag only gates Canvas-primitive Zig code."
    },
    "graph": {
      "triggers": [
        { "kind": "featureMarker", "input": "runtime/features/graph.ts" }
      ],
      "buildOptions": ["has-graph"],
      "note": "wgpu-native is foundational; this flag only gates Graph-primitive Zig code."
    },
    "text-rendering": {
      "triggers": [
        { "kind": "featureMarker", "input": "runtime/features/text-rendering.ts" }
      ],
      "buildOptions": ["has-text-rendering"],
      "note": "freetype is foundational; this flag only gates text-rendering Zig code paths."
    },
    "image": {
      "triggers": [
        { "kind": "featureMarker", "input": "runtime/features/image.ts" }
      ],
      "buildOptions": ["has-image"],
      "note": "stb-image is foundational; this flag only gates Image-primitive Zig code."
    },
    "video": {
      "triggers": [
        { "kind": "featureMarker", "input": "runtime/features/video.ts" }
      ],
      "buildOptions": ["has-video"],
      "nativeLibraries": ["libmpv"],
      "note": "wgpu-native is foundational. libmpv is dlopen'd at runtime — the registry entry exists so pack-sdk knows to stage libmpv.so.2 alongside the SDK payload when has-video, not because it gets link-time gated."
    },
    "audio": {
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/audio.tsx" },
        { "kind": "featureMarker", "input": "runtime/features/audio.ts" }
      ],
      "buildOptions": ["has-audio"]
    },
    "terminal": {
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/useTerminalRecorder.ts" },
        { "kind": "featureMarker", "input": "runtime/features/terminal.ts" }
      ],
      "buildOptions": ["has-terminal"],
      "nativeLibraries": ["libvterm"]
    },
    "physics": {
      "triggers": [
        { "kind": "featureMarker", "input": "runtime/features/physics.ts" }
      ],
      "buildOptions": ["has-physics"],
      "nativeLibraries": ["box2d"]
    },
    "sqlite": {
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/sqlite.ts" },
        { "kind": "metafileInput", "input": "runtime/hooks/localstore.ts" },
        { "kind": "metafileInput", "input": "runtime/hooks/useLocalStore.ts" },
        { "kind": "metafileInputPrefix", "input": "cart/sweatshop/lib/storage/" }
      ],
      "buildOptions": ["has-sqlite"],
      "nativeLibraries": ["sqlite3"]
    },
    "http-client": {
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/http.ts" },
        { "kind": "metafileInput", "input": "runtime/hooks/browser_page.ts" }
      ],
      "buildOptions": ["has-http-client"],
      "nativeLibraries": ["curl", "tls.zig"]
    },
    "crypto": {
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/crypto.ts" }
      ],
      "buildOptions": ["has-crypto"],
      "nativeLibraries": ["libsodium"]
    },
    "privacy": {
      "shipGate": "privacy",
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/usePrivacy.ts" }
      ],
      "buildOptions": ["has-privacy"],
      "v8Bindings": ["privacy"],
      "nativeLibraries": ["libsodium"]
    },
    "use-host": {
      "shipGate": "useHost",
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/useHost.ts" }
      ],
      "buildOptions": ["has-process", "has-httpsrv", "has-wssrv", "has-net"],
      "v8Bindings": ["process", "httpsrv", "wssrv", "net"]
    },
    "connection": {
      "shipGate": "useConnection",
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/useConnection.ts" }
      ],
      "buildOptions": ["has-net", "has-tor", "has-websocket"],
      "v8Bindings": ["net", "tor", "websocket"]
    },
    "fs": {
      "shipGate": "fs",
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/fs.ts" },
        { "kind": "metafileInput", "input": "runtime/hooks/useFileContent.ts" },
        { "kind": "metafileInput", "input": "runtime/hooks/useFileDrop.ts" },
        { "kind": "metafileInput", "input": "runtime/hooks/useFileWatch.ts" }
      ],
      "buildOptions": ["has-fs"],
      "v8Bindings": ["fs"]
    },
    "websocket": {
      "shipGate": "websocket",
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/websocket.ts" },
        { "kind": "metafileInput", "input": "runtime/hooks/useConnection.ts" }
      ],
      "buildOptions": ["has-websocket"],
      "v8Bindings": ["websocket"]
    },
    "telemetry": {
      "shipGate": "telemetry",
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/useTelemetry.ts" },
        { "kind": "metafileInput", "input": "cart/inspector/bridge.ts" },
        { "kind": "metafileInput", "input": "cart/sweatshop/host.ts" },
        { "kind": "metafileInput", "input": "cart/component-gallery/components/telemetry/TelemetryPanel.tsx" },
        { "kind": "metafileInput", "input": "cart/component-gallery/stories/telemetry-stats.story.tsx" }
      ],
      "buildOptions": ["has-telemetry"],
      "v8Bindings": ["telemetry"],
      "nativeLibraries": ["sqlite3"]
    },
    "zigcall": {
      "shipGate": "zigcall",
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/math.ts" }
      ],
      "buildOptions": ["has-zigcall"],
      "v8Bindings": ["zigcall", "zigcall_list"]
    },
    "sdk": {
      "shipGate": "sdk",
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/http.ts" },
        { "kind": "metafileInput", "input": "runtime/hooks/browser_page.ts" }
      ],
      "buildOptions": ["has-sdk"],
      "v8Bindings": ["sdk"],
      "nativeLibraries": ["curl", "tls.zig"]
    },
    "voice": {
      "shipGate": "voice",
      "triggers": [
        { "kind": "metafileInput", "input": "runtime/hooks/useVoiceInput.ts" }
      ],
      "buildOptions": ["has-voice"],
      "v8Bindings": ["voice"]
    },
    "lua-worker": {
      "triggers": [
        { "kind": "featureMarker", "input": "runtime/features/lua-worker.ts" }
      ],
      "buildOptions": ["has-lua-worker"],
      "note": "luajit is foundational; this flag only gates worker-pool Zig code paths."
    }
  },
  "shipGate": {
    "flagOrder": ["privacy", "useHost", "useConnection", "fs", "websocket", "telemetry", "zigcall", "sdk", "voice"]
  }
}
